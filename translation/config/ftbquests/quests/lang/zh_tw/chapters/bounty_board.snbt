{
  chapter.4F0F16931654DF58.title: "懸賞板",
  quest.0065DA4214B7B303.quest_desc: ["&e遠古骸龍法老&r出現於&d異界地牢&r結構之中。", "", "你能夠在&d虛空斷層&r環帶中找到這些地牢。"],
  quest.0065DA4214B7B303.title: "&6遠古骸龍法老&r擊殺者",
  quest.040795388568AB69.quest_desc: ["&d終界守衛&r出現於&e廢棄堡壘&r結構之中。", "", "你能夠在&e終界&r環帶中找到該結構。"],
  quest.040795388568AB69.title: "&d終界守衛&r擊殺者",
  quest.099481C1F0718B67.quest_desc: ["&#FCD205牧師&r出現於&d僭越牧師的故事&r傳送門當中。"],
