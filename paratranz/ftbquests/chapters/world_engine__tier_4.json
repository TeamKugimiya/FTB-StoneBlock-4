  "quest.45A3E686E32AB95D.quest_desc": {
    "original": "Found within the \u0026bTwilight Forest\u0026r ring, the vault of the \u0026aLich\u0026r is the first of five Twilight bosses you need to find.",
    "translation": "出現於\u0026b暮光森林\u0026r環帶的\u0026a巫妖\u0026r寶庫之中，他會是你總共要尋找的五位暮光頭目的第一位。",
    "context": "chapters/world_engine__tier_4.snbt / quest 45A3E686E32AB95D",
    "meta": {
      "line_split_policy": "lf",
      "snbt_value_shape": "list_of_string"
    }
  },
