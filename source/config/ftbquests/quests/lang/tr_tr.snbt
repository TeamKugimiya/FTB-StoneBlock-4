		"[\"\", {\"text\": \"Not\", \"color\": \"yellow\"}, \": Daha fazla erken güç seçeneği istiyorsan \", {\"text\": \"Güç Üretimi\", \"color\": \"red\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"391B65CD04A90459\"}, \"hoverEvent\": {\"action\": \"show_text\", \"contents\": \"Güç Bölümüne Git\"}}, \" bölümüne bir göz at.\"]"
