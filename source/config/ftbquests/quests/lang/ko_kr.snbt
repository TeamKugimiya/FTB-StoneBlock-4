	file.0000000000000001.title: "&6스톤블록 4"
	quest.0065DA4214B7B303.quest_desc: [
		"&e고대 잔재&r는 &d다른 세계 던전&r 안에서 찾을 수 있습니다."
		""
		"이것들은 &d공허 균열&r 고리 주위에 흩어져 있습니다."
	]
	quest.0065DA4214B7B303.title: "&6고대 잔재&r 처치하기"
	quest.0071ADE2804C1B24.title: "빛의 인도자 확인 2"
	quest.007CD364F96C2912.quest_desc: ["&a자유로운 달리기&r 부츠는 보호 기능이 거의 없지만 모든 낙하 피해를 방지합니다."]
	quest.007F4A173D5CA51F.quest_desc: [
		"아마 \"교감\"은 좀 과장이었을 겁니다."
		""
		"특정 몹의 영혼이 필요하며, 이는 죽음의 사신처럼 코스프레하고 &a낫&r을 휘두르는 것을 의미합니다."
		""
		"몹은 &a낫&r으로 처치하면 영혼을 방출하므로, 영혼을 얻으려면 특정 몬스터를 사냥해야 합니다."
		""
		"&7&o다음 페이지 스포일러 ->"
		"{@pagebreak}"
		"좀비와 스켈레톤은 이 제작에 필요한 모든 영혼을 가지고 있어야 합니다."
	]
	quest.007F4A173D5CA51F.title: "&f영혼 수집"
	quest.0089BFB911BD5E5B.quest_desc: [
		"각 &2스케일 모듈&r당 1블록의 반경으로만 작동할 수 있지만, &e방해 매트릭스&r는 그만큼 강력합니다."
		""
		"&3포트론&r으로 전력을 공급받고 주파수에 &a생체 인식 식별자&r가 있으면, 설치된 &a모듈&r을 사용하여 적대적인 몹 처치, 청크 주장 또는 팀원 간의 상호 작용 거부, 그리고 핵 사고 &l(당신의 잘못이 아닙니다)&r 근처에 너무 가까이 오는 사람들에게 경고하는 등 다양한 주요 기능을 수행할 수 있습니다."
	]
	quest.0089BFB911BD5E5B.title: "&e방해 매트릭스"
	quest.009EE2933A83120B.quest_desc: ["&6W.E.R.K&r가 시스템 오류를 겪었습니다. 아마 &d와름라이트&r가 그녀의 형제 &k&6카오스&r의 흔적을 찾을 수 있을 것입니다."]
	quest.009EE2933A83120B.title: "&f추적 &6&k카오스"
	quest.009FE1E1B3017486.quest_desc: ["&c몹 도살 공장&r은 고기용 수동 몹을 죽이는 것 이상으로, 이를 &d핑크 슬라임&r으로 줄여줍니다. 이는 &eI.F&r 진행에 필수적인 액체입니다."]
	quest.009FE1E1B3017486.title: "&c몹 도살 공장"
	quest.00A7C1FE54F86429.quest_desc: [
		"&e아포테오시스&r는 세 가지 새로운 값으로 바닐라 마법 부여 시스템을 재정비하여, 업그레이드 가능한 진행 상황으로 높은 레벨의 마법 부여를 가능하게 합니다. 마법 부여 설정을 업그레이드하면서 이러한 값들을 관리하고 싶을 것입니다:"
		""
		"&a에테르나&r: 마법 부여대의 힘으로, 책장의 등급에 따라 제한됩니다. 이 능력치는 최대 마법 부여 레벨을 결정합니다."
		""
		"&c퀀텀&r: 높은 힘으로 마법 부여할 때 발생하는 내재된 혼돈입니다. 이것은 마법 부여의 무작위성을 결정합니다."
		""
		"&d아르카나&r: 마법 부여의 전반적인 품질과 양입니다. 이것은 마법 부여의 희귀성과 사용당 적용되는 마법 부여 수를 결정합니다."
	]
	quest.00A7DEFCF07BC63A.quest_desc: [
		"The \\&zRed Katar&r is the ultimate weapon from &6ProjectE&r."
		""
		"ProjectE의 추가 기능에 키 바인딩을 설정하면 활성화할 때마다 주변의 모든 것에 25의 피해를 입힙니다."
	]
	quest.00A7DEFCF07BC63A.title: "&c레드 카타르"
	quest.00EF9BD860108718.quest_desc: [
		"&a철 화로&r를 &a강화: 발전기&r를 사용하여 발전기로 변환할 수 있습니다!"
		""
		"그 자체로는 석탄이나 나무와 같은 아이템을 태워 화로 등급에 따라 전력을 생성할 수 있습니다. 이 발전기를 &a폭파 강화&r와 결합하여 철이나 다이아몬드와 같은 금속을 태워 더 많은 전력을 생성할 수 있습니다."
	]
	quest.011DBD2652E49B97.quest_desc: [
		"&6아포테오시스&r에는 기본적으로 \"CTRL + T\"를 사용하여 액세스할 수 있는 새로운 &b월드 등급&r 시스템이 있습니다."
		""
		"[\"You start at \", {\"text\": \"Haven\", \"color\": \"#7E7E7E\"}, \" upon acquiring your first \", {\"text\": \"Affix Item\", \"color\": \"#55FF55\"}, \", and unlock more tiers as you advance in the mod.\"]"
		""
		"더 높은 등급은 모든 차원에서 난이도와 보상을 증가시킵니다. 이러한 보상은 등급 메뉴(\"CTRL + T\")에서 확인할 수 있습니다."
		""
		"&b월드 등급&r을 진행하려면 기본적으로 \"L\"을 사용하여 &6아포테오시스&r 발전과제를 확인하고, 해골이 있는 탭으로 가서 진행 상황을 안내받을 수 있습니다."
		""
		"이 퀘스트의 다음 페이지에서 모든 요구 사항을 확인할 수도 있습니다."
		"{@pagebreak}"
		"&b월드 등급&r"
		""
		"[\"\", {\"text\": \"Haven\", \"color\": \"#7E7E7E\"}, \" - Acquire your first \", {\"text\": \"Affix\", \"color\": \"#55FFFF\"}, \" gear.\"]"
		""
		"[\"\", {\"text\": \"Frontier\", \"color\": \"#55FF55\"}, \" - Equip a full set of \", {\"text\": \"Common\", \"color\": \"#7E7E7E\"}, \" or higher \", {\"text\": \"Affix\", \"color\": \"#55FFFF\"}, \" gear.\"]"
		""
		"[\"\", {\"text\": \"Ascent\", \"color\": \"#5454FC\"}, \" - Equip a full set of \", {\"text\": \"Uncommon\", \"color\": \"#55FF55\"}, \" or higher \", {\"text\": \"Affix\", \"color\": \"#55FFFF\"}, \" gear and slay an \", {\"text\": \"Apotheosis\", \"color\": \"#FFAA00\"}, \" boss monster.\"]"
		""
		"[\"\", {\"text\": \"Summit\", \"color\": \"#B900B9\"}, \" - Equip a full set of \", {\"text\": \"Rare\", \"color\": \"#5454FC\"}, \" or higher \", {\"text\": \"Affix\", \"color\": \"#55FFFF\"}, \" gear and slay the Wither\"]"
		""
		"[\"\", {\"text\": \"Pinnacle\", \"color\": \"#EA6F14\"}, \" - Equip a full set of \", {\"text\": \"Epic\", \"color\": \"#B900B9\"}, \" or higher \", {\"text\": \"Affix\", \"color\": \"#55FFFF\"}, \" gear and slay the Chicken Jockey Boss\"]"
		""
		"각 단계별 변경 사항은 &b월드 단계&r 메뉴("
	]
	quest.011DBD2652E49B97.title: "&f아포틱 월드 등급"
	quest.012AEBFDB1F1512E.quest_desc: ["&e저스트 다이어 띵즈&r 갑옷은 &a대장장이 템플릿&r을 통해 등급을 올릴 수 있으며, 네더라이트보다 더 나은 갑옷을 위해 더 많은 &2업그레이드&r를 수용할 수 있습니다."]
	quest.012AEBFDB1F1512E.title: "&f저스트 다이어의 갑옷"
	quest.012DF07A81C69AAA.quest_subtitle: "주요 월드 엔진 업그레이드"
	quest.012DF07A81C69AAA.title: "&d공명하는 공허&r"
	quest.0138DA9E72BF9CE0.quest_desc: ["이 나침반은 가장 가까운 &a치유의 샘&r으로 당신을 안내할 것입니다."]
	quest.0138DA9E72BF9CE0.title: "&f치유의 샘&a 찾기"
	quest.0171649B0F984DBB.quest_desc: ["이 퀘스트는 &d와름라이트의 &6기록 보관소&r로 가는 웨이포인트를 설정합니다."]
	quest.0171649B0F984DBB.title: "&f와름라이트 찾기&d"
	quest.0173ED2BED248CF6.quest_desc: ["&a물질&r &e송신기&r와 &a수신기&r를 사용하여 세계 내에서 왕복 순간이동을 설정할 수 있습니다. "]
	quest.018B19721F4404FF.quest_desc: ["엔더 진주 또는 엔더의 눈을 소비하여 전력을 생성합니다."]
	quest.0191028C1E2EAA31.quest_desc: [
		"&e말룸의 &a낫&r을 사용하면 적에게서 &b영혼&r을 거둘 수 있습니다."
		""
		"&d구원의 칼날&r은 치명적인 강화 패시브 효과와 증가된 공격 범위로 초반 보스에게 탁월할 수 있습니다."
	]
	quest.0191028C1E2EAA31.title: "&e말룸 낫&f"
	quest.019C7CBC9B62C803.quest_desc: [
		"서랍장의 외관이 마음에 들지 않으신가요? 대신 &a틀이 있는 서랍장&r을 만드세요!"
		""
		"이 서랍들은 다른 아이템과 함께 제작하여 서랍의 모양을 원하는 대로 바꿀 수 있습니다. 제작대에서 각 칸은 서랍의 특정 질감에 해당합니다."
		""
		"- 첫 번째 슬롯: 외부 텍스처"
		"- 두 번째 슬롯: 내부 텍스처"
		"- 세 번째 슬롯: 틀이 있는 서랍"
		"- 네 번째 슬롯: 구분선 텍스처"
	]
	quest.01C338263242935F.title: "TF 동쪽"
	quest.01D2CEAF59872C33.quest_desc: [
		"&a보석 절단대&r는 &b보석&r을 업그레이드하는 데 사용됩니다."
		""
		"&b보석&r을 업그레이드하려면 &a보석 가루&r, 희귀 재료, 그리고 같은 희귀도의 두 번째 &b보석&r이 필요합니다. &b보석&r의 업그레이드 재료 및 가루 비용은 희귀도에 따라 증가합니다."
		""
		"정확한 업그레이드 비용은 테이블 인터페이스에 표시됩니다."
	]
	quest.01D2CEAF59872C33.title: "&a보석 절단대"
	quest.01DB719967817220.quest_desc: [
		"&d초임계 위상 변환기&r(&dSPS&r)는 많은 양의 &b폴로늄&r에서 소량의 &5반물질&r을 생성하기 위해 가능한 많은 전력을 사용하는 거대한 구조물입니다."
		""
		"이는 가능한 모든 &c핵 폐기물&r을 완전히 제거하지만, &b폴로늄&r을 처리하는 데 사용되는 에너지가 생성되는 에너지보다 많기 때문에 추가 전력이 필요합니다."
		"{@pagebreak}"
		"화학 &b폴로늄&r을 하나의 &dSPS 포트&r에 공급하고, 내부에 있는 &d과충전된 코일&r에 연결된 다른 포트에 전력을 공급하고, &5반물질&r을 추출하기 위한 또 다른 &dSPS 포트&r에 공급하십시오."
		""
		"&5반물질&r 1000mB마다 단일 &5반물질 펠릿&r으로 만들 수 있습니다."
		""
		"{image:ftb:textures/quests/mekanism/sps_supercritical.png width:100 height:100 align:center}"
	]
	quest.01DB719967817220.title: "&d초임계 위상 변환기"
	quest.0219C9D8447C8936.quest_desc: [
		"&2시간문 투영기&r는 여행을 위한 시간문을 열 수 있는 조잡한 장치입니다!"
		""
		"웅크리고 땅에 배치한 다음 &a위치 카드&r를 삽입하거나, 인벤토리에 있는 아이템에 위치 카드를 사용하십시오."
		""
		"위치 카드를 삽입하고 &b크로논&r이 충분하면 포털 문을 열 수 있습니다."
		""
		"이는 두 가지 방법 중 하나로 수행됩니다: 손에서 웅크리지 않고 사용하거나, 블록 모드에서 레드스톤 신호를 받을 때입니다."
	]
	quest.0219C9D8447C8936.title: "&2시간문 투영기"
	quest.0224277CBEC1375E.quest_desc: [
		"&eAE2&r는 &bAE&r라고 불리는 자체 전력 단위를 가지고 있습니다. 기본적으로 다른 소스에서 직접 전력을 수용하지 않습니다."
		""
		"그러나 &a에너지 수용체&r를 사용하여 FE 전력을 네트워크의 AE 전력으로 변환할 수 있으며, 이는 &2유리 케이블&r을 사용하여 분배할 수 있습니다."
		""
		"네트워크에 더 많은 기계를 추가하면서 전력이 부족해지기 시작하면, 나중에 사용할 전력을 저장하는 &b에너지 셀&r을 사용하여 에너지 버퍼를 만드는 것이 도움이 될 수 있습니다."
		"{@pagebreak}"
		"또한 &d크리스탈 공명 발전기&r를 사용하여 무료 전력을 생성할 수도 있습니다."
		""
		"이 발전기는 내부에 있는 크리스탈의 진동에서 무료 에너지를 추출하여 약 20 AE/t를 생성합니다. 이러한 진동으로 인해 AE 네트워크당 하나만 가질 수 있습니다."
	]
	quest.0224277CBEC1375E.title: "&f네트워크에 전력 공급하기&b"
	quest.02735F0443CA9727.quest_desc: [
		"이 나침반은 &3금고&3의 위치를 가리킵니다."
		""
		"&7&o금고에서 256블록 이내에 있을 때 나침반을 쉬프트 + 우클릭하면 입구로 즉시 순간이동할 수 있습니다!&r"
	]
	quest.02735F0443CA9727.title: "&f금고 찾기&3"
	quest.027E1E97D874D0EB.title: "무한 만남"
	quest.02BC8FCDB2D94F0E.quest_desc: [
		"&3강화&f에 필요한 블록을 제출하고 보상을 받으면 팀의 &6월드 엔진&r이 자동으로 조립됩니다."
		""
		"&e참고&f: 강화가 있어야 할 곳에 배치된 블록은 사라집니다."
	]
	quest.02BC8FCDB2D94F0E.title: "&f양자 터널 업그레이드 자동 제작&3"
	quest.02F6AC9E53029E0A.quest_desc: [
		"&b인쇄 회로&r와 &a인쇄된 실리콘&r, 그리고 &c레드스톤&r 조각을 조합하여 완전한 &d프로세서&r를 제작할 수 있습니다."
		""
		"이 &d프로세서&r는 &a터미널&r, &e디스크 드라이브&r 등 대부분의 전자 장치에 필요한 주요 제작 부품입니다."
		""
		"가능한 한 빨리 생산을 자동화하는 것이 좋습니다!"
	]
	quest.02F6AC9E53029E0A.title: "AE2 프로세서"
	quest.0306C0D774144DAD.quest_desc: [
		"이 나침반은 &3금고&3의 위치를 가리킵니다."
		""
		"&7&o금고에서 256블록 이내에 있을 때 나침반을 쉬프트 + 우클릭하면 입구로 즉시 순간이동할 수 있습니다!&r"
	]
	quest.0306C0D774144DAD.title: "&f금고 찾기&3"
	quest.030F1F8A4B0C1EBF.quest_desc: [
		"&c반응로 열 환기구&r는 가장 뜨거운 주변 부품(&3연료봉&r 또는 &c열 파이프&r)에서 열을 제거하고 &d반응로&r 밖으로 배출합니다."
		""
		"제거되는 열의 양은 주변 부품의 온도에 따라 달라집니다. 온도가 높은 부품일수록 더 많은 열이 제거됩니다."
		""
		"&c반응로 열 파이프&r는 &3연료봉&r에서 열을 받아 주변 &c열 환기구&r로 분산시킵니다."
		""
		"주변 부품에서 전달되는 최대 열량은 두 부품 간의 온도 차이에 따라 결정됩니다."
	]
	quest.030F1F8A4B0C1EBF.title: "&c열 환기구 &f\\n\\&\\n&c열 파이프"
	quest.033F3D2427ED6F40.quest_subtitle: "더 많은 레드스톤 제어를 허용합니다"
	quest.0355F5FB00143754.title: "패브리케이터 확인 1"
	quest.036047DE66198D10.quest_desc: [
		"&a나뭇잎&r이 말라 있으면 더 강한 섬유를 만드는 데 사용할 수 있습니다."
		""
		"&a모닥불&r을 만들고 &a나뭇잎&r을 그 안에 넣어 말리십시오. 마르면 &a갈퀴&r로 부수어 짚으로 만들 수 있습니다."
	]
	quest.036047DE66198D10.title: "&f불을 느껴보세요"
	quest.036C11AC70835846.quest_desc: [
		"&a엔더릭 레이저&r는 주로 &a플럭사이트&r를 생성하는 데 사용되지만, RF를 무선으로 전송하거나 세계의 블록을 채굴하는 데에도 사용될 수 있습니다."
		""
		"기계 또는 블록을 &a엔더릭 레이저&r에 연결하려면, &e대상 지정자&r를 사용하여 기계 또는 블록을 쉬프트 + 우클릭한 다음, 엔더릭 레이저를 쉬프트 + 우클릭하여 연결하십시오."
		""
		"&l&c경고!&r 레이저를 멈추지 않고 연결된 블록을 제거하면 레이저 시야 범위 내의 모든 블록이 채굴됩니다."
	]
	quest.036C11AC70835846.title: "&f엔드의 힘&d"
	quest.03AC1C56F20BB662.quest_desc: ["&d신비한 정수&r를 얻었다면, 업그레이드를 위해 제작할 수 있는 몇 가지 마법서가 있습니다!"]
	quest.03BEFC2150D09E7A.quest_desc: [
		"&d무선 그리드&r는 &3무선 송신기&r 범위 내에 있을 때 저장 네트워크에 원격으로 접근할 수 있게 합니다."
		""
		"각 &d무선 그리드&r는 해당 &a그리드&r와 동일한 기능을 제공합니다."
	]
	quest.03E48CD6E5DB806F.quest_desc: [
		"더 많은 &6아카이브&r를 잠금 해제했으니, 로비를 탐험하고 &d와름라이트의 메아리&r를 찾을 시간입니다."
		""
		"&d드라코닉 에너지&r 업그레이드를 &6월드 엔진&r에 적용하기 위해 그들과 협력하세요."
		""
		"&7&o로비 어디에서든 &e/echo wyrmwright&7을(를) 사용하여 그들을 만난 후 이 메아리로 직접 순간이동할 수 있습니다."
	]
	quest.03E48CD6E5DB806F.title: "&f만나기 &d와름라이트"
	quest.04013A6813F80EF7.quest_desc: [
		"간단한 석탄 발전기가 좋다고 생각한다면, &a간단한 연료 발전기&r를 사용해 보세요."
		""
		"석탄을 태우는 대신, &6Just Dire Things&r의 특별한 &6연료&r를 태우며, 최고 등급은 시간당 4k RF를 생산합니다!"
	]
	quest.040795388568AB69.quest_desc: [
		"&d엔더 가디언&r은 &e폐허가 된 성채&r 구조물 안에서 발견됩니다."
		""
		"이 구조물은 &e엔드&r 고리에서 찾을 수 있습니다. "
	]
	quest.040795388568AB69.title: "&d엔더 가디언&r 처치하기"
	quest.0415C8A3274EF9D1.quest_desc: [
		"거대한 블랙홀의 사건의 지평선에 도달했습니다. 주변을 탐험하고 &6카오스&r를 찾으세요."
		""
		"그와 협력하여 드라코닉 종족이 가장 소중히 여기는 창조물에 대해 배우고, &3각성된 코어 업그레이드&r를 &6월드 엔진&r에 적용하세요."
	]
	quest.0415C8A3274EF9D1.title: "&f만나기 &6카오스"
	quest.0428CA9172ACC5E3.quest_desc: ["이 아이템은 전력 없이도 작동하는 범용 무선 터미널입니다."]
	quest.0428CA9172ACC5E3.title: "크리에이티브 무선 범용 그리드"
	quest.0448DC5884C8ED55.quest_desc: [
		"더 많은 &6아카이브&r가 잠금 해제되었으니, 로비에서 &d병참 장교의 메아리&r를 찾아 탐험할 시간입니다."
		""
		"이 &d메아리&r와 협력하여 첫 &3주요 업그레이드&r를 발견하세요."
		""
		"&7&o로비 어디에서든 &e/echo quartermaster&7을(를) 사용하여 그들을 만난 후 이 메아리로 직접 순간이동할 수 있습니다."
	]
	quest.0448DC5884C8ED55.title: "&f만나기 &d병참 장교"
	quest.046FCE929A728A34.quest_desc: [
		"무한&r의 경이로움이 블록 형태로 압축되었습니다."
		""
		"&6월드 엔진&r을 완성하기 위해 무한&r으로 돌아가세요."
	]
	quest.0484D6030DF690BD.quest_desc: [
		"더 많은 &6아카이브&r가 잠금 해제되었으니, 로비에서 &d기계공의 메아리&r를 찾아 탐험할 시간입니다."
		""
		"&d기계공&r은 정밀한 공학과 움직이는 구조물에 특화되어 있습니다."
		""
		"이 &d메아리&r와 협력하여 &3그림자 케이싱 업그레이드&r를 &6월드 엔진&r에 적용하세요."
		""
		"&7&o로비 어디에서든 &e/echo machinist&7을(를) 사용하여 그들을 만난 후 이 메아리로 직접 순간이동할 수 있습니다."
	]
	quest.0484D6030DF690BD.title: "&f만나기 &d기계공"
	quest.0484DE13B27E77D0.title: "작업 화면 설명"
	quest.04886BA191FF452F.title: "바다 서쪽"
	quest.049DE43A1B31C38F.quest_desc: ["이 장에서는 아이템을 저장하는 기본적인 방법들을 다룹니다!"]
	quest.049DE43A1B31C38F.title: "&a일반 저장 옵션"
	quest.04ABB8DD43099429.quest_desc: [
		"&a마그마이터&r는 &c용암&r 및 기타 뜨거운 유체를 태워 시간이 지남에 따라 전력을 생성합니다."
		""
		"용암을 생성하는 좋은 방법이 있다면 초반에 유용한 발전기이지만, &e더 발전된 연료&r를 자동화할 수 있게 되면 훨씬 더 좋아집니다!"
	]
	quest.04BF47162CC46237.quest_subtitle: "언어더, 고고학자"
	quest.04E68DA90DC83B45.quest_desc: [
		"필요한 블록을 &3업그레이드&f에 제출하고 보상을 받으면 팀의 &6월드 엔진&r이 자동으로 조립됩니다."
		""
		"그래도 &6월드 엔진&r 근처에 회전 동력원을 설치하고 연결해야 합니다."
		""
		"&e참고&f: 업그레이드가 있어야 할 곳에 배치된 블록은 사라집니다."
	]
	quest.04E68DA90DC83B45.title: "&f자동으로 &3그림자 케이싱 업그레이드&3 구축"
	quest.051AA9C595DC9B02.quest_desc: ["이 퀘스트는 &d촉매의 &6아카이브&r로 순간이동하는 웨이포인트를 설정합니다."]
	quest.051AA9C595DC9B02.title: "&f찾기 &d촉매"
	quest.0533C0C07AE600FD.quest_desc: [
		"&e메커니즘 &d핵분열 반응로&r는 핵분열 연료와 냉각수를 받아 &6핵 폐기물&r과 &b뜨거운 냉각수&r로 변환합니다."
		""
		"&d핵분열 반응로&r는 자체적으로 전력을 생성하지 않습니다. &6터빈&r으로 보낼 수 있는 증기를 생산할 수 있습니다."
		"{@pagebreak}"
		"&d반응로&r는 포트를 통해 멀티블록으로 직접 배관될 수 있는 두 가지 형태의 냉각수를 받습니다. &b물 냉각&r은 더 간단하지만 덜 효과적이며, &6나트륨 냉각&r은 더 강력하지만 추가 멀티블록이 필요합니다."
		""
		"냉각수를 공급하지 않으면 작동 중인 원자로가 멈추지는 않지만, &c과열&r되어 &c내부 손상&r을 입고 결국 &c폭발&r하여 &c방사성 물질&r을 방출하게 됩니다. 폐기물을 비우지 않으면 환경으로 &c누출&r되어 &e방사능&r으로 축적됩니다."
		""
		"구조가 작을수록 문제가 발생할 가능성이 적고 느립니다. 시간을 갖고 테스트해 보세요."
		""
		"&7&o건설 및 작동은 다음 페이지에 있습니다.&r"
		"{@pagebreak}"
		"가장 작은 작동 가능한 &d핵분열 반응로&r는 3x4x3 멀티블록이며, 최대 18x18x18까지 확장될 수 있습니다. 모든 &d반응로&r의 가장자리는 &a반응로 케이싱&r이어야 하지만, 면에는 반응로 유리, 로직 어댑터 및/또는 포트가 포함될 수도 있습니다."
		""
		"입방체가 완전히 구축되고 내부에 최소 하나의 &2핵분열 연료 조립체&r와 상단에 &a제어봉 조립체&r가 있으면 &d반응로&r 멀티블록이 형성됩니다."
		""
		"&d핵분열 반응로&r에 공급하려면 최소 4개의 &a핵분열 반응로 포트&r가 필요합니다: &b물&r을 입력하는 포트 하나, &2연료&r 포트 하나, &7증기&r를 출력하도록 설정된 포트 하나, &c폐기물&r을 출력하도록 설정된 포트 하나입니다. &d반응로 포트&r는 &9설정기&r로 쉬프트 + 우클릭하여 전환할 수 있습니다."
		""
		"&d반응로&r는 멀티블록에 대한 다른 정보를 읽거나 자동으로 켜고 끄기 위해 &a핵분열 반응로 로직 어댑터&r를 받을 수도 있습니다."
		"{@pagebreak}"
		"&d반응로&r는 틱당 최대 1mB * (&3연료 조립체&r 수)의 속도로 연료를 태울 수 있으며, 최소 0.01mB/틱까지 가능합니다."
		""
		"이 속도는 냉각수 수요와 &7증기&r 및 &c핵 폐기물&r의 생산량도 조정합니다. 레시피를 확인하고 파이프가 모든 속도와 냉각수 생산량을 처리할 수 있는지 확인하세요."
		""
		"{image:ftb:textures/quests/mekanism/fission_reactor_open.png width:100 height:100 align:center}"
	]
	quest.0533C0C07AE600FD.title: "&a메커니즘&r &d핵분열 반응로&r"
	quest.056492E163706EC5.quest_desc: [
		"&a디슬로케이터&r는 세계에서 스니크 + 우클릭하여 순간이동 위치를 저장하는 데 사용할 수 있습니다."
		""
		"저장한 후에는 단순히 우클릭하여 저장된 위치로 최대 32번까지 순간이동할 수 있습니다."
		""
		"&a바인딩되지 않은 디슬로케이터&r는 설정한 후 &a디슬로케이터 받침대&r에 배치하여 웨이스톤처럼 순간이동 장소로 사용할 수 있습니다. 받침대를 사용해도 내구도가 소모되지 않습니다!"
	]
	quest.056492E163706EC5.title: "&a이동 장치"
	quest.056990503617C147.quest_desc: [
		"&d와이번&r 도구는 내구도 대신 전력을 소모하며, 인벤토리에 모듈을 배치하여 사용자 정의할 수 있습니다."
		""
		"모듈 인벤토리는 기본적으로 바인딩되지 않은 &e모듈 도구&r 키를 통해 접근할 수 있습니다."
		""
		"&e참고&r: 이것을 제작하려면 &c고급 기계 블록&r과 &6월드 엔진 업그레이드&r가 필요합니다."
	]
	quest.056990503617C147.title: "&d와이번&f 도구"
	quest.056C62BBBCEB1173.quest_desc: [
		"&d원자로&r의 폐기물 버퍼가 넘치거나 방사능 화학 물질을 담고 있는 튜브/기계가 파괴되면, 방사능원이 세상에 유출되어 &c핵 사고&r를 일으킵니다."
		""
		"강력한 &c방사능&r원은 현실 시간으로 몇 시간 동안 월드에 남아 있을 수 있습니다. 방사능에 피폭되었다면, &a거리&r, &a보호&r 또는 둘 다를 통해 방사능을 받는 것을 중단하고 방사능이 서서히 사라지도록 하는 것 외에는 다른 방법이 없습니다."
		"{@pagebreak}"
		"&a방사능 폐기물 통&r은 일반 및 사용된 &c핵 폐기물&r이 천천히 붕괴될 수 있는 안전한 장소를 제공합니다; 여러 개의 통을 병렬로 사용할 수 있습니다. 이 물질은 다른 어떤 방법으로도 &c파괴될 수 없습니다&r. &b폴로늄과 플루토늄&r은 통에서 붕괴되지 않지만 저장할 수 있습니다. 비교기는 &a폐기물 통&r이 얼마나 가득 찼는지 읽을 수 있습니다."
		""
		"완전한 &6방사능 보호복&r 또는 이에 상응하는 업그레이드가 방사능으로부터 당신을 보호하는 데 필요합니다. 그러나 이것들은 방사능 효과를 치료하지 않으며, 생물에게 장착할 수도 없으므로 방사능 물질이 관리되는 곳에 주의를 기울여야 합니다."
		"{@pagebreak}"
		"&e핵 사고를 피하기 위한 팁&f:"
		""
		"&c핵 사고&r는 '만약'보다는 '언제' 일어날 일로 여기는 것이 더 안전합니다. 방사성 물질을 생산하기 전에 예방 조치를 준비해 두십시오."
		""
		"핵 폐기물을 처리할 때는 전체 양을 사용하고, 남은 폐기물은 폐기물 통에서 붕괴되도록 하십시오."
		""
		"화학 물질을 보유하고 있는 파이프가 실수로 파괴되어 발생하는 핵 사고가 플레이어들 사이에서 가장 흔한 원인이며, 이는 &o끔찍한&r 상황입니다. &eApplied Energistics&r 또는 &ePipez&r와 같이 화학 물질을 보유하지 않고 전송하는 물류를 사용하십시오."
	]
	quest.056C62BBBCEB1173.title: "&f방사능과 당신"
	quest.059B456424293FF3.quest_desc: ["&d에테르 가스&r의 힘으로 최종 등급의 기계 프레임을 제작할 수 있습니다!"]
	quest.059B456424293FF3.title: "&6최고 기계 프레임"
	quest.05A6946A5AF26684.quest_desc: [
		"무선 레드스톤을 찾고 있다면, &6Create&r에는 무선 레드스톤을 다른 링크에 연결할 수 있는 간단한 &a레드스톤 링크&r가 있습니다. &aCreate 렌치&r를 사용하여 레드스톤 신호를 전송할 링크를 토글할 수 있습니다."
		""
		"&6RFTools&r에는 비슷한 것이 있지만, 두 개의 별도 블록으로 되어 있습니다."
	]
	quest.05A6946A5AF26684.title: "무선 레드스톤"
	quest.05BB2A6101B519A0.quest_desc: ["&6차원 카드&r는 상당한 에너지 비용으로 차원 간 네트워크에 접근할 수 있게 해줍니다."]
	quest.05C3502C9F7BB7A3.quest_desc: [
		"&6메카 슈트&r는 일부 폴로늄과 기타 고급 &eMekanism&r 재료로 제작할 수 있습니다. 이 동력 장비는 그 자체로도 매우 강력하지만, 행운부터 비행까지 다양한 &b모듈&r로 크게 강화될 수 있습니다!"
		""
		"선택한 &b모듈&r의 복사본을 &a개조 스테이션&r의 유사한 슬롯에 배치하고, 화살표가 가리키는 슬롯에 해당 장비를 배치하면 됩니다."
	]
	quest.05C3502C9F7BB7A3.title: "&6메카 슈트"
	quest.05CEF45909A11F60.quest_desc: [
		"&2Sophisticated Backpacks&r는 인벤토리 문제를 해결하는 간단한 방법을 제공합니다! 또한 더 많은 아이템을 담기 위해 업그레이드할 수 있으며, 휴대용 제작대를 위한 &a제작 업그레이드&r와 같이 모험에 도움이 되는 수많은 멋진 업그레이드가 있습니다."
		""
		"키 바인딩을 사용하여 쉽게 접근할 수 있도록 &e큐리오 슬롯&r에 넣을 수도 있습니다. 또한 메인 핸드에 있는 상태에서 Shift + 우클릭하여 세계에 배치할 수도 있습니다."
		""
		"[\"You can place these in a curio slot for easy access using the keybind \", { \"keybind\": \"keybind.sophisticatedbackpacks.open_backpack\", \"color\": \"green\" }, \".\"]"
		""
		"&e참고&r: 배낭은 파이프나 케이블에 연결되지 않습니다."
	]
	quest.05CEF45909A11F60.title: "&eSophisticated Backpacks"
	quest.05F1EC4F14A449AD.quest_desc: [
		"&aIndustrial Foregoing&r의 &r광석 레이저 베이스&b는 &a레이저 드릴&r를 사용하여 광석을 무한정 생성하는 데 사용할 수 있습니다."
		""
		"UI 내에서 Y 레벨을 설정하여 찾고 싶은 광석 유형을 결정하고, &a색상 렌즈&r를 설치하여 &a레이저 베이스&r가 특정 광석 유형을 전문화하도록 할 수 있습니다."
		""
		"이 기계는 &b포트론 주입 블록&r &6월드 엔진 업그레이드&r와 함께 사용할 수 있게 됩니다."
	]
	quest.05F1EC4F14A449AD.title: "&f가상 채굴"
	quest.0628BC9A79EA0FDE.title: "유용한 아이템"
	quest.066342488E03F3B5.quest_desc: [
		"&b다이아몬드&r는 훌륭한 도구를 만들지만, 부서지기 쉽고 산산조각 나는 경향이 있습니다."
		""
		"&a원자 분해기&r를 사용하면 강화하여 더 강하게 만들 수 있습니다."
		""
		"&a분해기&r는 제작에 특별한 재료가 필요합니다. &2지질학자&r는 필요한 결정을 어디서 찾을 수 있는지 정확히 알고 있을 것입니다."
	]
	quest.066342488E03F3B5.title: "&f광물 재구성"
	quest.066B47D2AB72355C.quest_desc: ["이 던전은 대략 x:512, z:512 근처에서 생성됩니다."]
	quest.066B47D2AB72355C.title: "&d비전 숲 찾기"
	quest.068C117DD3DD10C2.title: "안내 확인 3"
	quest.06A86C3EC5CBF204.quest_subtitle: "발굴자, 고고학자"
	quest.06C9E9DBE25887D9.quest_desc: ["&a용암 발전기&r는 용암을 소비하여 RF를 생성합니다. &6Oritech&r의 RF 생성은 &b애드온&r으로 증가할 수 있습니다."]
	quest.06D54A3D73AB7DE8.title: "기체 저장"
	quest.06EC32E6140E68C1.quest_desc: [
		"&2에트로 결정&r의 힘을 사용하여 &d양자 자동 제작⟧&r으로 가장 빠른 자동 제작 설정을 만들 수 있습니다."
		""
		"기본 제작 블록은 &d양자 제작 유닛&r이며, &6양자 제작기&r와 &6양자 컴퓨터 멀티블록&r 모두에 필요합니다."
	]
	quest.06EC32E6140E68C1.title: "&d양자 자동 제작"
	quest.07062B805D9238C0.quest_desc: [
		"모드의 핵심 장치인 &a경험치 오벨리스크&r는 경험치(XP) 레벨을 &b코그니튬&r이라는 유체로 내부적으로 변환하여 손실 없이 저장하고 정밀하게 조작할 수 있게 해줍니다."
		""
		"다른 인지 장치는 &a조율의 지팡이&r, 즉 인지의 \"렌치\"로 이 블록에 연결하여 기능을 활성화하거나 향상시킬 수 있습니다. &a기억 태블릿&r을 연결하여 해당 지역의 오벨리스크에 원격으로 접근할 수 있습니다. 이 연결은 플레이어별입니다."
		""
		"&7&o주변의 경험치 구슬을 수동으로 수집할 수도 있습니다."
	]
	quest.077F5C3829CA7300.title: "음식"
	quest.08000D28B577EF94.quest_desc: ["이 퀘스트 보상을 받으면 &d메아리의 &6아카이브&r 입구에 웨이포인트가 설정됩니다."]
	quest.08000D28B577EF94.title: "&f마법사 찾기&d"
	quest.08145422E66D2B7D.quest_desc: [
		"&d양자 얽힘 전송기&r는 아이템, 에너지, 가스 및 액체를 무선으로 전송할 수 있습니다."
		""
		"설치 후 인터페이스를 열려면 마우스 오른쪽 버튼을 클릭하세요. 안에서 특정 주파수를 설정하여 다른 &d얽힘 전송기&r와 연결하여 무선 전송할 수 있습니다."
		""
		"&d얽힘 전송기&r에는 버퍼가 있어 소량의 전력, 가스 등을 저장할 수 있습니다. 특히 가스를 전송하는 데 사용한다면 블록의 입출력을 결정하기 위해 측면을 올바르게 설정해야 합니다!"
	]
	quest.081EA35CCBDF793F.quest_desc: [
		"닭은 알과/또는 자원을 낳을 장소가 필요하며, 이를 위해 &2둥지&r가 사용됩니다."
		""
		"닭이 &2둥지&r에 있는 동안 자원을 생산하려면 해당 등급에 맞는 씨앗이 필요합니다. 이 등급별 씨앗은 &b영혼&r을 사용하여 제작됩니다."
		""
		"닭의 레벨이 높을수록 씨앗당 생산되는 자원이 많아집니다."
		""
		"&e참고&f: &2둥지&r의 이름을 변경하여 정리하면, 특히 &a둥지 수집기&r를 사용할 때 더 편리합니다."
	]
	quest.081EA35CCBDF793F.title: "둥지 궁극"
	quest.08204AA5ACCC914E.quest_desc: ["&a배낭&r도 염색할 수 있습니다! 이는 배낭의 색상 코드를 지정하거나 검은색 배낭으로 멋지게 보이게 하는 데 유용합니다."]
	quest.082551D21363A1D9.title: "&d아르스 무기"
	quest.0826EF3E7B15B219.quest_desc: ["분홍색 아이템을 소비하여 전력을 생성합니다."]
	quest.08766B8721B4E541.quest_desc: [
		"네더 반지 안에서 &c고대 전투장&r을 발견할 수도 있습니다."
		""
		"전장 너머에는 &c갑옷 조각 더미&r를 볼 수 있습니다. 이 더미를 채굴하는 것은 유혹적일 수 있지만, 이 갑옷을 입었던 &d고대 기사들&r을 방해할 수도 있습니다."
		""
		"진행을 위해서는 그들 중 하나를 처치해야 합니다. 그들은 &c그을린 정수&r를 떨어뜨리기 때문입니다."
		""
		"또한 진홍빛 숲의 &e호글린&r이 적절하게 이름 붙여진 &c호그스킨&r을 떨어뜨리는 것도 주목할 만합니다. 이는 일부 개선된 주문 책 제작에 필요합니다."
	]
	quest.08766B8721B4E541.title: "&f네더의 마법&c"
	quest.087D1FBAE8A425C0.quest_desc: [
		"순간이동 코어의 힘을 사용하여, &d차원문&r을 &6메카니즘&r으로 직접 만들 수 있어 기지 주변이나 차원 간 이동이 가능합니다!"
		""
		"하나를 만들려면 1개의 &d순간이동기&r 블록과 9개의 &b순간이동기 프레임&r 블록이 필요합니다. 일단 지으면 순간이동기 블록에 전력을 공급해야 하며, 그러면 열어서 주파수 이름을 설정할 수 있습니다. 이름을 지정한 후에는 완료 버튼을 클릭하는 것을 잊지 마세요!"
		""
		"&e참고&r: 이를 만들기 위해서는 &b포트론 주입 블록&r &6월드 엔진 업그레이드&r가 필요합니다."
		"{@pagebreak}"
		"이제 다른 모든 순간이동기가 해당 주파수를 볼 수 있으며, 다른 순간이동기를 만들고 주파수를 선택하여 연결할 수 있습니다."
		""
		"{image:ftb:textures/quests/mekanism/portalframe.png width:100 height:100 align:center}"
		"{@pagebreak}"
		"&d휴대용 순간이동기&r를 사용하면 모든 순간이동기에 접근할 수 있어, 전력이 공급되는 한 어느 곳으로든 즉시 이동할 수 있습니다!"
		""
		"손에 들고 사용하면 주파수 목록이 표시됩니다. 그런 다음 하나를 선택하고 순간이동을 클릭하세요!"
	]
	quest.087D1FBAE8A425C0.quest_subtitle: "자막 포함"
	quest.087D1FBAE8A425C0.title: "&f포탈 &d만들기&f!"
	quest.091B8E814908DEDF.quest_desc: [
		"&d원자 대장간&r은 고급 컴퓨터 칩을 만들고, 심층암을 강화하며, 심지어 광석을 복제할 수도 있는 강력한 기계입니다!"
		""
		"이 멀티블록은 꽤 크며, 총 &b8개의 기계 코어&r가 필요합니다."
		""
		"에너지 파이프는 &d원자 대장간&r에 직접 연결할 수 없습니다; &a엔더 레이저&r로 무선 전력을 공급해야 합니다."
	]
	quest.091F82E2770F3011.title: "고대 확인 1"
	quest.094A534C72917405.quest_desc: ["이 던전은 &b바다&r 고리의 하부에서 생성됩니다."]
	quest.094A534C72917405.title: "&b얼음 거미 굴 찾기"
	quest.099481C1F0718B67.quest_desc: ["\\&#FCD205사제&r는 &d너무 많이 아는 사제 이야기!&r 관문에서 찾을 수 있습니다."]
	quest.099481C1F0718B67.title: "\\&#FCD205사제 처치"
	quest.099594F0A383C280.quest_desc: [
		"&c고급 기계 프레임&r은 기계 프레임의 다음 등급 업그레이드입니다."
		""
		"이 기계 프레임은 &d정지 챔버&r 및 &3광석 레이저 베이스&r와 같은 가장 중요한 기계를 만드는 데 사용됩니다."
	]
	quest.099594F0A383C280.title: "&c고급 기계 프레임"
	quest.09D15AF118F0C8D8.quest_desc: ["위의 모든 &r크리에이티브⟧ 아이템을 획득했다면, 이제 어떤 시스템에 무한한 전력을 공급할지 결정할 때입니다."]
	quest.09D15AF118F0C8D8.title: "승천 등급 2 - 초월"
	quest.09DE55D4265E6E9D.quest_desc: [
		"기지 주변에 보기 흉한 케이블이 너저분하게 늘어나는 것이 싫으신가요?"
		""
		"&e케이블 외관&r(모드)은 모든 케이블을 숨기는 만능 솔루션을 제공합니다."
		"{@pagebreak}"
		"빈 &b외관&r을 설정하려면, 변경하려는 블록과 함께 제작 그리드에 놓으세요. 그러면 블록이 \"소모\"되지만, &b외관&r을 다시 제작 그리드에 놓고 블록을 추출하여 이 과정을 되돌릴 수 있습니다."
		""
		"설치가 완료되면, 보기 흉한 케이블 위에 &bFacade&r을(를) 덮어 씌우세요. 그러면 케이블이 사라집니다!"
		""
		"&aFacade Wrench&r을(를) 사용하여 Shift + 우클릭으로 파사드의 투명도를 전환할 수 있습니다."
	]
	quest.09DE55D4265E6E9D.title: "&e케이블 파사드"
	quest.0A1243F0A9541645.quest_desc: ["&r무한 동력 카드&r는 보호막에 영구적으로 동력을 공급할 수 있습니다."]
	quest.0A1243F0A9541645.title: "무한 전력 카드"
	quest.0A2DB5AFC89E852F.quest_desc: [
		"&a코크스 오븐&r은 일반 석탄을 &3코크스 석탄&r과 &7크레오소트 오일&r로 전환하는 초반 멀티블록입니다."
		""
		"&3코크스 석탄&r은 더 효율적인 연료이며, &a크레오소트 오일&r은 많은 제작법에 사용될 것입니다."
		""
		"이 멀티블록을 만들려면 &a코크스 벽돌&r로 3x3x3 큐브를 만든 다음, 가운데 블록을 &b엔지니어의 망치&r로 우클릭하여 활성화하세요."
	]
	quest.0A2DB5AFC89E852F.title: "&f코크스 오븐"
	quest.0A3C1CD48C85E17D.quest_desc: [
		"&7심층암&r 고리 하층부에서 &d고대 도시&r를 만날 확률이 있습니다."
		""
		"아래에는 분명 아무것도 없을 겁니다. 조용히 잠입해서 &d메아리 파편&r 몇 개를 찾아보세요."
		""
		"이 파편을 획득한 후 &d메아리 마법사&r의 메아리를 보게 될 것입니다."
		""
		"&e참고&r: &d마법사&r는 &d길잡이&r도 일부 제공할 수 있으며, 그들의 임무를 완료하면 구매할 수 있다고 언급했습니다."
	]
	quest.0A3C1CD48C85E17D.title: "&f감시자에게서 훔치기"
	quest.0A6E103A6945D11E.quest_desc: [
		"&a주조소&r는 진행에 핵심이며 &6오라이텍&r 기계를 만드는 데 필요한 모든 합금을 만드는 데 특화되어 있습니다."
		""
		"이 멀티블록을 만들려면 총 3개의 &b기계 코어&r가 필요합니다. 먼저 &a주조소&r 블록을 배치한 다음, 코어를 배치해야 할 위치를 보려면 우클릭하세요. 코어가 제자리에 있으면 다시 우클릭하여 기계를 완성하세요!"
		""
		"참고: 이러한 합금 중 일부는 손으로 또는 다른 모드 기계로 제작할 수도 있지만, 그렇게 하면 종종 더 많은 자원이 소모됩니다."
	]
	quest.0A6E103A6945D11E.title: "&f주조소&6"
	quest.0A92084D7043133A.quest_desc: [
		"&b애드온&r은 선택한 애드온 유형에 따라 멀티블록 기계를 개선하는 데 사용됩니다. "
		""
		"이것들은 기계의 특정 면에 부착되거나 &a기계 확장기&r에 부착될 수 있습니다. 각 확장기는 더 많은 애드온을 부착할 수 있는 더 많은 면을 제공합니다!"
		""
		"기계 인터페이스 내의 &b애드온 GUI&r를 확인하여 기계의 어느 면에 애드온을 부착할 수 있는지 항상 확인할 수 있습니다."
	]
	quest.0A92084D7043133A.title: "&f기계 맞춤 설정!"
	quest.0AA1977AC1B5E5A9.quest_desc: [
		"모루는 평범한 장비를 수리하는 데는 좋지만, 마법이 깃든 물건은 수리하기가 훨씬 비싸거나 불가능할 수도 있습니다. &a수리 파일론&r을 사용하면, &e정령 도가니&r는 정령과 수리 재료를 장비 조각에 집중시켜, 해당 장비가 이미 &b특정 마법&r과 관련이 있거나 완전히 평범한 경우에도 작동합니다."
		""
		"이것은 &e부서진 임페투스&r를 수리하는 유일한 방법이기도 합니다."
	]
	quest.0AAA6858DAF43067.quest_desc: [
		"조약돌만으로는 멀리 갈 수 없습니다."
		""
		"&a돌 망치&r를 만들어 조약돌을 더 고운 재료로 부술 수 있도록 하세요. 어딘가에는 광물이 있어야 합니다!"
	]
	quest.0AAA6858DAF43067.title: "&f주먹질에서 부수기로"
	quest.0ABD10520EAB1C57.quest_desc: [
		"&a보관함 제어기&r를 사용하면 여러 서랍을 한 번에 연결하고 상호 작용할 수 있습니다. 이는 서랍 시스템으로 아이템을 자동으로 넣고 빼는 데 매우 유용합니다!"
		""
		"&3연결 도구&r를 사용하여 서랍을 제어기에 연결한 후, 제어기를 두 번 우클릭하면 인벤토리의 모든 아이템을 서랍 네트워크로 직접 넣을 수 있습니다! 이는 제어기로 아이템을 파이프로 넣을 수도 있다는 것을 의미합니다."
		""
		"&a제어기 액세스 포인트&r는 메인 제어기에 연결되어 있는 한 추가 제어기로 사용할 수 있습니다."
	]
	quest.0ABD10520EAB1C57.title: "보관함 제어기"
	quest.0ACCAD3AEF57F2E2.quest_desc: [
		"&7흙&r을 &2곡괭이&r로 파는 대신, &a조잡한 솔&r을 사용하여 농장을 시작하기 위한 &2씨앗&r과 같은 작은 물체를 찾을 수 있습니다!"
		""
		"잔디나 &d즐거운 흙&r도 &a수동 몹 농장&r을 만드는 데 사용할 수 있으며, 이는 특히 &b가죽&r과 같은 음식 및 자원의 좋은 공급원이 될 수 있습니다."
		""
		"&d안내의 메아리&r는 또한 수동 몹이 포함된 관문을 판매합니다."
	]
	quest.0ACCAD3AEF57F2E2.title: "&f흙 속 솔질"
	quest.0AD2F3DB33241628.quest_desc: [
		"&eArs &a주문 책&r은 주문을 생성하고 시전할 수 있는 다재다능한 도구입니다."
		""
		"&eArs &2도구&r는 &d마법사의&r &3근원 업그레이드&r를 완료한 후에 사용할 수 있습니다. 이 마법 도구들은 주문 부여를 통해 방대한 양의 맞춤 설정을 제공할 수 있습니다."
	]
	quest.0AD2F3DB33241628.title: "&eArs &f도구"
	quest.0ADBBF7BA99D2811.quest_desc: ["&eActually Additions의 &a올인원 도구&r는 모든 도구를 한 번에 사용할 수 있어 핫바 공간을 절약하는 데 유용한 추가 기능입니다!"]
	quest.0ADBBF7BA99D2811.title: "&f올인원 도구"
	quest.0AFA74FA77E9056B.title: "바다 남쪽"
	quest.0AFF8E28FC51B123.quest_desc: [
		"최소한의 번거로움으로 두 개의 간단한 블록을 교체해야 합니까? &c교체 지팡이&r를 사용해 보세요!"
		""
		"최소한의 번거로움으로 블록을 집어 다른 곳에 배치해야 합니까? 집기 지팡이를 사용해 보세요!"
	]
	quest.0B02B72259362345.quest_desc: ["이 퀘스트 보상을 받으면 &d메아리의 &6기록 보관소&r 입구에 웨이포인트가 설정됩니다."]
	quest.0B02B72259362345.title: "&f제작기&d 찾기"
	quest.0B1E459D12D11A0D.quest_desc: [
		"&a모드&r와 &2모듈&r는 &d프로젝터&r에게 어떻게 작동해야 하는지 지시합니다."
		""
		"&a모양 모드&r는 &b힘의 장 블록&r이 배치될 형태를 정의하고 &2방향 모듈&r &7(다음 퀘스트)&r는 세계에 배치할 위치를 지정합니다."
		""
		"매트릭스 슬롯에 있는 &e반전 모듈&r은 윤곽선만 만드는 대신 &l전체&r 투사된 볼륨을 &b장 블록&r으로 채웁니다."
		""
		"&7&o다음 페이지에서 더 많은 모드 세부 정보를 확인하세요."
		"{@pagebreak}"
		"&a큐브 모드&r는 축을 따라 스케일 모듈의 방향을 존중하며, 밀폐된 필드를 형성하기 위해 세 축 각각이 정의되어야 합니다."
		""
		"&a구체 모드&r는 필드 슬롯의 모든 &2스케일 모듈&r을 단일 반지름 추가로 취급하여, 모양 사용자 정의를 줄이는 대가로 광대한 영역을 둘러쌀 수 있게 합니다."
		""
		"&a튜브 모드&r는 &a큐브 모드&r와 거의 동일하지만, 결과 면 중 두 개가 열려 있습니다."
		""
		"&a피라미드 모드&r는 수평 축을 따라 꼭짓점이 있는 4면 피라미드를 형성하며, 세 축 모두 정의되어야 하고 높이를 위해 상하 방향을 존중해야 합니다."
		""
		"&a원통 모드&r는 수평 축을 반지름으로, 상하 축을 총 높이로 사용합니다."
		"{@pagebreak}"
		"&b사용자 지정 모드&r는 영역의 양쪽 모서리를 설정하는 데 사용할 수 있습니다. Shift + 우클릭하면 해당 영역 내의 모든 비어 있지 않은 블록에 필드 구조가 설정됩니다. 공기를 Shift + 우클릭하면 선택이 해제됩니다."
		""
		"&b이 모드&r는 &2스케일 모듈&r을 무시하고 선택된 영역의 중앙을 기본 원점으로 사용합니다. &d위장 모듈&r은 일반 동작 대신 선택된 블록을 복사합니다."
	]
	quest.0B1E459D12D11A0D.title: "&f필드 정의하기&b"
	quest.0B25350118D515DF.quest_desc: ["&6월드 엔진&r의 최종 업그레이드는 블록 형태의 \\&z무한&r의 힘을 필요로 합니다."]
	quest.0B25350118D515DF.quest_subtitle: "주요 월드 엔진 업그레이드"
	quest.0B295CE75D367D59.quest_desc: [
		"돌로 만들어진 세계에서는 나무가 중요합니다. 얻을 수 있는 모든 것을 활용해야 합니다!"
		""
		"첫 나무 조각으로 &a나무 가위&r를 만들어 잎도 제대로 수확하세요!"
	]
	quest.0B295CE75D367D59.title: "&f잎사귀를 남기지 마세요"
	quest.0B3FD3C2AD980AD7.title: "고대 만남"
	quest.0B65713A23351790.quest_desc: [
		"&d와이번 검&r은 수많은 맞춤 설정 옵션을 제공하는 동력 검입니다."
		""
		"&6드라코닉 에볼루션&r 장비는 각 아이템 내부에 모듈 업그레이드를 저장할 수 있는 자체 인터페이스를 가지고 있습니다."
		""
		"이를 통해 &d모듈&r을 사용하여 다양한 방식으로 모드의 모든 아이템을 업그레이드할 수 있습니다."
	]
	quest.0B65713A23351790.title: "&d와이번 &f무기"
	quest.0B69B9E1209A9234.quest_desc: [
		"주요 목표는 &b월드 엔진&r을 &c고급 기계 블록&r으로 업그레이드하는 것이지만, 먼저 전력 처리 방식을 업그레이드해야 합니다."
		""
		"단일 &c니트로 티어 엔더 셀&r을 설치하면 &e엔더&r의 힘과 관련된 더 복잡한 제작을 처리할 수 있습니다."
		""
		"물론 이를 위해서는 최소한 하나의 &d네더 스타&r가 필요합니다."
		""
		"&d촉매의 메아리&r에게 돌아가 &6월드 엔진&r을 업그레이드하는 방법을 보여주도록 하세요."
	]
	quest.0B69B9E1209A9234.quest_subtitle: "주요 월드 엔진 업그레이드"
	quest.0B69B9E1209A9234.title: "&f엔더 기술"
	quest.0B92679772DB0C68.quest_desc: [
		"&a축과&r &a톱니바퀴&r는 기계와 구조물에 회전력을 전달하는 주요 수단입니다."
		""
		"&a톱니바퀴&r &b고찰&r을(를) 확인하여 시스템 내에서 &b분당 회전수&r(&bRPM&r)를 늘리거나 줄이는 데 어떻게 사용할 수 있는지 알아보세요."
	]
	quest.0BAF0C06F01C4E80.quest_subtitle: "에너지 용량 및 에너지 전송 속도 향상"
	quest.0BD2630DFA958C65.title: "황혼의 만남"
	quest.0BE524ECA97A0E63.quest_desc: [
		"&c경고&r: 이 퀘스트를 완료하면 모든 팩 진행 상황이 즉시 건너뛰게 됩니다."
		""
		"&o무엇을 하고 있는지 알고 있는 경우에만 사용하세요. 되돌리기 버튼은 없습니다."
	]
	quest.0BEF15E1352A5F72.quest_desc: [
		"숙련된 &d차원술사&r가 당신을 위해 일하게 되면, &d복제 원석&r이라는 매우 귀중한 광석을 발견하게 될 것입니다."
		""
		"이것이 &6복제&r를 시작하는 방법이며, 이를 통해 아이템을 &b물질&r로 분해할 수 있습니다. 이 물질은 동일한 종류의 &b물질&r로 구성된 다른 아이템으로 변환될 수 있습니다."
		""
		"강철의 연금술사 수준의 연금술을 생각해보세요."
	]
	quest.0BEF15E1352A5F72.title: "&6물질 복제&r"
	quest.0BF770CB2B6312CF.quest_desc: [
		"더 후반의 &e크리에이트&r로 진행하려면 다양한 기능을 위해 다른 판을 제작해야 합니다."
		""
		"&3철 판&r은 대부분의 기계와 아이템에 사용되는 가장 일반적인 판입니다."
		""
		"&3구리 판&r은 일반적으로 유체 관련 부품에 사용됩니다."
		""
		"&3금 판&r은 기타 잡다한 제작법에 사용됩니다."
	]
	quest.0BFACB0AAEE7F4C2.quest_desc: [
		"인벤토리 관리는 매우 중요하며, 그것이 바로 &d주머니 보관함&r의 용도입니다!"
		""
		"이 장치들은 당신이 채집한 아이템을 내부에 놓인 것에 따라 자동으로 줍습니다. 이것은 채광 여행 중에 인벤토리를 조약돌로 깨끗하게 유지하는 데 완벽합니다."
		""
		"참고: 이 장치들은 초과 아이템을 자동으로 삭제합니다. 즉, 스택 한도를 채우면 해당 아이템은 삭제됩니다. 한 번에 더 많이 저장하려면 티어를 업그레이드하세요!"
	]
	quest.0BFACB0AAEE7F4C2.title: "&d주머니 보관함"
	quest.0C0B04B6FEFD2928.quest_desc: [
		"&a임포터&r는 네트워크에 자원을 입력하는 데 사용되며, &a익스포터&r는 네트워크에서 아이템을 내보냅니다."
		""
		"&3인터페이스&r는 네트워크에 동시에 입력하고 출력할 수 있으며, 동일한 블록 공간 내에서 &a임포터&r 및 &2익스포터&r 역할을 합니다."
	]
	quest.0C0B04B6FEFD2928.title: "I/O 연결"
	quest.0C2523AA8CA20CC4.quest_subtitle: "초록색 + 다이아몬드"
	quest.0C2DAB30B7A2A7C0.title: "5단계 '그리고' 확인"
	quest.0C5173F51D68317C.quest_desc: [
		"&5그림자 정령&r을 사용하여 강력한 무기를 제작할 수 있습니다."
		""
		"&6분열된 세계&r의 특수 능력은 적을 향해 유도되는 날아다니는 검을 소환합니다."
	]
	quest.0C59F30673774398.quest_desc: [
		"&a조절기 업그레이드&r는 시스템에서 가져오거나 내보내는 아이템의 양을 제어합니다."
		""
		"&a익스포터&r에서 사용하면, 대상 인벤토리에 구성된 수량의 아이템이 포함될 때까지 시스템에서 아이템을 내보냅니다."
		""
		"&a임포터&r에서 사용하면, 대상 인벤토리에 구성된 수량의 아이템을 유지하고 초과 아이템을 저장 네트워크로 가져옵니다."
		""
		"설정하려면 인터페이스를 열기 위해 우클릭하고 구성하려는 아이템을 오른쪽 슬롯에 넣은 다음 구성하려는 아이템 수량을 입력하세요."
	]
	quest.0C784115309E7C1C.quest_desc: [
		"AE2 시스템에 무선으로 액세스하려면 &d무선 액세스 포인트&r와 &d무선 제작 터미널&r을 만들 수 있습니다."
		""
		"액세스 포인트에 &b무선 부스터&r를 설치하면 범위가 확장되지만 작동에 더 많은 에너지가 소모됩니다."
		""
		"&d무선 제작 터미널&r을 사용하면 네트워크의 무선 액세스 포인트에 링크할 수 있습니다. 인터페이스의 슬롯에 배치하면 어디서든 신호가 있는 곳에서 모든 아이템에 액세스하고 이동 중에도 제작할 수 있습니다!"
	]
	quest.0C784115309E7C1C.title: "&d무선 네트워크 액세스&r"
	quest.0CA6DA721A97542F.quest_desc: [
		"인벤토리의 이 작은 버튼을 클릭하여 액세스할 수 있는 수백 가지 아이템을 &e큐리오 슬롯&r에 넣을 수 있습니다:"
		""
		"{image:curios:textures/gui/curios/button_small.png width:25 height:25 align:center}"
		""
		"JEI에서 슬롯 이름을 앞에 'Slot: '을 붙여 특정 슬롯 아이템을 검색할 수 있습니다. 예를 들어: &aSlot: Head&r 또는 &aSlot: Feet&r."
	]
	quest.0CA6DA721A97542F.title: "&e큐리오&r 아이템"
	quest.0CA75E81F6824B22.quest_desc: [
		"마법과 탐험 모두에 관심이 있다면 &eIron's Spells 'n Spellbooks&r을 시도해 보세요. 이것은 플레이할 수 있는 수많은 주문을 추가하는 놀라운 마법 모드입니다."
		""
		"탐험 전리품으로 &a주문 책&r을 찾거나, 몇 개의 주문을 담을 &a허술한 일지&r 또는 &a철제 마도서&r를 만들어 시작할 수 있습니다. 몇 개의 스타터 &d주문 두루마리&r도 제공해 드릴 것입니다!"
		""
		"이것들은 일회용 아이템으로 시전하거나, 마나를 사용하여 원하는 때에 시전할 수 있도록 &a주문 책&r에 넣을 수 있습니다."
	]
	quest.0CA75E81F6824B22.title: "&eIron's Spells 'n Spellbooks"
	quest.0CAA799855644363.quest_subtitle: "유리 + 금"
	quest.0CE3C7A6DE787371.quest_desc: [
		"이 나침반은 &3금고&3의 위치를 가리킵니다."
		""
		"&7&o금고에서 256블록 이내에 있을 때 나침반을 Shift + 우클릭하면 입구로 즉시 순간이동할 수 있습니다!&r"
	]
	quest.0CE3C7A6DE787371.title: "&f리치의 &3위치 찾기"
	quest.0D159FD643581C18.quest_desc: [
		"&d기계공&r은 잊혀지고 잠재적으로 &c위험한&r &3금고&r에 대해 언급했는데, 이는 &6월드 엔진의 &3그림자 케이싱 업그레이드&r를 만드는 데 필요한 합금을 포함해야 합니다."
		""
		"&3석재&r와 &3심층암&r 고리 주위를 파서 &3금고&r를 찾으세요. &d기계공&r이 제공한 나침반을 사용하세요."
	]
	quest.0D159FD643581C18.title: "&f과거의 잔재"
	quest.0D38D67E3FD120CB.quest_desc: [
		"[\"\", {\"text\": \"Chaotic\", \"color\": \"rainbow\"}, \" weapons are the final upgrades to \", {\"text\": \"Draconic\", \"color\": \"gold\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"5388B67410670702\" }, \"hoverEvent\": {\"action\": \"show_text\", \"contents\": \"Go to Draconic Weapons Quest\"}}, \" weapons, with the most room for \", {\"text\": \"Upgrade Modules\", \"color\": \"green\"}, \" and maximum customizability.\"]"
		""
		"또한 올인원 도구이자 무기인 \\&z카오스 지팡이&r로 업그레이드하거나 제작할 수 있습니다."
		""
		"모듈 인벤토리는 기본적으로 바인딩되지 않은 키 바인딩 &e도구 모듈&r을 통해 액세스할 수 있습니다."
	]
	quest.0D38D67E3FD120CB.title: "\\&z카오스 &f무기"
	quest.0D57D3662EB40CE3.quest_desc: [
		"&eEnderIO&r의 &a축전기 은행&r은 에너지를 저장하는 데 사용됩니다!"
		""
		"이것들은 인터페이스 내에서 쉽게 구성할 수 있습니다. 멀티블록 전력 뱅크를 만들기 위해 이것들을 함께 쌓을 수도 있습니다."
	]
	quest.0D57D3662EB40CE3.title: "&a커패시터 뱅크&r"
	quest.0D864FD6A668D8C6.quest_desc: ["&3인터페이스&r는 네트워크에 동시에 입력하고 출력할 수 있으며, 동일한 블록 공간 내에서 &a임포터&r 및 &2익스포터&r 역할을 합니다."]
	quest.0DB5CBE2E76D2FD9.quest_desc: [
		"&6Pipez&r 모드는 &b아이템&r, &9유체&r, &c전력&r 또는 &2기체&r를 전송하는 여러 유용한 파이프를 추가합니다. &d범용 파이프&r를 사용하여 모든 것을 하나의 파이프로 압축할 수도 있습니다."
		""
		"파이프를 추출하도록 설정하려면, 추출하려는 블록에 연결된 파이프 끝에 &a파이프 렌치&r를 Shift + 우클릭해야 합니다. 완료되면 파이프를 &b파이프 업그레이드&r로 업그레이드하여 더 빠르게 만들거나 필터를 허용하는 등 더 많은 기능을 추가할 수 있습니다!"
		""
		"&e참고&r: &a파이프&r를 제작하려면 &a기계 블록&r과 &6월드 엔진 업그레이드&r가 필요합니다."
	]
	quest.0DB5CBE2E76D2FD9.title: "파이프"
	quest.0DE73FC2EE3C60A9.title: "안내 5 완료"
	quest.0DF48D4589272952.title: "&f10시간 플레이&a"
	quest.0DF5D2B35FDEE536.quest_desc: [
		"&eXNET&r은 단일 연결 네트워크에 최대 8개의 채널 유형(에너지, 아이템, 유체, 가스, 화학 물질 등)을 설정할 수 있는 물류 모드입니다."
		""
		"그러면 기계와 저장 장치를 단일 네트워크에 연결하고 관리할 수 있으며, 공간을 거의 차지하지 않고 지저분한 케이블 없이 사용할 수 있습니다."
		""
		"시작하려면 약간의 전력(FE), &a컨트롤러&r 및 일부 &2커넥터&r가 필요합니다."
		""
		"&e참고&r: &a컨트롤러&r를 제작하려면 &a포트론 주입 블록&r과 &c엔더 셀&r &3월드 엔진 업그레이드&r가 필요합니다."
	]
	quest.0DF5D2B35FDEE536.title: "XNet"
	quest.0DF9EE9016483463.title: "WE 설계도를 보상에 추가"
	quest.0E06BDC6265EB7F7.quest_desc: [
		"&3컨트롤러&r는 네트워크의 채널 수를 늘리는 데 사용됩니다. 초기 게임에서는 필요하지 않으며, 기본적으로 32개의 채널을 사용할 수 있습니다. &3컨트롤러&r가 없는 네트워크는 &bAd-Hoc&r로 간주됩니다."
		""
		"&e참고&r: &3컨트롤러&r를 제작하려면 &b포트론 주입 블록&r과 &6월드 엔진 업그레이드&r가 필요합니다."
		"{@pagebreak}"
		"&3컨트롤러&r는 ME 네트워크의 라우팅 허브로 간주됩니다. 동일한 네트워크에 2개의 별도 &3ME 컨트롤러&r를 가질 수 없지만, 추가 채널이 필요한 경우 거대한 멀티블록 설정을 구축할 수 있습니다."
		""
		"단일 &6컨트롤러&r는 팩의 설정에 따라 면당 &b128개의 채널&r을 제공합니다. 컨트롤러를 추가하면 채널에 대해 걱정할 필요가 거의 없을 것입니다."
		""
		"멀티블록 컨트롤러 구축에 대한 자세한 정보와 규칙은 &eAE2 가이드&r에서 찾을 수 있습니다."
	]
	quest.0E06BDC6265EB7F7.title: "&f더 많은 &3채널 추가"
	quest.0E0B4F549B42AF63.quest_desc: [
		"&a반응로 연료봉&r은 열을 생성하기 위해 &6반응로 연료 포트&r에서 &d우라늄&r 또는 &6플루토늄&r &a펠릿&r을 공급받아야 하는 내부 구성 요소입니다."
		""
		"&a연료 포트&r는 반응로 천장에 배치됩니다. 이 포트는 반응로 바닥까지 연결된 &a연료봉&r이 필요합니다."
		""
		"&6우라늄 펠릿&r을 만들려면 &6원자 대장간&r에 접근하여 &6우라늄 보석&r을 만들어야 합니다."
		"{@pagebreak}"
		"연료를 태울 때 &a연료봉&r은 특정 양의 에너지를 생성하는 중성자 펄스를 생성합니다. 펄스를 많이 받을수록 더 많은 에너지를 생성합니다. 그러나 이웃한 구성 요소가 &a연료봉&r인 경우, 이웃한 구성 요소에도 펄스가 전달됩니다."
		""
		"생성된 열의 양은 연료봉의 총 펄스 수(내부 + 외부 펄스)를 기준으로 합니다."
		""
		"단일 &a막대기&r는 내부 펄스 1개를 생성하고, &a이중 막대기&r는 4개, &a사중 막대기&r는 12개를 생성합니다."
		"{@pagebreak}"
		"&e중성자 반사기&r를 사용하여 펄스를 원래 위치로 되돌려 보내 이웃한 막대기와 유사하게 작동하여 효율성을 높일 수 있습니다."
		""
		"각 &a연료봉&r은 스택 위의 &b반응로 연료 포트&r에서 고정된 양의 연료를 소비합니다. 각 연료 펠릿에는 용량이 있으며, 각 막대기는 1 용량 단위를 사용하고, 이중 막대기는 2개, 사중 막대기는 4개를 사용합니다."
	]
	quest.0E0B4F549B42AF63.title: "&a원자로 봉"
	quest.0E107AC18FCFDB57.quest_desc: [
		"이제 &a프리모젤 점액&r이 있으니, 이 메커니즘이 어떻게 작동하는지 알아보기 위해 사용할 수 있습니다."
		""
		"먼저 &a프리모젤 점액&r을 열린 공간에 배치한 다음, &b설탕&r 또는 &b썩은 살점&r을 주어 활성화하세요. 이제 변환을 시작하기 위해 &2철 블록&r을 아무 면에나 배치할 수 있습니다."
		""
		"{image:ftb:textures/quests/just_dire_things/impure_daisy.png width:200 height:100 align:center}"
		"{@pagebreak}"
		"&b점액&r이 천천히 퍼져나가며 완전히 뒤덮이는 것을 볼 수 있습니다. 과정이 완료되면 &a원석 페리코어&r가 남게 됩니다."
		""
		"&7&o일부 셰이더는 이 효과를 제대로 표시하지 않으므로, 변경 사항을 보려면 비활성화하는 것이 좋습니다."
		""
		"이 광석을 채굴하면 &a원석 페리코어&r를 얻을 수 있으며, 이를 제련하여 &a페리코어 주괴&r를 만들 수 있습니다."
		""
		"&e참고&r: 행운은 이 광석에 적용되지 않습니다. 일반적으로 원석 3~4개를 얻게 됩니다."
	]
	quest.0E107AC18FCFDB57.title: "&a점액 변환&r"
	quest.0E610A03BB4007B6.quest_desc: ["몹 드랍 아이템을 사용하여 전력을 생성합니다."]
	quest.0E7AD6BCF9F8605F.quest_desc: [
		"이제 &6월드 엔진&r이 &d엔더&r 제작을 처리할 수 있으므로, &d엔더&r에 가지 않고 &e드래곤 알&r을 얻어야 합니다."
		""
		"&e엔더&r 고리 안에서 매우 특별한 &3금고&r를 찾을 수 있으며, 그 안에는 위험한 전투와 아마도 드래곤 알이 있을 것입니다."
		""
		"&d강력한 엔더 닭 알&r을 제작하여 중앙 고리의 &a디슬로케이터 받침대&r에서 사용하여 보스를 소환해야 합니다."
		"{@pagebreak}"
		"준비가 되어 있지 않다면 매우 어려운 전투가 될 수 있습니다!"
		""
		"&d강력한 엔더 닭&r은 방패를 가지고 소환되며, 피해를 입기 전에 방패를 부숴야 합니다. 이것은 &2닭 막대기&r로 때려야만 부술 수 있습니다."
		""
		"이 보스는 레이저 공격을 포함하여 여러 가지 다른 공격을 합니다. 이 공격은 당신을 죽일 가능성이 높습니다. 이 공격 중에는 숨는 것을 잊지 마세요!"
		"{@pagebreak}"
		"&d드래곤 알&r을 손에 넣으면 &6월드 엔진&r이 그 정수를 블록 형태로 추출할 수 있어야 합니다."
		""
		"&d촉매의 메아리&r로 다시 돌아가 &6월드 엔진&r을 업그레이드하는 방법을 알아보세요."
		""
		"[\"\", {\"text\": \"Note\", \"color\": \"yellow\"}, \": It's worth setting up an \", {\"text\": \"Extractor\", \"color\": \"green\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"0EBA58B7FD2AF36D\"}, \"hoverEvent\": {\"action\": \"show_text\", \"contents\": \"Go to Extractor Quest\"} }, \" to get more \", {\"text\": \"Dragon Eggs\", \"color\": \"light_purple\"}, \", or you can redo the fight over and over.\" ]"
		""
		"&7&o다음 페이지에서 설정하기 ->"
		"{@pagebreak}"
		"{image:ftb:textures/quests/dragon_egg_extraction.png width:70 height:200 align:center}"
	]
	quest.0E7AD6BCF9F8605F.quest_subtitle: "주요 월드 엔진 업그레이드"
	quest.0E7AD6BCF9F8605F.title: "&f아기에게서 사탕 빼앗기"
	quest.0EAEEF79436FDFA7.quest_desc: [
		"이 나침반은 &3금고&3의 위치를 가리킵니다."
		""
		"&7&o금고에서 256블록 이내에 있을 때 나침반을 Shift + 우클릭하면 입구로 즉시 순간이동할 수 있습니다!&r"
	]
	quest.0EAEEF79436FDFA7.title: "&f히드라 찾기&3"
	quest.0EBA58B7FD2AF36D.quest_desc: [
		"&aXycraft&r의 &b추출기&r는 &d드래곤 알&r 또는 &7하늘 돌 가루&r와 같은 희귀 자원을 쉽게 생성하는 데 필수적입니다."
		""
		"이 기계는 &b포트론 주입 블록&r과 &6월드 엔진 업그레이드&r로 사용할 수 있게 됩니다."
	]
	quest.0EBA58B7FD2AF36D.title: "&fXycraft 추출기&r"
	quest.0EE0A8941A69703E.quest_desc: [
		"&2주문 두루마리&r를 모으면 &a주문 기록 장치&r를 사용하여 주문 책에 새길 수 있습니다."
		""
		"테이블 인터페이스에서 주문을 새길 주문 책을 삽입할 수 있습니다. 그런 다음 책 아래 왼쪽 빈 슬롯에 주문 두루마리를 추가하고 위에 있는 아이콘을 클릭하여 주문을 새길 수 있습니다."
		""
		"각 주문 책은 서로 다른 수의 주문을 담을 수 있으며, 저희의 시작 주문 책은 6개만 담을 수 있습니다. 곧 업그레이드하는 것이 좋을 것입니다!"
		"{@pagebreak}"
		"또한 인터페이스에서 주문을 선택한 다음 오른쪽에 있는 주문 두루마리를 클릭하여 주문을 제거할 수도 있습니다."
		""
		"주문은 &a주문 책&r을 장신구 슬롯에 장착하여 시전할 수 있습니다."
		""
		"장착되면 기본적으로 &bR&r 키 바인딩을 사용하여 두루마리 바퀴를 열 수 있습니다. 선택한 주문은 &bV&r를 눌러 시전할 수 있습니다."
		""
		"이 모든 것은 키 바인딩에서 변경할 수 있습니다. &acategory:아이언의 주문과 주문서 - 일반&r을(를) 검색해 보세요."
		""
		"빠른 시전 옵션도 있습니다!"
	]
	quest.0EE0A8941A69703E.title: "&a주문 새기기"
	quest.0EE35D6E57FAD973.quest_desc: [
		"모든 마법 부여 설정에 가장 유용한 아이템 중 하나입니다!"
		""
		"&6마법 부여 도서관&r은 마법 부여를 위한 저장소 역할을 합니다. 충분한 저레벨 마법 부여가 있다면 더 높은 레벨의 마법 부여 책을 만들어 줄 수도 있습니다."
		""
		"&e참고&r: 이것은 \\&z상점 전용 아이템&r입니다!"
	]
	quest.0EFA11536D00E653.quest_desc: [
		"초반 게임에서 &2바이오 연료&r는 &a바이오 발전기&r에 주입될 때 훌륭한 에너지원으로 사용될 수 있습니다."
		""
		"참고: 큰 사각형이 있는 앞면에서만 전력을 추출할 수 있습니다."
	]
	quest.0EFA11536D00E653.title: "바이오 발전기"
	quest.0F1B7185D8F4CDE6.quest_desc: [
		"&7암흑 물질 도구&r는 빠르고 부서지지 않으며, 암흑 물질 &a곡괭이&r는 일반 모드와 3블록 너비 채굴 모드 간에 전환할 수 있습니다."
		""
		"&eProjectE&r 도구는 EMC로 충전(기본값: \"V\")하여 각 도구를 우클릭할 때 강력한 광역 효과 능력을 부여할 수 있습니다."
	]
	quest.0F1B7185D8F4CDE6.title: "&7암흑 물질 &f도구"
	quest.0F3EDB9AE592016B.quest_subtitle: "에너지 용량 및 에너지 전송 속도 향상"
	quest.0F3EDB9AE592016B.title: "&f기계 축전기 애드온"
	quest.0F48353EDD296510.quest_desc: ["&d와름라이트&r와 대화하여 &d공명하는 공허&r를 제작하면 &3월드 엔진 업그레이드&r 설치 방법을 알려줄 것입니다."]
	quest.0F7CB818AC0A9187.quest_desc: [
		"엔더 닭과 싸운 후 &r작은 혼돈 조각&r에 접근할 수 있습니다."
		""
		"&a유체 레이저&r를 사용하여 \\&z녹은 혼돈&r을 추출해야 하며, 이는 &6작은 혼돈 조각&r으로 변환될 수 있습니다."
		""
		"[\"You can learn more about how to do this in the \", {\"text\": \"Bringing Home The Chicken quest\", \"color\": \"light_purple\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"4D7C7DE95E56C7B3\"}, \"hoverEvent\": {\"action\": \"show_text\", \"contents\": \"Go to Quest\"}}, \" in the T5 chapter.\"]"
	]
	quest.0F7CB818AC0A9187.title: "\\&z혼돈 조각"
	quest.0FD446B7912E00CB.quest_desc: ["모든 부품을 결합하여 &c고급 기계 블록&r을 만들 시간입니다."]
	quest.0FD446B7912E00CB.quest_subtitle: "주요 월드 엔진 업그레이드"
	quest.0FD446B7912E00CB.title: "&f고급 기계 업그레이드"
	quest.0FED418633235211.title: "&f중반 바닐라 검"
	quest.0FF5D73B3256F400.quest_desc: [
		"&3업그레이드&f에 필요한 블록을 제출하고 보상을 받으면 팀의 &6월드 엔진&r이 자동으로 조립됩니다."
		""
		"&e참고&f: 업그레이드가 있어야 할 곳에 배치된 블록은 사라집니다."
	]
	quest.0FF5D73B3256F400.title: "&f자동 제작 &3정령 업그레이드"
	quest.0FFC6CBB213B30AD.quest_desc: ["우유와 끈적한 아이템을 소비하여 전력을 생성합니다."]
	quest.101B8D9769D835AB.quest_desc: [
		"&3업그레이드&f에 필요한 블록을 제출하고 보상을 받으면 팀의 &6월드 엔진&r이 자동으로 조립됩니다."
		""
		"&e참고&f: 업그레이드가 있어야 할 곳에 배치된 블록은 사라집니다."
	]
	quest.101B8D9769D835AB.title: "&f자동 제작 &3크로니톤 업그레이드"
	quest.1069575C4B5BCE39.quest_desc: [
		"&e리파인드 스토리지 2&r (&eRS2&r)는 아이템, 유체, 기체를 저장할 수 있는 확장 가능한 디지털 저장 네트워크 모드입니다."
		""
		"[\"To get started with \", {\"text\": \"RS2\", \"color\": \"yellow\"}, \" you'll need to get some \", { \"text\": \"Certus Quartz\", \"color\": \"aqua\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"73EC5E7F2300B99D\"}, \"hoverEvent\": {\"action\": \"show_text\", \"contents\": \"Go to Certus Quartz Quest\"}}, \" to make \", {\"text\": \"Quartz Enriched Iron\", \"color\": \"green\"}, \" and \", {\"text\": \"Quartz Enriched Copper\", \"color\": \"dark_green\"}, \".\"]"
		""
		"프로세서는 &eRS2&r 네트워크의 대부분의 핵심 구성 요소를 제작하는 데 사용됩니다."
		""
		"[\"These can only be assembled inside a \", { \"text\": \"Circuit Fabricator\", \"color\": \"light_purple\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"663460DE8AF7E464\" }, \"hoverEvent\": {\"action\": \"show_text\", \"contents\": \"Go to Circuit Fabricator Quest\"} }, \".\"]"
	]
	quest.1069575C4B5BCE39.title: "리파인드 스토리지 2"
	quest.106A9E7AD6051D8C.title: "안내 완료 3"
	quest.107C26E8BF309BC1.quest_desc: [
		"모험을 하는 동안 &d신비한&r 전리품을 많이 발견하게 될 것입니다."
		""
		"가장 흔하게 발견되는 아이템은 &d신비한 정수&r입니다. 이것은 &d신비한 천&r을 만들고, &b마나 물약&r을 양조하는 데 사용할 수 있습니다!"
		"{@pagebreak}"
		"또한 &a빈 룬석&r을 찾을 수 있으며, 이는 모드에서 가장 강력한 장비 중 일부를 만드는 &2룬석&r을 제작하는 데 사용됩니다. &a빈 룬석이 아닌 것&r은 마법사를 처치한 후에도 찾을 수 있습니다."
		""
		"&b미스릴&r은 공허에서 일반적인 방법으로는 얻을 수 없는 전설적인 금속입니다. 적어도 일반적인 방법으로는요. 아마도 어떤 마법적인 원천이 그것을 제공할 수 있을 것입니다. 일종의 문일까요..."
	]
	quest.107C26E8BF309BC1.title: "&f신비한 발견"
	quest.10DEA5CE1800F935.quest_desc: [
		"&7&o때로는 일이 잘못될 때가 있고, 마인크래프트에는 \"실행 취소\" 버튼이 없기 때문에 저희가 추가했습니다."
		""
		"실수로 &6월드 엔진&r 기계 블록을 부순 경우, 이 버튼을 클릭하면 복구됩니다."
		""
		"이것은 기존 설정과 &6월드 엔진&r 내부의 아이템을 모두 삭제한다는 점을 명심하세요."
	]
	quest.1111B3ACEDDF5633.quest_desc: [
		"만약 \\&z작은 혼돈 조각&r이 \\&z반물질&r과 충돌하게 둔다면, 당신의 세계를 파괴할 수도 있습니다."
		""
		"또는 \\&z블랙홀&r의 작고 전혀 해롭지 않은 아이템 버전이 당신이 집어 들 수 있도록 떨어질 것입니다."
		""
		"추측 게임을 해봅시다!"
	]
	quest.1111B3ACEDDF5633.title: "\\&z블랙홀&r"
	quest.11A35E8F97ACA240.quest_desc: [
		"[\"\", {\"text\": \"Draconic\", \"color\": \"gold\"}, \" tools are upgraded versions of \", {\"text\": \"Wyvern\", \"color\": \"light_purple\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"056990503617C147\" }, \"hoverEvent\": {\"action\": \"show_text\", \"contents\": \"Go to Wyvern Tools Quest\"}}, \" tools, with room for more \", {\"text\": \"Upgrade Modules\", \"color\": \"green\"}, \" and better customizability.\"]"
		""
		"올인원 도구이자 무기인 &6드라코닉 지팡이&r도 제작할 수 있습니다."
		""
		"모듈 인벤토리는 기본적으로 바인딩되지 않은 키 바인딩 &e도구 모듈&r을 통해 액세스할 수 있습니다."
		""
		"&e참고&r: 이를 제작하려면 &c고급 기계 블록&r과 &d드라코닉 에너지&r &6월드 엔진 업그레이드&r가 있어야 합니다."
	]
	quest.11A35E8F97ACA240.title: "&6드라코닉 &f도구"
	quest.11BB3C62703E0B3E.quest_desc: [
		"영혼을 직접 블록에 가두는 것은 아마도 가장 윤리적인 일은 아니겠지만, &6월드 엔진&r은 더 발전된 제작을 위해 그 힘을 활용할 수 있습니다."
		""
		"&3영혼 블록 업그레이드&r를 설치하는 방법을 배우려면 이것을 &d지옥의 존재&r에게 가져가세요."
	]
	quest.11C58E38DE9488BE.quest_desc: [
		"&bMob Grinding Utils&r의 &a몹 분쇄기&r는 레드스톤 신호를 받으면 몹 농장의 처치 과정을 자동화할 수 있습니다."
		""
		"더 많은 피해를 입히거나, 더 많은 전리품을 떨어뜨리거나, 몹이 머리를 떨어뜨리도록 업그레이드할 수도 있습니다!"
		""
		"&a참고&r: 아이템이 세상에 떨어질 때 집어 올릴 무언가가 여전히 필요합니다."
	]
	quest.11C58E38DE9488BE.quest_subtitle: "몹 갈기 유틸리티"
	quest.11C58E38DE9488BE.title: "&f몹 때려잡기"
	quest.11CC48D772573E73.quest_desc: [
		"\\&z무한의 무기&r는 무한한 양의 피해를 입힙니다."
		""
		"&7&o말 그대로 몹에게 '/kill' 명령을 실행합니다."
	]
	quest.11CC48D772573E73.title: "\\&z무한의 무기"
	quest.11F69E1E4FE4D5CD.quest_desc: [
		"필요한 고급 회로에는 &d플럭사이트&r라는 특수 수정이 필요합니다."
		""
		"이 수정은 &d자수정 수정&r에 직접 에너지를 빔으로 쏘아 생성할 수 있습니다. 이를 위해서는 &c엔더릭 레이저&r와 &b목표 지정기&r를 만들어야 합니다."
		"{@pagebreak}"
		"&c엔더릭 레이저&r를 제작한 후에는 수정을 성장시킬 수 있는 &d발아하는 자수정 블록&r 근처에 설치해야 합니다."
		""
		"&b목표 지정기&r를 &d자수정 수정&r에 대고 쉬프트 + 우클릭하면 위치를 지정기에 저장할 수 있습니다. 저장한 후, 레이저가 발사될 위치를 지정하려면 &c엔더릭 레이저&r에 대고 쉬프트 + 우클릭하세요."
		""
		"제대로 수행하면 레이저가 발사되어 수정을 &d플럭사이트&r로 변환합니다."
		""
		"이를 사용하여 &d플럭스 게이트&r를 제작하세요."
	]
	quest.11F69E1E4FE4D5CD.title: "&f플럭스의 힘"
	quest.1237537100194BED.title: "&e처치&f: &7위더"
	quest.1278BB2F13A74537.quest_subtitle: "언더서, 지질학자"
	quest.12CB62610FEAADA0.quest_desc: ["드래곤의 숨결을 소모하여 발전합니다."]
	quest.131199313AE3F5E9.quest_desc: ["&a전동 제련기&r는 본질적으로 업그레이드할 수 있는 동력 화로입니다!"]
	quest.131199313AE3F5E9.title: "&f우리의 첫 &a동력 화로"
	quest.133ECE7BDDC8C13D.quest_desc: [
		"이제 <blank>을(를) 획득했으니, &6인도의 메아리&r는 더 많은 &d기록 보관소&r를 발견할 수 있다고 언급했습니다."
		""
		"로비로 돌아가서 무엇을 찾을 수 있는지 확인하세요!"
	]
	quest.133ECE7BDDC8C13D.quest_subtitle: "2단계 퀘스트라인 잠금 해제"
	quest.133ECE7BDDC8C13D.title: "&f잃어버린 메아리 찾기"
	quest.136E32BEF40CCB1B.quest_subtitle: "언더서, 지질학자"
	quest.137039009E8EBA03.quest_desc: [
		"&6ProjectE&r는 충분한 EMC와 &c네더라이트 스미싱 템플릿&r을 확보하면 만들 수 있는 몇 가지 매우 강력한 도구를 가지고 있습니다."
		""
		"이 도구들은 EMC로 충전할 수 있습니다(기본값: \"V\"). 각 도구를 우클릭하면 강력한 범위 효과 능력이 부여됩니다."
		""
		"&e참고&r: 이를 제작하려면 &a기계 블록&r &6월드 엔진 업그레이드&r가 필요합니다."
	]
	quest.137039009E8EBA03.title: "프로젝트 E 도구"
	quest.137EC884018376A1.quest_desc: [
		"&c네더라이트&r 장비는 &a고대 잔해&r와 &c네더라이트 대장장이 형판&r을 확보하면 훌륭한 갑옷이 됩니다."
		""
		"[\"You may get \", {\"text\": \"Ancient Debris\", \"color\": \"green\"}, \" early by going to the \", { \"text\": \"Nether Dungeon\", \"color\": \"red\", \"underlined\": true, \"clickEvent\": {\"action\": \"change_page\", \"value\": \"21A521011401074F\"}, \"hoverEvent\": {\"action\": \"show_text\", \"contents\": \"Go to Nether Dungeon Quest\"}}, \", which can spawn in the Deepslate Ring.\" ]"
	]
	quest.137EC884018376A1.title: "&f바닐라 네더라이트 갑옷"
	quest.13874944C284A510.quest_desc: [
		"&b오컬티즘&r은 악마 영역에서 당신을 위해 광질할 정령을 바인딩하여 무한한 광석을 생성하는 것을 제공합니다."
		""
		"이는 &d차원 광산&r과 &d바인딩된 채굴기 폴리오트&r를 사용하여 수행할 수 있습니다."
		""
		"채굴기 폴리오트를 &d차원 광산&r에 배치하면 시간이 지남에 따라 광석이 생성됩니다."
	]
	quest.13874944C284A510.title: "&f정령 채광"
	quest.138CB008CE4C838B.quest_desc: [
		"&6아르스 누보&r를 사용하면 &d의식&r을 수행하여 몹을 소환하고, 떠다니는 섬을 건설하는 등 더 많은 것을 할 수 있습니다!"
		""
		"첫 의식을 치르려면 &3의식 화톳불&r과 수행하고 싶은 다양한 &d의식 서판&r 중 하나를 제작해야 합니다. 화톳불을 내려놓고 원하는 의식의 서판을 사용한 다음, 빈 손으로 다시 우클릭하여 의식을 수행하세요."
		""
		"대부분의 의식은 활성화하기 위해 &d마나&r가 필요하므로 근처에 병을 준비하세요!"
		"{@pagebreak}"
		"의식은 특정 아이템을 사용하여 &a강화&r할 수도 있습니다. 이는 먼저 &3의식 서판&r을 사용하는 것으로 시작하여, 강화 요구 사항을 충족하기 위해 아이템을 화톳불에 하나씩 사용하는 방식으로 이루어집니다. 완료되면 빈 손으로 우클릭하여 의식을 활성화할 수 있습니다."
	]
	quest.13C8B2286F5184C7.quest_desc: ["충전되면 &3순간이동 지팡이&r를 사용하면 바라보는 방향으로 최대 100블록까지 순간이동합니다."]
	quest.13D1BC0C49543326.quest_desc: [
		"이 퀘스트는 &d고대의 &6기록보관소&r로 가는 웨이포인트를 설정합니다."
		""
		"&e참고&f: &d황혼&r과 &d고대인&r은 동일한 &6기록보관소&r를 공유합니다."
	]
	quest.13D1BC0C49543326.title: "&f고대인&d 찾기"
	quest.13E0F74B9A1DAB58.quest_desc: [
		"이 나침반은 &3금고&3의 위치를 가리킵니다."
		""
		"&7&o금고에서 256블록 이내에 있을 때 나침반을 Shift + 우클릭하면 입구로 즉시 순간이동할 수 있습니다!&r"
	]
	quest.13E0F74B9A1DAB58.title: "&f금고 찾기&3"
	quest.13EC7C64DFBD1556.quest_desc: [
		"&a오라이텍&r의 &6기본 발전기&r는 모든 종류의 화로 연료를 태워 소량의 전력을 생성하는 스타터 발전기입니다."
		""
		"모드의 &c에너지 파이프&r를 사용하거나 다른 종류의 에너지 케이블을 사용하여 전력을 전송할 수 있습니다."
	]
	quest.13EC7C64DFBD1556.title: "&f오라이텍 스타터 발전기"
	quest.13FD704C45145E23.quest_desc: [
		"&a유체 추출기&r는 모드에서 가장 먼저 만들고 싶은 기계입니다."
		""
		"이 기계는 앞에 놓인 모든 나무 원목에서 &7라텍스&r를 끌어옵니다. &7라텍스&r가 많이 필요하므로 몇 개 만드는 것이 좋습니다!"
		""
		"이 기계는 전력이 필요하지 않지만, 전력이 공급되면 &b3배 더 빠르게&r 작동합니다."
		""
		"대부분의 원목은 평균적인 양을 제공하지만, &a아카시아 원목&r과 &a맹그로브 원목&r이 가장 많이 제공됩니다!"
	]
	quest.13FD704C45145E23.title: "&f라텍스 추출&7"
	quest.13FE28AF74A357CD.quest_desc: [
		"&a기계 벨트&r는 컨베이어 벨트와 같은 시스템을 만들어 아이템 및/또는 &b회전력&r을 전송하는 데 사용될 수 있습니다."
		""
		"&eCreate&r 기계는 가능한 경우 &a벨트&r의 아이템과 자동으로 상호 작용합니다."
	]
	quest.13FE28AF74A357CD.title: "Create 아이템 옵션"
	quest.1402FA427FF1B8B3.quest_subtitle: "언더서, 차원 이동 전문가"
	quest.141CE17C25D2A53A.quest_desc: [
		"배낭의 업그레이드를 만들려면 먼저 &a업그레이드 베이스&r를 제작해야 합니다."
		""
		"많은 유용한 업그레이드를 만들 수 있습니다. 예를 들어, 수많은 아이템을 저장하기 위한 슬롯 스택 제한을 늘리는 &a스택 업그레이드&r 또는 배고플 때 자동으로 먹이를 주는 &a먹이 업그레이드&r가 있습니다!"
		""
		"모두 확인해 보세요!"
	]
	quest.143E07D2565798AB.quest_desc: [
		"&e오라이텍&r은 대부분 &b기계 코어&r를 필요로 하는 &a멀티블록 기계&r를 구축하는 데 중점을 둡니다. 기계의 툴팁을 확인하여 필요한 코어 수를 항상 확인할 수 있습니다."
		""
		"7가지 종류의 &a기계 코어&r가 있으며, 각 코어는 멀티블록 기계에 부착할 수 있는 &b애드온&r의 총 수를 증가시킵니다."
		""
		"일단 시작을 위해 처음 두 단계 중 하나를 만들 수 있습니다!"
	]
	quest.143E07D2565798AB.title: "기계 기본"
	quest.14537A63D3BDC09B.quest_desc: [
		"&3업그레이드&f에 필요한 블록을 제출하고 보상을 받으면 팀의 &6월드 엔진&r이 자동으로 조립됩니다."
		""
		"&e참고&f: 업그레이드가 설치될 위치에 배치된 블록은 사라집니다."
	]
	quest.14537A63D3BDC09B.title: "&f자동 건설 &3유포니움 업그레이드"
	quest.1461682BD1978BA8.quest_desc: [
		"&a분쇄기&r는 주로 광석과 금속을 &b가루&r로 분해하는 데 사용되는 &b중형 기계&r입니다."
		""
		"불운하게도 그 안에 빠진 적들을 갈아서 관련 드롭 아이템을 얻는 데 사용할 수도 있습니다."
		""
		"멀티블록을 구축하는 데 도움이 되는 &b기술자의 설명서&r를 꼭 확인하세요!"
	]
	quest.1461682BD1978BA8.title: "&f분쇄기"
	quest.150BB4679DD2B4B5.quest_desc: [
		"믿기 어렵겠지만, 소는 사과와... 점토를 정말 좋아합니다? 이 둘을 합치면 무엇이 나올까요?"
		""
		"소에게 &a클애플&r을 먹이면 무작위 아기 &b유체 소&r로 변환됩니다. 완전히 성장하면 이 소들을 착유하여 해당 유체의 양동이를 얻을 수 있습니다!"
		""
		"일반 소와 달리 &b유체 소&r는 착유 빈도에 재사용 대기시간이 있습니다."
		""
		"&b클애플&r을 사용하여 만들 수 있는 &a유체 소&r 목록 ->"
		"{@pagebreak}"
		"- 구리"
		"- 철"
		"- 주석"
		"- 아연"
		"- 납"
		"- 니켈"
		"- 은"
		"{@pagebreak}"
		"- 알루미늄"
		"- 금"
		"- 우라늄"
		"- 자수정"
		"- 레드스톤"
		"- 탄소"
		"- 슬라임"
		"- 오스뮴"
	]
	quest.150BB4679DD2B4B5.title: "유체 소"
	quest.1520491A7804E08E.quest_desc: [
		"&a작업자 토큰&r을 &2발굴기&r에서 사용하려면 다음 3가지 직업 중 하나를 가진 주민이 필요합니다:"
		""
		"- &a고고학자&r: 흙, 먼지, 진흙, 모래를 브러싱할 수 있습니다. 작업대에는 &a장식용 화분&r을 사용합니다."
		""
		"- &2지질학자&r: 자갈, 소울 샌드, 부서진 키비를 브러싱할 수 있습니다. 작업대에는 &2수집 테이블&r을 사용합니다."
		""
		"- &d차원술사&r: 네더랙, 엔드 스톤, 기타 암석을 브러싱할 수 있습니다. 작업대에는 &d공명 공학 블록&r을 사용합니다."
	]
	quest.1520491A7804E08E.title: "&f발굴 주민"
	quest.159DE084D82C6A1C.quest_desc: [
		"&2정원 클로슈&r는 물, 전력, 흙이 있으면 작물 재배를 자동화할 수 있는 필수 기계입니다."
		""
		"다른 등급의 흙은 다른 성장 속도를 가집니다!"
	]
	quest.159DE084D82C6A1C.title: "정원 클로슈"
	quest.15B551FCA8790707.quest_desc: ["이 퀘스트 보상을 받으면 &d메아리의 &6기록 보관소&r 입구에 웨이포인트가 설정됩니다."]
	quest.15B551FCA8790707.title: "&f위치 찾기 &d마법사"
	quest.15DE76B303680F79.quest_desc: [
		"&d용 조련사&r는 용에 대해 많은 것을 알고 있습니다. 이 시점에서는 &d용의 먼지&r를 가지고 있어야 합니다."
		""
		"그것은 용의 가루 맞죠?"
		""
		"몇 가지 용 관련 아이템을 만든 후 &d용 조련사의 메아리&r에게 돌아가 이 &3업그레이드&r를 설치하는 방법을 알아보세요."
	]
	quest.15DE76B303680F79.quest_subtitle: "주요 월드 엔진 업그레이드"
	quest.15DE76B303680F79.title: "&d용의 핵&r"
	quest.160C4C63A3CEACE1.title: "포트론 주입 블록 거래"
	quest.1617D99EA1AE47E4.quest_desc: [
		"&b확인&f: &l크로논 생성기 제출&r"
		""
		"&b잠금 해제됨&f:"
	]
	quest.1617D99EA1AE47E4.title: "안내 1.2 확인"
	quest.1628081CB8A2E5CA.quest_subtitle: "언어더, 지질학자"
	quest.165A1B6F56051FA6.quest_desc: [
		"&e템패드&r는 특수 임시 포털인 타임도어를 사용하여 장소를 이동하는 순간이동 모드입니다."
		""
		"&e템패드&r 모드를 사용하여 &6크로논 생성기&r와 &a크로논 셀&r을 이미 만들었습니다."
		""
		"&a위치 카드&r가 다음 단계이며, &2타임도어 프로젝터&r 또는 &6템패드&r와 같은 다른 장치에서 사용할 위치 데이터를 등록하는 데 사용됩니다."
		""
		"이것들은 &a지갑&r에 보관하여 인벤토리를 깔끔하게 유지할 수 있습니다."
	]
	quest.165A1B6F56051FA6.title: "&6템패드&r 모드"
	quest.1666835CA3297C7D.quest_desc: [
		"2개의 특별한 &a장인 두루마리&r가 &6이중성&r 보석을 만드는 방법을 알려줄 것입니다."
		""
		"이 보석은 &e금속&r과 &d보석&r의 속성을 모두 가지며 전반적으로 품질이 더 높습니다."
		""
		"&e참고&r: 이 두 레시피 모두 &d마법 부여&r &6월드 엔진 업그레이드&r가 필요합니다."
	]
	quest.1666835CA3297C7D.title: "&6이중성&r &a보석&r"
	quest.166A223222AD76FC.quest_desc: ["&r창조적 행운의 펜던트&r는 펜던트에 넣으면 &d행운의 상자&r의 행운을 설정할 수 있게 해줍니다."]
	quest.166A223222AD76FC.title: "크리에이티브 찬스 펜던트"
	quest.166BA0D04A1686C7.quest_desc: [
		"&3포트론&r은 &a강압 유도기&r 또는 다른 &b포트론 기반 기계&r의 버퍼에서 추출할 수 있습니다."
		""
		"이는 다른 모드의 유체 추출 방법을 사용하여 수행할 수 있습니다."
		""
		"&7&o유체 관리 옵션은 "
		""
		"&7&o참고: 이 퀘스트를 완료하려면 할당된 &2작업 화면&r에 버킷 분량(1000mB)을 펌핑해야 합니다."
	]
	quest.166BA0D04A1686C7.title: "&f추출 &3포트론"
	quest.1680080BED98F027.quest_desc: ["이 퀘스트 보상을 받으면 &d메아리의 &6기록 보관소&r 입구에 웨이포인트가 설정됩니다."]
	quest.1680080BED98F027.title: "&f위치 찾기 &d촉매제"
	quest.16B60BCB8240F808.quest_desc: [
		"&d패턴 인코딩 터미널&r을 사용하여 패턴을 인코딩한 후에는 &a패턴 공급기&r에 배치할 수 있습니다. &a공급기&r는 연결된 블록을 사용하여 제작을 완료하려고 시도합니다."
		""
		"기계가 필요 없는 모양 및 모양 없는 제작 레시피의 경우, &a공급기&r를 &3분자 조립기&r 옆에 배치할 수 있습니다. 분자 조립기는 단순한 자동 제작기입니다!"
		"{@pagebreak}"
		"처리 과정이 필요한 다른 자동 제작 작업의 경우, &a공급기&r를 제작하려는 기계를 향하도록 배치합니다."
		""
		"예를 들어, &2화로&r를 &a공급기&r 앞에 배치하고 해당 제련 레시피를 패턴에 인코딩하여 &a공급기&r에 넣으면 자동 제련을 설정할 수 있습니다."
		""
		"&a패턴 공급기&r는 &c절단 칼⟧&r을 사용하여 이름을 바꿀 수도 있어 패턴 단말기에서 더 쉽게 찾을 수 있습니다!"
		"{@pagebreak}"
		"&a패턴 공급기&r와 &3조립기&r를 더 빠르게 작동시키는 방법에 대한 자세한 내용은 AE2 가이드를 확인하세요!"
	]
	quest.16B60BCB8240F808.title: "&f패턴 저장하기"
	quest.16C312C27F9805DB.title: "§z세계의§r &r신"
	quest.16F7490FA5DE307C.quest_desc: [
		"&a몹 분쇄기&r는 &b인더스트리얼 포고잉&r의 것으로, 몹 농장에서 몹을 쉽게 분쇄할 수 있습니다."
		""
		"전원이 공급되면 이 기계는 작동 영역 내의 모든 몹을 즉시 처치하고 전리품을 인벤토리로 자동으로 수집합니다."
		""
		"작동 영역은 애드온을 사용하여 업그레이드할 수 있으며, 활성화 속도도 마찬가지입니다."
	]
	quest.16F7490FA5DE307C.quest_subtitle: "인더스트리얼 포고잉"
	quest.16F7490FA5DE307C.title: "&f몹 분쇄하기"
	quest.1770A460E1FD7CC8.quest_desc: [
		"[\"\", {\"text\": \"Particle Accelerators\", \"color\":\"#FF55FF\"}, \" can be built in various ways, depending on their goals. A straight line of \", {\"text\": \"Linear Motors\", \"color\":\"#55FF55\"}, \" can shoot particles at something, but higher speeds are more efficiently reached with a circular design. Very large rings might be needed to reach certain elements. Slow particles require \", {\"text\": \"Guide Rings\", \"color\": \"#55FF55\"}, \" to be close together, so starting in a small ring and then \", {\"text\": \"using redstone\", \"color\":\"#55FFFF\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"778A876616D4638E\" } }, \" to move to a larger ring often makes sense.\"]"
		""
		"일부 경우에는 여러 개의 고리 단계가 필요할 수 있습니다."
	]
	quest.1770A460E1FD7CC8.title: "&f가속기 설계"
	quest.17AC5EBEBDC124E9.quest_desc: [
		"&a에코 인코더&r를 사용하여 &2토큰&r으로 주민을 변환하기 위해 웅크리기 + 우클릭을 할 수 있습니다."
		""
		"이 &2토큰&r은 &a주민&r을 시간에 맞춰 인코딩하여 필요할 때 배치할 수 있게 합니다."
		""
		"&a에코 인코더&r는 충전량이 제한되어 있으므로 &6월드 엔진&r에 다시 넣어서 충전해야 합니다."
		""
		"&d안내의 메아리&r가 이제 다음 단계를 안내할 것입니다."
	]
	quest.17AC5EBEBDC124E9.title: "&f정신없는 자의 토큰"
	quest.17C23A586C708425.quest_desc: [
		"&d플루토늄 펠릿&r을 얻으면 &6중성자 수집기&r를 제작할 수 있습니다."
		""
		"이 기계는 약 6분마다 &r중성자 더미&r를 생성합니다. 몇 개를 만드는 것이 좋습니다. 그렇지 않으면 한참 기다려야 합니다."
	]
	quest.17C23A586C708425.title: "§z중성자§r"
	quest.17D5EB0E89BC10D7.quest_desc: [
		"&a엔더제닉&r 발전기 설정은 핵물리학 학위가 필요하지 않은 가장 복잡한 에너지 발전기 중 하나입니다."
		""
		"이 발전기는 &d엔더 진주&r를 서로 '던져서'(&e스마트 렌치&r로 대상 지정) 순간이동 효과를 취소하고, 억제된 에너지를 흡수하여 동력을 추출합니다."
		""
		"억제된 진주를 계속 보유하면 에너지가 소모되며, 진주를 던진 후 &a엔더제닉&r은 &3쿨다운 상태&r에 들어가므로, 효율을 위해 레드스톤을 사용한 적절한 타이밍이 중요합니다. 이 과정은 완벽하지 않기 때문에 때때로 진주가 던져진 후 기계에서 산산조각날 수 있습니다."
	]
	quest.17DE59BAD714DE63.quest_desc: [
		"많은 요리 레시피에 &b우유&r가 필요합니다."
		""
		"그래서 &6우유 양동이&r에 소를 밀어 넣으면 됩니다. &b주방 멀티블록&r에 추가하면, 요청 시 우유 양동이를 레시피에 제공합니다."
		""
		"하지만 어떻게 얻을 수 있을까요? 먼저 &a우유 병&r을 만들어야 합니다. 이것은 우유를 자체적으로 저장할 수 있지만, 주방을 위해 재생 가능한 우유 공급원을 원할 것입니다."
		"{@pagebreak}"
		"다음으로, 우유 병을 소가 들어갈 수 있는 충분히 큰 구멍에 놓아야 합니다."
		""
		"소를 우유 병 바로 위에 있는 구멍으로 유인한 다음, 모루를 구멍에 떨어뜨립니다. 이렇게 하면 소가 병 안으로 으깨집니다!"
		""
		"이렇게 하면 주방을 위해 시간이 지남에 따라 우유가 천천히 공급됩니다."
		""
		"&e참고:&r 유체 소에 대해서도 동일한 작업을 수행할 수 있습니다!"
	]
	quest.17DE59BAD714DE63.title: "&f무료 우유!"
	quest.188CEC9710C2F404.quest_desc: [
		"&a철 상자&r 모드는 표준 상자에 기본적인 금속 업그레이드를 추가합니다."
		""
		"이것들은 쉽게 제작할 수 있으며, 전리품 벌에 의해 머리를 맞았을 때 얻었을 수도 있습니다."
	]
	quest.18A36EA79A9355C4.quest_desc: [
		"&d와이번 융합 주입기&r로 업그레이드하려면 코어 주위에 최소 8개의 &d드라코늄 주입기&r가 필요합니다."
		""
		"각 주입기가 필요한 아이템을 우클릭하여 업그레이드를 제작할 수 있습니다. 각 주입기에는 전원도 필요합니다."
		""
		"모든 아이템을 주입기에 넣으면 메인 아이템을 &a코어&r에 넣을 수 있으며, 레드스톤 신호를 받으면 제작이 시작됩니다."
	]
	quest.18A36EA79A9355C4.title: "&d와이번 &f융합"
	quest.18AF36E1C2375101.quest_desc: ["&7심층암&r의 잠재된 마법 능력을 사용하여 테이블 안에서 더 강력한 마법 부여를 제공하는 책장을 만들 수 있어야 합니다."]
	quest.18AF36E1C2375101.quest_subtitle: "마이너 월드 엔진 업그레이드"
	quest.18AF36E1C2375101.title: "&f심연의 마법"
	quest.18E10F15FD94258B.quest_desc: [
		"&6월드 엔진&r에 사용되는 케이싱을 만들기 전에 &c용암&r과 &d흑요석&r을 확보해야 합니다."
		""
		"아직 하지 않았다면, &6기계공&r에게 가서 &b엔트로피 조작기&r를 얻어 용암을 만드는 방법을 확인하세요."
		""
		"&d흑요석&r은 기본 케이싱의 강도를 지탱할 만큼 충분히 강한 재료이지만, 먼저 &a판금&r으로 압착해야 합니다."
	]
	quest.18E10F15FD94258B.title: "&f흑요석 성형"
	quest.193690C049F4B4BB.quest_desc: [
		"&2망치&r를 사용하여 흙을 모래로, 그리고 &a가루⟧&r로 부술 수도 있습니다. 이것들은 진행에 필요한 다양한 자원을 제공할 것입니다."
		""
		"&2망치&r는 &a압축된 블록&r을 부수어 일을 더 빠르게 할 수도 있습니다!"
	]
	quest.193690C049F4B4BB.title: "&f더 부수기"
	quest.19C13B2B7F137956.title: "간단한 순간이동기"
	quest.19C696F8143FB1B6.title: "&6각성한 드라코늄 &f거래"
	quest.19C7CC772EC56E7B.quest_desc: [
		"알을 얻으면 무지개의 어떤 색과도 조합하여 &a염색된 닭알&r을 만들 수 있습니다."
		""
		"이 알들을 던지면 해당 색의 닭으로 부화할 확률이 있습니다."
		""
		"비록 1단계 닭으로 간주되지만, 이 닭들은 더 높은 단계의 닭을 번식시키는 데 필요합니다!"
	]
	quest.19C7CC772EC56E7B.title: "기본 염료 닭"
	quest.19C9BB7952E89BA7.quest_desc: ["이제 &r블랙홀&r을 용기에 넣었으니, &6라디언스&r에게 돌아가 업그레이드를 설정하는 방법을 배우세요."]
	quest.19C9BB7952E89BA7.title: "&f라디언스와 &6대화하기"
	quest.1A2D8034C07D988B.quest_desc: [
		"&6사이&f는 &2마인크래프트&r에 흥미로운 개념을 가져온 모드입니다. &d마법 주문을 프로그래밍하고&r &c탄환&r에 담는 것이 가능하다면 어떨까요?"
		""
		"- 테크노매직 여정을 시작하려면 &6CAD 조립기&r와 어떤 종류든 &6기본 CAD 장치&r를 만드세요. &bCAD&r는 &b\"&o캐스팅 보조 장치&r\"&r를 의미합니다."
		""
		"{@pagebreak}"
		"&8&o그리고 이 모드는 Vazkii가 만들었으니.... &l멋지다⟧&r는 뜻이죠!&r&r"
	]
	quest.1A2D8034C07D988B.quest_subtitle: "테크노매직 애니메이션에서 영감을 받은 모드!"
	quest.1A2D8034C07D988B.title: "사이"
	quest.1A84E167BFF8C2E4.quest_desc: [
		"흙도 없고... 나무도 없고... 도구도 없지만... 당신의 주먹은 여전히 있습니다."
		""
		"&a돌&r을 부숴 &2조약돌&r을 얻어 작업하세요."
		""
		"&e참고&r: 빈 손으로 해야 합니다!"
	]
	quest.1A84E167BFF8C2E4.title: "&f바위처럼 단단하게"
	quest.1A89ACDC528588D5.quest_desc: [
		"&b셀레스티젬&r은 &6Just Dire Things&r의 갑옷 다음 단계입니다."
		""
		"내구도를 사용하는 대신, 이 갑옷은 대신 &c에너지&r를 사용하며, 더 많은 업그레이드를 설치할 수 있습니다."
		""
		"이것들은 &d고대 도시&r로 여행을 떠나 &d보이드쉬머 구슬&r을 만든 후에 만들 수 있습니다."
	]
	quest.1A89ACDC528588D5.title: "&b천상의 보석 갑옷"
	quest.1AA08B095A8B378F.quest_desc: [
		"자동화를 설정할 때, 서랍으로 아이템을 밀어 넣거나 당기는 것은 복잡해질 수 있습니다. 그때 저장 도구가 유용합니다!"
		""
		"&3구성 도구&r는 서랍이 특정 아이템과만 상호 작용하도록 잠그는 데 사용됩니다. 서랍에서 아이템을 계속 꺼내거나 넣을 때 매우 유용합니다!"
		"{@pagebreak}"
		"&e전문가 팁&r: 서랍을 &a저장 컨트롤러&r에 연결했다면, 컨트롤러에서 설정 도구를 사용하여 연결된 모든 서랍을 한 번에 잠글 수 있습니다!"
		""
		"모드를 변경하여 서랍의 수량 표시를 숨기거나 FPS를 절약하기 위해 서랍의 아이템 렌더링을 비활성화하는 등 여러 모드를 설정할 수 있습니다."
	]
	quest.1ABA5F2ECAA6D9D2.quest_desc: [
		"&e메카니즘&r은 팩에서 최고의 물류 케이블과 파이프를 제공합니다! 이 아이템들은 세계에서 업그레이드할 수 있으며 내부 버퍼도 있습니다."
		""
		"이 파이프와 케이블을 설정하려면 &d설정 도구&r를 사용하는 것이 가장 좋습니다. 이것은 메카니즘의 렌치이며 여러 유용한 기능도 제공합니다."
	]
	quest.1ABA5F2ECAA6D9D2.title: "메카니즘 파이프"
	quest.1B10A2DED0629D6B.quest_desc: [
		"배낭에 대한 동일한 업그레이드와 마찬가지로, &d공허 업그레이드&r는 아마도 설치할 수 있는 가장 유용한 업그레이드 중 하나일 것입니다."
		""
		"이것은 상자에 들어가는 특정 아이템을 공허하게 만들 수 있으며, 꽤 멋진 일을 할 수 있는 필터가 함께 제공됩니다. 특정 모드의 모든 것을 공허하게 만들도록 필터를 설정할 수도 있습니다!"
	]
	quest.1B20BEE2BE4476A7.quest_desc: [
		"&e오라이텍의 &a사이버네틱 업그레이드&r를 통해 완전한 사이버펑크가 되어 토글 가능한 업그레이드를 캐릭터에 직접 설치할 수 있습니다."
		""
		"이 업그레이드는 특정 연구 스테이션을 필요로 할 수 있으며, 이동 속도 또는 공격 피해 증가부터 플레이어를 영구적으로 투명하게 만들거나 크리에이티브 비행을 부여하는 것까지 다양합니다."
	]
	quest.1B20BEE2BE4476A7.title: "&6사이버네틱 강화&r"
	quest.1B3B2B9697D7AEA6.quest_desc: [
		"&d이클립스 합금&r 도구는 &6Just Dire Things&r의 최종 등급 도구입니다."
		""
		"이것은 모드 최고의 업그레이드를 사용할 수 있는 동력 도구입니다."
		""
		"이것들은 &d치킨 조키&r를 처치하고 &d섀도우펄스 구슬&r을 만든 후에 만들 수 있습니다."
	]
	quest.1B3B2B9697D7AEA6.title: "&d이클립스 합금 &f도구"
	quest.1B8BB733ADF897FE.quest_desc: [
		"&e생산적 금속 작업장&r은 합금을 제련하고 단조하며 다양한 부품으로 주조하는 데 사용됩니다."
		""
		"먼저 &c불 점토&r를 제작한 다음, 이를 제련하여 &4불 벽돌&r을 만드세요. 이것은 &6주조소&r 구조물을 만드는 데 사용될 것입니다."
		""
		"&e야금술 대백과&r는 &6주조소&r를 설정하는 방법을 보여줄 수 있습니다."
	]
	quest.1B8BB733ADF897FE.title: "&e생산적 금속 작업장 &6주조소"
	quest.1BC994881BC225ED.quest_desc: [
		"마법 스풀과 다양한 재료를 조합하여 &a직조공 작업대&r에서 신비로운 갑옷에 적용하면, 갑옷의 방어력과 다른 이점은 유지하면서 외형이 바뀝니다."
		""
		"&e고대 직조&r는 갑옷을 대체 버전으로 변환하지만, 다른 모든 직조는 갑옷을 하나의 고정된 모습으로 바꿉니다."
		""
		"&o&7예: 영혼 사냥꾼 로브와 영혼 얼룩 흉갑은 코너드 직조를 적용하면 동일하게 보일 것입니다.&r"
	]
	quest.1BF77D602FFDF292.quest_desc: [
		"&d무한 범위 부스터&r는 같은 차원 내 어디에서든 네트워크에 액세스할 수 있게 해줍니다."
		""
		"&6차원 카드&r는 상당한 에너지 비용으로 차원 간 네트워크에 액세스할 수 있게 해줍니다."
	]
	quest.1BF77D602FFDF292.title: "차원 범위 업그레이드"
	quest.1BFDE3507411C116.quest_desc: [
		"주조소를 제어하고 제련 액체를 저장하기 위해 &6주조소&r에는 &a컨트롤러&r와 &2탱크&r가 필요합니다."
		""
		"물론, 물건을 제련할 만큼 충분한 열을 견딜 수 있도록 &6주조소&r 기반을 튼튼하게 만들어야 합니다."
		""
		"&7&o이것들은 염색하여 기지 미학에 맞출 수 있습니다."
	]
	quest.1BFDE3507411C116.title: "&f주요 &6주조소 &f구성 요소"
	quest.1C0024A48898FB90.quest_desc: [
		"&a연금술 촉매&r를 중심으로 &a정령 도가니&r는 정령을 먼지나 보석과 같은 물리적 형태로 전환하여 그들의 속성에 맞출 수 있습니다. 이것은 촉매의 재료를 천천히 소모하지만, 수리하거나 새로 만들 수 있습니다."
		""
		"특히 &e'불타는 석영'&r은 공허에서 달리 찾을 수 없습니다."
		""
		"다른 유형의 촉매도 제작할 수 있어, 정령을 더 다양한 자원으로 전환할 수 있습니다."
	]
	quest.1C3DFCB335276952.title: "메카니즘 반응로"
	quest.1C6508B8B2C94CAF.quest_desc: [
		"이 전력 소모 도구는 &a개조 테이블&r에서 업그레이드할 수 있습니다."
		""
		"채굴 범위와 속도를 높이거나 섬세한 손길 또는 행운을 적용하기 위해 업그레이드를 설치할 수 있습니다."
	]
	quest.1C6508B8B2C94CAF.title: "&e채굴 장치"
	quest.1CA7E96F42B75C2F.quest_desc: [
		"만들 수 있는 첫 번째 기계 중 하나는 &a동력 화로&r입니다!"
		""
		"이 기계를 만들려면 먼저 &a동력 화로&r 블록을 배치한 다음, 그 위에 &b기계 코어&r를 배치하세요. 그런 다음 우클릭하여 만들 수 있습니다."
		""
		"이것은 초반 게임에서 괜찮은 기계이지만, &b애드온&r을 사용하여 훨씬 빠르게 업그레이드할 수 있습니다."
	]
	quest.1CA7E96F42B75C2F.title: "&f동력 &a화로"
	quest.1CA8D89EE7C50CFD.title: "셜커 처치"
	quest.1CC15C703CEC4190.quest_desc: [
		"&e임머시브 엔지니어링&r(&eI.E&r)은 재미있고 유용한 멀티블록이 많은 현실주의 기반 기술 모드입니다."
		""
		"시작하려면 &a엔지니어 망치&r를 제작하세요. 이 망치는 제작법과 멀티블록 활성화에 사용됩니다."
		""
		"&a엔지니어 설명서&r는 이러한 멀티블록 기계를 설정하는 방법을 보여주는 최고의 친구가 될 것입니다."
	]
	quest.1CC15C703CEC4190.title: "&e임머시브 엔지니어링"
	quest.1CCD08A54B3F94C4.quest_desc: [
		"팩의 대부분 아이템에는 EMC 값이 없지만, &d암흑 물질&r과 &c붉은 물질&r은 EMC 외에도 사용할 수 있습니다."
		""
		"이 둘 중 하나를 &b분해기&r를 사용하여 엄청난 양의 &a물질&r로 전환할 수 있습니다."
	]
	quest.1CCD08A54B3F94C4.title: "물질 과부하"
	quest.1CFBFD1CE648772F.quest_desc: [
		"무선으로 전력 저장 장치에 연결하려면 전력을 &d엔더 셀&r에 펌핑해야 합니다."
		""
		"이것은 &b주파수&r에 막대한 양의 에너지를 저장하는 데 사용되며, 다른 엔더 셀이나 &6엔더 게이트&r를 사용하여 어떤 차원에서든 접근할 수 있습니다."
	]
	quest.1CFD4CE2704F2ADE.quest_desc: [
		"&b잉크&r를 손에 넣으면, &a주문 대장간&r을 사용하여 새로운 주문 두루마리를 제작하는 데 사용할 수 있습니다."
		""
		"각 두루마리마다 &b잉크&r, 종이, 그리고 제작하려는 &b주문 학파&r를 결정하는 특정 아이템이 필요합니다. 각 학파의 모든 아이템을 보려면 &eJEI&r를 사용할 수 있습니다!"
		"{@pagebreak}"
		"사용된 &b잉크&r의 등급이 제작할 수 있는 주문의 레벨을 결정합니다. 특정 주문은 더 높은 등급의 잉크로만 제작할 수 있습니다."
		""
		"팁: 피글린과 거래하는 것은 &d울음하는 흑요석&r을 얻는 쉬운 방법이지만, 다른 방법도 있습니다!"
	]
	quest.1CFD4CE2704F2ADE.title: "&a주문 제작&d"
	quest.1D52FC5D0EAD911B.title: "안내 확인 2"
	quest.1D87C5E9D52341C4.quest_desc: [
		"&e드라코닉 에볼루션&r에서 더 고급 아이템을 제작하려면 &d융합 제작&r이라는 특별한 제작 설정을 사용해야 합니다."
		""
		"&d융합 제작 코어&r는 설정의 중앙에 있어야 하며, &d드라코늄 융합 제작 추출기&r는 코어를 향해 2블록 간격으로 배치되어야 합니다."
		""
		"코어는 시작을 위해 레드스톤 신호도 필요합니다."
	]
	quest.1D87C5E9D52341C4.title: "융합 제작"
	quest.1D8B2D2B03DF3256.quest_desc: ["&d와름라이트&r는 &2크로논 공명기&r를 제작하면 형제의 마지막 알려진 위치를 찾을 수 있다고 말합니다."]
	quest.1D8B2D2B03DF3256.title: "&f승천한 메아리 찾기&6"
	quest.1DA11C69EFDA19EC.quest_subtitle: "언어더, 지질학자"
	quest.1DA78BAB2A6E2C82.quest_desc: [
		"모드 베테랑들에게 &e엔더IO&r는 놀라운 파이프인 &d컨duit&r 때문에 좋은 추억을 가지고 있었습니다."
		""
		"이 &d컨duit&r는 구성이 매우 유연하며 같은 블록 공간에 여러 컨duit를 저장할 수도 있습니다. 케이블의 모양이 마음에 들지 않으면 덮개를 씌우기 위해 &2파사드&r를 사용할 수도 있습니다!"
		""
		"&a예타 렌치&r를 사용하여 쉽게 구성할 수 있습니다. 파이프가 &2외관&r 아래에 숨겨져 있다면, 렌치를 손에 들고 있으면 쉽게 구성할 수 있도록 파이프가 드러납니다."
	]
	quest.1DA78BAB2A6E2C82.title: "엔더IO 컨duit"
	quest.1DC5DE6E9F0D0B2C.quest_desc: [
		"주문은 &a주문 책&r을 장신구 슬롯에 장착하여 시전할 수 있습니다."
		""
		"장착 후, 기본적으로 &bR&r 키를 눌러 두루마리 바퀴를 열 수 있습니다. 선택한 주문은 &bV&r를 눌러 시전할 수 있습니다."
		""
		"이 모든 것은 키 바인딩에서 변경할 수 있습니다. &acategory:\"Iron's Spells 'n Spellbooks - General\"&r을(를) 검색해 보세요."
		""
		"빠른 시전 옵션도 있습니다!"
	]
	quest.1DC5DE6E9F0D0B2C.title: "&b주문 시전"
	quest.1DE16238ECFB074D.title: "카오스 만남"
	quest.1E061D2E5C560867.quest_desc: [
		"&c체세드 경기장&r은 &e엔드&r 고리에서 발견되는 거대한 구조물입니다."
		""
		"이 경기장에는 자체 보스 전투가 포함되어 있습니다!"
	]
	quest.1E061D2E5C560867.title: "&c체세드 경기장 찾기"
	quest.1E077BC4B8832C98.quest_desc: ["&b황혼 숲&r 고리의 상층부에서 발견되는 &a예티&r의 금고는 두 번째 황혼 보스입니다."]
	quest.1E077BC4B8832C98.title: "&f예티의 동굴"
	quest.1E2A91B73A752B3B.quest_desc: [
		"&a생체 인식 식별기&r는 &d강제장&r 및 &e방해 매트릭스&r가 개별적으로 작동하기 위한 요구 사항입니다. 예를 들어 필드 블록을 통과하기 위해 숨을 수 있습니다."
		""
		"필드 블록 안에서 숨지 않은 플레이어는 즉각적인 &c무한한 피해&r를 입습니다.&r"
		""
		"자신에게 등록된 &b식별 카드&r와 관련 플레이어당 하나의 카드가 필요합니다. 등록된 &b카드&r는 &a식별기&r 기계의 슬롯에 배치됩니다."
		""
		"다른 플레이어는 &b카드&r로 숨기 + 오른쪽 클릭하여 등록할 수 있습니다."
		"{@pagebreak}"
		"GUI 설명:"
		""
		"첫 번째 슬롯은 &b카드&r에 등록된 플레이어에게 다양한 \"권한\"을 허용하거나 거부하는 용도입니다."
		""
		"두 번째 슬롯은 첫 번째 슬롯의 &b카드&r의 권한을 두 번째 슬롯에 넣은 모든 &b카드&r에 복사합니다."
		""
		"세 번째 슬롯은 &b카드&r에 등록된 플레이어에게 모든 권한을 부여합니다. 이 슬롯에 카드가 없으면 &a식별기&r는 &l작동하지&r 않습니다."
		""
		"나머지 9개의 슬롯은 &b카드&r를 안에 넣으면 해당 플레이어에게 정의된 권한을 적용합니다."
	]
	quest.1E2A91B73A752B3B.title: "&a생체 인식 식별기"
	quest.1E307C13D534A75C.title: "빛 굴절기 확인 1"
	quest.1E6014F4B7CBE373.quest_desc: [
		"&6배터리&r는 &d선택적 부착물&r로, &bCAD&r에 장착할 수 있으며, 기본 Psi 에너지가 부족할 때 방출할 수 있도록 &b예비 Psi 에너지&r를 준비할 수 있게 해줍니다."
		""
		"&e&n보조 배터리처럼요!&r"
		""
		"특히 이 배터리는 다음을 제공합니다:"
		""
		"► &a오버플로우&r: 400"
	]
	quest.1E6014F4B7CBE373.title: "&d3단계&f CAD 배터리"
	quest.1E6E38DC6183463A.quest_desc: [
		"&eDE&r 에너지 코어는 완전히 업그레이드되면 거의 무한한 양의 전력을 저장할 수 있는 계층적 에너지 저장 솔루션입니다."
		""
		"핵심 구성 요소는 &a에너지 코어&r와 &2에너지 코어 안정기&r이며, 코어에서 최대 8블록 떨어진 어느 방향으로든 배치할 수 있습니다."
		""
		"코어에 전력을 삽입하거나 추출하려면 코어에서 10블록 이내에 &b에너지 파일론&r을 설치한 다음 그 위나 아래에 유리 블록을 배치해야 합니다."
		"{@pagebreak}"
		"코어를 업그레이드하려면 각 단계마다 &a에너지 코어&r를 더 많은 &d드라코늄 블록&r으로 둘러싸야 합니다. 8단계에서는 &6각성된 드라코늄 블록&r으로도 둘러싸야 합니다."
		""
		"에너지 코어에는 인터페이스 내에 빌드 가이드가 있어 상호작용 시 인벤토리에서 블록을 자동으로 배치할 수 있습니다."
		""
		"8단계에서는 &2안정기&r를 링 형태로 업그레이드해야 하며, 총 36개의 블록(링당 9개)이 필요합니다."
	]
	quest.1E6E38DC6183463A.title: "&eDE &f에너지 코어"
	quest.1EC4F12DACE04299.quest_desc: ["크리에이트 금고에서 획득"]
	quest.1EEC74B18B1BFBB5.quest_desc: [
		"&a배터리&r는 에너지를 이동하며 저장하는 좋은 방법입니다. 유선 또는 무선 충전 방식으로 충전할 수 있습니다."
		""
		"손에 들고 있을 때, 쉬프트 우클릭하여 방전 모드로 전환하고 인벤토리의 다른 아이템을 충전할 수 있습니다."
	]
	quest.1F052C1F0AC1330C.title: "광휘 만남"
	quest.1F0F37429F1177DF.quest_desc: [
		"더 많은 &6아카이브&r가 잠금 해제되었으므로, 로비에서 &d황혼의 메아리&r를 찾아 탐험할 시간입니다."
		""
		"그들과 협력하여 &6월드 엔진&r의 &3황혼 업그레이드&r를 잠금 해제하세요."
		""
		"&7&o로비에서 &e/echo twilight&7를 사용하여 이 메아리를 만난 후에는 어디서든 직접 순간이동할 수 있습니다."
	]
	quest.1F0F37429F1177DF.title: "&f에코&d 만나기"
	quest.1F1A15B6E079F31F.quest_desc: [
		"&c고급 기계 블록&r의 회로를 제작하려면 안정적인 손만으로는 부족합니다."
		""
		"이를 위해서는 매우 정밀한 기계가 필요합니다. &a조립기&r면 충분할 것입니다."
		""
		"&e참고&r: 이 기계를 조립하려면 어떤 티어든 3개의 &a기계 코어&r가 필요합니다."
		""
		"[{\"text\": \"\", \"color\": \"gray\", \"italic\": true}, \"If you wish to learn more about Oritech, check out the \", { \"text\": \"Oritech Chapter\", \"color\": \"gray\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"1FD2F304ADC237D0\"}, \"hoverEvent\": {\"action\": \"show_text\", \"contents\": \"Go to Oritech Questline\"} }, \".\"]"
	]
	quest.1F1A15B6E079F31F.title: "&f더 고급 제작대"
	quest.1F1C11D77667DEB4.quest_desc: [
		"&6코어&r는 &aCAD의 필수적인 부분&r이며, 항상 최상의 것을 만들도록 노력하세요. &a기본적으로 CAD의 CPU와 같습니다&r."
		""
		"모든 &6CAD 코어&r에는 &d&l복잡성 값&r&r이 있으며, 이는 &d얼마나 많은 계산을 할 수 있는지&r를 의미합니다."
		"&8&o(선택자, 연산자 등은 주문의 복잡성을 증가시킬 수 있습니다)&r&r"
		""
		"또한, 모든 &6CAD 코어&r에는 &3&l투영 값&r&r이 있으며, 이는 단순히 &3디버그되지 않은 트릭을 한 번에 수행할 수 있는 총 개수&r입니다."
		""
		"이 &6코어&r는 특히 다음 중 하나를 제공할 수 있습니다:"
		""
		"► &d복잡성&r: 30 또는 36"
		""
		"► &3투영&r: 6 또는 7"
	]
	quest.1F1C11D77667DEB4.title: "&d3단계&f CAD 코어"
	quest.1F66695405A4863D.quest_desc: [
		"&d크로니톤 별&r은 시간과 공간을 변경하는 힘으로 가득 차 있습니다."
		""
		"&6월드 엔진&r을 사용하여 이 힘을 추출하여 &6월드 엔진&r 자체를 &2크로니톤 유리&r에 주입하여 업그레이드해야 합니다."
		""
		"&e참고&r: &d크로니톤 별&r은 유리를 사용하여 &6월드 엔진&r을 업그레이드한 후 복원할 수 있습니다."
	]
	quest.1F66695405A4863D.quest_subtitle: "마이너 월드 엔진 업그레이드"
	quest.1F66695405A4863D.title: "&f시간-공간 유리"
	quest.1F9D3474C8A655A9.quest_desc: [
		"&6안내 기록 보관소&r에 오신 것을 환영합니다."
		""
		"여정을 시작하기 위해 &d메아리&r와 대화하세요..."
		""
		"&e참고&f: 친구와 함께 플레이하는 경우, 팀에 다른 사람을 초대하기 &n전에⟧&r 이 퀘스트를 먼저 완료하고 집 기지로 돌아가세요."
	]
	quest.1F9D3474C8A655A9.title: "&f신비로운 길..."
	quest.1FE2B36C234A35C9.quest_desc: ["&2약제사&r는 &a삶과 죽음의 이야기&r 게이트웨이에서 찾을 수 있습니다."]
	quest.1FE2B36C234A35C9.title: "&2약제사⟧ 처치"
	quest.1FEEBCA6D633B479.quest_desc: [
		"&e엔더 저장소&r는 아이템과 유체를 차원 간에 저장할 수 있게 해줍니다."
		""
		"&a엔더 상자&r는 일치하는 색상 패턴을 가진 다른 상자와 인벤토리를 연결합니다. 색상을 변경하려면 양털 패드에 염료를 사용하면 됩니다."
		""
		"&e참고&r: 이것들을 제작하려면 &b크로니톤 유리&r &6월드 엔진 업그레이드&r가 필요합니다."
		"{@pagebreak}"
		"&a엔더 주머니&r를 사용하면 같은 색상 패턴의 &a엔더 상자&r에 원격으로 접근할 수 있습니다. 주머니를 &a엔더 상자&r에 우클릭하면 주머니의 색상이 해당 상자의 색상과 일치하도록 변경됩니다."
		""
		"&a엔더 탱크&r는 &a엔더 상자&r와 같은 방식으로 작동하지만 아이템 대신 액체를 저장합니다."
		""
		"&b다이아몬드&r를 &a엔더 상자&r의 걸쇠에 사용하면 해당 다이아몬드를 사용한 플레이어의 별도 개인 네트워크로 이동합니다. 이는 서버 사용에 특히 유용합니다."
	]
	quest.1FEEBCA6D633B479.title: "&e엔더 저장소"
	quest.20168B6357665708.quest_desc: ["이 퀘스트 보상을 받으면 &d메아리의 &6아카이브&r 입구에 웨이포인트가 설정됩니다."]
	quest.20168B6357665708.title: "&f물품 관리인 &d찾기"
	quest.201BB935C9972574.quest_desc: [
		"하급 주문 슬롯 개선은 많은 양의 &c호그스킨&r과 약간의 &b비전 천&r으로 제작할 수 있습니다."
		""
		"이것은 &a비전 모루&r를 통해 &a주문서&r에 반복적으로 적용하여 최대 12개의 주문 슬롯을 부여할 수 있으며, 약한 일지에도 가능합니다!"
	]
	quest.201BB935C9972574.title: "&f주문 슬롯 개선"
	quest.206987FC6B1524F8.quest_desc: [
		"&a원자 재구성기&r는 재료를 결정화하는 데 사용되며 &e실제 추가물&r에서 사용되는 주요 기계 중 하나입니다."
		""
		"전원이 공급되면 최대 10블록 거리까지 레이저 빔을 발사하거나, 레이저가 다른 블록과 접촉할 때까지 발사됩니다."
		""
		"레이저의 양쪽 면에 배치된 떨어뜨린 아이템이나 블록을 결정화합니다."
	]
	quest.206987FC6B1524F8.title: "&a원자 재구성기"
	quest.206F8B25D5A3CB7E.title: "촉매제 만나기"
	quest.20D7DA6055C540FA.quest_desc: [
		"현상금 게시판의 대부분의 퀘스트는 반복 가능하며 &a매일 24시간마다 새로고침⟧&r됩니다!"
		""
		"각 퀘스트의 시계 작업은 보상을 수집한 후 재사용 대기시간을 표시합니다."
	]
	quest.20D7DA6055C540FA.title: "퀘스트 타이머"
	quest.20F9CC6590B8990C.quest_desc: [
		"&6아르스&r에는 일상적인 작업을 돕기 위해 소환할 수 있는 많은 마법 생물이 있습니다. 이것들은 &d지배 지팡이&r를 사용하여 제어할 수 있습니다!"
		""
		"각각의 기능에 대해 더 자세히 알아보려면 &a낡은 마도서&r 안내서를 참조하세요."
	]
	quest.210753664AB84703.quest_desc: [
		"&a합금 제련기&r는 &e엔더IO&r에서 가장 많이 사용되는 기계가 될 것입니다. 대부분의 기계와 장치는 여기서 생산되는 합금이 필요하기 때문입니다! 아, 그리고 &b축전기&r로 업그레이드할 수 있습니다."
		""
		"&a합금 제련기&r 인터페이스에서 자동화를 개선하기 위해 여러 가지 방법으로 구성할 수 있습니다. 측면 투입/방출 구성, 레드스톤 구성, 그리고 세 가지 모드 간 전환이 가능합니다:"
		"{@pagebreak}"
		"&e합금 전용 모드&r: 합금 제련기에서 합금만 생성하도록 허용합니다."
		""
		"&e용광로 전용 모드&r: 합금 제련기를 용광로로 취급합니다."
		""
		"&e합금 및 제련&r: 이 모드는 합금과 제련을 모두 수행하므로, 일부 아이템이 합금으로 변환되기 전에 제련될 수 있어 자동화 시 문제가 될 수 있습니다."
	]
	quest.210753664AB84703.title: "&a합금 제련기"
	quest.212600F8D3C1E1EB.quest_desc: [
		"&e염수&r를 다른 열 증발탑으로 통과시키면 &6액체 리튬&r으로 변환됩니다."
		""
		"액체 리튬으로는 할 수 있는 것이 많지 않으므로, &a회전식 응축기&r를 사용하여 기체로 변환해야 합니다."
		""
		"&aMekanism&r에서 최고의 전력 저장 장치를 만들기 위해, &a화학 결정기&r를 사용하여 리튬을 &6리튬 분말&r로 변환해야 합니다. 결정기는 제작에 &d궁극의 제어 회로&r가 필요합니다!"
	]
	quest.212600F8D3C1E1EB.title: "&d리튬 분말"
	quest.21322BAF061FE83F.quest_desc: [
		"&6뉴트로늄&r은 시작점으로 사용할 수 있지만, 이제 활성화해야 합니다. &r중성자 활성화기&r는 이를 위한 다중 블록 기계입니다."
		""
		"이 기계는 이 돌 세계에 명백히 부족한 태양의 힘을 시뮬레이션하기 위해 열이 필요합니다."
		"{@pagebreak}"
		"이는 &e핵 폐기물&r을 &d폴로늄&r으로, &e리튬&r을 &a삼중수소&r로 변환할 수 있으며, 단일 &6중성자 활성화기&r로 전력을 공급받습니다."
	]
	quest.21322BAF061FE83F.title: "\\&z중성자 활성화기&r"
	quest.213FE1D19D589513.quest_desc: [
		"&e바우블리 하트 크리스탈&r을 사용하면 최대 80개의 하트(체력 160)까지 최대 체력을 증가시킬 수 있습니다. 이는 각 티어의 캐니스터를 최대 20개까지 &a하트 아뮬렛&r 안에 넣어 수행할 수 있습니다."
		""
		"&c붉은 하트&r는 적대적인 몹을 처치할 때 드롭될 수 있습니다."
		""
		"&e노란 하트&r는 대부분의 보스에게서 드롭됩니다."
		""
		"&a녹색 심장&r은 &d워든&r과 &c이그니스&r에게서 드롭됩니다."
		""
		"&9파란색 심장&r은 \\&z강력한 엔더 치킨&r, &6리바이어던&r, &6타이로스&r, &c말레딕투스&r에게서 드롭됩니다."
	]
	quest.213FE1D19D589513.title: "&6보석 심장 결정"
	quest.2140EAC255C3EA09.quest_desc: [
		"&a다중 블록 프린터&f와 &a다중 블록 검증기&f는 새로운 구조물을 구축하고 손상된 다중 블록을 검증하는 데 도움이 되는 두 가지 도구입니다."
		""
		"다음 페이지에서 각 아이템 사용법을 알려드립니다."
		"{@pagebreak}"
		"&a멀티블록 프린터&f는 특정 구조물만 지원하며, 이는 &eJEI&r에서 “&a멀티블록 프린터&r”를 검색하고 “&aⓘ&f 호환 가능"
		""
		"필요한 블록을 모으고 멀티블록을 위한 충분한 공간을 확보한 후, &b컨트롤러&r를 배치하고 &a멀티블록 프린터&r로 우클릭하세요."
		""
		"그러면 인벤토리의 아이템을 사용하여 블록을 자동으로 배치합니다."
		""
		"블록 배치를 방해하는 것이 있거나 인벤토리에서 아이템을 찾을 수 없는 경우, &a멀티블록 프린터&f의 작동이 멈추고 문제를 설명하는 오류가 표시됩니다."
		"{@pagebreak}"
		"&a멀티블록 검증기&f는 &e커스텀 기계 장치&r 멀티블록을 진단하고 유지하는 데 도움이 됩니다."
		""
		"이를 &b커스텀 기계 장치 컨트롤러&r에 사용하면 모든 &a설치된 멀티블록 모듈&f이 표시됩니다."
		""
		"또한 월드 엔진을 자동으로 재정렬할 수 있습니다."
		""
		"모든 멀티블록 코어를 재설정할 수도 있습니다. 이 작업은 &c&n&l손실된 아이템을 환불하지 않습니다&r&c&n오류가 발생한 코어로&r, 해당 코어의 아이템은 사실상 사라지게 됩니다."
	]
	quest.2140EAC255C3EA09.title: "멀티블록 도구"
	quest.214D210F200CD11F.quest_desc: [
		"&d타임 트위스터&r는 타임라인에 죽음이나 차원 변경과 같은 중요한 이벤트를 기록합니다. 충분한 &b크로논&r이 있다면 이 타임라인 이벤트의 정확한 위치로 순간이동할 수 있습니다."
		""
		"어떤 이벤트가 기록되는지는 타임 트위스터의 인터페이스를 통해 설정할 수 있습니다."
	]
	quest.215E7EB95A7C64A3.quest_desc: [
		"모든 초가 중요하므로, 그것들을 &6시간 주머니&r에 넣어야 합니다."
		""
		"이 주머니는 인벤토리에 있는 동안 시간을 저장합니다. 이 시간은 주머니를 사용하여 거의 모든 것에 틱을 추가하는 데 사용할 수 있습니다."
		""
		"무언가가 너무 느리다면, 저장된 시간을 사용하여 더 빠르게 만드세요!"
		""
		"&7&o시간을 살 수 없다고 누가 말했나요?"
	]
	quest.215E7EB95A7C64A3.title: "\\&z시간 주머니"
	quest.21A521011401074F.quest_desc: ["이 던전은 &7심층암&r과 &c네더랙&r 고리에서 생성됩니다."]
	quest.21A521011401074F.title: "&c네더 던전 찾기"
	quest.21E1A72027DBF236.quest_desc: [
		"&3업그레이드&f에 필요한 블록을 제출하고 보상을 받으면 팀의 &6월드 엔진&r이 자동으로 조립됩니다."
		""
		"&e참고&f: 업그레이드가 있어야 할 곳에 배치된 블록은 사라집니다."
	]
	quest.21E1A72027DBF236.title: "&f자동 제작 &3고급 기계 업그레이드"
	quest.22103051C3EE2BA0.quest_desc: [
		"&aSAG 밀&r은 아이템을 가루로 분쇄하며, 광석 수확량을 늘리는 데 사용할 수 있습니다."
		""
		"&b분쇄용 공&r은 기계 전력 사용량과 아이템 처리 출력을 개선하는 데 사용할 수 있습니다. 분쇄용 공에는 여러 티어가 있지만, 시작할 때는 항상 &3부싯돌&r을 사용할 수 있습니다."
	]
	quest.22103051C3EE2BA0.title: "&fSAG 밀"
	quest.226E5BD0BEB1BA75.quest_desc: ["이것들은 &c콴타&r 100% 추가 또는 &c콴타&r 및 &5아르카나&r 제거와 같은 특정 보너스를 제공하는 고유한 선반입니다."]
	quest.226E5BD0BEB1BA75.title: "&a기타 선반"
	quest.228D69F6ACAE761B.quest_subtitle: "발굴자, 지질학자"
	quest.22B83D03C6C3E61E.quest_subtitle: "작동 속도를 향상시키지만 에너지 효율은 감소시킵니다"
	quest.22B94BDDC08B3FA9.quest_desc: [
		"&a황동 케이싱&r을 &d흑요석 판&r으로 강화하면 기차의 무게를 견딜 수 있을 만큼 튼튼한 케이싱을 만들 수 있습니다."
		""
		"이것은 &6월드 엔진&r을 업그레이드하기 위한 큰 단계입니다!"
		""
		"진행 상황을 보여주기 위해 &d기계공&r에게 돌아가세요."
	]
	quest.22B94BDDC08B3FA9.title: "&f기차 케이싱"
	quest.231726AD865A945F.quest_desc: [
		"&6메카니즘&r은 &a에너지 큐브&r와 &a에너지 태블릿&r을 사용하여 간단한 에너지 저장 기능을 제공합니다. 태블릿은 인벤토리용 배터리입니다!"
		""
		"&a에너지 큐브&r는 인터페이스의 올바른 슬롯에 아이템을 넣어 충전할 수도 있습니다."
	]
	quest.2323A6EEDF97BE96.title: "길잡이 확인 1"
	quest.2341297707B00E93.quest_desc: [
		"이 챕터의 나머지 발전기들은 &a최종 게임 발전기&r로 간주됩니다."
		""
		"이 발전기들은 사용자 정의가 가능하며, 비교적 적은 유지보수로 팩에서 가장 높은 양의 전력을 생성할 수 있습니다."
		""
		"&e참고&r: &6Oritech&r의 반응기는 대폭 상향되었습니다."
	]
	quest.23562C59CEDE9879.quest_desc: [
		"&e데우스 엑스 마키나&f는 이 돌 세계에서 수많은 괴물과 싸울 때 당신에게 힘을 부여합니다."
		""
		"같은 보스에게 죽을 때마다 피해 저항력과 살해자에게 가하는 피해량이 증가합니다."
	]
	quest.23562C59CEDE9879.title: "&6데우스 엑스 마키나"
	quest.238137090A4F8FD6.title: "마이너 WE 업그레이드 확인"
	quest.23DC842244086CB9.title: "길잡이 만나기"
	quest.24401E59D87AC23A.quest_desc: [
		"&6융합로&r는 &eMekanism&r의 최종 에너지 발전기입니다. &a중수소&r와 &2삼중수소&r 또는 둘의 혼합물&r로 연료를 공급받으며, 상대적으로 적은 유지보수로 막대한 양의 전력 및/또는 열을 생산할 수 있습니다. 두 연료 구성 요소 모두 물과 에너지만으로 생산됩니다!"
		""
		"&6융합로&r 자체는 이 수준의 전력을 정당화하고 이를 억제하기 위해 상당한 양의 &b핵분열 후&r 재료를 필요로 합니다."
		"{image:ftb:textures/quests/mekanism/fusion_reactor.png width:100 height:100 align:center}"
		""
		"{@pagebreak}"
		"&6융합로&r를 구축하려면, 서로의 중간 지점에서 연결되는 5x5 크기의 건물 재료 정사각형 세 개를 배치하고, 정사각형의 모서리를 &2융합로 케이싱&r로 교체한 다음, 중간 지점 주위에 네 개의 &2케이싱&r을 추가하십시오."
		""
		"그런 다음 상단 중앙 지점을 &6융합로 제어기&r로 교체하고, 나머지 모든 건축 블록은 반응로 유리, 포트 또는 레이저 초점 매트릭스로 교체할 수 있습니다."
		""
		"&6반응로&r를 시작하려면 &aD-T 연료&r가 &e홀로라움&r에 담겨 &2제어기&r 내부에 소량 필요하며, 연료는 &6반응로&r에 공급되어야 합니다. 그런 다음 비활성화된 &b레이저 증폭기&r가 다른 레이저에서 에너지를 수집한 후 4억 FE 이상의 단일 빔을 &3레이저 초점 매트릭스&r에 쏘아 &6반응로&r에 쏘아야 합니다."
		""
		"여기서 출력 모드로 설정된 &a융합로 포트&r에서 에너지, 증기 또는 열을 추출할 수 있습니다."
	]
	quest.24401E59D87AC23A.title: "융합로"
	quest.244134B3BF63A680.quest_subtitle: "언어더를 통해 사용 가능"
	quest.24CE908ED60FD514.quest_desc: [
		"&a분쇄기&r는 가루와 바이오매스를 만드는 데 사용할 수 있는 간단한 기계입니다."
		""
		"게임 초반에는 이것이 &6엔더 화합물&r을 얻는 가장 좋은 방법이기도 합니다."
	]
	quest.24CE908ED60FD514.title: "&f이제 부술 시간이야"
	quest.24D045E9CE30A016.quest_subtitle: "언어더, 지질학자"
	quest.24F370B893D01143.quest_subtitle: "언어더, 지질학자"
	quest.25023C87AA259688.quest_desc: [
		"갑옷 형태의 보호 기능은 많지 않지만, 이 갑옷을 모두 착용한 상태에서 \"Shift\"를 누르고 있으면 몹에게 탐지되지 않을 정도로 작은 골판지 상자로 변신합니다."
		""
		"&7&o이것은 약탈에 유용할 수 있습니다."
	]
	quest.25023C87AA259688.quest_subtitle: "&o몰래 몰래"
	quest.25023C87AA259688.title: "&f골판지 갑옷"
	quest.2568C81FA7914FE2.quest_desc: [
		"&6양자 얽힘기&r는 모든 &b양자 저장소&r를 효과적으로 4배로 늘립니다."
		""
		"멀티블록 구조당 하나만 사용할 수 있습니다."
	]
	quest.2568C81FA7914FE2.title: "&6양자 데이터 얽힘기"
	quest.25B9F4FD7CA67A0B.quest_desc: [
		"&a차원 전지&r는 &a파워셀 카드&r 채널을 통해 서로 무선으로 저장소를 공유할 수 있는 에너지 저장 블록입니다. 이 과정에서 거리에 따라 약간의 손실이 발생하며, 에너지를 끌어오는 전지를 &b주입&r하면 개선됩니다."
		""
		"에너지를 삽입하거나 추출하려면 &e스마트 렌치&r를 사용하여 전지의 측면을 구성하십시오. 파란색 측면은 전지가 에너지를 받도록 하고, 노란색 측면은 전지가 에너지를 내보내도록 합니다."
		""
		"&aPowercell 카드&r를 설정하고 &b무선 에너지 채널&r을 생성하려면, 연결되지 않은 &a차원 전지&r의 가장 왼쪽 슬롯에 연결되지 않은 카드를 넣기만 하면 됩니다. 그러면 전력을 전송할 새 채널이 카드에 등록됩니다. 이 채널에 카드를 추가하려면, 오른쪽에 있는 슬롯에 연결되지 않은 카드를 넣으세요."
	]
	quest.25B9F4FD7CA67A0B.title: "차원 전지"
	quest.25C6F433BD3128C4.quest_desc: ["&eImmersive Engineering&r의 이 원거리 6발 리볼버는 다양한 종류의 총알과 애드온으로 장전할 수 있습니다."]
	quest.25C6F433BD3128C4.title: "&eI.E &f리볼버"
	quest.25CCA572C4D5CEA0.quest_desc: [
		"첫 번째 \\&zAscension&r 단계는 신과 같은 존재가 되는 것입니다."
		""
		"이 차원에서 가장 강력한 무기와 갑옷으로 자신을 무장하십시오."
		""
		"\\&zcreative items&r의 힘을 얻을 자격이 있음을 증명하십시오."
		""
		"&e참고&r: 이 장의 모든 퀘스트는 &n&6작업 화면&r을 사용하여 완료해야 합니다."
	]
	quest.25CCA572C4D5CEA0.title: "승천 티어 1 - 에테르"
	quest.25E0E97D705F3514.quest_subtitle: "IronJs를 위해 제거해야 함"
	quest.2646D51DBAD8AD42.quest_desc: [
		"&b확인&f: 그림자 케이싱 얻기"
		""
		"&b잠금 해제됨&f: \"금고 생성\" 기술적으로 플레이어는 그 전에 거기에 도달할 수 있습니다."
	]
	quest.2646D51DBAD8AD42.title: "기계공 확인 1"
	quest.26727A01D814C5A9.title: "공허 조각"
	quest.2682A911828C2D88.quest_desc: [
		"&e틀이 있는 블록&r을 사용하면 거의 모든 다른 블록의 질감을 사용하는 사용자 지정 블록과 모양을 만들 수 있습니다!"
		""
		"이를 위해 틀이 있는 블록을 배치한 다음, 원하는 질감이 있는 블록을 틀이 있는 블록에 사용하여 질감을 복사하십시오."
		""
		"이 블록에는 몇 가지 멋진 기능도 있습니다. 예를 들어, 틀이 있는 블록에 &6발광석 가루&r를 사용하면 빛나게 할 수 있습니다!"
	]
	quest.2682A911828C2D88.title: "&2틀이 있는 블록"
	quest.268CC540E5B605A9.quest_desc: [
		"책장의 마지막 티어는 &d드래곤의 숨결&r 주입을 통해 잠금 해제됩니다."
		""
		"이를 위해 &a80&r &6에테르나&r, &a15&r에서 &a30&r 사이의 &c콴타&r, 그리고 최소 &a60&r &d아르카나&r가 필요합니다."
		""
		"&d아르카나&r가 충분하지 않다면, 작은 보너스를 제공하는 양초를 사용할 수 있습니다."
		""
		"&e참고&r: &d드래곤의 숨결&r은 &d닭 조키&r 전투에서 얻을 수 있습니다."
	]
	quest.268CC540E5B605A9.title: "&e깨달음 얻기"
	quest.2690BF30D8119E77.quest_desc: [
		"&e맞춤 기계 장치&r에는 거의 모든 다른 블록의 질감을 사용하는 사용자 지정 블록과 모양을 볼 수 있는 내장 구조 미리보기 기능이 있습니다!"
		""
		"이 기능을 사용하려면 UI에서 제작법 화살표를 클릭한 다음 JEI에서 구조 블록을 클릭하여 세계에서 블록 배치를 확인하십시오."
		""
		"&7&o다음 페이지에는 안내를 위한 스크린샷이 있고, 마지막 페이지에는 완성된 구조물의 스크린샷이 있습니다. ->"
		"{@pagebreak}"
		"{image:ftb:textures/quests/ae2/circuit_fabricator_ui.png width:180 height:100 align:center}"
		"{image:ftb:textures/quests/ae2/circuit_fabricator_jei.png width:205 height:144 align:center)"
		"{@pagebreak}"
		"최종 구조물은 신비로운 큐브 블록의 세 면 모두에 활기찬 석영 유리와 함께 아래 그림과 같아야 합니다."
		""
		"{image:ftb:textures/quests/ae2/circuit_fabricator_full.png width:180 height:150 align:center}"
	]
	quest.2690BF30D8119E77.title: "회로 제작기 조립"
	quest.269DC26776DD377D.quest_desc: [
		"&d고급 강화기&f는 &2강화기&f의 개선된 멀티블록 버전입니다."
		""
		"틱 속도로 제작법을 처리하기 위해 최대 한 스택의 &eMekanism &a속도 업그레이드&r를 사용할 수 있어 후반 게임 제작법에 이상적입니다."
		""
		"&e&n참고&r: 일부 제작법은 표준 &2강화기&r와 다르므로 자동화 설정을 확인하십시오."
	]
	quest.269EE6FF35CA9857.quest_desc: [
		"&6Oritech&r의 대부분 발전기는 &a증기 보일러 애드온&r을(를) 사용할 수 있습니다. 이를 통해 애드온에 물을 펌핑하여 발전기의 전력 출력을 &b증기⟧로 변환할 수 있습니다."
		""
		"그런 다음 &a증기 엔진&r으로 펌핑하여 RF를 생성할 수 있습니다. 생성된 에너지는 &a증기 보일러 애드온&r을(를) 사용하는 기본 발전기에서 생성된 에너지와 합산됩니다."
		""
		"&a증기 엔진&r의 속도는 저장된 증기량에 따라 달라집니다. 증기가 많을수록 압력이 높아져 더 빠르게 작동합니다. 속도는 탱크의 채워진 비율에 따라 선형적으로 조정되며, 탱크가 가득 차면 최대 배율은 10입니다."
		"{@pagebreak}"
		"하지만 &a증기 엔진&r의 효율은 속도에 따라 달라집니다. 효율이 높을수록 생산되는 증기 단위당 더 많은 RF를 얻을 수 있습니다. 기계의 효율은 약 700% 속도로 작동할 때 가장 높습니다. 이보다 낮거나 높으면 이상적인 수율보다 낮아집니다."
		""
		"에너지는 빨간색 기계 슬롯에서 추출할 수 있으며, 유체 포트는 파란색으로 표시됩니다."
	]
	quest.26B74124E89189F7.quest_desc: [
		"마법 부여의 최종 단계에 필요한 기본 선반입니다."
		""
		"&d주입된 드래곤의 숨결&r 뒤에 잠겨 있다는 점 외에도, 엔드 선반은 비교적 저렴합니다."
	]
	quest.26B74124E89189F7.title: "&e엔드 선반"
	quest.26CE741ECA36BBC5.quest_desc: [
		"&eJust Dire Things&r 무기는 &a대장장이 도구 양식&r을 통해 등급을 올릴 수 있으며, 네더라이트보다 좋은 도구로 등급이 올라감에 따라 더 많은 &2강화&r를 받을 수 있습니다."
		""
		"&b페리코어&r와 &c블레이즈골드&r는 사용 가능한 첫 두 등급의 도구입니다."
	]
	quest.26CE741ECA36BBC5.title: "&eJust Dire Things &f도구"
	quest.26D7C5298D95C69A.quest_desc: [
		"&b보석 세공&r을(를) 제작할 때 &a밴딩 재료&r 자체를 사용하여 효과 및/또는 능력치 증가를 부여할 수 있습니다."
		""
		"하지만 주된 용도는 &a보석&r 효과를 품질 배율로 증폭하는 것입니다."
		""
		"대부분의 바닐라 보석은 작동하지만, 목록은 JEI에서 &ajewelry_metal&r을(를) 검색하여 찾을 수도 있습니다."
	]
	quest.26D7C5298D95C69A.title: "&a결속 재료"
	quest.26F18323EB6EFCA0.quest_desc: ["&bSNAD&r 블록을 사용하면 선인장이나 사탕수수 농장을 쉽게 만들 수 있습니다. 또한 레드스톤 신호를 주어 작물의 성장 속도를 높일 수도 있습니다."]
	quest.26F18323EB6EFCA0.title: "&fSNAD"
	quest.26F3ECD3CC9E7CDA.quest_desc: [
		"&c고급 기계 블록&r은 현대 기술의 경이로움입니다."
		""
		"이것들을 &d촉매제&r에게 가져다주면 &3월드 엔진 업그레이드&r를 설치하는 방법을 알려줄 것입니다."
	]
	quest.2722C0E2E8993658.quest_desc: [
		"완벽하게 갖춰진 마법 부여 설비의 중심입니다."
		""
		"&d드라코늄 엔드 선반&r은 추가적인 능력치를 제공하지 않지만, &a에테르나&r를 20만큼 높여 최대 &6100&r까지 도달할 수 있게 합니다."
		""
		"&d진주빛 엔드 선반&r은 최고의 범용 책장으로, &c콴타&r와 &d마나&r 모두에 상당한 양을 제공합니다."
	]
	quest.2722C0E2E8993658.title: "&e레벨 100 마법 부여"
	quest.272E84656D0F133C.quest_desc: [
		"기본 선반과 그 위에 최대 5개의 통나무를 쌓아 기둥을 만들고, 로그에 영혼을 사용하여 특정 영혼 기호에 맞출 수 있습니다. 적절한 기호 세트가 만들어지면, 기본 선반을 우클릭하여 토템 기둥을 활성화하여 &e정령 의식&r을 소환합니다. 다시 하면 의식이 비활성화됩니다."
		""
		"이 의식들은 세계 또는 그 영역에 서 있는 사람들에게 다양한 효과를 미칩니다. 여러 의식을 한 영역에 소환할 수 있지만, 같은 의식을 두 개 이상 소환하면 서로 취소됩니다."
		""
		"&a토템 지팡이&r를 사용하면 이 영역이 무엇인지 알 수 있으며, 맞춤 설정된 로그에 사용하여 활성화 없이 빛나게 할 수 있습니다."
	]
	quest.272E84656D0F133C.title: "토템 의식"
	quest.27439A8D79B21B73.quest_desc: [
		"더 많은 &6기록 보관소&r를 해제함에 따라, 로비 탐험과 &d고대의 메아리&r 찾기가 시작됩니다."
		""
		"그들과 협력하여 &d깊은 어둠&r의 비밀을 배우고 &3유포니움 업그레이드&r를 &6월드 엔진&r에 해제하세요."
		""
		"&7&o만나면 &e/echo ancient&7을 사용하여 로비 어디에서든 이 메아리로 직접 순간이동할 수 있습니다."
	]
	quest.27439A8D79B21B73.title: "&f고대인&d 만나기"
	quest.275C5A38C3231690.quest_desc: ["&d소스&r를 생산할 수 있는 능력을 얻으면 &d마법사&r에게 돌아가 &6월드 엔진&r에 주입하는 방법을 배워야 합니다."]
	quest.276D2B384F21AC10.quest_desc: ["&eJust Dire Things&r 무기는 &a대장장이 도구 양식&r을 통해 등급을 올릴 수 있으며, 네더라이트보다 좋은 도구로 등급이 올라감에 따라 더 많은 &2강화&r를 받을 수 있습니다."]
	quest.276D2B384F21AC10.title: "&fJust Dire's Weaponry"
	quest.277181E358575312.quest_desc: [
		"모든 사람이 &c&m무고한 소를 도살하는&r 동물 농장을 좋아하는 것은 아닙니다. 대신 언데드를 처치하여 &a썩은 살점&r을 얻을 수 있으며, 이는 &b가죽&r으로 &2화로&r에서 치료될 수 있습니다."
		""
		"이 가죽으로 &2배낭&r을 만드는 것을 고려하는 것이 좋을 것입니다!"
	]
	quest.277181E358575312.title: "&f썩은 살점을 가죽으로"
	quest.27D28CC22BB5C665.quest_subtitle: "다른 업그레이드 제작에 사용됩니다"
	quest.27D28CC22BB5C665.title: "기본 업그레이드"
	quest.283EA4E7BA93DA11.quest_desc: [
		"&a강화기&r는 주변의 네 개의 아이템을 소모하여 보석을 강화합니다."
		""
		"각 &a진열대&r를 &a강화기&r의 각 면에서 세 블록 떨어진 곳(두 블록 간격)에 설치해야 합니다."
		""
		"&a진열대&r의 아이템 위치는 중요하지 않지만, 전력을 공급해야 합니다."
	]
	quest.283EA4E7BA93DA11.title: "&f보석 강화"
	quest.28683BFE22FBCCFC.quest_desc: [
		"화로에서 통나무를 구워 &7목탄&r으로 만들 수 있다는 것을 알고 계셨나요!"
		""
		"이것은 초반에 좋은 연료 공급원이 될 수 있습니다."
	]
	quest.28683BFE22FBCCFC.title: "&f목탄과 당신"
	quest.28C1BB5C88F65CA0.quest_desc: [
		"&d와이번&r 등급 주입기를 사용하면 &6각성된 드라코늄&r을 만들 수 있지만, &6드래곤 심장&r이 필요합니다. 사실 여러 개의 &6드래곤 심장&r이 필요합니다."
		""
		"엄청난 양의 &6각성된 드라코늄&r이 필요하므로, 이 방법은 만드는 데 최선의 방법이 아닙니다."
	]
	quest.28C1BB5C88F65CA0.title: "&6각성된 드라코늄"
	quest.28DB6A7095E20B2A.title: "반응로"
	quest.28E63B302DFCF6D9.quest_desc: [
		"마법 부여 설정에 따라 &d마력&r을(를) 약간 증폭해야 할 수도 있습니다."
		""
		"&d마법 부여대&r 주변에 놓인 양초가 이를 위해 훌륭하게 작동합니다!"
	]
	quest.28E63B302DFCF6D9.title: "&d마력&r 아이템"
	quest.28F636FAA3397479.quest_desc: ["&6RFTools&r의 &a기본 석탄 발전기&r는 화로 연료 아이템을 태워 전력을 생성하는 사용하기 쉬운 발전기입니다."]
	quest.28F636FAA3397479.title: "&f기본 석탄 발전기"
	quest.294AB45D52BE342B.quest_desc: [
		"&6Create&r는 아이템을 저장하고 자동 제작하는 매우 독특한 방법을 가지고 있습니다!"
		""
		"&a아이템 금고&r는 많은 아이템을 저장할 수 있지만, 안에 무엇이 있는지 볼 수 있는 인터페이스는 없습니다."
		""
		"&a포장기&r를 사용하여 아이템을 포장하고 다른 저장소로 보내 인벤토리 정렬 시스템을 만들 수 있습니다!"
		"{@pagebreak}"
		"&2재고 링크&r는 저장소의 아이템을 저장소 네트워크에 연결하는 데 도움이 됩니다."
		""
		"이를 &a재고 티커&r와 결합하면 연결된 저장소에서 아이템을 요청할 수 있습니다."
	]
	quest.294AB45D52BE342B.title: "&6Create의 &e인벤토리 시스템"
	quest.2950D495BCF2D52D.quest_desc: [
		"&6월드 엔진&r을 업그레이드하려면 재료를 처리하기 위한 몇 가지 기본 기계를 만들어야 합니다."
		""
		"이를 위해 기본적인 회로와 금속 합금이 필요합니다. &a야금 주입기&r는 이를 위한 훌륭한 기계가 될 것입니다."
		""
		"또한 구성 요소를 수용할 매우 내구성 있는 기계 케이싱이 필요합니다."
		""
		"[\"\", {\"text\": \"Note\", \"color\": \"yellow\"},  \": Take a look at the \", {\"text\": \"Power Generation\", \"color\": \"red\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"391B65CD04A90459\"}, \"hoverEvent\": {\"action\": \"show_text\", \"contents\": \"Go to Power chapter\"}}, \" chapter if you want some more early power options.\"]"
		""
		"임무를 완료한 후 &d수비대장&r에게 돌아가야 합니다."
	]
	quest.2950D495BCF2D52D.title: "&f금속 주입"
	quest.2A456EFB14ECA6C2.title: "&d와일든 키메라 처치"
	quest.2AB07DEF9E14C784.title: "3단계 '또는' 확인"
	quest.2AB58696A843E9C2.quest_desc: [
		"더 많은 &6기록 보관소&r가 잠금 해제되었으므로, 로비 탐험과 &d제작자의 메아리&r 찾기의 시간입니다."
		""
		"이 &d메아리&r와 함께 &c열 업그레이드&r를 &6월드 엔진&r에 잠금 해제하세요."
		""
		"&7&o로비에서 &e/echo fabricator&7를 사용하여 메아리를 만난 후 어디에서든 이 메아리로 직접 순간이동할 수 있습니다."
	]
	quest.2AB58696A843E9C2.title: "&f제작자를 만나세요&d"
	quest.2AD996C548EBF4A4.quest_desc: [
		"&6주조소&r는 다음 생명체에서 물질을 추출하는 데에도 사용할 수 있습니다:"
		""
		"- 플레이어: &c녹은 고기"
		"- 엔더맨: &3녹은 엔더"
		"- 주민/시장 상인: &2녹은 에메랄드"
		"- 마녀: &d녹은 자수정"
		"- 벌: &6꿀"
		"- 블레이즈: &c녹은 블레이즈"
	]
	quest.2AD996C548EBF4A4.title: "몹 녹이기"
	quest.2B02D9425E19F560.quest_desc: [
		"제대로 작동하지 않는 것을 발견했습니까?"
		""
		"[\"We'd love to know so we can fix it! You can stop by to let us know on \", {\"text\": \"Discord\", \"color\": \"aqua\", \"underlined\": true, \"clickEvent\": {\"action\": \"open_url\", \"value\": \"https://discord.com/invite/X5UGvBs\"}, \"hoverEvent\": {\"action\": \"show_text\", \"contents\": [\"Open the Discord invite\"]} }, \" or by making a bug report on \", {\"text\": \"GitHub\", \"color\": \"light_purple\", \"underlined\": true, \"clickEvent\": {\"action\": \"open_url\", \"value\": \"https://github.com/FTBTeam/FTB-Modpack-Issues/issues\"}, \"hoverEvent\": {\"action\": \"show_text\", \"contents\": [\"Open the GitHub link\"]} }, \".\"]"
	]
	quest.2B02D9425E19F560.title: "&f버그 발견?"
	quest.2B21D8D19E0413AC.quest_desc: ["&c죽음의 왕&r은 &a지하 묘지&r에서 &3돌&r과 &7심층암&r 층에서 찾을 수 있습니다."]
	quest.2B21D8D19E0413AC.title: "&c죽음의 왕 처치"
	quest.2B2BB685DE246BCC.quest_desc: ["용암(및 선택적으로 레드스톤)을 소비하여 전력을 생성합니다."]
	quest.2B86CBB61E10051F.quest_desc: ["&c화염술사&r는 &c얼음과 불의 이야기&r 게이트웨이에서 찾을 수 있습니다."]
	quest.2B86CBB61E10051F.title: "&c화염술사 처치"
	quest.2BB6C51E445A1C95.quest_desc: [
		"&6얽힘&r을 사용하면 두 블록을 함께 묶어 마치 동일한 블록처럼 상호 작용할 수 있습니다!"
		""
		"이를 통해 아이템, 에너지, 유체 등을 즉시 전송할 수 있습니다."
		""
		"&c중요&r: &6월드 엔진&r에 이것을 사용하는 것이 더 많은 인터페이스 측면을 제공할 것입니다!"
	]
	quest.2BB6C51E445A1C95.title: "\\&z블록 얽기&r"
	quest.2BC86AF57781BE63.quest_desc: [
		"&a슬라이스앤스플라이스&r는 몹 머리를 특수 기계 부품으로 변환하는 데 사용됩니다."
		""
		"작동하려면 두 개의 도구가 필요합니다: &a도끼&r와 &a가위&r. 각 작업은 각 도구에서 내구도를 하나씩 소모합니다. &a도끼&r는 최소한 철 등급이어야 하며, 다른 모드의 &a가위&r도 작동할 수 있습니다."
	]
	quest.2BC86AF57781BE63.title: "&f슬라이스앤스플라이스"
	quest.2BFD68083AD1B894.quest_desc: [
		"&a구축기&r는 네트워크의 자원을 블록 또는 아이템 개체로 세계에 배치할 수 있습니다."
		""
		"각 &e케이블 등급&r 업그레이드는 이전 등급보다 더 빠르게 작동하며 더 많은 필터 슬롯을 가지고 있습니다."
		""
		"&7&o각 아이템의 툴팁에서 정확한 속도를 확인하세요."
	]
	quest.2BFD68083AD1B894.title: "구축기"
	quest.2C0C63951FDED180.quest_desc: [
		"&d입자 가속기&r는 상당히 복잡합니다! 이 때문에 각 부분은 어떻게 작동하는지 분해하기 위해 별도의 퀘스트로 나뉩니다."
		""
		"이 기계로 새 아이템을 만들려면 두 개의 별도 컨트롤러에서 아이템을 충돌시켜야 합니다."
		""
		"&d가속기 자기장&r은 고리 중앙에 배치하고 &d입자 가속기&r에 연결하여 고리가 처리할 수 있는 속도량을 늘릴 수 있습니다."
		""
		"가속기에 연결하려면 &6고급 대상 지정기&r가 필요합니다."
	]
	quest.2C0C63951FDED180.title: "&d입자 가속기"
	quest.2C141655079AC173.quest_desc: [
		"&d와이번&r 무기는 내구도 대신 전력을 소비하며 모듈을 인벤토리에 넣어 사용자 정의할 수 있습니다."
		""
		"모듈 인벤토리는 기본적으로 바인딩되지 않은 &e도구 모듈&r 키 바인딩을 통해 액세스할 수 있습니다."
	]
	quest.2C141655079AC173.title: "&d와이번&f 무기"
	quest.2C1649AE3DADD71D.quest_desc: [
		"&e건축 막대기&r는 건축 과정을 훨씬 빠르게 만드는 모든 것입니다."
		""
		"손에 &e건축 막대기&r를 들고 있으면 한 번의 클릭으로 모든 방향으로 블록을 확장할 수 있습니다!"
		""
		"또한 &e막대기&r에 추가할 수 있는 몇 가지 멋진 업그레이드가 있습니다. 예를 들어 내구도 대신 전력을 사용하게 하는 것과 같습니다."
	]
	quest.2C1649AE3DADD71D.title: "&b더 빠른 건축"
	quest.2C40123DF5EBA846.title: "갑옷"
	quest.2C8099E185CA2B60.quest_desc: [
		"&a커피 메이커&r는 소비 시 여러 버프를 제공하는 물약과 같은 음료를 만드는 데 사용됩니다."
		""
		"이 기계는 작동하려면 전력이 필요하며, 물과 &a커피콩&r을 &a빈 컵&r에 섞어 &a커피 잔&r을 만듭니다."
		""
		"GUI에 최대 8개의 아이템을 추가하여 특별한 버프를 제공할 수 있습니다."
		"{@pagebreak}"
		"참고: GUI의 작은 숫자는 아이템이 소비되는 순서를 나타내므로 올바른 버프 순서를 확인하세요."
		""
		""
		"다음 버프를 양조할 수 있습니다:"
		""
		"복어: &9물속 호흡&r (최대 2개)을 제공합니다."
		""
		"마그마 크림: &6화염 저항&r (최대 2개)을 제공합니다."
		""
		"황금 당근: &e야간 투시&r (최대 2개)을 제공합니다."
		"{@pagebreak}"
		"발효된 거미 눈: &7투명화&r (최대 2개)을 제공합니다."
		""
		"가스트 눈물: &c재생력&r (최대 3개)을 제공합니다."
		""
		"블레이즈 가루: &d힘 강화&r (최대 4개)을 제공합니다."
		""
		"설탕: &b속도 증가&r (최대 4개)을 제공합니다."
		""
		"우유 병/양동이: 버프에 1분을 추가하지만 레벨은 1 감소시킵니다."
	]
	quest.2CA2995C290D13F5.quest_desc: [
		"[\"The \", {\"text\": \"AE2-Replication Bridge\", \"color\": \"green\"}, \" connects your \", {\"text\": \"ME Network\", \"color\": \"aqua\"}, \" with a \", { \"text\": \"Replication Matter Network\", \"color\": \"yellow\", \"underlined\": true, \"clickEvent\": {\"action\": \"change_page\", \"value\": \"0BEF15E1352A5F72\"}, \"hoverEvent\": {\"action\": \"show_text\", \"contents\": \"Go to Replication Chapter\"}}, \", seamlessly integrating the two systems.\"]"
		""
		"두 시스템을 연결하려면 &aAE2-복제 브릿지&r가 케이블을 통해 두 시스템에 연결되어야 합니다. 이를 통해 다음을 수행할 수 있습니다:"
		""
		"- AE2 터미널을 사용하여 물질 수량 확인"
		"- AE2 자동 제작을 사용하여 복제 요청"
		"- 제작 우선순위 구성"
		""
		"&7&o추가 설정 정보는 GuideME 문서를 참조하세요."
	]
	quest.2CA2995C290D13F5.title: "&dAE2-복제 브릿지"
	quest.2CA74676EAC1A040.quest_desc: [
		"&e모듈식 역장 시스템&r (간단히 &eMFFS&r)은 역장과 기타 방어 수단을 추가하여 기지를 보호하는 기술 모드입니다."
		""
		"시작하려면 &a강압 유도기&r를 제작하세요."
		""
		"&7&oMFFS 기계는 기본적으로 작동하려면 레드스톤 신호가 필요하며, 대부분은 인터페이스의 왼쪽 상단에서 반전될 수 있습니다."
		"{@pagebreak}"
		"&a강압 유도기&r에는 두 가지 모드가 있습니다:"
		""
		"&e유도 모드&r는 다른 모드나 인벤토리의 방전 가능한 아이템에서 에너지를 소비하여 &3포트론&r을 생성합니다."
		""
		"&e통합 모드&r는 약간의 손실을 감수하고 &3포트론&r을 에너지로 변환합니다."
		""
		"내부에 &2청금석&r 또는 &2네더 석영&r을 넣으면 &a강제 유도기&r의 변환율이 소비될 때 세 배가 됩니다."
	]
	quest.2CA74676EAC1A040.title: "&e모듈식 역장 시스템&r"
	quest.2CB37185A7FAF348.quest_desc: [
		"&eMFFS&r 기계는 작동하려면 시스템의 일부여야 합니다. 같은 &b주파수&r에 있는 기계는 같은 시스템의 일부가 됩니다."
		""
		"&b주파수&r는 인터페이스에서 설정하거나, 기계의 &a주파수 카드&r를 사용하여 설정할 수 있습니다. 이 카드는 해당 인터페이스 슬롯에 배치하면 기계의 &b주파수&r를 복사할 수 있습니다."
	]
	quest.2CB37185A7FAF348.title: "&a시스템 주파수"
	quest.2CB418AE76610E8F.quest_desc: [
		"&a스패너&r를 사용하여 네트워크 장치를 회전시키거나, 웅크린 상태에서 사용하면 분해할 수 있습니다."
		""
		"네트워크 장치를 분해하면 현재 설정, 업그레이드 및 패턴이 모두 유지됩니다."
	]
	quest.2CEF038B5DA1FF25.quest_desc: ["불꽃놀이를 소비하여 전력을 생성합니다."]
	quest.2D0E345C7C7B3AC0.title: "병참 장교 회합"
	quest.2D110AB9A38178C5.quest_desc: [
		"네더랙 깊숙한 곳에 숨겨진 &d지옥의 존재&r는 &3금고&r가 &c네더&r 고리에 묻혀 있으며, 매우 위험한 타는 영혼이 사는 곳이라고 언급했습니다."
		""
		"주크박스가 좋아하는 노래로 활성화되면 &3금고&r가 살아납니다."
		""
		"&e참고&r: 이 금고는 위험합니다. 전투 준비를 하고 오세요!"
		"{@pagebreak}"
		"&3금고&r를 잠금 해제하려면, 음악 디스크로 활성화된 후 춤을 한 번 완료해야 합니다. &c블레이즈&r를 처치하여 &c열기&r를 높이거나, 가장 밝은 색의 바닥 타일을 따라 춤을 추면 됩니다."
	]
	quest.2D110AB9A38178C5.title: "&f디스코의 불꽃"
	quest.2D178651FB267E91.title: "숙련의 증표 거래"
	quest.2D1B390B363E0F27.quest_desc: [
		"&eDE &b에너지 결정&r은 최소한 하나의 &aI/O 결정&r과 하나의 &2무선 결정&r을 포함하는 에너지 네트워크를 통해 RF 전력을 연결된 블록으로 전송할 수 있습니다."
		""
		"무선 수정을 우클릭하여 연결을 시작하고, 다른 블록에 우클릭하여 연결하세요."
		""
		"&a릴레이&r는 다른 네트워크 구성 요소에만 연결할 수 있으므로 네트워크 범위를 확장하는 데만 사용됩니다."
		""
		"&7&o전송 속도는 다음 페이지에서 확인하세요 ->"
		"{@pagebreak}"
		"각 수정 등급은 연결당 다른 양의 전력을 출력할 수 있습니다:"
		""
		"&a기본 등급&r은 최대 32,000 RF/t를 전송할 수 있습니다."
		""
		"&d와이번 등급&r은 최대 128,000 RF/t를 전송할 수 있습니다."
		""
		"&6드라코닉 등급&r은 최대 256,000 RF/t를 전송할 수 있습니다."
	]
	quest.2D1B390B363E0F27.title: "드라코닉 에너지 전송"
	quest.2D20EDB447787183.quest_desc: [
		"비록 &e벨트&r를 자동 보도와 &e무게 추출기&r를 사용하여 자신을 날려버리는 데 사용할 수 있지만, &6Create&r 모드를 사용하여 기지의 다른 구역을 여행하는 더 정교한 방법이 있습니다. 바로: &6하이퍼튜브&r!"
		""
		"단일 또는 이중 방향 &b하이퍼튜브 경로&r는 &a하이퍼튜브 입구 블록&r을 배치한 다음, 별도의 지점으로 확장하기 위해 &a하이퍼&m링크&r&a튜브 블록&r을 클릭하여 만들 수 있습니다. 더 긴 거리를 위한 연결 지점을 설정하기 위해 하이퍼튜브 블록을 배치할 수 있습니다."
		""
		"&7Ficsit 기술의 현재 또는 이전과의 모든 유사성은 우연의 일치입니다.&o"
	]
	quest.2D20EDB447787183.title: "&6Create: 하이퍼튜브"
	quest.2D35AD2FDC93FA46.title: "TF 남쪽"
	quest.2D8FCC93C758D070.title: "영혼 저장 부품"
	quest.2D95FEECCF48B088.quest_desc: [
		"&a드라코닉 축전기&r는 휴대용 배터리로, 인벤토리의 다른 아이템에 전력을 저장하고 공급할 수 있습니다."
		""
		"&e참고&f: 축전기는 장신구 슬롯에도 넣을 수 있습니다."
		""
		"[\"At this point you will also gain access to \", { \"text\": \"Wyvern Tools\", \"color\": \"light_purple\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"056990503617C147\"}, \"hoverEvent\": {\"action\": \"show_text\", \"contents\": \"Go to Wyvern Tools Quest\"}}, \", \", { \"text\": \"Wyvern Weapons\", \"color\": \"light_purple\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"0B65713A23351790\"}, \"hoverEvent\": {\"action\": \"show_text\", \"contents\": \"Go to Wyvern Weapons Quest\"}}, \", and the \", {\"text\": \"Wyvern Chestpiece\", \"color\": \"light_purple\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"2DF77DA2ED65FBAC\"}, \"hoverEvent\": {\"action\": \"show_text\", \"contents\": \"Go to Wyvern Chestpiece Quest\"}}, \".\"]"
	]
	quest.2D95FEECCF48B088.title: "&d드라코닉 &f축전기"
	quest.2D99F429A18BEED1.title: "촉매 확인 2"
	quest.2DB9D91CFB15C210.quest_desc: ["회로를 만들기 위해 주입기를 사용하여 &2기계 프레임&r에 필요한 것을 만드세요."]
	quest.2DB9D91CFB15C210.title: "&f기본 회로"
	quest.2DF77DA2ED65FBAC.quest_desc: [
		"&d와이번 흉갑&r은 수많은 사용자 지정 옵션을 제공하는 동력 갑옷입니다."
		""
		"&6드라코닉 진화&r 장비는 각 장비 조각 안에 모듈식 업그레이드를 저장할 수 있는 자체 인터페이스를 가지고 있으며, 키 바인딩(&e도구 모듈&r)을 통해 접근할 수 있습니다."
		""
		"이를 통해 &a업그레이드 모듈&r을 사용하여 이 흉갑을 여러 가지 방법으로 업그레이드할 수 있습니다."
	]
	quest.2DF77DA2ED65FBAC.title: "&d와이번 &f흉갑"
	quest.2E53319ED51DC7C8.quest_desc: ["믿기 어렵겠지만, 이 던전은 &e엔드&r 고리에서 생성됩니다."]
	quest.2E53319ED51DC7C8.title: "&d엔드 던전 찾기"
	quest.2E619195856B3B9F.quest_desc: [
		"&a메카니즘&r의 &b광석 생성기&r를 사용하면 &c레이저&r에 전력을 충전한 다음, 생성기로 보내 광석을 만들 수 있습니다."
		""
		"이 기계는 &b포트론 주입 블록&r &6월드 엔진 업그레이드&r로 사용할 수 있게 됩니다."
	]
	quest.2E619195856B3B9F.title: "&f메카 레이저로 광석 생성하기"
	quest.2E7B0F8AF8BA8041.title: "메카 텔레포터"
	quest.2E9F9DD6660745B3.quest_desc: [
		"&aCreate&r의 &b기계식 수확기&r는 회전하는 구조물에 부착하여 접촉하는 모든 작물을 자동으로 수확할 수 있습니다."
		""
		"이것은 &bCreate&r를 사용하는 것을 좋아하는 사람들에게 훌륭한 선택이 될 수 있습니다!"
	]
	quest.2E9F9DD6660745B3.title: "기계식 수확"
	quest.2EA7D8A9632F845F.quest_desc: [
		"&3업그레이드&f에 필요한 블록을 제출하고 보상을 받으면 팀의 &6월드 엔진&r이 자동으로 조립됩니다."
		""
		"&e참고&f: 업그레이드가 있어야 할 곳에 배치된 블록은 삭제됩니다."
	]
	quest.2EA7D8A9632F845F.title: "&f자동 구축 엔더리움 업그레이드&3"
	quest.2EC3F054AB506916.title: "고급 기계 블록 거래"
	quest.2ECAD5F752E445F1.quest_desc: [
		"[\"\", { \"text\": \"Prometheum\", \"color\": \"#FCD205\"}, \" is an advanced material that can only be produced in an \", { \"text\": \"Atomic Forge\", \"color\":\"#FF55FF\"}, \".\" ]"
		""
		"[\"This powerful resource is essential for crafting \", {\"text\": \"Prometheum Tools\", \"color\":\"#FCD205\"}, \" and the \", {\"text\": \"Ultimate Machine Core\", \"color\":\"#FF55FF\"}, \".\"]"
	]
	quest.2EE5352D8E5F715F.title: "거미 처치"
	quest.2EEE782146096F9C.quest_desc: ["아마도 건축가들에게 최고의 모드 중 하나인 &e건축 도구&r 모드는 건축을 더 좋게 만들기 위한 몇 가지 새로운 도구를 추가합니다!"]
	quest.2EEE782146096F9C.title: "&e건축 도구"
	quest.2F15D918EF183051.quest_desc: [
		"&6스톤블록 4&r는 플레이 스타일에 따라 플레이하고 진행할 수 있는 많은 옵션을 가진 스토리 기반 모드팩입니다."
		""
		"이 팩에는 모든 유형의 플레이어를 위한 수많은 모드가 있습니다. 모드는 스토리라인에 따라 잠겨 있을 수 있으므로 진행을 위한 다양한 옵션을 탐색하십시오!"
		""
		"도전을 원하는 사람들을 위해, 팩의 마지막 도전은 &d월드 엔진&r을 완료하는 것입니다. 당신이 해낼 수 있다고 생각하십니까?"
	]
	quest.2F15D918EF183051.title: "&6스톤블록 4&r에 오신 것을 환영합니다!"
	quest.2F2DC018DD6A2A23.quest_desc: [
		"&a보석&r은 대부분의 &b장신구&r의 일부로, 효과나 속성을 부여합니다."
		""
		"다른 &b장신구&r 조각은 &a보석&r에 의해 다르게 영향을 받으므로, 제작하기 전에 각 조각을 주의 깊게 확인하십시오."
		""
		"대부분의 바닐라 보석이 작동하지만, JEI에서 &ajewelry_gem&r을 검색하여 목록을 확인할 수도 있습니다."
	]
	quest.2F2DC018DD6A2A23.title: "&a보석"
	quest.2F8BB4724991B7C4.quest_desc: [
		"저장된 물질을 기반으로 아이템을 복제하려면 먼저 &a식별 챔버&r를 사용하여 만드는 방법을 배워야 합니다."
		""
		"챔버는 아이템 만드는 방법을 기억하기 위해 &d메모리 칩&r이 필요합니다. 각 칩은 최대 16개의 아이템을 저장할 수 있습니다."
		""
		"&a칩 저장소&r를 &a식별 챔버&r 위에 놓으면, 가득 찼을 때 칩을 저장소로 자동으로 밀어 넣습니다."
	]
	quest.2F9F60F308C42FB0.quest_desc: [
		"이제 &b프시메탈 CAD&r와 아마도 몇 개의 &a부착물&r을 가지고, 다음과 같은 또 다른 간단하면서도 복잡한 주문을 만들 시간입니다."
		""
		"► &6&l트릭: \"더 강한 주입\"&r"
		""
		"&b프시메탈&r을(를) 만들기 위해 이전에 했던 것처럼, 그리드에 이 트릭을 넣고 &e탄환&r에 복사하기만 하면 됩니다."
		""
		"그렇게 한 후, &b다이아몬드&r를 &6프시 보석&r으로 변환할 수 있습니다!"
	]
	quest.2F9F60F308C42FB0.quest_subtitle: "프시 에너지로 주입된 다이아몬드!"
	quest.2F9F60F308C42FB0.title: "프시 보석"
	quest.2FF6307E57E005C8.quest_subtitle: "IE 분쇄기 필요, IE에서만 사용 가능"
	quest.2FFA4CF8C062AD5E.quest_desc: [
		"&a가져오기&r 및 &a내보내기 버스&r를 사용하면 시스템과 다른 연결된 인벤토리로 아이템을 파이프로 옮길 수 있습니다."
		""
		"이것은 인터페이스 및 패턴 제공자와 함께 사용하여 모든 기지를 완전히 자동화할 수 있습니다!"
		""
		"이 장치들은 &a카드&r로 업그레이드하여 레드스톤에 민감하게 만들거나, NBT 특정 아이템을 수락하거나 하지 않도록(퍼지), 또는 &e가속&r 및 &e용량 카드&r로 속도와 용량을 늘릴 수 있습니다."
	]
	quest.300503F48627E3DB.title: "네더 파편"
	quest.30453DA99EE2BCBF.title: "와이번 장인 만나기"
	quest.304B25BADD64077D.quest_desc: [
		"다음 단계로 업그레이드하여 배낭의 전체 저장 용량을 늘릴 수 있습니다!"
		""
		"기본 배낭에서 &a구리&r 또는 &a철&r로 업그레이드할 수 있습니다. 먼저 구리로 업그레이드하면 구리에서 업그레이드하는 데 철괴 4개만 필요하므로 철을 절약할 수 있습니다."
		""
		"각 단계는 더 많은 &a업그레이드 슬롯&r을 허용합니다!"
	]
	quest.304B25BADD64077D.title: "&f단계별 업그레이드"
	quest.30689B890F5E7A03.quest_desc: [
		"아이템에 마법을 주입하는 기본은 &d마법 부여대&r로 시작합니다."
		""
		"이 마법 부여대는 주변의 책장의 잠재된 마법 에너지를 끌어들입니다. 기본 책장은 한계가 있습니다!"
		""
		"&e참고&r: 진행을 위해 필요한 &b에테르나&r 레벨에 도달하려면 &a주입된 지옥 책장&r 또는 &a주입된 바다 책장&r이 필요합니다!"
	]
	quest.30689B890F5E7A03.title: "&f마법 주입"
	quest.308135F2F191443E.title: "크리에이티브 토글 레이저"
	quest.308D9819EA67D3F0.quest_desc: [
		"이 줄의 발전기는 &a초기 게임 발전기&r로 간주됩니다!"
		""
		"이 발전기는 만들기 쉽고 전력망을 구축함에 따라 잘 확장될 수 있습니다."
	]
	quest.30902357747A64F1.quest_desc: [
		"&2예티&r를 물리치면 두 개의 새로운 금고를 찾을 수 있습니다."
		""
		"&b황혼의 숲&r 고리 위쪽에서 찾을 수 있으며, &a눈의 여왕 성&r의 금고를 발견할 수 있습니다."
	]
	quest.30902357747A64F1.title: "&f눈의 여왕 궁전"
	quest.309D995CCCDB3AEE.quest_desc: ["&d와이번 장인&r이 드라코닉 힘으로 주입된 &a크로논 배터리&r를 제공하여 이 도구가 ⟦z골절된 공허⟧&r에 접근할 수 있게 했습니다. 이 위치는 이제 &2액션 패드&r에도 연결되었습니다."]
	quest.309D995CCCDB3AEE.title: "&f와이번 장인에게 말하기&d&f"
	quest.30DC15C5BF42A9DE.title: "바다 동쪽"
	quest.30EE07811728D901.quest_desc: [
		"&6월드 엔진&r이 거의 완전한 기능을 갖추었습니다. 마지막 단계는 궁극의 금속을 만드는 것입니다."
		""
		"이제 \\&z무한 금괴&r를 만들 시간입니다."
	]
	quest.30EE07811728D901.title: "\\&z무한 금괴&r"
	quest.30F922372D95D407.quest_desc: [
		"&e분재 화분&r은 나무 농사를 쉽게 만듭니다!"
		""
		"흙 한 조각, 묘목, 도끼를 넣으면 하나의 블록에서 미니 나무 농장을 만들 수 있습니다."
		""
		"모래를 솔질하면 점토를 얻을 수 있습니다."
	]
	quest.30F922372D95D407.title: "&f분재 나무"
	quest.31042D7EBA3B39AD.title: "무한 확인 1"
	quest.310F815C02B2CAF8.quest_desc: [
		"이 퀘스트는 &d황혼의 &6기록 보관소&r로 가는 웨이포인트를 설정합니다."
		""
		"&e참고&f: &d황혼&r과 &d고대인&r은 같은 &6기록 보관소&r를 공유합니다."
	]
	quest.310F815C02B2CAF8.title: "&f황혼&d 찾기"
	quest.31705AD5BE50E2CB.quest_desc: [
		"&a가압 반응기&r는 1개의 액체, 1개의 기체, 1개의 아이템을 결합하여 새로운 아이템과 때로는 기체 부산물을 생산하는 고급 기계입니다."
		""
		"이것은 &6에텐&r, &6HDPE 펠릿&r 등을 만드는 데 사용됩니다!"
	]
	quest.317FE947A23C965A.title: "제작자 만나기"
	quest.31C83D9253FFF685.quest_desc: [
		"&3산업용 터빈&r은 &7증기&r를 에너지로 변환하고, &9포화 응축기&r를 사용하여 선택적으로 &b물&r로 다시 변환하는 수직 멀티블록 구조입니다. 터빈이 에너지로 가득 차면 멈추거나 증기를 배출하므로 주의하십시오."
		""
		"이 멀티블록의 최소 크기는 5x5x5 구조이지만, 높이에 한 층만 추가하면(5x6x5) 전력 생산량이 &64배&r가 됩니다. 따라서 이 퀘스트에서는 이 치수(5x6x5)를 최소값으로 취급합니다. 터빈의 최대 크기는 17x18x17인데, 터빈 너비는 회전하는 블레이드를 위해 홀수여야 합니다."
		""
		"&3산업용 터빈&r은 &d핵분열 반응로&r보다 복잡하지만, 많은 &7증기&r 흐름을 처리할 수 있습니다."
		"{@pagebreak}"
		"다중 블록은 &a터빈 케이싱&r 프레임이 필요하며, 하단 면은 &a구조 유리&r 또는 더 많은 &a케이싱&r으로 채워져야 합니다."
		""
		"&b터빈 로터&r는 하단의 중앙 블록에 쌓이며, 각 로터에는 두 개의 &3터빈 블레이드&r가 적용됩니다."
		""
		"&a구조 유리&r, &3터빈 밸브&r, &a케이싱&r만 로터 상단까지 면을 채울 수 있습니다."
		""
		"{image:ftb:textures/quests/mekanism/turbine1transp.png width:100 height:100 align:center}"
		"{@pagebreak}"
		"&3회전 복합체&r는 로터 위에 위치하며, &2압력 분산기&r로 둘러싸여 다중 블록의 하단 부분을 닫습니다."
		""
		"&d전자기 코일&r은 복합체 위에 있으며, 최소 하나는 복합체에 닿아야 하고, 여러 개를 사용하는 경우 모두 연결되어야 합니다."
		""
		"&3포화 응축기&r는 재활용해야 하는 물의 양에 따라 남은 공간을 채울 수 있습니다."
		""
		"{image:ftb:textures/quests/mekanism/turbine2transp.png width:100 height:100 align:center}"
		"{@pagebreak}"
		"남은 빈 공간은 이제 &a유리&r, &a케이스&r 또는 &2터빈 통풍구&r로 채울 수 있습니다. 멀티블록은 형성되기 위해 1개의 &2통풍구&r만 필요하지만, &7증기&r 흐름에 도움이 되므로 많을수록 좋습니다."
		""
		"형성된 후에는 멀티블록과 상호작용하여 현재 속도와 상태를 확인할 수 있습니다. &e통계 메뉴&r는 빌드의 어떤 부분이 &7증기&r 흐름과 생산 속도를 제한하는지 나열할 수 있습니다."
		""
		"&d핵분열 원자로 &a증기 포트&r는 &a터빈 밸브&r로 내보낼 수 있으며, &2터빈 벤트&r는 &b물&r을 &d원자로&r 입력 포트로 내보내 파이프 없이 순환할 수 있습니다!"
		""
		"{image:ftb:textures/quests/mekanism/turbine3transp.png width:100 height:100 align:center}"
	]
	quest.31C83D9253FFF685.title: "&a메카니즘&r &e터빈&r"
	quest.31CCB73669788855.quest_desc: ["이 퀘스트 보상을 받으면 &d에코의 &6기록 보관소&r 입구에 웨이포인트가 설정됩니다."]
	quest.31CCB73669788855.title: "&f기계공 찾기&d"
	quest.31F2DAA7A3EA9970.quest_desc: [
		"이 서랍 생성기는 물, 용암, 흑요석을 생성하는 데 매우 유용할 수 있습니다."
		""
		"이 아이템들은 상점에서만 구할 수 있습니다."
	]
	quest.31FD89FA8B730048.quest_desc: [
		"&a속도 업그레이드&r는 네트워크 장치가 작동하는 속도를 높입니다."
		""
		"&a스택 업그레이드&r는 네트워크 장치가 한 번에 이동할 수 있는 아이템의 양을 늘립니다."
	]
	quest.3208AF90091D1B6B.quest_desc: [
		"&a간단한 재련대&r를 사용하여 이제 새로운 속성이 부여된 아이템을 재련할 수 있습니다."
		""
		"재연마는 이미 &b속성&r이 있는 아이템으로 제한되지 않으며, 유효한 모든 아이템으로 횟수에 상관없이 수행할 수 있습니다."
		""
		"&a간단 재연마대&r를 사용하면 &9희귀&r 등급까지의 아이템을 재연마할 수 있습니다. 더 높은 등급의 아이템을 재연마하려면 이 테이블을 업그레이드해야 합니다."
		"{@pagebreak}"
		"재단조 작업대에는 세 개의 입력 슬롯이 있습니다:"
		""
		"- 중앙 슬롯에는 재단조하려는 아이템이 들어갑니다;"
		""
		"- 왼쪽 위 슬롯에는 재단조하려는 등급의 재료가 들어갑니다;"
		""
		"- 오른쪽 하단 슬롯에는 재련 시 연료로 사용되는 &a부활의 부적&r이 들어 있습니다."
		""
		"각 등급의 재단조에는 경험치, 인장, 재료의 기본 비용이 있으며, 다른 두 옵션을 선택하면 두 배 또는 세 배가 될 수 있습니다."
	]
	quest.3208AF90091D1B6B.title: "&a간단한 재련대"
	quest.322B81D896CBDF16.quest_desc: [
		"&d입자 가속&r은 매우 복잡한 주제이지만, 반드시 수행해야 합니다."
		""
		"먼저 &e플루토늄 가루&r를 만들고, 이를 사용하여 &d플루토늄 펠릿&r을 만들어야 합니다."
		""
		"[\"\", {\"text\": \"Note\", \"color\": \"yellow\"},  \": Take a look at the \", {\"text\": \"Particle Acceleration\", \"color\": \"light_purple\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"2C0C63951FDED180\"}, \"hoverEvent\": {\"action\": \"show_text\", \"contents\": \"Go to Particle Acceleration Quest\"}}, \" quest if you want to learn more.\"]"
	]
	quest.322B81D896CBDF16.title: "&6입자 가속&r"
	quest.323A230EB571C4CA.quest_desc: [
		"&a리액터&r는 전력 생산이 본격적으로 시작되는 곳입니다!"
		""
		"이것들은 &6우라나이트&r를 &b석탄&r과 &c레드스톤&r을 사용하여 태워 엄청난 양의 전력을 생산합니다."
		""
		"이 팩에서는 &e리액터에 물을 사용할 수 없습니다!"
		""
		"하나를 만들려면 인벤토리에 &a36개의 리액터 블록&r이 필요합니다. 오른 클릭하여 배치하면 공간이 있다면 자동으로 3x4x3 구조를 구축합니다."
		""
		"&a참고&r: &6우라나이트&r는 &a에너지화 구체&r에서 만들어지며, 이는 &c열&r &6월드 엔진&r 업그레이드가 필요합니다."
		""
		"물은 충분한 냉각수가 되지 못합니다. JEI에서 리액터 블록에 &aU&r를 눌러 사용할 수 있는 냉각수를 확인할 수 있습니다."
	]
	quest.325826C9B71AD7E1.quest_desc: [
		"&a황동&r은 다루기 쉽고 유연한 합금으로, 기본적인 케이싱을 만드는 데 사용할 수 있습니다."
		""
		"더 튼튼한 기반을 만들기 위해 &d흑요석 판&r과 이것들을 결합해야 합니다."
	]
	quest.325826C9B71AD7E1.title: "&f기본 케이싱"
	quest.325D35004FF683C2.quest_desc: [
		"&6양자 컴퓨터&r는 궁극의 자동 제작 멀티블록으로, 제작 저장 공간만 있다면 동시에 무제한의 제작 작업을 수행할 수 있습니다."
		""
		"&6양자 컴퓨터 코어&r는 이 멀티블록의 핵심이며, 그 자체로 &b8개의 보조 프로세서&r와 &b256MB의 저장 공간&r 역할을 합니다."
		""
		"그 자체로 자동 제작에 사용할 수 있지만, &6양자 컴퓨터&r 멀티블록 내에서 사용하면 처리 능력을 더욱 확장할 수 있습니다."
	]
	quest.325D35004FF683C2.title: "&fThe &6양자 컴퓨터 &f코어"
	quest.32653261B16850B3.quest_desc: [
		"&a눈의 여왕&r과 &2히드라&r를 모두 처치하면, 마지막 금고가 열립니다."
		""
		"&d기사 유령&r의 금고는 &b황혼의 숲&r 고리 안에서 여러분의 마지막 퍼즐이자 전투가 될 것입니다."
	]
	quest.32653261B16850B3.quest_subtitle: "마이너 월드 엔진 업그레이드"
	quest.32653261B16850B3.title: "&f마지막 황혼의 금고"
	quest.32A6859ECF7E775F.title: "마법 부여사 확인 1"
	quest.32ACE9E47B8A6C87.quest_desc: [
		"&6프시메탈 외골격 슈트&f는 &b주문 시전&f을 일상적인 모험에 완벽하게 통합할 수 있게 해주는 갑옷입니다!"
		""
		"&b슈트의 주문&f은 &6CAD&f를 집중점으로 사용하여 시전되므로, 일반적인 &dCAD 제한&f이 적용됩니다."
		""
		"&6프시메탈 외골격 슈트&f의 각 부품은 &6CAD 조립기&f에서 &b최대 세 개의 주문 탄환&f까지 장착할 수 있지만, 안타깝게도 일부 변형은 슈트와 잘 작동하지 않습니다."
		""
		"&f슈트 부품은 성공적으로 &b주문&f을 시전한 횟수를 기억합니다. 이 횟수는 &e&l선택기: 성공 횟수&r&f에서 접근할 수 있습니다."
		""
		"{@pagebreak}"
		""
		"&f&6슈트 부품&r에 사용할 &b주문&f을 선택하려면, &d&l외골격 컨트롤러&r&f를 제작하세요."
		""
		"&f&d컨트롤러&f를 사용하려면, 그것을 들고 &bPsi 마스터 단축키&r &8(기본 키: c)&r를 누르세요."
		""
		"&2오른쪽 및 왼쪽 마우스 버튼을 사용하여 사이클링&r하여 &6슈트 부품&r을 선택할 수 있습니다."
		""
		"구성하려는 &6슈트 부품&r을 선택했으면, &6CAD&f로 하는 방식과 동일한 방식으로 표시되는 &b주문 탄환&f 중 하나를 선택하세요."
		""
		"&f비어 있는 &c네 번째 슬롯&r을 선택하면 해당 슈트 부품이 완전히 비활성화됩니다. 활성화 기준이 충족되더라도 &n주문은 시전되지 않습니다&r."
	]
	quest.32ACE9E47B8A6C87.quest_subtitle: "레이젤 승인!"
	quest.32ACE9E47B8A6C87.title: "사이오닉 갑옷!"
	quest.32B4188E9438E43F.title: "유체 저장"
	quest.32C6E1FD67863F50.quest_desc: [
		"&d연금술 가마솥&r은 일반적인 양조대보다 업그레이드된 것입니다."
		""
		"이 가마솥은 물약을 양조하는 데 사용되며, &b주문 두루마리&r를 분해하여 제작에 사용된 &b잉크&r를 재활용할 기회를 얻는 데도 사용됩니다."
		""
		"또한 정기적으로 &c피 물약&r을 얻는 주요 방법입니다. 가마솥 안에 시체를 공급하기만 하면 됩니다!"
	]
	quest.32C6E1FD67863F50.title: "&f연금술 &d가마솥"
	quest.3334E05101A7297F.quest_desc: [
		"&a반응로&r는 많은 양의 전력을 소모하여 일반적인 &eAE2&r 재료를 생산할 수 있는 매우 빠른 기계입니다."
		""
		"공예품이 시작되려면 충분한 전력이 필요하므로 적절한 전력 버퍼를 확보하는 것이 중요합니다. 필요한 레시피를 처리하기 위해 물이나 용암을 여기에 내보낼 수 있습니다."
		""
		"&e참고&r: &a반응로&r는 공예를 위해 &dME 양자 고리&r와 &c고급 기계 블록&r &6월드 엔진 업그레이드&r 모두 필요합니다."
	]
	quest.333E8FBE15AE980D.quest_desc: [
		"&c핵 폐기물&r은 &a방사성 폐기물 통&r에 안전하게 버려져 천천히 붕괴될 수 있지만, &d원자로&r는 여전히 유용한 새로운 제품을 추출할 수 있는 많은 폐기물을 생성합니다."
		""
		"방사성 폐기물을 원심분리하면 &3플루토늄&r이 생성되고, &6중성자 활성화기&r로 추가 방사선을 조사하면 &9폴로늄&r이 생성됩니다. 두 과정 모두 방사성 화학 물질의 양을 크게 줄입니다."
		"{@pagebreak}"
		"이 화학 물질은 &2펠릿&r으로 추가 변환되어, 결국 붕괴되어야 하는 마지막 몇 개의 화학 불순물을 제거할 수 있습니다."
		""
		"이 &2펠릿&r은 높은 등급의 장비와 모드의 궁극적인 발전기인 &d융합 원자로&r를 공예하는 데 사용됩니다."
	]
	quest.333E8FBE15AE980D.title: "&f폴로늄이라고 말하면 플루토늄이라고 말하는 당신"
	quest.333F134987890582.quest_desc: [
		"&3결정 조립기&r는 &bExtendedAE&r의 많은 복잡한 아이템을 공예하는 데 사용됩니다."
		""
		"한 번에 4개의 &2프로세서&r를 공예하는 데에도 사용할 수 있습니다!"
	]
	quest.3371E3F69A27D1E5.quest_desc: [
		"마지막 &d메아리&r를 찾는 데 오류가 있었던 것 같습니다."
		""
		"시스템이 지금까지 만난 것들과 다르게 그것들을 참조하는 것 같습니다."
		""
		"아마 &d와름라이트&r가 무언가를 알고 있을지도 모릅니다..."
	]
	quest.3371E3F69A27D1E5.title: "&f하이페리온 잠금 해제&6"
	quest.3382AC7FEFE0B76E.quest_desc: ["[\"You may get \", {\"text\": \"Ancient Debris\", \"color\": \"green\"}, \" early by going to the \", { \"text\": \"Nether Dungeon\", \"color\": \"red\", \"underlined\": true, \"clickEvent\": {\"action\": \"change_page\", \"value\": \"21A521011401074F\"}, \"hoverEvent\": {\"action\": \"show_text\", \"contents\": \"Go to Nether Dungeon Quest\"}}, \", which can spawn in the Deepslate Ring.\" ]"]
	quest.3382AC7FEFE0B76E.title: "&f바닐라 네더라이트 무기"
	quest.33A9FF901E2D7725.quest_desc: [
		"모드의 대부분의 기계를 만들기 위해 &2강철 케이싱&r이 필요합니다!"
		""
		"&e참고&r: 대부분의 기계는 내부 푸시/풀 제한이 있으며, 파이프로 우회할 수 있습니다. 생산 속도를 높이고 싶다면 파이프를 활용하세요."
	]
	quest.33E4C81B762892B2.quest_desc: [
		"&e오라이텍&r은 기술 모드를 바꾸는 사용자 정의 가능한 멀티블록 기계를 중심으로 하는 기술 모드입니다!"
		""
		"기본 광석 처리부터 &d입자 가속기&r 설정까지, 이 모드에는 모든 것이 있습니다."
		""
		"시작하려면 모드의 주요 공예 재료인 &a니켈 원석&r이 필요합니다."
	]
	quest.33E4C81B762892B2.title: "&f오리테크&e에 오신 것을 환영합니다&f!"
	quest.33EDFB2DC1BEA7F0.quest_desc: ["&3자동 공예 모니터&r를 통해 모든 활성 공예 요청의 상태를 볼 수 있습니다."]
	quest.33EDFB2DC1BEA7F0.title: "자동 공예 모니터"
	quest.33FEE29B3EF5A420.quest_subtitle: "언어더, 다른 세계 돌"
	quest.340D7F25B5EB0D33.quest_desc: [
		"다음 등급의 구슬은 &d보이드쉬머 구슬&r이며, &b다이아몬드 블록&r을 &b셀레스티젬&r으로 변환할 수 있습니다."
		""
		"활성화하려면 스컬크, 코러스 열매 또는 엔더 진주를 먹여야 합니다."
		""
		"이전 등급과 마찬가지로, 이 구슬은 이전 자원을 더 빠른 속도로 생산할 수도 있습니다."
	]
	quest.340D7F25B5EB0D33.title: "&f천상의 보석&d 만들기"
	quest.3435641A78B90D97.quest_desc: [
		"&b분해 모듈&r은 필드가 생성될 기존 블록을 부수고 아이템으로 떨어뜨리는 데 단독으로 사용할 수 있습니다. &b수집 모듈&r도 함께 있으면, &d프로젝터&r는 해당 아이템을 인접한 상자나 다른 인벤토리로 배치할 수 있습니다."
		""
		"&b안정화 모듈&r은 &d프로젝터&r가 인접한 상자/인벤토리에서 블록 아이템을 가져와 해당 블록으로 필드를 교체하도록 합니다."
		""
		"&b스펀지 모듈&r은 모드의 필드에 의해 둘러싸인 &l전체&r 공간에 영향을 미쳐, 내부에 있는 모든 유체를 증발시킵니다."
	]
	quest.3435641A78B90D97.title: "&f영역에 영향을 미치기"
	quest.34A2BA2C754CE27A.quest_desc: [
		"&2둥지 피더&r와 &a둥지 수집기&r는 30블록 이내의 모든 근처 둥지에서 씨앗을 전달하고 아이템을 수집할 수 있습니다. 이 범위는 각 둥지의 인터페이스에서 '+' 및 '-' 버튼을 클릭하여 구성할 수 있습니다."
		""
		"&2둥지 공급기&r를 사용하면, &2공급기&r 인터페이스 내의 각 둥지 오른쪽 필터 슬롯으로 인벤토리나 JEI에서 씨앗 아이템을 드래그하여 어떤 씨앗을 어떤 둥지에 먹일 수 있는지 필터링할 수 있습니다."
		""
		"두 블록 중 하나가 작동하려면, 왼쪽의 `[ ]`를 클릭하여 `[x]`로 표시하여 자원을 수집할 둥지를 선택해야 합니다."
		""
		"&e참고&f: &2둥지&r의 이름을 바꾸면 이 인터페이스에 이름이 표시됩니다."
	]
	quest.34A2BA2C754CE27A.title: "무선 닭"
	quest.34C8824842867F5D.quest_desc: ["&r강력한 엔더 닭&r은 지도 북쪽과 남쪽 모두에 집이 있으며, 특히 &e엔드&r 고리에 있습니다. 소문에 따르면 이 닭은 파괴할 수 없는 방패를 가지고 있다고 합니다. 아마 &b닭 막대기&r가 도움이 될지도 모릅니다..."]
	quest.34C8824842867F5D.title: "&e처치&f: \\&z강력한 엔더 닭"
	quest.34D191F76AA69707.quest_desc: [
		"&e플럭스 네트워크&r는 궁극의 무선 전력 솔루션입니다!"
		""
		"&a플럭스 가루&r는 모드의 모든 블록을 공예하는 주요 공예 재료입니다."
		""
		"&e참고&r: &e플럭스 가루&r는 공예를 위해 &a기계 블록&r와 &c엔더 셀&r &6월드 엔진 업그레이드&r가 필요합니다."
	]
	quest.34D191F76AA69707.title: "플럭스 네트워크"
	quest.34EC72BBCD9F197F.quest_desc: [
		"이 &a초급 주문책&r을 사용하면 &a1단계 주문&r을 시전할 수 있습니다! 또한 첫 번째 주문을 만드는 데 도움이 되도록 이미 학습된 기본적인 주문 지식(&b문양&r이라고 함)이 함께 제공됩니다."
		""
		"새로운 주문을 만들려면 &2서기 테이블&r을 사용하여 &b문양&r을 만들어야 합니다."
		""
		"제작되면, 이를 배치하여 새로운 &b문양&r을 연구하고 제작할 수 있습니다. 문양은 주문 제작의 기초가 되며, &d주문&r에 대한 새로운 부분을 알려줍니다."
		""
		"&b문양&r을 만드는 방법을 배워봅시다!"
		"{@pagebreak}"
		"&b문양&r도 등급이 있습니다. &a초급 주문책&r으로는 &a1단계 문양&r만 시전할 수 있습니다. 더 높은 등급의 주문을 시전하려면 주문책을 업그레이드해야 합니다."
		""
		"&b문양&r을 제작하려면, 주문책을 손에 들고 서기 테이블을 마우스 오른쪽 버튼으로 클릭해야 합니다. 그러면 &b문양&r 메뉴가 열립니다!"
		"{image:ftb:textures/quests/ars/glyphmenu.png width:225 height:175 align:center}"
		"{@pagebreak}"
		"그러면 이미 학습한 것을 포함하여 만들 수 있는 모든 &b문양&r이 표시됩니다. 오른쪽에서 등급별로 필터링하거나 특정 문양을 검색할 수 있습니다."
		""
		"첫 번째 &b문양&r으로 &a증폭&r을 만들어 봅시다! 검색한 다음 클릭하여 하단에 필요한 아이템을 확인하고, '선택' 버튼을 클릭하세요."
		""
		"이제 메뉴를 닫고 필요한 아이템을 들고 작업대를 우클릭하면 마법이 일어나는 것을 볼 수 있습니다!"
	]
	quest.34EC72BBCD9F197F.title: "&f첫 주문책"
	quest.3506242698EDF435.quest_desc: [
		"&a스택 업그레이드&r는 배낭의 각 슬롯의 스택 크기를 곱합니다. 이것들은 같은 종류의 아이템을 많이 저장하는 데 매우 유용합니다!"
		""
		"다른 업그레이드와 결합하면 &a탱크&r 또는 &a배터리&r 업그레이드와 같이, 이러한 업그레이드의 전체 저장 한도도 늘어납니다."
	]
	quest.3506242698EDF435.title: "&f스택 업그레이드"
	quest.353F6C94B5D5FF0B.quest_desc: [
		"&6에테르나&r를 더욱 높이려면 &3심층 선반&r을 제작하고 주입해야 합니다."
		""
		"이 선반은 &6에테르나&r를 최대 &a75&r까지 높일 수 있습니다."
		""
		"또한 \\&z마법 보물의 깊은 선반&r을 사용하여 마법 부여 테이블이 \\&z보물 마법 부여&r를 부여하도록 할 수 있습니다."
		""
		"&e참고&r: 심층 선반은 &6월드 엔진 업그레이드&r에 사용할 수 있습니다."
	]
	quest.353F6C94B5D5FF0B.title: "심층의 선반"
	quest.35412128EF4B8692.title: "마법 부여가 만나기"
	quest.355C3ACB16CC2DE9.quest_desc: [
		"&6양자 가속기&r는 멀티블록에 각각 &b8개의 보조 처리 장치&r를 추가합니다."
		""
		"멀티블록 구조물 안에 이것들을 많이 두는 것이 좋습니다."
	]
	quest.355C3ACB16CC2DE9.title: "&6양자&d 가속"
	quest.35791C02AC048594.quest_desc: [
		"&a크로논 셀&r을 사용하면 &b크로논&r이라고 불리는 시간의 힘을 저장할 수 있습니다."
		""
		"&2크로논 발전기&r는 &a셀&r을 위해 &b크로논&r을 천천히 생성하며, 이를 통해 /home 명령어로 집으로 순간이동할 수 있습니다."
		""
		"또한 &a셀&r을 손에 들고 웅크리기 + 우클릭하여 &6월드 엔진&r으로 순간이동할 수도 있습니다."
	]
	quest.35791C02AC048594.quest_subtitle: "/home 잠금 해제"
	quest.35791C02AC048594.title: "&f크로논 관리"
	quest.35A0BC59FB62D5F9.title: "바다 조각"
	quest.35E8F57E93106BFE.quest_desc: [
		"&a패턴&r은 제작 또는 가공 레시피를 저장하는 데 사용됩니다. 이는 &3패턴 그리드&r 내에서 수행할 수 있으며, 한 번에 최대 &a패턴&r 스택을 담을 수 있습니다."
		""
		"레시피를 설정하려면 먼저 가장 오른쪽에 있는 인터페이스에서 모드를 선택하십시오. 그런 다음 JEI에서 제작하려는 아이템을 검색하고 해당 레시피 옆의 '+' 아이콘을 클릭하십시오. 이렇게 하면 &a패턴&r이 자동으로 설정되지만, 원하면 수동으로 설정할 수도 있습니다."
		""
		"자동 제작 가능한 자원은 그리드에서 볼 때 노란색 배경을 갖게 됩니다."
	]
	quest.35E8F57E93106BFE.title: "패턴"
	quest.364AA0C55F3312DE.title: "심층암 조각"
	quest.364B2143B874582D.quest_desc: [""]
	quest.364B2143B874582D.title: "&f월드 엔진 발견"
	quest.36BA7AADD98E9868.quest_subtitle: "다이아몬드 + 금"
	quest.36CB035F6484A70F.quest_desc: [""]
	quest.36CB035F6484A70F.title: "&f가죽"
	quest.36DD75256D280C4A.quest_desc: [
		"기계는 &a애드온&r을 설치하여 업그레이드할 수 있습니다."
		""
		"다양한 종류의 애드온이 있으며, 대부분은 기계의 속도나 효율성을 높여줍니다."
		""
		"&a범위 업그레이드&r는 &a몹 분쇄기&r와 같은 특정 기계의 유효 범위를 늘립니다."
	]
	quest.36DD75256D280C4A.title: "&b기계 애드온"
	quest.36E0D875AA8E2F66.quest_desc: [
		"구의 마지막 티어는 &5섀도우펄스 구&r라고 불립니다."
		""
		"이 구는 &6네더라이트 블록&r을 &5이클립스 합금 원광석&r으로 변환할 수 있습니다."
		""
		"활성화하려면 엔더 진주 또는 후렴과를 먹여야 합니다."
		""
		"이전 티어와 마찬가지로, 이전의 모든 주괴 블록도 더 높은 비율로 변환할 수 있습니다."
	]
	quest.36E0D875AA8E2F66.title: "&d이클립스 원광석"
	quest.370B05FC62884456.quest_desc: [
		"&a초고온 발열체&r는 히터의 핵심에 완벽합니다."
		""
		"만들고자 하는 히터 유형에 두 가지 선택지가 있는 것처럼 보일 수 있지만, &c장작 히터&r는 석탄이나 나무를 통해서만 열을 생성할 수 있어 &6월드 엔진&r을 가열하기에 불충분합니다."
		""
		"반면에 &c저항 히터&r는 전력을 직접 열로 변환하는 데 특화되어 있습니다. 전력 변환량을 세밀하게 조정할 수 있으며 훨씬 더 많은 열을 생성합니다."
		""
		"&e참고&r: 약 350°C에 도달하려면 2k FE/t가 이상적입니다."
		"{@pagebreak}"
		"히터에 전력을 공급하려면 발전기나 에너지 큐브를 가져오거나, &d스펙터 코일&r을 사용하여 무선 전력 전송을 해야 합니다."
		""
		"대부분의 제작은 작동하기 위해 약 &c350°C&r가 필요하며, 제작이 완료되려면 해당 온도를 유지해야 합니다."
	]
	quest.370B05FC62884456.quest_subtitle: "소규모 월드 엔진 업그레이드"
	quest.370B05FC62884456.title: "&f열을 올리자"
	quest.37104662F0BDDE66.quest_desc: [
		"&e디지털 저장소&r를 &6응용 에너지학 2&r 또는 &6정제된 저장소 2&r로 시작하려면 먼저 &a완벽한 발아하는 서투스 블록&r을 &6월드 엔진&r을 사용하여 제작해야 합니다. 이를 위해서는 &a기계 블록&r 업그레이드가 필요합니다."
		""
		"&o&7네, 보상은 장식용입니다. 이것은 버그가 아닙니다."
	]
	quest.37104662F0BDDE66.title: "&a디지털 저장소&r"
	quest.371D1FEFBD49CCFF.quest_desc: [
		"&b셀레스티젬&r은 &6저스트 다이어 띵즈&r의 다음 티어 무기입니다."
		""
		"내구도를 사용하는 대신, 이 무기들은 &c에너지&r를 사용하며, 더 많은 업그레이드를 설치할 수 있습니다."
		""
		"이것들은 &d고대 도시&r로 여행을 다녀온 후 &d보이드쉬머 구&r를 만들면 만들 수 있습니다."
	]
	quest.371D1FEFBD49CCFF.title: "&b셀레스티젬&f 무기"
	quest.37499343396BC372.quest_desc: ["이 퀘스트 보상을 받으면 &d메아리의 &6기록 보관소&r 입구에 웨이포인트가 설정됩니다."]
	quest.37499343396BC372.title: "&f와름라이트 찾기&d"
	quest.375A2BF4EA6F4EA9.title: "4단계 '또는' 확인"
	quest.375DBC764A420D98.title: "지옥의 만남"
	quest.376227602F2E3DA4.quest_desc: [
		"\\&z시간 수정&r은 인벤토리 안에 있을 때 현실을 구부리는 고급 재료입니다."
		""
		"이 결정체는 &6월드 엔진&r에서 만들어지며, 이를 위해서는 &d공명하는 공허&r와 &c고급 기계 블록&r 업그레이드가 필요합니다."
	]
	quest.376227602F2E3DA4.title: "&r시간 결정체&r"
	quest.37A6FBA47B056D57.title: "그림자 케이싱 거래"
	quest.37CC00D0136EFDAE.title: "안내 확인 4.1"
	quest.37F99696A47264FD.quest_desc: ["이 챕터는 모험에 필요한 장비를 제작, 강화, 마법 부여하는 다양한 방법을 알려주는 데 중점을 둡니다!"]
	quest.37F99696A47264FD.title: "&f모험을 위한 장비 갖추기!"
	quest.38124EBC1E14AB38.quest_desc: [
		"이 고통받는 영혼은 또 다른 &6월드 엔진&r 업그레이드에 대한 비밀을 간직하고 있습니다."
		""
		"&3금고&r의 수호자를 처치하여 이그니티움 주괴를 획득하십시오."
	]
	quest.38124EBC1E14AB38.title: "&f이그니티움"
	quest.3819423319D1A414.quest_desc: [
		"더 많은 &6월드 엔진&r 업그레이드가 잠금 해제되면, &d안내의 메아리&r가 당신이 발견할 더 많은 것을 제공할 것입니다."
		""
		"대화 후, 더 많은 &6기록 보관소&r의 잠금이 해제될 것입니다!"
	]
	quest.3819423319D1A414.quest_subtitle: "3단계 챕터 잠금 해제"
	quest.3819423319D1A414.title: "&f솔라리스 잠금 해제&3"
	quest.381B55C984A8BD33.quest_desc: [
		"&2스케일 모듈&r은 지정된 축을 따라 블록 하나를 추가하며, 이는 일부 &a모드&r에서는 미러링되고 다른 모드에서는 방향성이 있습니다."
		""
		"&2번역 모듈&r은 &d투사기&r를 기준으로 지정된 방향으로 모듈당 투영 영역을 한 블록씩 이동시킵니다. 자체에서 시작됩니다."
		""
		"&2회전 모듈&r은 지정된 방향으로 모듈당 투영 영역을 2도씩 회전시킵니다."
	]
	quest.381B55C984A8BD33.title: "&f크기에 관한 &b문제"
	quest.383DAD591823C746.quest_desc: [
		"&3업그레이드&f에 필요한 블록을 제출하고 보상을 받으면 팀의 &6월드 엔진&r이 자동으로 조립됩니다."
		""
		"&e참고&f: 업그레이드가 있어야 할 위치에 배치된 블록은 무효화됩니다."
	]
	quest.383DAD591823C746.title: "&f자동 제작 &3황혼 업그레이드"
	quest.387FB75C400B5D34.quest_desc: [
		"&d테서랙트&r는 에너지, 아이템, 유체를 무선으로 전송할 수 있는 블록입니다."
		""
		"이 모든 것은 개인 또는 공개로 구성할 수 있는 네트워크를 사용하여 수행할 수 있습니다."
		""
		"옛날처럼 새로운 제작법도 있습니다!"
		""
		"&e참고&r: 프레임을 제작하려면 &a기계 블록&r과 &c엔더 셀&r &3월드 엔진 업그레이드&r가 필요합니다."
	]
	quest.38869642A2E6F8B6.quest_desc: [
		"물류에 관해서는 &e모듈식 라우터&r가 모든 것을 할 수 있습니다. 이 모드는 &a자동 클릭&r, &a블록 파괴&r 등 수많은 유용한 기능을 제공합니다!"
		""
		"이러한 모든 기능은 메인 블록인 &d모듈식 라우터&r 내에서 수행됩니다. 기능을 부여하려면 무엇을 해야 할지 알려주는 &a모듈&r이 필요합니다. 이 모듈은 &a증강 장치&r를 사용하여 구성하고 업그레이드할 수 있습니다."
		""
		"&e참고&r: &a모듈식 라우터&r는 제작을 위해 &b포트론 주입 블록&r &6월드 엔진 업그레이드&r가 필요합니다."
	]
	quest.38869642A2E6F8B6.quest_subtitle: "모든 것을 할 수 있습니다"
	quest.38869642A2E6F8B6.title: "모듈식 라우터"
	quest.388FDE6183B26A5E.title: "와이번 코어 거래"
	quest.38E2176886386133.quest_desc: [
		"&a합금 용광로&r는 콘스탄탄, 인바, 일렉트럼, 청동과 같은 합금을 만드는 데 사용되는 초반 멀티블록입니다."
		""
		"이것을 만들려면 &a용광로 벽돌&r로 2x2x2 큐브를 만들고, &a엔지니어의 망치&r로 한 면을 마우스 오른쪽 버튼으로 클릭하세요."
	]
	quest.38E2176886386133.title: "&f합금 용광로"
	quest.38EDDC529FD4C665.quest_subtitle: "발굴자, 지질학자"
	quest.3900E67C8B833980.quest_desc: [
		"&a장인 두루마리&r는 전리품으로 얻거나 상점&r에서 구매할 수 있습니다."
		""
		"&b보석&r 청사진을 배우려면 손에 &a장인 두루마리&r를 들고 우클릭하세요."
	]
	quest.3900E67C8B833980.title: "&a장인 두루마리"
	quest.3917A0EC517F70E6.quest_desc: [
		"&3업그레이드&f에 필요한 블록을 제출하고 보상을 받으면 팀의 &6월드 엔진&r이 자동으로 조립됩니다."
		""
		"&e참고&f: 업그레이드가 들어가야 할 곳에 배치된 블록은 무효화됩니다."
	]
	quest.3917A0EC517F70E6.title: "&f자동 조립: &3소스 업그레이드"
	quest.39751E377C0F22EE.quest_desc: [
		"&a복제 단말기&r를 사용하면 복제할 아이템을 요청할 수 있습니다."
		""
		"단말기는 네트워크 내 &d메모리 칩&r에 저장된 아이템과 오른쪽에 있는 &a물질 탱크&r에 저장된 총 물질 양을 보여줍니다."
	]
	quest.39758AAD01EEB3C8.quest_desc: [
		"선반 경로에 따라 주입 레벨에 도달하려면 추가 &c퀀텀&r이 필요할 수 있습니다."
		""
		"&c해골&r은 훌륭하게 작동하며 &c퀀텀&r에 &a+5&r 부스트를 제공합니다!"
	]
	quest.39A6CE8A1D5B2D8F.quest_desc: [
		"&6Just Dire Things&r의 &a간단 석탄 발전기&r는 석탄이나 나무와 같은 일반 연소 가능한 아이템을 태울 수 있지만, 모드 자체의 &a프라이멀 석탄&r과 같은 다양한 등급의 석탄도 태울 수 있습니다!"
		""
		"이 특수 석탄을 사용하면 더 많은 전력이 생산되며, 상위 등급은 최대 960 RF/t를 생산합니다."
		""
		"&a포켓 발전기&r는 같은 일을 하지만 인벤토리에서 아이템을 충전합니다."
	]
	quest.39BC89942A5CA7E1.quest_subtitle: "에너지 효율을 향상시킵니다."
	quest.39ED88D2EF2F617B.quest_desc: [
		"온갖 종류의 &b호기심과 장신구&r를 장비하는 것은 흔한 일이지만, 특정 선택은 기피됩니다. &a브로치&r는 이러한 선택 사항 중 하나를 다른 것으로 교환하여 약간의 조정을 허용합니다. 이러한 옵션 중에는 새로운 &b룬 슬롯&r을 허용하는 것도 있습니다."
		""
		"룬은 기본 재료를 &a룬 작업대&r에 삽입한 다음 필요한 양과 종류의 정령을 적용하여 만들어집니다."
		""
		"룬은 매우 다양한 강력한 효과를 제공합니다. 일부는 &e토템&r이 수행하는 개인적인 형태의 &b정령 의식&r을 적용하고, 다른 일부는 눈에 띄는 능력치 버프를 제공하며, 또 다른 일부는 자체 고유한 특성을 가지고 있습니다."
		"평소처럼, 자세한 내용은 &e백과사전&r을 참조하세요."
	]
	quest.39ED88D2EF2F617B.title: "룬 제작"
	quest.39F10D110D7E77B7.quest_desc: [
		"&c네더라이트&r 도구는 &a고대 잔해&r와 &c네더라이트 대장장이 주형&r를 손에 넣으면 사용하기 좋습니다."
		""
		"[\"You may get \", {\"text\": \"Ancient Debris\", \"color\": \"green\"}, \" early by going to the \", { \"text\": \"Nether Dungeon\", \"color\": \"red\", \"underlined\": true, \"clickEvent\": {\"action\": \"change_page\", \"value\": \"21A521011401074F\"}, \"hoverEvent\": {\"action\": \"show_text\", \"contents\": \"Go to Nether Dungeon Quest\"}}, \", which can spawn in the Deepslate Ring.\"]"
	]
	quest.39F10D110D7E77B7.title: "&f바닐라 네더라이트 도구"
	quest.39F6026AB205841A.quest_desc: [
		"이 팩에는 &eFTB 울티마인&r이 포함되어 있지만, &a돌&r에는 작동하지 않습니다!"
		""
		"[\"Ultimine can be toggled with the keybind \", { \"keybind\": \"key.ftbultimine\", \"color\": \"green\" }, \".\"]"
		""
		"또한 작동하려면 손에 도구가 있어야 합니다."
	]
	quest.39F6026AB205841A.title: "울티마인 참고 사항"
	quest.3A106E4D6EE35D7A.quest_subtitle: "발굴자, 조약돌"
	quest.3A1424B69AD511BD.quest_desc: [
		"&eActually Additions &a드릴&r은 작동을 위해 전력을 소비하며 여러 가지 다른 보강재로 업그레이드할 수 있습니다."
		""
		"완전히 충전된 드릴은 &d기계공&r 상점에서 구할 수 있습니다."
	]
	quest.3A1424B69AD511BD.title: "&eActually Additions &f드릴"
	quest.3A43CCB33A024711.quest_desc: [
		"&6작업대&r는 인게임 &e템패드&r 장치 역할을 합니다."
		""
		"작동하려면 &6템패드&r를 도킹해야 하며, 작업대에 기능과 &d시간 왜곡 장치&r의 타임라인 능력을 제공합니다(설치된 경우)."
		""
		"시간 문을 더 오래 열어두는 것과 같은 더 많은 옵션과 구성이 제공되며, 템패드에 선택적 업그레이드를 설치할 수 있는 기능도 있습니다."
		"{@pagebreak}"
		"&d플레이어 순간이동 업그레이드&r를 사용하면 &6템패드&r가 활성 &a위치 방송기&r 또는 &d감시 장치&r를 장착한 플레이어를 감지할 수 있습니다."
	]
	quest.3A43CCB33A024711.title: "&6작업대"
	quest.3A47929FBAEEBD8B.quest_subtitle: "발굴자, 조약돌"
	quest.3A53BB7A6B708966.quest_desc: [
		"&a45&r &6에테르나&r에 도달하면 선반을 주입할 수 있습니다!"
		""
		"&c주입된 지옥 선반&r을 만들려면 최소 &a30&r &c퀀텀&r이 필요하며, &b주입된 바다 선반&r은 &a15&r &c퀀텀&r과 &a10&r &d아르카나&r가 필요합니다."
		""
		"&d주입된 책장&r을 사용하면 다음 업그레이드를 위해 최대 &a60&r &6에테르나&r에 도달할 수 있습니다."
	]
	quest.3A53BB7A6B708966.title: "주입된 선반"
	quest.3A59D1773EBD3B8A.quest_desc: [
		"&d양자 네트워크 브릿지&r를 사용하면 기지에서 멀리 떨어진 기계와 저장소를 AE2 네트워크에 연결하여 원격으로 자동화할 수 있습니다."
		""
		"이것이 &6월드 엔진&r을 자동화하는 방법입니다!"
		""
		"양자 고리는 어떤 면에 연결하든 총 128개의 채널만 허용합니다. 또한 연결 챔버에 인접한 4개의 양자 고리에만 연결할 수 있으며, 모서리는 연결되지 않습니다."
		""
		"각 멀티블록은 중앙에 &6ME 양자 링크 챔버&r가 있는 &b8개의 양자 링&r으로 구성됩니다. 두 개를 연결하려면 &d양자 얽힘 특이점&r을 만들어 각 링크 챔버에 사용하여 연결해야 합니다."
		"{@pagebreak}"
		"양자 링은 어느 면에 연결하든 총 128개의 채널만 허용합니다. 또한 모서리는 연결되지 않으므로 링크 챔버에 인접한 4개의 양자 링에만 연결할 수 있습니다."
		""
		"&e참고&r: 작동하려면 양쪽 모두 청크 로딩이 필요합니다."
	]
	quest.3A59D1773EBD3B8A.quest_subtitle: "마이너 월드 엔진 업그레이드"
	quest.3A59D1773EBD3B8A.title: "&6양자 네트워크 브릿지"
	quest.3A7774F5F0FD174E.quest_desc: [
		"다음 업그레이드로 진행하려면 &6에테르나&r를 &a45&r까지 올려야 합니다. 이는 업그레이드된 선반으로 달성할 수 있습니다."
		""
		"&c지옥 선반&r은 제작하기 더 쉽고 &c양자력&r을 높이는 데 중점을 둡니다."
		""
		"&b바다 선반&r은 시작하기 위해 약간의 낚시가 필요하지만, 대신 &d비전력&r 값을 높입니다."
		""
		"&d정령 감응 수정&r 또한 &6오컬티즘&r에서 45를 달성하는 데 매우 효과적입니다."
	]
	quest.3A7774F5F0FD174E.title: "업그레이드된 선반"
	quest.3AB006907366227A.quest_desc: [
		"정령을 어떤 것에도 주입하는 것은 보통... &o환영받지 못한다&r고 할 수 있습니다."
		""
		"[\"To start this process, you'll need a \", {\"text\": \"Spirit Altar\", \"color\": \"green\"}, \" to commune with spirits. You can find \", {\"text\": \"Runewood Trees\", \"color\": \"dark_green\"}, \" within the \", { \"text\": \"Arcane Grove\", \"color\": \"light_purple\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"066B47D2AB72355C\" }, \"hoverEvent\": {\"action\": \"show_text\", \"contents\": \"Go to Arcane Grove Quest\"}}, \" just be ready to put up a fight.\"]"
		""
		"&2룬 나무&r를 수확한 후에는 제단을 만들기 위해 &d정제된 영혼석&r 한 개가 필요합니다."
		""
		"[\"This requires either throwing raw ores into the \", {\"text\": \"Weeping Well\", \"color\": \"blue\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"754ADB22C6B8041F\"}, \"hoverEvent\": {\"action\": \"show_text\", \"contents\": \"Go to Weeping Well Quest\"}}, \" structure, or \", {\"text\": \"The Magician\", \"color\": \"light_purple\"}, \" can help you out for the right price.\"]"
	]
	quest.3AB006907366227A.title: "&f정령과의 거래"
	quest.3AC24F0B92156F55.quest_desc: [
		"&d조립기&r는 2x2 제작 그리드를 특징으로 하며, 에너지가 있고 입력 슬롯에 아이템이 있으며 출력 슬롯에 완성된 제품을 위한 공간이 있는 한 자동으로 아이템을 조립합니다."
		""
		"일부 기계 부품은 &a조립기&r 없이 제작할 수 있지만, 그렇게 하면 더 많은 자원이 소모됩니다."
	]
	quest.3AC24F0B92156F55.title: "&fThe &d조립기"
	quest.3ACF3359B3B59A05.quest_desc: [
		"&e정교한 저장소&r를 통해 상자, 통 및 기타 여러 가지를 만들고 업그레이드할 수 있습니다!"
		""
		"이 &a저장소들&r은 더 많은 아이템을 담거나, 유체를 담거나, 광석을 제련하는 것과 같은 특정 작업을 자동화할 수도 있습니다."
		""
		"시작하려면 일반 상자나 통을 &a정교한 상자&r 또는 &a정교한 통&r으로 변환하려면 거기에 &a기본 구리 등급 업그레이드&r를 사용하세요."
		""
		"&e참고&r: &a기본 구리 등급 업그레이드&r는 상점에서 구매해야만 얻을 수 있습니다. 구리 이후의 저장 등급 업그레이드는 제작할 수 있습니다."
	]
	quest.3ACF3359B3B59A05.title: "&e정교한 저장소"
	quest.3B06321F0E2F0EC9.title: "1단계 WE '또는' 확인"
	quest.3B0DA478464D29CC.title: "&f초반 바닐라 검"
	quest.3B2B26B1AD947CC5.quest_desc: [
		"&a대형 에너지 저장소&r는 기본값 20M RF를 저장하며 &b애드온&r으로 업그레이드할 수 있습니다."
		""
		"&a대형 에너지 저장소&r는 모든 녹색 포트에서 에너지를 받지만 빨간색 포트 하나로만 출력할 수 있습니다. 레드스톤 신호는 모든 에너지 출력을 비활성화합니다."
	]
	quest.3B33C4D5A2D400D4.quest_desc: [
		"&b하늘 돌&r은 거래를 통해 &d플럭스 연구원&r 주민에게서, 친절한 &e떠돌이 상인&r에게서, 또는 &b하늘 돌 가루&r를 제련하여 얻을 수 있습니다."
		""
		"각 고리의 &a텔레패드&r 구조물에서도 블록을 찾을 수 있습니다. &d공허 고리&r는 또한 하단 섹션에 &b하늘 돌&r 블록을 가지고 있습니다."
	]
	quest.3B33C4D5A2D400D4.title: "&f하지만 &b하늘 돌&f은 어디에?"
	quest.3B9DB4204A7CC6CD.quest_desc: [
		"&2시간 문 표식&r은 세계의 특정 위치를 표시하기 위해 땅에 배치됩니다."
		""
		"우클릭하면 표시 이름, 색상 및 액세스 설정을 구성할 수 있는 인터페이스가 열립니다."
		""
		"&6크로노마크&r는 더 많은 사용자 정의 옵션을 제공하는 업그레이드된 버전입니다."
	]
	quest.3B9DB4204A7CC6CD.title: "시간 문 표식"
	quest.3B9E10A560C565CC.quest_desc: [
		"&a순간이동기&r는 &6간단한 순간이동기&r에서 세계 내에서 빠른 순간이동 패드를 설정하는 데 사용할 수 있습니다."
		""
		"&d엔더 파편&r은 &a순간이동기&r에 쉬프트 + 우클릭하여 위치 데이터를 저장한 다음, 파편을 다른 &a순간이동기&r에 설치할 수 있습니다."
		""
		"완료되면 &a순간이동기&r 위에서 쉬프트를 눌러 순간이동할 수 있습니다!"
	]
	quest.3B9E10A560C565CC.title: "간단한 순간이동기"
	quest.3BD07A9C3A6ED05A.quest_desc: [
		"어둡고 빈 공간 속에서, 생명체들이 돌의 깊은 곳에서 기어 올라오는 소리가 들립니다."
		""
		"운이 좋으면 죽은 &a주민&r이 움직이는 것을 발견할 수도 있습니다."
		""
		"빈 어두운 방을 만들어 &a좀비 주민&r이 스폰되도록 하고, &2치유의 샘물&r을 사용하여 되살리세요."
		""
		"&e참고&f: 방을 &a치유의 샘물&r에 너무 가깝게 짓지 마세요. 몹이 거기서 스폰되지 않을 것입니다! 미니맵 아래 또는 'F3'을 사용하여 &b생물 군계 이름&r을 찾으세요."
	]
	quest.3BD07A9C3A6ED05A.quest_subtitle: "나를 깨워줘"
	quest.3BD07A9C3A6ED05A.title: "&f나를 살려줘"
	quest.3BFF8EFB5E7186A4.quest_desc: [
		"&6양자 컴퓨터&r 멀티블록 내부는 다양한 블록 조합을 사용하여 사용자 정의할 수 있으며, 추가 &b양자 저장소&r도 포함됩니다."
		""
		"&6양자 컴퓨터 저장소&r 블록은 멀티블록이 한 번에 처리할 수 있는 동시 작업 수를 효과적으로 증가시킵니다."
	]
	quest.3BFF8EFB5E7186A4.title: "&d양자 저장소"
	quest.3C0A24054C75BF91.title: "병참 장교 확인 1"
	quest.3C25B0FAC773D70A.title: "&d아르스의 도구"
	quest.3CADD463CFC2FE32.quest_desc: [
		"&a열전 발전기&r는 양쪽에 있는 블록 간의 온도 차이를 사용하여 &aLV&r 전력을 생성합니다."
		""
		"이는 전력을 생성하기 위해 차가운 블록/유체와 뜨거운 블록/유체를 반대쪽에 배치해야 함을 의미합니다."
		""
		"&a기술자 설명서&r 또는 JEI에서 호환되는 블록 목록을 확인할 수 있습니다."
		""
		"&e참고&r: 이것은 상점 전용 아이템입니다."
	]
	quest.3CD3CA5B619F5698.quest_desc: ["&a행운&r 및 &a섬세한 손길&r 업그레이드는 &a파괴기&r에서 채굴된 블록에 마법 부여를 적용하는 데 사용할 수 있습니다."]
	quest.3CE848B7CB98859F.quest_desc: [
		"&d배포기&r는 플레이어 상호 작용을 모방하고 아이템 레시피를 처리하는 데 사용됩니다."
		""
		"&d배포기&r는 소를 젖 짜고, 양을 털 깎고, 경작지를 만들고, 몬스터를 공격하는 등 더 많은 작업을 할 수 있습니다."
	]
	quest.3CFDFD0BA7D30118.quest_desc: [
		"&6Stoneblock 4&r에서는 월드가 고리 형태로 생성됩니다!"
		""
		"약 712블록까지 확장되는 미리 생성된 돌 고리 안에서 시작합니다. 그 후의 각 고리는 512블록까지만 확장됩니다."
		"{@pagebreak}"
		"고리들은 다음과 같은 순서입니다:"
		""
		"1. &3돌&r"
		"2. &7심층암&r"
		"3. &c네더&r"
		"4. &e엔드&r"
		"5. &d황혼의 숲&r (미로 돌)"
		"6. &b바다&r (이끼 낀 조약돌)"
		"7. \\&z공허 균열&r (기타 돌, 위쪽 층에는 스카이 스톤)"
		"{@pagebreak}"
		""
		"{image:ftb:textures/quests/worldgen_rings.png width:300 height:300 align:center}"
	]
	quest.3CFDFFDCDC306A83.quest_desc: [
		"&a주방 멀티블록&r을 업그레이드하기 위해 제작할 수 있는 몇 가지 추가 아이템이 있습니다!"
		""
		"&a랙&r은 멀티블록에 사용될 도구를 추가합니다."
		""
		"&a과일 바구니&r에 과일을 보관할 수도 있습니다."
	]
	quest.3CFDFFDCDC306A83.title: "주방 추가 기능"
	quest.3D0CD724F9302BDD.quest_desc: [
		"&r느린 용해기 9000&r은 아이템을 녹이는 기본적인 기계입니다. 속도가 놀라울 것입니다."
		""
		"전력을 사용하여 녹은 금속과 합금을 만들 수 있습니다. &6Productive Metalworks&r의 &a주조 탭&r을 옆에 부착하면 &a주조 테이블&r 또는 &a주조 받침대&r에 금속을 부어낼 수도 있습니다."
		""
		"적절한 &a주조&r를 얻으면 이를 사용하여 판, 주괴 등을 만들 수 있습니다!"
		""
		"&e참고&r: 한 번에 한 가지 종류의 유체만 담을 수 있습니다."
	]
	quest.3D0CD724F9302BDD.title: "The &rSlowMelter 9000"
	quest.3D0CE267A8FD95CD.quest_desc: [
		"&2예티&r를 물리치면 두 개의 새로운 금고를 찾을 수 있습니다."
		""
		"황혼의 숲 고리 하층부에서 &b황혼의 숲&r 고리 하층부에서 &a히드라의 굴 금고&r를 찾을 수 있습니다."
		""
		"&e참고&r: &c히드라&r가 임대료를 내지 못해 새로운 세입자들이 그 자리를 차지했습니다."
	]
	quest.3D0CE267A8FD95CD.title: "&f히드라의 둥지"
	quest.3D0DC34C36A173F5.quest_desc: ["&e오라이텍의 &2엑소 슈트&r는 월드를 탐험하는 데 매우 유용한 효과를 제공하지만, 집을 떠나는 위험에 대한 보호는 제공하지 않습니다."]
	quest.3D0DC34C36A173F5.title: "&2엑소 슈트"
	quest.3D220672224EDBD7.quest_desc: ["모든 &6CAD 장치&r에는 &cC&r&2o&r&9l&r&do&r&er&r &b부착물&r 공간이 있으며, 이는 순전히 장식용이지만 확실히 더 멋지게 보이게 할 수 있습니다!"]
	quest.3D220672224EDBD7.quest_subtitle: "CAD를 게이머 CAD로 바꿀 시간입니다."
	quest.3D220672224EDBD7.title: "색상의 세계"
	quest.3D239E5AD486D419.quest_desc: [
		"만약 &c악마&r와 함께 플레이하고 싶다면, 의식을 통해 그들을 소환할 방법이 필요합니다. 이를 위해 &a분필&r이 필요합니다."
		""
		"&a분필&r은 &b의식&r을 위한 문양을 그리는 데 사용됩니다. &e오컬티즘&r을 진행하면서 다양한 색상의 &a분필&r을 발견하게 될 것입니다."
		""
		"&a다른 세계의 재&r와 &a불탄 다른 돌&r을 조합하여 &7불순한 흰색 분필&r을 만들 수 있으며, 이를 &a영혼의 불꽃&r에 던져 &a흰색 분필&r로 정화할 수 있습니다."
		""
		"분필은 땅에서 문지르기 매우 어렵습니다. 잘못 배치된 문양을 제거하려면 &a분필 붓&r을 사용할 수 있습니다."
	]
	quest.3D239E5AD486D419.title: "&f기본 분필"
	quest.3D687BF735E54AE8.title: "블레이즈 처치"
	quest.3D767C3E2F0DE320.quest_desc: [
		"&6양자 컴퓨터&r 멀티블록의 구조는 3x3x3에서 7x7x7 정사각형까지 다양할 수 있습니다."
		""
		"최소한 &6양자 컴퓨터 코어&r를 포함해야 하며, 큐브의 모든 모서리와 면은 &d양자 구조 블록&r이어야 합니다."
		""
		"&d양자 제작 장치&r는 멀티블록 내의 빈 공간을 채우는 데 사용될 수 있지만, 내부에 배치될 때 다른 목적은 수행하지 않습니다."
	]
	quest.3D767C3E2F0DE320.title: "&fThe &6양자 컴퓨터 &f구조"
	quest.3DCD6DC36B31EEF4.quest_desc: [
		"이 &3월드 엔진 업그레이드&r를 설치하면 마침내 &6월드 엔진&r을 마스터하기 시작한 것 같습니다."
		""
		"로비로 돌아가 &d안내의 메아리&r를 찾아 다음 단계를 확인하고 더 많은 &6기록 보관소&r를 잠금 해제하세요!"
	]
	quest.3DCD6DC36B31EEF4.title: "&f망각 잠금 해제&d"
	quest.3DF42A6D832C0492.quest_desc: [
		"&d액션 패드&r는 시대를 초월한 경이로움입니다. 홈, 스폰, 월드 엔진 순간이동과 같은 자주 사용하는 많은 명령을 이 장치를 통해 라우팅할 수 있습니다."
		""
		"[\"You can open the menu by using the item or with the keybind \", { \"keybind\": \"ftbpackcompanion.key.open_action_pad\", \"color\": \"green\" }, \".\"]"
		""
		"다른 순간이동 옵션은 다양한 &d메아리&r를 만나고 팩을 진행하면서 더 많이 나타날 것입니다."
		""
		"장치를 잃어버린 경우, 퀘스트북 비상 아이템 탭에서 교체품을 청구할 수 있습니다."
	]
	quest.3DF42A6D832C0492.title: "액션 패드"
	quest.3E0D5504617365AD.title: "좀먹은 피글린 처치"
	quest.3E1DB27DAB197F6B.quest_desc: [
		"더 많은 &6기록 보관소&r가 잠금 해제됨에 따라 로비를 탐색하여 &d길잡이의 메아리&r를 찾을 때입니다."
		""
		"이 &d메아리&r를 도와 &b월드 엔진&r의 &a크로니톤 유리&r 업그레이드를 잠금 해제하세요."
		""
		"&7&o처음 만나고 &e/echo wayfinder&7를 사용하여 로비 어디에서든 이 메아리로 직접 순간이동할 수 있습니다."
	]
	quest.3E1DB27DAB197F6B.title: "&f만나다 &d길잡이"
	quest.3E2C26828FF869F3.quest_desc: [
		"첫 번째 &b의식&r으로 &b아비아르의 원형 오망성진&r을 사용하여 &7폴리오트 분쇄기&r를 소환할 것입니다."
		""
		"이를 수행하는 가장 쉬운 방법은 가이드북의 &b펜타클&r 탭으로 이동한 다음 &b아비아르의 원형&r을 찾는 것입니다. 오른쪽에는 그것의 렌더링과 함께 하단 오른쪽에 &b눈 아이콘&r이 보일 것입니다."
		""
		"이것을 클릭하면 펜타클을 만드는 데 도움이 되는 &b홀로그램&r을 배치할 수 있습니다!"
		"{@pagebreak}"
		"&b오망성진&r의 배치를 그리고 완성했다면, &2황금 희생 그릇&r에서 8블록 이내의 아무 곳에나 4개의 &a희생 그릇&r을 배치할 수 있습니다."
		""
		"대부분의 &b펜타클&r에는 이것들을 위한 완벽한 장소가 있다는 것을 알 수 있습니다!"
		""
		"다음으로, 필요한 아이템들을 &a제물 그릇&r에 넣고, &a결속의 책: 폴리엇 (결속됨)&r을 중앙의 &6황금 제물 그릇&r에 넣으세요."
		""
		"모든 아이템이 제자리에 놓이면, 황금 제물 그릇을 우클릭하여 의식을 시작할 수 있습니다!"
		"{@pagebreak}"
		"그릇 안의 아이템들은 모두 사라질 때까지 소모되며, 그 후 &7폴리엇 분쇄기&r가 &a황금 제물 그릇&r 옆에 나타날 것입니다."
		""
		"다른 모든 &b분쇄기&r와 마찬가지로, &7폴리엇 분쇄기&r는 아이템을 가루로 갈아내며, 결과물의 2배를 제공합니다."
		""
		"분쇄기는 다음 색상의 분필을 만드는 데도 필요합니다!"
	]
	quest.3E2C26828FF869F3.title: "&f당신의 첫 의식"
	quest.3E3A7F72F835E497.quest_desc: [
		"다양한 음식을 탐험하도록 장려하기 위해, 이 팩의 음식은 더 많이 시도할수록 &6추가 체력&r을 부여합니다."
		""
		"먹은 음식과 다음 요리 임계값을 추적하려면 언제든지 &a음식 책&r을 볼 수 있습니다."
	]
	quest.3E3A7F72F835E497.title: "&f음식 다양성"
	quest.3E50C85AFC627BDC.quest_desc: [
		"오리테크의 \\&#fcd205프로메튬&r 도구는 강력한 부서지지 않는 도구입니다."
		""
		"이 \\&#fcd205곡괭이&r는 일반적인 단일 블록 모드에 섬세한 손길이 내장되어 있으며, 3x3 영역을 채굴하는 영역 모드도 있습니다."
		""
		"이 \\&#fcd205전투 도끼&r는 즉시 나무를 부수고 많은 피해를 줍니다."
		""
		"&e참고&r: 이것들을 제작하려면 &a기계 블록&r &6월드 엔진 업그레이드&r가 필요합니다."
	]
	quest.3E50C85AFC627BDC.title: "\\&#fcd205프로메튬 도구"
	quest.3E72FB579DF147FE.quest_desc: [
		"이제 &a진행의 최상단&r에서, &6&l트릭: 흑단 또는 상아&r&r을 &d엔드&r에서 실행하여 &6상아 또는 흑단 물질&r을 얻을 수 있습니다."
		""
		"그것들로 &6모드에서 제작 가능한 최고의 CAD 장치&r에 접근할 수 있으며, 능력치는 약간씩 다를 수 있으므로 선호하는 것을 선택하세요."
		""
		"► 또한 지적할 만한 좋은 점은 이 &6트릭&r을 사용하면 이전의 모든 변환도 할 수 있다는 것입니다. &d엔드 차원&r에서 만들려고 하지 마세요."
	]
	quest.3E72FB579DF147FE.quest_subtitle: "흑단과 상아 CAD!"
	quest.3E72FB579DF147FE.title: "서바이벌에서 접근 가능한 최고의 CAD"
	quest.3E7E07DB49639EA5.quest_desc: [
		"인퓨저와 약간의 &c레드스톤&r으로, 기본 &a합금&r과 &a회로&r를 만드는 것으로 시작할 수 있습니다! 더 고급 기계를 위해 함께 결합하여 &c고급 제어 회로&r를 만들 수도 있습니다."
		""
		"이것들은 &e메카니즘&r의 대부분의 아이템을 만드는 데 사용될 것입니다."
	]
	quest.3E89531AEC1CF0DA.quest_desc: ["필요한 &a기계 블록&r을 모두 제작한 후에는 &d군수 담당관&r에게 돌아가 &6월드 엔진&r에서 어디에 배치해야 하는지 배워야 합니다."]
	quest.3EB56937CCDFCB2A.quest_desc: [
		"&b주조&r는 도구, 무기 및 갑옷을 위한 금속을 주조하거나, 주괴 및 기타 형태로 만드는 데 사용됩니다. 비슷한 모양의 아이템에 &3녹은 강철&r을 부어 만듭니다."
		""
		"&aController&r에서 어떤 유체가 흘러나올지 선택한 다음, 아래에 &2Casting Basin&r을 놓고 배수구를 클릭하면 재료를 얻을 수 있습니다."
		""
		"&7&o이 과정은 레드스톤으로 자동화될 수 있습니다."
	]
	quest.3EB56937CCDFCB2A.title: "주조"
	quest.3EF3DBD1F6ADEAEC.quest_subtitle: "언어더, 차원 이동 전문가"
	quest.3F5480E01ABA887B.quest_desc: [
		"&aAutocrafter&r는 최대 9개의 구성된 레시피 &aPatterns&r와 4개의 &aSpeed Upgrades&r를 수용합니다."
		""
		"&a자동 제작기&r가 기계나 상자를 향하고 있다면, 해당 블록으로 제작법 아이템을 밀어 넣으려고 시도할 것입니다. 그렇지 않으면 제작법을 수행하려고 시도할 것입니다."
		""
		"&7&o자동 제작기는 바라보고 있는 블록을 향해 설치됩니다."
	]
	quest.3F5480E01ABA887B.title: "자동 제작"
	quest.3F75F781DE5123F4.quest_desc: [
		"&6오리텍 원자로&r는 대량의 에너지를 생성하는 좋은 방법입니다!"
		""
		"원자로는 여러 부품으로 구성된 크고 사용자 지정 가능한 멀티블록이며, &6핵 원자로 제어판&r이 주요 인터페이스 블록입니다."
		""
		"이 인터페이스는 원자로의 현재 상태와 부품의 온도 및 통계를 보여줍니다. 또한 내부의 첫 번째 레이어만 표시합니다."
		""
		"&6원자로&r는 우라늄 또는 플루토늄 펠릿을 소비하여 에너지를 생성하며, 생성되는 에너지 양은 &a원자로 봉&r과 봉 옆의 &b중성자 반사기&r의 수에 따라 결정됩니다."
		""
		"&c원자로를 충분히 냉각시키는 것이 중요합니다!&r 원자로는 큰 구멍을 만드는 것을 좋아합니다."
	]
	quest.3F81256B4E65076F.quest_desc: [
		"나무의 마법적인 속성은 세상에 남겨진 마법의 정수를 끌어들일 수 있습니다."
		""
		"&a주입실&r을 제작하고 &a청금석&r을 &d소스 보석&r으로 변환하세요."
	]
	quest.3F81256B4E65076F.title: "&f마법 정수 주입"
	quest.3F8D9684ADAC01E8.title: "촉매제 확인 3"
	quest.3FA9D6A475E4D1C6.quest_desc: [
		"&d길잡이&r는 이 세계를 여행하는 데 필요한 모든 것을 알고 있습니다."
		""
		"그는 &3심층암&r 고리로 둘러싸인 &3보관소&r 안에 숨겨진 비밀의 힘에 대해 언급했습니다."
		""
		"&e참고&r: &a탐험가의 나침반&r을 만들어 &3보관소&r를 찾는 데 도움이 될 수 있습니다!"
		""
		"이 &3보관소&r의 퍼즐을 풀고 길을 찾으면 &d크로니톤 별&r을 손쉽게 얻을 수 있을 것입니다."
	]
	quest.3FA9D6A475E4D1C6.title: "&f&2크로니톤 별 찾기"
	quest.3FD6F10BE6F06FFF.quest_desc: ["각 &d조립기 매트릭스 제작 코어&r는 최대 8개의 제작 작업을 동시에 실행할 수 있습니다."]
	quest.3FD6F10BE6F06FFF.title: "&d조립기 매트릭스 제작 코어"
	quest.3FE863C60B2D2719.quest_desc: [
		"&d드래코닉 에볼루션&r의 &6마법 부여 제거기&r는 경험치와 약간의 내구도 손상을 대가로 아이템에서 마법 부여를 제거하는 데 사용될 수 있습니다."
		""
		"일반 마법 부여 설정과 유사하게, &d마법 해제기&r 주변에 책장을 배치하여 피해를 줄일 수 있습니다."
	]
	quest.3FE99AE10B0737BB.quest_desc: [
		"&a기본 상자&r는 단일 아이템 유형을 많이 저장합니다. 또한 &a돌 생성기&r 업그레이드가 설치되어 있으면 조약돌을 생성할 수도 있습니다."
		""
		"\\&#5EFCB6Basic Fluid Tank&r는 단일 종류의 유체를 32개의 양동이만큼 저장할 수 있으며, 양동이처럼 사용할 수도 있습니다."
		""
		"손에 들고 있을 때 쉬프트 키를 누른 상태에서 마우스 휠을 스크롤하면 &a양동이&r 모드로 변경할 수 있습니다. 이렇게 하면 물이나 용암과 같은 유체를 여러 양동이만큼 퍼낼 수 있습니다."
	]
	quest.3FE99AE10B0737BB.title: "\\&#5EFCB6메카니즘 저장 옵션"
	quest.400EF0F598308431.quest_desc: [
		"이제 &7라텍스&r가 있으니 &a라텍스 처리 장치&r를 만들 수 있습니다."
		""
		"전원이 공급되면 이 기계는 유체 라텍스를 받아 건조 고무로 변환하며, 이를 제련하여 &a플라스틱&r을 얻을 수 있습니다."
		""
		"이를 위해 다른 모드의 생성기를 사용할 수 있습니다."
	]
	quest.400EF0F598308431.title: "&fProcessing &7Latex &fInto &aPlastic"
	quest.400FD8861E907DDA.quest_desc: [
		"&a디스크 인터페이스&r는 저장소 네트워크와 제공된 &b저장 디스크&r 간에 아이템을 전송합니다."
		""
		"&b저장 디스크&r는 업그레이드된 부품과 기존 디스크를 제작 칸에서 결합하여 다음 등급으로 직접 업그레이드할 수 있으며, 이 과정에서 기존 디스크를 반환하면서 모든 아이템을 유지합니다."
		""
		"&e케이블 등급&a과 &r디스크 인터페이스&r는 아이템 전송 속도를 업그레이드하고 더 많은 필터 슬롯을 제공합니다."
	]
	quest.400FD8861E907DDA.title: "저장된 아이템 상호작용"
	quest.4032C8BD158D1776.quest_desc: [
		"&d아르스 누보&r의 &6워프 스크롤&r은 두 가지 다른 용도로 사용됩니다."
		""
		"쉬프트 + 우클릭하면 스크롤에 향후 사용을 위해 위치 데이터가 저장됩니다. 스크롤을 사용하여 해당 지점으로 순간이동할 수 있으며, 이 과정에서 스크롤이 소모됩니다."
		""
		"대신, &a소스톤&r으로 차원문 틀을 만들고 스크롤을 던져 일방향 차원문을 만들 수 있습니다!"
		""
		"&e참고&r: &a워프 스크롤&r을 제작하려면 &b황혼의 숲&r &6월드 엔진 업그레이드&r가 필요합니다."
		"{@pagebreak}"
		"&d안정화된 워프 스크롤&r은 위치를 저장하는 데에도 사용할 수 있으며, 블록에 사용하면 임시 차원문이 열립니다."
	]
	quest.4032C8BD158D1776.title: "워프 스크롤"
	quest.4080C053E58A8B55.quest_desc: [
		"&6바블리 하트 캐니스터의&r 무기는 삽입된 각 &b하트 캐니스터&r마다 기본 피해 +1을 추가하며, 최대 +96의 기본 피해를 줄 수 있습니다."
		""
		"&e참고&r: 이를 제작하려면 &d정령&r과 &a기계 블록&r &6월드 엔진 업그레이드&r가 필요합니다."
		""
		"&7&o하트는 인터페이스를 통해 삽입해야 합니다."
	]
	quest.4080C053E58A8B55.title: "&a생명력 무기"
	quest.4094F70F627F492C.quest_desc: ["&6월드 엔진&r은 실제로 \\&z블랙홀&r을 업그레이드로 사용할 수 있지만, 이를 위한 컨테이너가 필요합니다."]
	quest.4094F70F627F492C.quest_subtitle: "주요 월드 엔진 업그레이드"
	quest.4094F70F627F492C.title: "&r공허의 힘"
	quest.40DCA09032568A0F.quest_desc: [
		"&a중계기&r를 사용하여 네트워크의 새 분기를 만들거나 저장소 네트워크의 일부를 켜거나 끌 수 있습니다."
		""
		"&a감지기&r는 네트워크에 있는 자원의 양에 따라 구성 가능한 레드스톤 신호를 방출합니다."
		""
		"&a저장소 모니터&r는 저장소 네트워크에 저장된 특정 자원의 양을 표시하도록 구성할 수 있습니다. 또한 클릭하여 이 모니터에서 직접 아이템을 가져올 수도 있습니다."
	]
	quest.40DCA09032568A0F.title: "기타 네트워크 장치"
	quest.40DDD27BA5E191FA.quest_desc: [
		"이 나침반은 &3금고&3의 위치를 가리킵니다."
		""
		"&7&o금고에서 256블록 이내에 있을 때 나침반을 쉬프트 + 우클릭하면 입구로 즉시 순간이동할 수 있습니다!&r"
	]
	quest.40DDD27BA5E191FA.title: "&f&3보관소 찾기"
	quest.4101E75F69C9909F.quest_desc: [
		"&d양자 아이템 오케스트레이션&r (&dQIO&r) 시스템은 &e메카니즘&r의 무선, 전력 불필요, 확장 가능한 디지털 저장 솔루션입니다."
		""
		"&dQIO&r는 순간이동기와 기계 보안과 유사한 주파수로 작동하므로, &2QIO 드라이브 배열&r의 주파수에 연결된 &aQIO 대시보드&r에서 아이템에 접근할 수 있습니다."
		""
		"&e응용 메카니즘&r은 &aME 시스템&r이 &a대시보드&r를 &2AE2 저장소 버스&r에 놓고 원하는 주파수를 설정하여 &dQIO&r 저장소에 접근할 수 있도록 합니다."
	]
	quest.4111541EAEF0E4FC.quest_desc: [
		"&d양자&r 갑옷은 네더라이트 등급의 보호 기능을 제공하며, 키 바인딩을 통해 다양한 &b모듈&r로 업그레이드할 수 있습니다."
		""
		"&e양자 갑옷 설정 열기&r 키는 기본적으로 바인딩되어 있지 않습니다."
	]
	quest.4111541EAEF0E4FC.title: "&d양자 &f갑옷"
	quest.4119A43052DB5E3E.quest_desc: [
		"&e유물&r 모드는 25개의 새롭고 독특한 아이템을 추가하며, 각 아이템은 레벨을 올리고 사용하려는 사람들에게 고유한 능력을 부여할 수 있습니다!"
		""
		"이것들은 전리품에서 찾을 수 있지만 상점에서 구매할 수도 있습니다!"
	]
	quest.4119A43052DB5E3E.title: "유물"
	quest.4126A470077923D2.quest_desc: [
		"&a골판지 상자&r는 상자, 스포너 등과 같은 블록 개체를 이동하는 데 사용할 수 있는 매우 유용한 아이템입니다!"
		""
		"블록에 상자를 사용하면 블록이 덮여 아이템으로 부수고 집을 수 있습니다. 이 아이템을 내려놓고 쉬프트 + 우클릭하면 상자가 제거됩니다."
	]
	quest.417573A657CAED05.quest_desc: [
		"&c네더&r 고리에서 재료를 모은 후에는 다음 등급의 점액으로 업그레이드할 수 있습니다."
		""
		"&c블레이즈블룸 점액&r은 &e금 블록&r을 변환하여 &6블레이즈골드&r라는 새로운 등급의 금속을 만들 수 있게 해줍니다. 마치 철로 했던 것처럼요."
		""
		"활성화하려면 네더 사마귀 또는 블레이즈 가루를 먹여야 합니다."
		""
		"또한 &a페리코어 원석&r을 생성하는 기능도 유지하고 있으므로, 철을 위해 다른 프리모겔 점액을 만들 필요가 없습니다. 뿐만 아니라 프리모겔보다 철을 더 빠르게 변환합니다!"
	]
	quest.417573A657CAED05.title: "&f&c블레이즈골드 제작"
	quest.4194852B70E0ECEB.quest_desc: [
		"&d안내의 메아리&r가 당신의 첫 번째 집을 만들도록 인도했습니다."
		""
		"&6기록 보관소&r에서 나와 거대한 차원문을 통해 들어가 이 세계에 당신의 자리를 만드세요!"
	]
	quest.4194852B70E0ECEB.title: "&f돌 세계의 시작"
	quest.4194F3C176E50B7B.quest_desc: [
		"&d구원의 경계&r:"
		"&7약하게 만드는 타격, 쓰러뜨리는 타격"
		""
		"&d세계의 무게&r:"
		"&7삶의 무작위 타격, 모든 끝이 다른 것의 몰락을 돕습니다"
		""
		"&d침식의 홀⟧&r:"
		"&7현실이 된 투쟁, 모든 강타가 영혼을 점점 더 질식시킵니다"
	]
	quest.4194F3C176E50B7B.title: "&6악성 무기"
	quest.41C439295D5558C2.quest_desc: [
		"칼날에 영혼석이 박혀 있어, &a조잡한 낫&r은 생물을 죽일 때 몸과 영혼 모두를 찢어 영혼을 형성하고 학살자에게 끌어들일 수 있습니다."
		""
		"&7낫은 또한 고유한 마법 부여를 받을 수 있으며, 이는 더 많은 영혼을 수집하거나 약간의 공중 부양을 제공하는 등 사용을 크게 개선하거나 변경할 수 있습니다."
		"{@pagebreak}"
		"이 영혼들은 &a영혼 제단&r에서 사용할 수 있습니다. 이 제단은 영혼 측면과 다른 주입 자원을 초점 아이템으로 집중시키는 장소입니다."
		""
		"제단 자체는 이 초점을 유지하고 사용된 영혼을 고정하는 역할을 하며, 다른 초점 재료는 제단에서 4블록 이내의 &e받침대&r에 배치해야 합니다. 모든 재료와 영혼이 제자리에 놓이면 제작이 자동으로 시작됩니다."
		""
		"제작 과정은 느릴 수 있지만, 이 범위 내에 배치된 최대 4개의 &e룬우드 오벨리스크&r는 제작 속도를 높여줍니다."
	]
	quest.41C439295D5558C2.title: "영혼 수확"
	quest.41ED404574094D5B.quest_desc: [
		"다음 단계에서는 &d이동 장치&r를 제작하여 &a정지 장치&r 바로 위에 직접 연결해야 합니다. 준비가 되면 경기장으로 가서 &d이동 장치&r를 &a받침대&r에 우클릭하세요."
		""
		"닭이 당신의 함정에 제대로 빠지기를 바랍니다."
		""
		"&r강력한 엔더 닭&r을 착유하면 &r녹은 혼돈&r을 얻을 수 있으며, 이를 사용하여 &6작은 혼돈 조각&r을 만들 수 있습니다."
	]
	quest.41ED404574094D5B.title: "착유... 닭?"
	quest.41F048EAE6949163.quest_desc: [
		"&6아르스&r에는 마법 장비에 대한 몇 가지 옵션이 있습니다."
		""
		"이 마법 세트를 만들려면 시작하기 위해 &a마법 꽃 씨앗&r을 &d비전 숲&r의 상자에서 찾아야 합니다. 이것은 &a마법 꽃&r으로 자라며, 모든 종류의 장비와 심지어 &d마법 두루마리&r를 제작하는 데 사용할 수 있습니다!"
		""
		"장비는 &a개조 테이블&r에서 &d실&r 형태로 업그레이드를 설치하도록 개조할 수 있습니다."
		"{@pagebreak}"
		"실은 제작한 다음 &3개조 테이블&r을 사용하여 갑옷에 새길 수 있습니다. 사용하려면 개조하려는 갑옷을 테이블 위의 받침대에 놓으십시오. 그러면 테이블의 태블릿에 사용 가능한 실 슬롯이 표시되며, 태블릿의 실을 마우스 오른쪽 버튼으로 클릭하여 갑옷에 추가할 수 있습니다. 이제 갑옷을 제거하기만 하면 됩니다!"
		""
		"실타래를 제거하려면 갑옷을 테이블에 놓고 빈 손으로 디스플레이와 상호 작용하십시오."
		""
		"더 많은 실 슬롯을 위해 마법 장비의 등급을 업그레이드하려면 &d마법 부여 장치&r를 사용할 수 있습니다."
	]
	quest.41F048EAE6949163.title: "&d아르스 갑옷"
	quest.420239DCDE0CB837.quest_subtitle: "AE2"
	quest.420239DCDE0CB837.title: "크리에이티브 에너지 셀"
	quest.427682661459BB4F.quest_desc: [
		"&c퀀타&r는 마법 부여 굴림에 무작위성을 더하며, 최대 혼돈 상태에서는 +100% 또는 -100%의 힘을 얻게 됩니다."
		""
		"&e안정화&r는 부정적인 효과를 상쇄하여 이점만 얻고 단점은 얻지 못하게 합니다."
	]
	quest.428E671C1444C97B.quest_subtitle: "발굴자, 고고학자"
	quest.42CE9840EED6B540.quest_desc: [
		"우리의 새로운 친구는 &e부서진 엔드스톤&r을 쉽게 만들 수 있도록 도와줄 것입니다. 하지만 계속하기 전에 &b의식&r과 &b펜타클&r에 대해 더 이해하는 것이 중요합니다!"
		""
		"간단히 말해, &b펜타클&r은 &a황금 희생 그릇&r 주위에 배치된 글리프, 그릇, 안정 장치의 형성입니다."
		""
		"&b의식&r은 아이템을 바쳐 &9다른 세계&r에서 &b정령&r을 소환하는 행위입니다."
		""
		"&b펜타클&r에는 4가지 종류가 있으며, 진행함에 따라 각 펜타클을 업그레이드할 수 있습니다."
		""
		"이는 4가지 유형의 &b펜타클&r을 모두 설정하기 위해 19x19 영역 4개만 있으면 된다는 것을 의미합니다!"
		"{@pagebreak}"
		"의식은 주로 &a결속&r, &a빙의&r, &a가족&r, &a소환&r의 네 가지 범주로 나뉩니다."
		""
		"당신의 &a아비아의 원&r &b펜타클&r은 &a소환 펜타클&r로 간주됩니다."
		""
		"다음 업그레이드는 &c오픽스의 부름&r이며, 이를 통해 &c지니&r를 소환할 수 있습니다."
		"{@pagebreak}"
		"다음 단계는 더 높은 등급의 펜타클이 필요하므로 새로운 색상의 &a분필&r을 구하는 것입니다."
		""
		"이 지식을 바탕으로 오컬티즘 모드를 정복할 준비가 되셨을 것입니다!"
	]
	quest.42CE9840EED6B540.title: "&f&b의식 및 펜타클에 대한 더 많은 정보"
	quest.42F76C9425677DB3.quest_desc: [
		"&b드라이브&r는 &dQIO 시스템&r의 저장 매체이며, 각 &2드라이브 배열&r에 최대 10개까지 장착할 수 있습니다. 주파수당 드라이브 또는 배열의 수에는 제한이 없습니다."
		""
		"각 등급은 저장할 수 있는 아이템의 종류와 저장할 수 있는 총 아이템 수를 모두 증가시킵니다."
	]
	quest.42F76C9425677DB3.title: "&dQIO 드라이브"
	quest.4348C9D795E92FCE.quest_desc: [
		"이 &a휴대용 에너지 저장 장치&r는 최대 100만 RF를 저장할 수 있으며 파손 시에도 에너지를 유지합니다."
		""
		"&a휴대용 에너지 저장 장치&r는 녹색 포트를 통해 모든 방향에서 에너지를 받아들이며, 단일 빨간색 포트를 통해서만 에너지를 출력할 수 있습니다. 레드스톤 신호는 모든 에너지 출력을 비활성화합니다."
	]
	quest.437F2C378CD6FE51.quest_desc: [
		"&a주입기&r는 &a탄소&r를 사용하여 철을 &2강철&r로 변환하는 데에도 사용할 수 있습니다!"
		""
		"석탄이나 목탄을 주입 슬롯에 넣어 탄소로 변환할 수 있으며, 목탄은 두 배의 양을 제공합니다. 기계에 넣은 후, 철을 한 번 통과시키면 &a강화된 철&r을 얻을 수 있습니다. 이를 다시 탄소로 주입하면 &2강철 가루&r가 되며, 이를 제련하여 &2강철 주괴&r를 만들 수 있습니다!"
		""
		"&2강철&r은 높은 내구성 때문에 도구를 만드는 데 훌륭한 재료이며, 모드의 기본 파이프를 만드는 데도 필요합니다."
	]
	quest.437F2C378CD6FE51.title: "강철 만들기"
	quest.43919D8A9EB5C627.quest_desc: [
		"&bIndustrial Foregoing&r의 &2수경 재배 침대&r는 작물이 자라는 가속 토양 역할을 합니다."
		""
		"작물을 자동으로 수확할 수 있으며, 업그레이드를 사용하고 위더의 &b에테르 가스&r를 사용하여 속도를 향상시킬 수도 있습니다."
		""
		"또한 &d시뮬레이션 수경 재배 침대&r를 사용하여 단일 작물의 성장을 여러 침대로 시뮬레이션할 수 있습니다!"
	]
	quest.43919D8A9EB5C627.title: "수경 재배 침대"
	quest.43949500F6A0B46A.quest_desc: [
		"&d제작 CPU 멀티블록&r은 &eAE2&r 내 자동 제작의 핵심입니다."
		""
		"이 멀티블록은 빈 블록 없이 직사각형 프리즘 형태로 구축되어야 하며, 최소 1개 이상의 &a제작 저장 장치&r를 포함해야 합니다. 선택 사항이지만 &a제작 보조 프로세서&r도 함께 사용하는 것이 좋습니다."
		"{@pagebreak}"
		"&a제작 저장 장치&r 블록은 제작에 필요한 재료를 저장하는 데 사용됩니다. 저장 용량은 한 번에 자동 제작을 요청할 수 있는 아이템의 수를 결정합니다."
		""
		"예를 들어, 1k개의 제작대를 제작하려면 1k개 모두의 재료를 저장할 충분한 제작 저장 장치가 필요합니다."
		"{@pagebreak}"
		"&d제작 보조 프로세서&r는 선택 사항이지만, 보조 프로세서가 추가될 때마다 더 많은 하위 작업을 한 번에 큐에 넣을 수 있고 복잡한 자동 제작 작업을 다소 빠르게 처리할 수 있으므로 권장됩니다."
		""
		"예를 들어, 1k개의 제작대를 제작하려면 통나무를 판자로 바꾸고, 판자를 테이블로 바꿔야 할 수 있습니다. 여러 개의 보조 프로세서가 있으면 멀티블록이 통나무를 판자로 바꾸는 동시에 판자를 테이블로 바꿀 수 있습니다. 그렇지 않으면 모든 통나무를 완료될 때까지 판자로 바꾸고, 그런 다음 모든 판자를 테이블로 한 번에 바꿀 것입니다."
		"{@pagebreak}"
		"한 가지 중요한 점은 각 &d제작 CPU 멀티블록&r은 한 번에 한 가지 유형의 작업만 처리할 수 있다는 것입니다. 예를 들어, 1k 제작 테이블과 1k 철괴 자동 제련을 동시에 만들고 싶다면 두 개의 별도 CPU 멀티블록이 필요합니다."
		""
		"더 자세한 정보는 언제든지 AE2 가이드를 참조할 수 있습니다."
	]
	quest.43949500F6A0B46A.title: "&f자동 크래프팅 멀티블록&d"
	quest.43A632369D0E2CE0.title: "가이드 완료 4.1"
	quest.43B92A87F280211F.title: "황혼 서쪽"
	quest.4402F6855A75B7F6.quest_desc: ["이 던전은 &2황혼 숲&r 고리 아래쪽에서 생성됩니다."]
	quest.4402F6855A75B7F6.title: "&2트롤 동굴 찾기"
	quest.4426687CCCDD759A.title: "마법사 확인 2"
	quest.4445906BD04FC37D.quest_desc: [
		"새로운 &3발굴&r 기술을 사용하면 브러시할 수 있는 다양한 블록에서 더 나은 재료를 쉽게 찾을 수 있습니다."
		""
		"&a먼지&r를 브러시하여 &3발굴&r할 수 있는 것을 확인해 보세요."
	]
	quest.4445906BD04FC37D.title: "&f발굴 전문가 되기"
	quest.44599533471DFDCB.quest_desc: [
		"&d정지실&r은 그 위에 있는 몹들을 무력화시키지만, 동시에 몹들을 치유하고 살려두려고 하는 고급 기계입니다."
		""
		"이것은 주로 &d위더&r를 가두어 &b에테르 가스&r를 추출하거나, &3감시자&r를 가두어 &3영혼&r을 추출하는 데 사용됩니다."
	]
	quest.44599533471DFDCB.title: "&f정지실&d"
	quest.4468BC270F100F27.quest_desc: [
		"&eEnderIO&r는 기계, 인벤토리 및 자동화 도구, 그리고 더 많은 기능을 갖춘 기술 모드입니다!"
		""
		"시작하려면 &a무한의 조각&r을 얻어야 합니다."
		""
		"이 팩에서는 &a무한의 조각&r을 얻기 위해 &a자갈&r을 불에 던질 수 있습니다."
	]
	quest.4468BC270F100F27.title: "&aEnderIO"
	quest.44842AC8247EFDF4.quest_subtitle: "발굴가, 지질학자"
	quest.4498E3F4B2DC24FC.quest_desc: [
		"궁극의 &eApotheosis&r 장비를 얻기 위해 몬스터를 사냥하고 &b보석&r을 찾아 세계를 탐험해야 합니다!"
		""
		"&b보석&r은 &b능력치&r 아이템에 적용하면 강력한 보너스를 제공하는 수정입니다."
		"{@pagebreak}"
		"아이템에 &b보석&r을 적용하려면, &a대장장이 작업대&r에서 아이템과 결합해야 합니다. 이를 위해서는 아이템에 열린 &a보석 홈&r이 있어야 합니다."
		""
		"보석은 아이템 유형에 따라 다른 보너스를 제공하며, &a보석 절단 작업대&r에서 업그레이드할 수 있습니다."
		""
		"&c고유 보석&r은 아이템당 한 번만 장착할 수 있지만, 대부분의 다른 보석은 중첩 보너스를 위해 여러 번 장착할 수 있습니다."
		""
		"몹과 보스를 처치하여 얻을 수 있는 다양한 &eApotheosis&r &b보석&r이 있습니다."
		"{@pagebreak}"
		"&b보석&r은 모루로 부수어 &a보석 가루&r를 만들 수도 있습니다."
		""
		"&a보석 가루&r는 다양한 용도로 사용할 수 있지만, 가장 먼저 만들 것은 &a구출 작업대&r입니다!"
	]
	quest.4498E3F4B2DC24FC.title: "&a보석"
	quest.44A61436D2FE34E9.quest_subtitle: "철 닭"
	quest.44A61436D2FE34E9.title: "좋은 시작점"
	quest.44B2831C7225AB4B.quest_desc: ["&7&oJEI에서 \"refinedtypes FE\"를 검색하여 전력을 추출하세요."]
	quest.44B2831C7225AB4B.title: "에너지 저장 부품"
	quest.44C341DE3BCD64CC.quest_desc: [
		"이 업그레이드된 &d마법 부여 도서관&r은 최대 레벨 31까지 마법 부여 값을 저장할 수 있습니다."
		""
		"&7&o실제 마법 부여된 책은 일반 팩 제한에 따라 여전히 제한된다는 점에 유의하세요.&r"
	]
	quest.44C341DE3BCD64CC.title: "\\&z알렉산드리아 도서관"
	quest.44D9A7C563B087C0.quest_subtitle: "발굴"
	quest.450A1BAD728F594B.quest_desc: [
		"기지에 &d양자 다리&r 멀티블록을 만든 후, 무선 터미널에 설치할 &6양자 다리 카드&r를 제작하고 연결할 수 있습니다! 이 카드를 사용하면 어떤 차원에서든 무선으로 네트워크에 액세스할 수 있습니다."
		""
		"두 개를 연결하려면 &d양자 얽힘 특이점&r 쌍을 만들어 하나는 &6양자 네트워크 다리&r에, 다른 하나는 카드와 함께 &d무선 터미널&r에 넣어야 합니다."
	]
	quest.450A1BAD728F594B.title: "&d무한 무선 액세스"
	quest.455930CEC0C90C0C.quest_desc: [
		"&eClavis&r 모드는 잠긴 상자와의 특별한 상호작용을 추가합니다."
		""
		"상자는 이제 따기 미니게임으로 잠겨 있습니다! 바늘을 잠금 장치에 맞추고 왼쪽 클릭하여 잠금을 해제하세요."
		""
		"놓치는 횟수가 적고 도전을 더 빨리 완료할수록 더 좋은 전리품을 얻을 수 있습니다!"
		""
		"&e참고&r: 실패하더라도 상자는 여전히 보상이 줄어든 채로 잠금 해제됩니다. &a자물쇠 따개&r를 사용하여 미니게임을 완전히 건너뛸 수도 있습니다."
	]
	quest.455930CEC0C90C0C.title: "\\&z전리품 상자"
	quest.456030ECDFA9CE3B.quest_desc: [
		"&b반응로 열 흡수기&r는 모든 인접한 구성 요소에서 고정된 양의 열을 제거하여 냉각이 필요한 구성 요소로 둘러싸여 있을 때 더 효율적입니다."
		""
		"얼음(또는 파란색/포장된 얼음) 형태의 냉각수 공급이 지속적으로 필요하며, &b흡수기&r 스택 위의 &b냉각수 포트&r를 통해 삽입할 수 있습니다."
		""
		"사용되는 냉각수의 양은 고정되어 있으며, 더 많은 면이 냉각된다고 해서 증가하지 않습니다. 각 틱마다 이웃마다 16개의 열이 제거됩니다."
		""
		"&b반응로 냉각수 포트&r는 &d반응로&r의 외부 천장에 배치되어야 하며, 그 아래에는 &b열 흡수기&r가 있어야 합니다."
	]
	quest.456030ECDFA9CE3B.title: "&b반응로 열 흡수기"
	quest.456904808D93A9E3.quest_desc: [
		"이 나침반은 &3보관소&3의 위치를 가리킵니다."
		""
		"&7&o보관소에서 256블록 이내에 있을 때 나침반을 쉬프트 + 우클릭하면 입구로 즉시 순간이동할 수 있습니다!&r"
	]
	quest.456904808D93A9E3.title: "&f보관소 찾기&3"
	quest.456B067C9CC123AD.quest_desc: ["&c히터&r를 제작한 후에는 &d제작기&r로 돌아가 &6월드 엔진&r과 함께 사용하는 방법을 배워야 합니다."]
	quest.45A3E686E32AB95D.quest_desc: ["&b황혼의 숲&r 고리 안에서 발견되는 &a리치&r의 보관소는 찾아야 할 다섯 개의 황혼 보스 중 첫 번째입니다."]
	quest.45A3E686E32AB95D.title: "&f리치의 소굴&f"
	quest.45B2C8BD2ACBA46D.quest_desc: [
		"&d원자로&r는 직사각형 벽으로 만들어야 하며, 프레임은 &a원자로 벽&r 블록으로 만들어야 합니다. 원자로의 최대 크기는 방향당 64블록입니다. 내부는 수직(y) 축에서 동일해야 합니다."
		""
		"벽 어딘가에 &6핵 원자로 제어판&r과 사용하려는 &c에너지 포트&r가 필요합니다."
		""
		"작은 3x3x3 반응로를 만드는 것도 가능하지만, 제대로 냉각시키려면 5x5x5로 시작하는 것이 좋습니다."
		""
		"&d원자로&r는 어느 정도의 열 축적을 허용하지만, 제대로 냉각된 설계는 열 누출을 발생시키지 않아야 합니다."
		"{@pagebreak}"
		"원하는 대로 &d원자로&r를 설계할 수 있습니다. 일반적으로 &a듀얼/쿼드 로드&r는 연료를 더 효율적으로 사용하여 펠릿당 총 RF를 더 많이 생성하지만, 냉각하기가 훨씬 더 어렵습니다."
		""
		"활성 냉각은 &b열 흡수기&r를 사용하거나, 수동 냉각은 &c열 배출구&r만으로 사용할 수 있습니다."
		""
		"만약 &a연료봉&r이 장시간 2000°C 이상의 온도를 유지하면 과열되어 &c핵 멜트다운&r을 유발할 것입니다!"
		""
		"해당 온도에 도달하기 전에 경고 사이렌이 울립니다. &d원자로&r의 크기와 &a연료봉&r의 수에 따라 멜트다운은 더 크거나 작은 폭발을 초래할 것입니다."
	]
	quest.45B2C8BD2ACBA46D.title: "원자로 설계"
	quest.45BA73F16B7AE681.quest_desc: [
		"더 깊은 심층암에서 발견되는 &3고대 도시&r에는 마침내 활성화될 수 있는 거대한 차원문이 있으며, 이를 통해 내부의 보스를 처치할 수 있습니다."
		""
		"차원문에 들어가면 실명 효과를 받게 되며, 이는 &3금고&r 안에서 강화된 적을 처치하여 얻는 몹 영혼으로 &d영혼 상자&r를 채워야만 치료할 수 있습니다."
		""
		"&c충전하려면 &d영혼 상자&c를 보조 손에 들어야 합니다!"
		""
		"&d영혼 상자&r를 채우면 시작 방에 있는 엘리베이터를 타고 보스 전투를 시작할 수 있습니다."
		""
		"&e참고&r: &6사신&r 마법 부여로 몹을 처치하면 상자가 더 빨리 채워집니다(레벨당 +1)."
	]
	quest.45BA73F16B7AE681.title: "&3고대의 차원문"
	quest.45CB3F325010A5AD.quest_desc: [
		"죽었을 때 경험치를 잃지 않도록 보관할 장소가 필요하신가요?"
		""
		"&6Just Dire Things&r의 &a경험치 보유기&r는 사용하기 쉽고, 설정 가능한 범위 내에서 주변의 경험치를 수집하는 데에도 사용할 수 있습니다."
		""
		"&6Cognition&r의 &a경험치 오벨리스크&r도 같은 방식으로 작동합니다!"
		""
		"&7신비로운 숲&r에 갈 때 죽지 않을 것이라고 생각하더라도, 안전을 위해 경험치를 저장하는 것이 좋습니다."
	]
	quest.45CB4500F3CEF539.quest_desc: [
		"&bIndustrial Foregoing&r의 &a재료 석재 공장&r은 시간이 지남에 따라 다양한 종류의 돌 블록을 무한정 생성할 수 있습니다."
		""
		"팩토리에서 만들 수 있는 다양한 아이템을 보려면 JEI에서 팩토리를 선택한 후 &bU&r 키를 누르세요."
	]
	quest.45CB4500F3CEF539.title: "&f석재 공장"
	quest.45E7D62C229F898C.quest_desc: [
		"&a제작 그리드&r를 사용하면 모든 연결된 인벤토리에 접근하여 중앙 한 곳에서 제작할 수 있습니다."
		""
		"다른 패널과 마찬가지로, 이것들은 &3조밀한 케이블&r에 연결할 수 없습니다. 유리, 차폐 또는 스마트 케이블은 작동합니다!"
		""
		"&b저장소 버스&r를 사용하면 기존 저장소를 네트워크에 연결할 수 있습니다."
	]
	quest.45E7D62C229F898C.title: "&aME 제작 터미널"
	quest.461A01BDC4D4B1BD.quest_desc: [
		"&a생성기&r는 저장소 네트워크에서 블록이나 아이템을 세계에 배치할 수 있습니다."
		""
		"&a파괴기&r는 세계의 블록이나 아이템을 부수어 저장소 네트워크에 넣을 수 있습니다."
		""
		"각 &e케이블 등급&r 업그레이드는 이전 등급보다 더 빠르게 작동하며 더 많은 필터 슬롯을 제공합니다."
	]
	quest.461A01BDC4D4B1BD.title: "세계 상호작용 장치"
	quest.464AED8311A32476.quest_desc: [
		"&eApotheosis&r에 대해 자세히 알아보기 전에, &b부여 효과&r가 무엇인지 알아야 합니다!"
		""
		"&b부여 효과&r는 모든 &eApotheosis&r 장비의 원동력입니다. 각 &b부여 효과&r는 마법 부여와 매우 유사하며, 아이템에 부여된 보너스를 제공합니다."
		"{@pagebreak}"
		"&b부여 효과&r 아이템은 세계를 탐험하면서 찾을 수 있으며, 효과는 아이템의 희귀도에 따라 다릅니다. 지하 동굴에서 찾을 수 있는 &eApotheosis&r 보스 몬스터에게서 더 흔하게 드롭되거나 밤에 무작위로 나타날 확률이 있습니다."
		""
		"아이템의 능력치, 효과, 내구성, 그리고 &b보석&r 섹션에서 다룰 &b보석 소켓&r와 같이 아이템의 특정 부분을 수정하는 몇 가지 다른 유형의 &b부여 효과&r가 있습니다."
	]
	quest.464AED8311A32476.title: "&f부여 효과 아이템 이해하기&a&f"
	quest.466E449BFD87E62F.quest_desc: ["&c고대 전장&r은 &c네더&r 고리의 윗부분에서 찾을 수 있습니다."]
	quest.466E449BFD87E62F.title: "&c고대 전장 찾기"
	quest.469C88B6CEC1F9E7.quest_desc: [
		"&2인지력&r은 &2경험치&r의 사용, 저장 및 생산을 확장하는 모드입니다."
		""
		"모드를 시작하려면 몇 가지 장치를 설정하면 만들기 쉬운 몇 가지 입문 수준의 재료가 필요합니다. 몇 가지 추가 재료를 제공해 드리겠습니다."
	]
	quest.469C88B6CEC1F9E7.title: "&2인지력&f: 지식 활용하기"
	quest.46A1341E5E97ABDC.quest_desc: [
		"&bAE 네트워크&r를 구축하기 전에 &2채널&r에 대해 이야기할 시간입니다. 걱정하지 마세요. 팩의 기본 설정은 &b기본 4배&r로 설정되어 있어 &eAE2&r가 처음인 플레이어가 더 쉽게 이용할 수 있도록 의도되었습니다."
		""
		"&2채널&r은 본질적으로 네트워크가 한 번에 상호 작용할 수 있는 총 장치 수의 제한입니다. 이는 몇 가지 영리한 메커니즘과 멀티블록 &3컨트롤러&r를 사용하여 증가시킬 수 있으며, 이는 다른 퀘스트에서 다룰 것입니다."
		""
		"증가된 설정으로, 추가 채널이 필요하기 전에 네트워크당 &232개의 채널&r을 사용할 수 있습니다."
		"{@pagebreak}"
		"네트워크의 다른 부분을 연결하려면 세 가지 유형의 ME 케이블을 사용할 수 있습니다: &b유리 케이블&r, &3밀집 케이블&r, 그리고 &d스마트 케이블&r."
		""
		"이 케이블 각각은 다른 수의 &2채널&r을 전달합니다. 이는 게임 후반부에 도달했을 때 모든 네트워크 부분에 &b유리 케이블&r을 연결하면 문제가 발생할 수 있음을 의미합니다."
		"{@pagebreak}"
		"&b유리 케이블&r은 전력을 전송하지만, 팩 설정으로 최대 &232개의 채널&r까지 전송할 수 있습니다."
		""
		"&d스마트 케이블&r은 채널을 추가하지 않지만, 케이블 자체의 선을 사용하여 사용 중인 채널 수를 시각적으로 보여줍니다."
		""
		"&3밀집 케이블&r은 최대 &2128개의 채널&r을 전송할 수 있지만, 버스나 패널에 연결하는 것은 지원하지 않습니다. &d밀집 스마트 케이블&r도 만들 수 있습니다!"
	]
	quest.46A1341E5E97ABDC.title: "&b케이블 및 &f채널&2"
	quest.47547FC5591CE0D3.quest_desc: [
		"&eActually Additions&r는 주로 레이저로 수정에 에너지를 공급하여 수정 생성 및 강화를 중심으로 합니다!"
		""
		"시작하려면 &2지질학자&r 레벨을 최소 2까지 올리고 &3영혼 모래&r를 브러시로 털어내도록 해야 합니다."
	]
	quest.47547FC5591CE0D3.title: "&eActually Additions"
	quest.4784FDEE62A479D0.quest_desc: [
		"&a악마의 꿈 씨앗&r은 잔디를 부수거나 &a갈고리&r를 &e모래&r에 사용하여 드물게 얻을 수 있습니다."
		""
		"만약 당신이 오컬트의 길을 선택한다면, 이 씨앗은 당신의 &b세 번째 눈&r을 여는 데 유용할 수 있습니다."
		""
		"&6영혼의 사전&r은 모드의 가이드북이지만, 특정 제작법에도 필요하며 &b홀로그램&r을 만들어 &d의식&r 구축을 도울 수 있습니다!"
	]
	quest.4784FDEE62A479D0.title: "&e오컬티즘"
	quest.47920CCF1C3CAE5B.title: "엔드 북쪽"
	quest.47C1E9F93CEF25D3.quest_desc: ["&3채굴 레벨&r을 높이면 블록을 솔질할 때 얻는 드롭 종류도 늘어납니다."]
	quest.47C1E9F93CEF25D3.title: "&f채굴 레벨"
	quest.47C45A0552FBC1BD.title: "&f50시간 플레이하기&d"
	quest.47D745A94C534B48.quest_desc: [
		"더 많은 &6기록 보관소&r가 잠금 해제되었으니, 로비 탐험을 시작하여 &d마법사의 메아리&r를 찾아야 합니다."
		""
		"이 &d메아리&r와 함께 작업하여 &3월드 엔진&r의 &r소스 업그레이드&6를 잠금 해제하세요."
		""
		"&7&o만나고 나면 &e/echo magician&7 명령어를 사용하여 로비 어디에서든 이 메아리로 직접 순간이동할 수 있습니다."
	]
	quest.47D745A94C534B48.title: "&f마법사를 만나세요&d"
	quest.48005B47655AD525.quest_desc: [
		"&d소스 보석&r의 힘으로 &d소스 중계기&r를 만들어 &r소스&2의 흐름을 활용할 수 있습니다."
		""
		"&a도미니언 완드&r를 사용하여 병 사이의 &d소스&r 흐름을 지시할 수 있습니다."
		""
		"&d소스&r &3월드 엔진 업그레이드&r를 설치하여 엔진에 &d소스&r를 넣어 더 많은 마법 아이템을 제작할 수 있습니다."
	]
	quest.48005B47655AD525.quest_subtitle: "마이너 월드 엔진 업그레이드"
	quest.48005B47655AD525.title: "&f월드 엔진 소스"
	quest.4843F5564CA5810C.quest_desc: [
		"&a디젤 발전기&r는 &dHV&r 전력을 생성하며 &2디젤&r과 같은 연료를 소비합니다."
		""
		"사용하는 연료에 따라 특정 연료는 발전기 안에서 더 오래 연소되어 더 많은 전력을 생성합니다."
		""
		"연료 전체 목록은 &b엔지니어 매뉴얼&r 또는 JEI를 참조하세요."
		""
		"건설 및 사용에 대해 더 자세히 알아보려면 &a엔지니어 매뉴얼&r의 &r전기 그리드&b 섹션을 참조하세요."
	]
	quest.4843F5564CA5810C.title: "디젤 발전기"
	quest.487BD65BA8F5337D.title: "기계공 만나기"
	quest.4882D3E03CC01268.quest_desc: [
		"&b저장 장치 버스&r를 사용하면 네트워크에서 상자 또는 &e저장 장치 컨트롤러&r(&6기능적 저장 장치&r 모드)와 같은 외부 저장 장치 블록/네트워크 안의 아이템을 보고 상호작용할 수 있습니다."
		""
		"&b저장 장치 버스&r는 다양한 종류가 있으며, 특정 아이템만 저장하고 상호작용하도록 필터링할 수도 있습니다."
		""
		"&7채널 하나만 사용하는 사실상 무한한 저장 장치 네트워크를 구축하는 것이 가능합니다.&o"
	]
	quest.4887C8EA4441F62B.quest_desc: [
		"&c연료 발전기&r는 석유와 유사한 유체를 소모하여 동력을 생성하는 3x3x2 멀티블록 발전기입니다."
		""
		"더 높은 등급의 연료는 동일한 RF/t를 제공하지만 훨씬 더 오래 지속됩니다!"
		""
		"&e참고&r: 연료 발전기에서 &aU&r를 누르면 사용할 수 있는 연료 목록 전체가 표시됩니다."
	]
	quest.48935E2DFCA1E835.quest_desc: [
		"\\&z강력한 엔더 치킨&r을 착유하면, 융합 설정을 업그레이드하고 가장 진보된 &eDE&r 아이템을 제작하는 데 사용되는 \\&z용암 혼돈&r을 얻을 수 있으며, 이를 \\&z혼돈 조각&r으로 굳힐 수 있습니다."
		""
		"이제 &6용의 비늘 장비&r를 \\&z혼돈 등급&r으로 업그레이드할 수 있습니다."
	]
	quest.48935E2DFCA1E835.title: "\\&z혼돈 융합"
	quest.48B3D104BEFE1959.quest_desc: [
		"&a만능 톱&r(&6Create&r 모드)을 사용하면 자라난 나무를 자동으로 수확하는 장치를 만들 수 있습니다!"
		""
		"이것을 &a배포기&r와 함께 사용하여 묘목을 다시 심으면 멋진 나무 농장을 만들 수 있습니다."
	]
	quest.48B3D104BEFE1959.title: "구조물 절단"
	quest.48C1A1BB346B7D07.quest_desc: [
		"&6시간 수정&r을 사용하여 &6시간 지팡이&r를 만들 수 있습니다."
		""
		"이것은 &6시간 유체&r를 사용하여 사용되는 모든 블록을 가속하며, 이는 병 속의 시간 또는 시간 주머니와 유사합니다."
	]
	quest.48C1A1BB346B7D07.title: "\\&z시간 지팡이"
	quest.496903AB7E8A0A92.quest_desc: [
		"&eIron's 보석 \\& 장신구&r는 재료와 &b보석&r을 결합하여 플레이어에게 특수 효과나 능력치 증가를 제공하는 데 중점을 둔 모드입니다."
		""
		"기본적인 &b장신구&r 제작을 시작하려면 &a보석 공예 작업대&r를 제작해야 합니다."
		""
		"더 고급 &b장신구&r를 배우려면 주민과의 거래를 통해 청사진을 찾거나 &6상점&r에서 구매해야 합니다."
		""
		"대부분의 &b장신구&r는 &a밴드 금속&r과 &a보석&r으로 구성됩니다."
	]
	quest.496903AB7E8A0A92.title: "&eIron's 보석 \\& 장신구&f!"
	quest.49835EC10C5AE8D8.quest_desc: [
		"&6양자 제작기&r는 &3분자 조립기&r, &a패턴 공급기&r, 그리고 &2ME 요청기&r의 역할을 모두 수행합니다."
		""
		"또한 매우 빠르게 제작할 수 있고, 여러 아이템을 동시에 재고로 유지하도록 설정할 수 있으며, &b가속 카드&r로 업그레이드할 수도 있습니다."
		""
		"유일한 제한은 총 9개의 &2패턴&r만 저장할 수 있다는 것입니다."
	]
	quest.49835EC10C5AE8D8.title: "&6양자 제작기"
	quest.49B8310D0C7A6C55.quest_desc: [
		"&3핵분열 연료&r(&d핵분열 원자로&r를 구동하는 데 필요)는 &e황&r, &7불소&r, &2우라늄&r을 일부 물 제품과 함께 처리하여 만들어집니다. 복잡해 보이지만 실제 생활과는 달리 생각보다 쉽습니다."
		""
		"먼저, &e황산&r을 사용하여 &7형석&r을 &9불산&r으로 분해합니다. 이 과정은 &2화학 용해기&r에서 이루어집니다."
		"{@pagebreak}"
		"둘째, &a우라늄&r 잉곳을 &6노란색 케이크 우라늄&r으로 농축한 후, &6산화 우라늄&r으로 산화시킵니다."
		""
		"마지막으로, &9불산&r과 &6산화 우라늄&r을 &a화학 주입기&r에서 결합한 후 &2동위원소 분리기&r로 보내 &3핵분열 연료&r를 생산합니다."
		""
		"&e팁&r: &7형석&r 블록은 단일 &7형석 결정&r만큼의 &e황산&r을 분해하는 데 사용되지만, 아홉 개의 &7결정&r만큼의 &9불산&r을 생산하여 &e황&r을 절약합니다!"
	]
	quest.49B8310D0C7A6C55.title: "핵분열 연료"
	quest.49DD167D6323406B.quest_desc: [
		"기능적 저장 장치는 &a유체 저장 장치&r를 사용하여 유체 저장도 처리할 수 있습니다!"
		""
		"유체를 서랍에 직접 펌핑하거나 유체 양동이를 사용하여 유체를 설정할 수 있습니다."
	]
	quest.4A1DBDE0963407E7.quest_desc: [
		"&e용의 비늘 진화&r(&eDE&r)는 용, 에너지, 그리고 매우 강력한 장비에 중점을 둔 중반에서 후반 게임 모드입니다."
		""
		"&eDE&r를 시작하려면 먼저 &a용의 비늘 가루&a를 모아야 합니다."
		""
		"[\"The main way to acquire this dust is to level up your \", {\"text\": \"Dimensionalist Unearther\", \"color\": \"light_purple\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"6F91297C4FAA43FE\"}, \"hoverEvent\": {\"action\": \"show_text\", \"contents\": \"Go to Dimensionalist Quest\"}}, \" at least tier 4, but you may also acquire it through other methods (check JEI).\"]"
		""
		"&a발굴 레벨&r이 충분히 높으면 &e엔드 돌&r을 수동으로 긁어낼 수도 있습니다."
	]
	quest.4A1DBDE0963407E7.title: "&f용의 비늘 진화에 오신 것을 환영합니다&e"
	quest.4A2EB77748103124.quest_desc: ["이 던전은 &3돌&r과 &7심층암&r 고리에서 찾을 수 있습니다."]
	quest.4A2EB77748103124.title: "&2시련의 방 찾기"
	quest.4A5FD3641E0A566E.quest_desc: [
		"&2반응로 에너지 포트&r는 &d반응로&r에서 생성된 에너지를 출력하는 데 사용되며, 외부 벽 중 하나에 배치해야 합니다."
		""
		"각 포트는 최대 25,000 RF/t를 출력할 수 있습니다."
		""
		"&c반응로 레드스톤 포트&r는 새로운 연료의 유입을 비활성화할 수 있지만, 반응로가 완전히 꺼지기 전에 이미 연소를 시작한 펠릿은 연소를 완료합니다."
		""
		"비교기를 사용하여 데이터를 출력할 수도 있습니다. 포트를 우클릭하여 순환할 수 있는 세 가지 모드가 있습니다: 에너지, 활성 막대 수, 온도."
	]
	quest.4A5FD3641E0A566E.title: "&2에너지 &f및 &c레드스톤&f 포트"
	quest.4A68D2CD7437589E.quest_desc: ["물약을 소모하여 전력을 생성합니다."]
	quest.4A707D443EC2DE33.quest_desc: [
		"&e기능성 서랍&r은 하나의 블록에 수많은 아이템을 저장하는 쉬운 솔루션을 제공하는 것을 목표로 하는 저장 모드입니다!"
		""
		"&a서랍장&r은 세 가지 종류가 있습니다: 단일 서랍장, 1x2 서랍장, 2x2 서랍장."
		""
		"2x2 서랍은 4개의 개별 아이템을 저장할 수 있지만, 총 기본 저장량은 4로 나뉩니다."
		"{@pagebreak}"
		"아이템을 넣으려면, 해당 아이템을 들고 &a서랍장&r을 우클릭하면 됩니다. 더블 우클릭하면 여러 스택을 한 번에 넣습니다."
		""
		"&a서랍장&r에서 아이템을 제거하려면, 좌클릭하면 한 번에 아이템 1개를 제거하고, Shift + 좌클릭하면 전체 스택을 꺼냅니다."
	]
	quest.4A707D443EC2DE33.title: "&e기능성 서랍"
	quest.4A8581D52BD1922B.quest_desc: [
		"더 고급 종류의 &b유체 소&r를 얻으려면 특정 소들을 함께 번식시켜 &c녹은 합금&r &b유체 소&r를 얻어야 합니다."
		""
		"예를 들어, &a철&r 소와 &e니켈&r 소를 번식시켜 &7인바&r &b유체 소&r를 만들 수 있습니다."
		""
		"JEI에서 더 나은 탐색을 위해, 퀘스트 보상으로 얻는 &a연금술 유리&r는 다양한 번식 조합을 보여줄 것입니다."
		""
		"또한 JEI에서 특정 녹은 금속을 검색하여 번식에 필요한 것을 확인할 수 있습니다."
	]
	quest.4A8581D52BD1922B.title: "유체 소 번식"
	quest.4A871B8D8648F305.quest_desc: [
		"가루 형태에서 제련되거나 합금됨"
		""
		"니켈과 다이아몬드를 야금술 주입으로 가루화"
	]
	quest.4A87B0D25DE57F3F.quest_desc: [
		"&d마법 부여가의&r 첫 번째 임무를 완료하기 전에, 더 단단한 돌을 찾아야 합니다."
		""
		"&7심층암&r을 찾을 때까지 더 깊이 파고드세요."
		""
		"마법처럼 보이지 않을 수도 있지만, 고대 마법의 잔재는 마법 부여력을 위해 활용될 수 있습니다."
	]
	quest.4A87B0D25DE57F3F.title: "&f더 깊이 파기"
	quest.4AC8D1AEFCED24FD.quest_desc: ["이 섹션은 전력을 무선으로 전송하는 다양한 방법에 대한 것입니다.&a무선으로&r."]
	quest.4B463FDAEAC42511.quest_desc: [
		"&3물질 응축기&r는 쓰레기통처럼 삽입된 모든 아이템을 파괴합니다. 버퍼 역할을 할 셀을 제공하면 대신 &a물질 구슬&r(1-16k) 또는 &d특이점&r (64k+)으로 변환할 수 있습니다."
		""
		"이 &d특이점&r은 거대한 저장 장치와 차원 간 연결을 만드는 데 중요합니다."
	]
	quest.4B463FDAEAC42511.title: "&f물질 응축기&3"
	quest.4B576E9FFA5D79CF.quest_desc: [
		"이 퀘스트에서 &6각성된 드라코늄&r이 많이 필요하다고 말한 것을 기억하시나요? &a378개&r의 &6각성된 드라코늄 블록&r이 필요합니다."
		""
		"&6월드 엔진&r을 업그레이드하려면 &a8단계 에너지 코어&r를 만들어야 하며, 여기에는 &a786개&r의 &d드라코늄 블록&r도 필요합니다."
		""
		"그렇다면 바우크하세요."
		""
		"&e참고&f: 이 &3업그레이드&r가 필요한 레시피는 활성화된 &a에너지 코어&r에서만 작동합니다."
	]
	quest.4B576E9FFA5D79CF.quest_subtitle: "주요 월드 엔진 업그레이드"
	quest.4B576E9FFA5D79CF.title: "&f8단계 에너지 코어"
	quest.4B6154D6F9B7C7BF.quest_desc: [
		"&a제작대&r는 인접한 인벤토리에 저장된 아이템을 가져올 수 있으며, 제작 그리드에도 아이템을 보관합니다."
		""
		"이것은 &eTinker's Construct&r 버전과 같이 작동합니다. 기억하는 사람들에게는 말이죠."
	]
	quest.4B6154D6F9B7C7BF.title: "&f제작대"
	quest.4B7A9469150AF3A1.quest_desc: ["&6프시메탈 도구&r는 &b다이아몬드 등급의 품질&r에 필적하는 도구 세트로, 각 도구는 의도된 작업을 수행할 때마다 &b주문&r을 시전할 수 있습니다."]
	quest.4B7A9469150AF3A1.quest_subtitle: "블라키스 승인!"
	quest.4B7A9469150AF3A1.title: "사이오닉 도구!"
	quest.4B8E75ACE0AA6FA0.quest_desc: ["언어더의 부순 키비에서 지질학자를 통해 얻을 수 있습니다."]
	quest.4B8E75ACE0AA6FA0.quest_subtitle: "광석 생성기 필요"
	quest.4B92EBBA1F2BBFEA.quest_desc: ["이 퀘스트 보상을 받으면 &dEcho's &6Archive&r 입구에 웨이포인트가 설정됩니다."]
	quest.4B92EBBA1F2BBFEA.title: "&f고대인 찾기&d"
	quest.4BA8E435EDA995AC.quest_desc: [
		"아마도 너무 많은 조약돌을 줍는 것에 지쳤을 것입니다. 그것들을 없애는 데 도움이 되는 &a공허 업그레이드&r를 만드는 것은 어떨까요?"
		""
		"이 업그레이드 자체로는 필터에 설정한 특정 아이템을 자동으로 무효화하도록 설정할 수 있습니다. 고급 버전으로 업그레이드하면 더 많은 필터 옵션을 사용할 수 있습니다!"
	]
	quest.4BAD7359CF074014.quest_desc: [
		"공허의 힘을 활용하기 전에, 원자 수준에서 제작할 기계를 만들어야 합니다."
		""
		"&d원자 대장간&r은 이를 위해 완벽하며, 공허에 담을 수 있을 만큼 강한 주괴를 제작할 수 있습니다."
		""
		"&e참고&r: &d원자 대장간&r은 &d엔더릭 레이저&r로 전력을 공급받아야 합니다."
	]
	quest.4BAD7359CF074014.title: "&6프로메튬 만들기&r"
	quest.4BB5ADD98F958712.quest_desc: ["이 던전은 &7돌&r과 &7심층암&r 고리에서 생성됩니다."]
	quest.4BB5ADD98F958712.title: "&7돌 던전 찾기"
	quest.4BB6832FE4685131.quest_desc: ["&3영혼&r을 사용하려면, &a영혼 폭풍&r을 가속하려는 블록에 겨누고 &d영혼 레이저 베이스&r에 &a영혼 파이프&r를 사용하여 연결하세요."]
	quest.4BB6832FE4685131.title: "&3영혼 운반"
	quest.4BBDC7BF4B9EAD72.quest_subtitle: "언어더, 고고학자"
	quest.4BCA8A5C3F80D375.quest_desc: [
		"&a이름 제거의 부적&r은 아이템의 접사 이름을 제거하여 일반 아이템 이름으로 되돌립니다."
		""
		"예를 들어: &dEndawn the Ogre Slayer's Windswept Burnt Shoes of the Spellwarden&r은 &d불탄 신발&r로 이름이 변경됩니다."
	]
	quest.4BEBF37F66E48801.quest_desc: ["우유 양동이를 &b유체 소&r에게 먹이면 일반 소로 되돌아갑니다."]
	quest.4BEBF37F66E48801.title: "취소합니다"
	quest.4BFF8EE3F588E006.quest_desc: [
		"더 많은 &6기록보관소&r가 잠금 해제되었으므로, 로비 탐색하여 &d마법 부여가의 메아리&r를 찾을 시간입니다."
		""
		"이 &d메아리&r와 함께 작업하여 &3월드 엔진&r의 &6마법 부여 업그레이드&r를 잠금 해제하세요."
		""
		"&7&o만나고 나면 로비 어디에서든 &e/echo enchanter&7를 사용하여 이 메아리로 직접 순간이동할 수 있습니다."
	]
	quest.4BFF8EE3F588E006.title: "&f마법 부여사와 만나기&d"
	quest.4C52D3DE2F7701D0.quest_desc: [
		"&b확인&f: 붓 제작"
		""
		"&b잠금 해제됨&f:"
	]
	quest.4C52D3DE2F7701D0.title: "안내 1.1 확인"
	quest.4C549866DEB8DB61.quest_desc: [
		"&a기계 부품&r을 제작하려면 &3기계 블록 업그레이드&r에 필요한 기본 기계가 필요합니다. 합금 전선과 금속 판을 만들기 위해서입니다."
		""
		"이 판들은 작업하기 훨씬 쉽고, &2기계 블록&r을 강화하여 &6월드 엔진&r 제작을 견딜 수 있게 합니다."
		""
		"&e참고&r: 이것들은 생산적인 금속 작업, 크리에이트 또는 이머시브 엔지니어링을 사용하여 얻을 수 있습니다."
	]
	quest.4C549866DEB8DB61.title: "&f기계 프레임 강화"
	quest.4C78823B3EFA3105.quest_desc: [
		"&d비전 장치&r는 기본적으로 아르스의 제작대입니다. 주변의 &a비전 받침대&r에 놓인 아이템을 사용하여 새로운 아이템을 만들거나, 마법 부여를 하거나, 나중에 마법사 갑옷을 업그레이드합니다."
		""
		"작동하려면 장치 아래에 &3비전 코어&r를 배치해야 합니다. 또한 장치에서 3블록 이내에 여러 개의 &a비전 받침대&r를 배치해야 합니다. 필요한 받침대의 수는 제작법에 따라 다릅니다!"
		""
		"일부 제작법에는 &d소스&r도 필요하므로, 3블록 이내에 &a소스 단지&r를 배치해야 합니다."
	]
	quest.4CE414ADD47790B2.quest_desc: [
		"&a복제기&r는 &d복제기 인클로저&r를 사용하여 속도를 높일 수 있으며, 이는 &a복제기&r에 Shift+우클릭하여 설치할 수 있습니다."
		""
		"또한 &a복제기 모터&r를 설치하여 속도를 구성할 수 있습니다. 모터를 제작하려면 먼저 모터용 &d물질 청사진&r을 제작해야 합니다."
		"{@pagebreak}"
		"이것을 &d메모리 칩&r과 함께 &a식별 장치&r에 넣어 복제 방법을 시스템에 가르친 다음, &a복제 단말기&r에서 제작하세요."
		""
		"&a복제기&r에 설치되면 속도를 구성할 수 있습니다. 최대 속도는 20%이지만 복제 실패 확률이 증가합니다."
	]
	quest.4D17FE7D41FEEC95.title: "혼돈의 도가니"
	quest.4D1EBD92C674531E.quest_desc: [
		"토템 기둥에 다섯 개의 비전 정령을 적용하고 활성화하면 &b속박되지 않은 의식&r이 발동됩니다."
		""
		"순수한 고대의 잠재력이 넓은 지역을 통해 터져 나오며, 유기적인 토템을 통해 집중되어 모든 종류의 자연 재료를 타락한 형태로 &ccorrupt&r시킵니다. 원래 형태가 원시 에너지를 감당할 수 없기 때문에 토템 기둥 자체도 포함됩니다."
		"{@pagebreak}"
		"이후 과정이 안정화되며, 활성화된 &a소울우드 토템&r은 이제 &a황폐한 대지&r에 놓인 재료를 매우 유용한 과정으로 변환하기 위해 에너지를 더 꾸준히 전달합니다."
		""
		"하지만 결과물인 &a소울우드 묘목&r은 성숙할 때마다 이 황폐의 돌진을 재생산합니다. 만약 있다면, 통제된 재배가 권장됩니다."
	]
	quest.4D1EBD92C674531E.title: "속박되지 않은 황폐"
	quest.4D55D9FBE06DAA46.quest_desc: [
		"무기, 갑옷, 마법서에 더 많은 힘을 부여하고 싶다면, &3강화 구슬&r을 제작하는 것이 가장 좋은 방법 중 하나입니다."
		""
		"이 구슬은 &a빈 강화 구슬&r과 8개의 &3룬&r을 조합하여 만들어집니다."
		""
		"강화 구슬을 장비에 추가하려면 &d비전 모루&r를 사용하세요. 장비당 최대 3개의 구슬을 적용할 수 있습니다."
	]
	quest.4D55D9FBE06DAA46.title: "&d강화 구슬"
	quest.4D64F277A4330749.quest_desc: [
		"&6B.E.E.R. (책장 확장 마법 부여 범위)&r는 마법 부여대가 책장을 스캔하는 범위를 수정할 수 있게 해줍니다!"
		""
		"일반적으로 마법 부여대는 주변 5x5x3 영역에서만 책장을 찾습니다. &6B.E.E.R.&r을 사용하면 이 범위를 더 확장할 수 있습니다!"
		""
		"마법 부여대의 범위를 수정하려면, &a수정 블록&r을 주 손에 들고 마법 부여대에 웅크리기+우클릭하면 됩니다."
		""
		"보조 손에 &a네더 석영&r 조각을 들고 있으면 대신 범위가 줄어듭니다."
	]
	quest.4D64F277A4330749.quest_subtitle: "줄여서 BEER"
	quest.4D64F277A4330749.title: "책장 확장 마법 부여 범위"
	quest.4D6D066B0855586D.quest_desc: [
		"바다 고리 안에는 공허에 의해 영향을 받은 생명체가 있습니다."
		""
		"행운을 빕니다."
		""
		"&e참고&r: 제단을 활성화하려면 &d심연의 제물&r이 필요합니다. 이를 제작하는 데 필요한 아이템은 &9산호석&r의 &a영원의 관문&r에서 얻을 수 있습니다."
	]
	quest.4D6D066B0855586D.title: "&d심연의 제물&r"
	quest.4D754E91D203A89A.quest_desc: [
		"이제 몇 가지 &6월드 엔진&r 업그레이드를 잠금 해제했으니, &d인도의 메아리&r로 돌아가야 합니다."
		""
		"다른 &d메아리&r에서 아직 받지 못한 보상이 있는지 확인하세요."
	]
	quest.4D754E91D203A89A.quest_subtitle: "2단계 챕터 잠금 해제"
	quest.4D754E91D203A89A.title: "&f인도가 더 필요해"
	quest.4D7C7DE95E56C7B3.quest_desc: [
		"강력한 엔더 치킨&r과 싸울 때 경기장에서 &a분리 장치 받침대&r를 보았을 수도 있습니다. 닭을 짜야 하므로 이제 그것을 사용할 때입니다."
		""
		"먼저 보스를 위한 &a정지 장치&r 설정을 시작하세요. &d컴팩트 머신&r과 같은 곳에서 하는 것이 좋을 수 있습니다."
		""
		"목표는 강력한 엔더 치킨&r을 &a정지 챔버&r로 순간이동시켜 &6유체 레이저 드릴&r을 사용하여 닭을 짜는 것입니다."
		""
		"&e참고&r: 닭은 같은 차원에 있으면 다시 순간이동합니다. &a컴팩트 머신&r에서 이 작업을 설정해야 합니다!"
		"{@pagebreak}"
		"&aLaser Base&r는 당신이 워프하는 닭의 크기에 따라 배치해야 합니다."
		""
		"목표는 기지를 닭의 머리 바로 위에 배치하는 것입니다. 만약 닭이 작다면, 닭보다 한 블록 위에 배치해야 합니다."
		""
		"작은 닭을 얻으려면, 소환하자마자 &d변위기&r에 배치하여 즉시 포털을 여세요."
	]
	quest.4D7C7DE95E56C7B3.title: "닭을 집으로"
	quest.4DABDC2484C732AC.quest_desc: [
		"&d아크 용광로&r는 금속 합금 및 광석 제련에 사용되는 거대한 기계입니다."
		""
		"&d아크 용광로&r는 더 많은 양의 전력을 소모하여 한 번에 많은 아이템 배치를 제련할 수 있습니다."
		""
		"다음 페이지에서는 &d아크 용광로&r의 인터페이스와 자동화에 대해 자세히 설명합니다."
		""
		"멀티블록을 만드는 데 도움이 되도록 &b기술자 설명서&r를 꼭 확인하세요!"
		"{@pagebreak}"
		"&l인터페이스:"
		""
		"상위 세 칸은 &d흑연 전극&r용이며, 사용함에 따라 마모됩니다."
		""
		"왼쪽의 열두 개 슬롯은 아이템 입력용이며, 온도 막대는 각 개별 아이템의 제련 진행 상황을 나타냅니다."
		""
		"왼쪽 상단의 버튼은 아이템이 열두 개의 슬롯에 분산되는지 여부를 변경합니다."
		""
		"오른쪽의 네 개 슬롯은 특정 제작법에 사용될 수 있는 추가 재료용입니다."
		"{@pagebreak}"
		"&l자동화:&r"
		""
		"입력과 추가 재료는 구조물 상단의 왼쪽 및 오른쪽 해치를 통해 삽입됩니다."
		""
		"후면의 하단 슬롯은 슬래그를 출력하고, 전면 슬롯은 주요 공정을 출력합니다."
		""
		"에너지는 후면의 세 개의 커넥터를 통해 삽입될 수 있습니다."
	]
	quest.4DABDC2484C732AC.title: "&d아크 용광로"
	quest.4DBD57AF035CAA6B.title: "&fPlay For &6100 Hours"
	quest.4DE483256F9E1D4F.quest_desc: [
		"&a인출의 부적&r은 아이템을 손상시키지 않고 아이템에 소켓된 모든 &b보석&r을 제거합니다."
		""
		"이것들은 또한 \\&z상점&r에서 구매할 수 있습니다!"
	]
	quest.4E0BAFDCADC617C5.title: "TF 파편"
	quest.4E4434B6CE1F2560.quest_desc: [
		"&6코어&r는 &aCAD의 필수적인 부분&r이며, 항상 최상의 것을 만들도록 노력하세요. &a이것은 기본적으로 CAD의 CPU입니다&r."
		""
		"모든 &6CAD 코어&r에는 &d&l복잡성 값&r&r이 있으며, 이는 &d한 번에 수행할 수 있는 연산 횟수&r를 의미합니다."
		"&8&o(선택기, 연산자 등은 주문의 복잡성을 증가시킬 수 있습니다)&r&r"
		""
		"또한, 모든 &6CAD 코어&r에는 &3&l투영 값&r&r이 있으며, 이는 단순히 &3디버그되지 않은 모든 주문을 한 번에 수행할 수 있는 총 횟수&r입니다."
		""
		"이 &6코어&r는 특히 다음 중 하나를 제공할 수 있습니다:"
		""
		"► &d복잡성&r: 20 또는 24"
		""
		"► &3투영&r: 3 또는 4"
	]
	quest.4E4434B6CE1F2560.title: "&b2단계&f CAD 코어"
	quest.4E474C940C683371.quest_desc: [
		"&6드라코닉 원자로&r는 궁극의 에너지 생성기로, 올바르게 설정하면 초당 수억 RF를 생산할 수 있습니다. &c이 원자로는 폭발할 수 있습니다!&r"
		""
		"설정을 시작하려면 &6반응로 코어&r를 중앙에 놓고, &a안정기&r를 각 방향으로 5블록까지 떨어뜨리고, &2주입기&r를 위 또는 아래에 놓으십시오."
		""
		"반응로에 연료를 공급하려면 &6각성된 드라코늄&r(한 번에 최대 8블록)과 막대한 양의 에너지를 공급해야 합니다. 더 많은 에너지를 공급할수록 더 많은 에너지를 생산합니다."
		""
		"&7&o다음 페이지에서 더 많은 정보 보기 ->"
		"{@pagebreak}"
		"{image:ftb:textures/quests/draconic_evolution/reactor_ui_charge.png width:150 height:133 align:center}"
		"반응로를 켜기 전에 이 인터페이스를 만나게 되며, 500블록 내의 모든 것을 날려버릴 수 있는 반응로 멜트다운을 피하려면 무엇이 무엇인지 알아야 합니다."
		""
		"다음 페이지에서 인터페이스를 왼쪽에서 오른쪽으로 살펴보겠습니다 ->"
		"{@pagebreak}"
		"- 코어 온도: 반응로 활성화를 위해 최소 2000°C가 필요합니다. 8000°C 이상의 온도는 코어를 기하급수적으로 가열하기 시작하여 멜트다운 발생 가능성을 높입니다."
		""
		"- 격납 필드 강도: 코어 주변의 보호를 제어합니다. 이 값이 0에 도달하면 반응로가 폭발합니다. 이 값이 낮을수록 더 많은 전력을 생산할 수 있습니다."
		""
		"- 에너지 포화도: 에너지를 더 많이 흡수할수록 증가하고 에너지를 끌어낼 때 감소합니다. 포화도가 높을수록 발전율이 낮아집니다. 높은 포화도는 온도도 높입니다."
		""
		"- 연료 변환: 남은 연료량과 에너지로 변환된 양(반응로를 계속 작동시키기 위해 틱당 소모되는 연료량)입니다. 완벽하게 균형 잡힌 반응로는 틱당 연료를 소모하지 않습니다. 균형이 오래 유지될수록 온도를 더 오래 유지할 수 있습니다."
		""
		"&7&o다음 페이지에서 더 보기 ->"
		"{@pagebreak}"
		"모든 것이 제자리에 있고 반응로에 연료를 공급했다면, 안전하게 '충전'을 눌러 반응로를 시작할 수 있습니다."
		""
		"먼저 격납 필드와 에너지 포화도를 50%로 변경한 다음 2kC까지 가열하기 시작합니다. 이때 반응로를 활성화할 수 있는 옵션이 제공됩니다. 모든 것이 잘 진행되면 아무것도 폭발하지 않습니다."
		""
		"활성화된 인터페이스는 다음과 같아야 합니다:"
		"{image:ftb:textures/quests/draconic_evolution/reactor_ui_activate.png width:188 height:166 align:center}"
	]
	quest.4E474C940C683371.title: "&6드라코닉 원자로"
	quest.4E623BAFD92591EE.quest_desc: [
		"&a여행의 지팡이&r는 스니크 + 우클릭으로 짧은 거리를 순간이동할 수 있는 강력한 도구입니다."
		""
		"&a여행 앵커&r를 사용하면 &a여행의 지팡이&r를 들고 있을 때 해당 블록 웨이포인트가 시야 범위 내에 있다면 순간이동할 수 있는 웨이포인트를 설정할 수 있습니다."
		""
		"&e참고&r: &a여행 앵커&r를 제작하려면 &b포트론 주입 블록&r &6월드 엔진 업그레이드&r가 필요합니다."
	]
	quest.4E6EC6E1A507A52B.quest_desc: [
		"&d엔더 게이트&r를 모든 기계에 설치하여 무선으로 전력을 전송할 수 있습니다."
		""
		"[\"These will only work if you have enough power in your \", {\"text\": \"Ender Cell\", \"color\": \"dark_purple\", \"underlined\": true, \"clickEvent\": {\"action\": \"change_page\", \"value\": \"1CFBFD1CE648772F\"}, \"hoverEvent\": {\"action\": \"show_text\", \"contents\": \"Go to Ender Cells Quest\"}}, \" network.\" ]"
	]
	quest.4E6EC6E1A507A52B.title: "&d엔더&r 게이트"
	quest.4E9EBB1268DEF8A6.quest_desc: [
		"TNT를 소비하여 전력을 생성합니다."
		""
		"&7&o작동 시, 이 블록은 상당한 플레이어 피해를 주는 폭발을 일으키지만 지형에는 영향을 주지 않습니다."
	]
	quest.4F27342D2DA7C605.quest_desc: [
		"&7자갈&r을 더 부수면 &a흙&r으로 변합니다!"
		""
		"&a흙&r에는 항상 씨앗이나 묘목이 들어 있습니다."
		""
		"&a흙&r을 &a돌 곡괭이&r로 부숴보세요."
	]
	quest.4F27342D2DA7C605.title: "&f정교한 픽"
	quest.4F2B35E4E3729560.quest_desc: [
		"최종 업그레이드가 완료됨에 따라 &6월드 엔진&r은 완전히 복원되어 모든 기능을 수행할 수 있게 되었습니다."
		""
		"이제 &6스톤블록 4&r를 완료했습니다!"
	]
	quest.4F3CA2DCE719D18A.quest_desc: [
		"&6양자 멀티스레더&r는 멀티블록 내의 모든 &b코프로세서&r를 효과적으로 4배로 증폭시킵니다."
		""
		"멀티블록 구조당 하나만 사용할 수 있습니다."
	]
	quest.4F3CA2DCE719D18A.title: "&6멀티스레딩"
	quest.4F72252AD2DCAECC.quest_desc: ["&a자동 제작 업그레이드&r는 네트워크에서 리소스를 내보내려고 할 때 누락된 리소스에 대한 자동 제작 요청을 시작합니다."]
	quest.4FA08F4A78785162.quest_desc: [
		"월드에서 블록을 부수거나, 설치하거나, 교체해야 하는 경우, &6그냥 디어의 일들&r에는 해당 기계가 있습니다."
		""
		"이 기계들은 인터페이스 내에서 사용하고 구성하기 쉽습니다."
	]
	quest.4FCD78F6E1712BD8.title: "안내 확인 1"
	quest.4FE01499D831CACC.quest_desc: [
		"더 많은 &6월드 엔진&r 레시피를 잠금 해제함에 따라 일부 레시피에 유체가 필요하다는 것을 알게 될 것입니다."
		""
		"JEI에 표시된 올바른 탱크에 &6월드 엔진&r 내부의 유체가 배치되었는지 확인하십시오. 그렇지 않으면 레시피가 제대로 작동하지 않습니다."
	]
	quest.4FE01499D831CACC.title: "&6월드 엔진&f 유체"
	quest.4FE945C26EDB2A53.quest_desc: [
		"&3영혼&r은 &3영혼&r당 15초 동안 틱 속도를 가속하여 거의 모든 기계의 속도를 높일 수 있습니다."
		""
		"이 &3영혼&r은 &d워든&r 위에 &b소울 레이저 베이스&r를 설치하고 &a레이저 드릴&r로 전력을 공급하여 추출할 수 있습니다. 그런 다음 &b파란색 레이저 렌즈&r를 안에 넣어 추출을 시작하십시오."
		""
		"&d워든&r 아래의 &d정지 챔버&r는 워든을 제자리에 고정할 뿐만 아니라 시간이 지남에 따라 치유합니다(애드온으로 개선됨)."
	]
	quest.4FE945C26EDB2A53.title: "&3소울 레이저 베이스"
	quest.500074C1D4EC9591.quest_desc: [
		"더 많은 &6기록보관소&r가 잠금 해제되었으니, 로비를 탐험하고 &d촉매의 메아리&r를 찾을 시간입니다."
		""
		"이 &d메아리&r를 사용하여 &3업그레이드&r를 여러 개 잠금 해제하세요. 여기에는 &b월드 엔진&r용 &c고급 기계 블록&r 업그레이드가 포함됩니다!"
		""
		"&7&o이 에코를 만나면 로비 어디에서든 &e/echo catalyst&7를 사용하여 직접 순간이동할 수 있습니다."
	]
	quest.500074C1D4EC9591.title: "&f만나기 &d촉매제"
	quest.50416F411ED15BA5.quest_subtitle: "광물 생성기가 필요합니다"
	quest.50AC369D1F5B7DD8.quest_desc: [
		"&b확인&f: 마법 나무와 묘목 얻기"
		""
		"&b해금되는 것&f: "
	]
	quest.50AC369D1F5B7DD8.title: "마법사 확인 1"
	quest.50B0E45705EDB5F2.quest_desc: [
		"&3업그레이드&f에 필요한 블록을 제출하고 보상을 받으면 팀의 &6월드 엔진&r이 자동으로 조립됩니다."
		""
		"&e참고&f: 업그레이드가 있어야 할 곳에 놓인 블록은 무효화됩니다."
	]
	quest.50B0E45705EDB5F2.title: "&f자동 제작: &3마법 부여 업그레이드"
	quest.50B7A38F7E66139C.quest_desc: [
		"열은 쉽게 생성되지만, 기계 간에 전송할 때 매우 쉽게 손실됩니다."
		""
		"열 손실을 줄이기 위해 이 특정 용도로 특별한 케이블이 있습니다."
		""
		"&d궁극의 열전도체&r 몇 개를 제작하세요. 이것이면 충분할 것입니다."
	]
	quest.50B7A38F7E66139C.title: "&f열 전달"
	quest.50B7CA94F8BB6F58.quest_desc: [
		"&a원심분리기&r는 특정 아이템을 분리하고 변환하는 간단한 기계로, 특히 &3탄소 섬유 가닥&r을 만듭니다."
		""
		"이 기계는 &b기계 유체 애드온&r으로 유체를 분리하여 &b플라스틱&r과 같은 아이템을 만들도록 업그레이드할 수 있으며, 나중에 &6파편 대장간&r을 사용하여 광석 처리를 자동화하는 데 사용할 수도 있습니다."
	]
	quest.50B7CA94F8BB6F58.title: "&f회전하여 승리하기"
	quest.50BB7069AC5A1A14.quest_desc: [
		"&c성채&r에서 &d공허 균열&r 고리에서 생성되는 \\&zTyros&r를 찾을 수 있습니다."
		""
		"보스를 소환하려면 &c불꽃 영혼 소환기&r가 필요합니다."
	]
	quest.50BB7069AC5A1A14.title: "&c에코 오브 타이로스 처치"
	quest.50E133C3E351255E.quest_desc: [
		"기계를 사용하여 자원을 만드는 대신 &eRoost Ultimate&r 모드의 닭을 키울 수 있습니다!"
		""
		"이 모드에는 합금을 제외한 대부분의 자원에 대한 닭 유형이 포함되어 있습니다. 합금은 유체 소로 만들 수 있습니다!"
		""
		"알과 깃털을 얻었다면 &a치킨 스틱&r을 만들어야 합니다. 이것은 모드의 렌치 역할을 하며, 세계에서 닭을 집어 올릴 수 있게 해줍니다."
	]
	quest.50E133C3E351255E.quest_subtitle: "궁극의 둥지"
	quest.50E133C3E351255E.title: "&f닭!!"
	quest.50EFBD8BDE0C88AF.quest_desc: ["&a범위 업그레이드&r는 &3무선 송신기&r의 범위를 16블록에서 최대 48블록까지 증가시킵니다."]
	quest.5119EFBB9FB39CDE.quest_desc: ["&d비전의 숲&r 구조물에서 이것을 찾거나, &d너무 많이 알았던 사제의 이야기!&r 관문에서 찾을 수 있습니다."]
	quest.5119EFBB9FB39CDE.title: "&d대사제 처치"
	quest.511B01F40006FC4B.quest_desc: [
		"\\&z무한 도구&r는 블록을 즉시 부술 수 있는 내구성이 없는 도구입니다."
		""
		"\\&z곡괭이&r와 \\&z삽&r는 'Shift + 우클릭'하여 모드를 전환할 수 있으며, 월드의 넓은 영역을 즉시 증발시킵니다."
	]
	quest.511B01F40006FC4B.title: "\\&z무한의 도구"
	quest.5151A30EB06C1122.quest_desc: [
		"수동으로 생성된 닭은 무작위로 달걀을 떨어뜨릴 수 있지만, 닭보다 먼저 달걀을 얻을 수도 있습니다."
		""
		"이것들은 &b약탈 벌&r 이벤트에서 무작위로 떨어지거나, 운이 좋다면 &b치킨 조키&r 이벤트에서도 알을 얻을 수 있습니다."
		""
		"[\"With access to eggs and feathers, you can get started on the \", { \"text\": \"Roost Ultimate\", \"color\": \"yellow\", \"underlined\": true, \"clickEvent\": {\"action\": \"change_page\", \"value\": \"50E133C3E351255E\"}, \"hoverEvent\": {\"action\": \"show_text\", \"contents\": \"Go to Roost Starting Quest\"} }, \" mod, allowing your chickens to produce other resources than just plain old eggs.\"]"
	]
	quest.5151A30EB06C1122.title: "&f닭이 먼저냐, 달걀이 먼저냐?"
	quest.517AAA103D89A14F.quest_desc: [
		"&6치킨 트레이너&r는 닭이 레벨을 올리는 체육관입니다."
		""
		"닭을 빠르게 강화하고 싶다면, 조련사에 넣고 등급별 씨앗을 먹이세요."
		""
		"재료를 생산하는 대신, 씨앗이 소모되고 닭에게 전체 경험치를 제공합니다."
	]
	quest.517AAA103D89A14F.quest_subtitle: "훈련 몽타주 큐"
	quest.517AAA103D89A14F.title: "체육관 가기"
	quest.51804232265672A9.quest_desc: [
		"&a쓰레기 슬롯&r 모드를 사용하면 모든 인벤토리에 슬롯을 열어 원치 않는 아이템을 삭제할 수 있습니다."
		""
		"[\"The slot in the inventory can be toggled with the keybind \", { \"keybind\": \"key.trashslot.toggle\", \"color\": \"green\" }, \".\"]"
		""
		"[\"You can also quickly delete items once the slot is open by using the keybind \", { \"keybind\": \"key.trashslot.delete\", \"color\": \"green\" }, \".\"]"
		""
		"인벤토리 상단 왼쪽에 있는 &a쓰레기통&r 아이콘을 사용할 수도 있습니다. &a/trashcan&r 명령어로도 접근할 수 있습니다."
	]
	quest.51804232265672A9.title: "&f인벤토리 쓰레기통!"
	quest.519C754DF20BF31E.quest_desc: ["구 점액으로 플랫 블록"]
	quest.519C754DF20BF31E.quest_subtitle: "(메아리 판매)"
	quest.51B3EF0BCEB804A4.quest_desc: [
		"&3업그레이드&f에 필요한 블록을 제출하고 보상을 받으면 팀의 &6월드 엔진&r이 자동으로 조립됩니다."
		""
		"&e참고&f: 업그레이드가 있어야 할 곳에 놓인 블록은 무효화됩니다."
	]
	quest.51B3EF0BCEB804A4.title: "&f자동 제작: &3드라코닉 업그레이드"
	quest.51EBCDC63A047562.quest_desc: [
		"&eMalum&r을 통해 3가지 종류의 갑옷을 사용할 수 있습니다."
		""
		"&a소울헌터 갑옷&r은 가죽 등급보다 약간 더 나은 보호 기능을 제공합니다."
		""
		"&b소울스테인드 갑옷&r은 다이아몬드 등급의 보호 기능을 제공합니다."
		""
		"&d악성 요새 갑옷&r은 네더라이트 등급의 보호 기능을 제공합니다."
	]
	quest.51EBCDC63A047562.title: "&eMalum &f갑옷"
	quest.51F3F949B8426B43.title: "크로니톤 유리 블록 거래"
	quest.521580755F40E4CC.quest_subtitle: "RS2"
	quest.521580755F40E4CC.title: "크리에이티브 컨트롤러"
	quest.527A754FEFC95F4C.quest_desc: ["이제 &r카오스&d를 말 그대로 짜냈으니, &d카오스&r &6에코본&r으로 돌아갈 시간입니다."]
	quest.527A754FEFC95F4C.title: "&f대화하기: &6카오스"
	quest.52ADC3D46CCB2659.quest_desc: [
		"&a연금술&r은 &d몹 스포너&r를 옮기고 업그레이드하는 기능을 제공하여 자신만의 몹 농장을 만드는 데 유용합니다. 스포너를 옮기려면 &b섬세한 손길&r이 부여된 곡괭이로 부수세요."
		""
		"몹 스포너는 &a몹 알&r을 사용하여 변경할 수 있으므로 자신만의 맞춤 스포너를 만들 수 있습니다. 스포너에 특정 아이템을 사용하면 더 빠르게 작동하고, 스폰 규칙을 무시하는 등 업그레이드할 수도 있습니다!"
		""
		"어떤 아이템을 사용해야 하는지 더 알아보려면 스포너에 대한 JEI 레시피를 확인하세요."
	]
	quest.52ADC3D46CCB2659.title: "어포시오시스 스포너"
	quest.52B46D49B5C4A7F2.quest_desc: ["&d가스 연소 발전기&r는 &d에텐⟧&r을 태워 매우 높은 속도로 전력을 생산할 수 있습니다! 각 발전기가 가득 차면 약 8k RF/t를 생산할 것으로 예상됩니다."]
	quest.52C305EDBE2CCC55.quest_desc: [
		"&a그리드&r를 사용하면 네트워크의 여러 부분을 다른 방식으로 상호 작용하고 볼 수 있습니다."
		""
		"표준 &a그리드&r를 사용하면 저장 네트워크의 리소스를 보거나, 제거하거나, 삽입하고, 레시피 요청을 보내는 등 다양한 작업을 할 수 있습니다."
		""
		"&3제작 그리드&r는 일반 &a그리드&r의 모든 기능을 제공하며, 통합 제작대도 제공합니다."
	]
	quest.52C305EDBE2CCC55.title: "네트워크 액세스"
	quest.53060D307C063C25.quest_desc: ["&a와이번 코어&r는 대부분의 &eDE&r 제작법 및 아이템에 사용되는 업그레이드된 제작 구성 요소입니다."]
	quest.534F1C46873C1358.quest_desc: [
		"이 줄의 발전기는 &a중반 발전기&r로 간주됩니다!"
		""
		"이 발전기들은 약간의 진행을 이루고 여러 &6월드 엔진 업그레이드&r를 잠금 해제하면 사용할 수 있게 됩니다."
		""
		"그중 일부는 &6파워&r &d리액터&r와 같이 후반 게임까지 업그레이드하거나 확장할 수 있습니다."
	]
	quest.537DE7A354AF8E9E.quest_desc: [
		"&b몹 그라인딩 유틸리티&r는 몹 농장에서 몹을 쉽게 이동시킬 수 있는 블록을 제공합니다."
		""
		"&a몹 팬&r은 몹을 밀어낼 수 있으며, 작업 영역을 늘리기 위해 업그레이드할 수 있습니다."
		""
		"&a개체 컨베이어&r는 몹을 화살표 방향으로 미는 바닥 블록입니다. 플레이어는 위에 있을 때 웅크리면 효과를 무효화할 수 있습니다."
	]
	quest.537DE7A354AF8E9E.title: "&f몹 이동시키기"
	quest.5388B67410670702.quest_desc: [
		"[\"\", {\"text\": \"Draconic\", \"color\": \"gold\"}, \" weapons are upgraded versions of \", {\"text\": \"Wyvern\", \"color\": \"light_purple\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"2C141655079AC173\" }, \"hoverEvent\": {\"action\": \"show_text\", \"contents\": \"Go to Wyvern Weapons Quest\"}}, \" weapons, with room for more \", {\"text\": \"Upgrade Modules\", \"color\": \"green\"}, \" and better customizability.\"]"
		""
		"모든 것을 갖춘 도구이자 무기인 &6드라코닉 파워 스태프&r도 제작할 수 있습니다."
		""
		"모듈 인벤토리는 기본적으로 바인딩되지 않은 &e도구 모듈&r 키바인드를 통해 접근할 수 있습니다."
	]
	quest.5388B67410670702.title: "&6드라코닉 &f무기"
	quest.53C947D1E96420A1.quest_desc: [
		"&a원자 분해기&r를 사용하여, 광물 변환용 렌즈인 &d채굴자의 렌즈&r를 설치하여 전력을 사용하여 특정 돌 블록을 광석으로 변환할 수 있습니다."
		""
		"이 렌즈는 돌, 심층암, 네더랙을 광석으로 변환할 수 있습니다."
		""
		"자동화하면 광석 생성에 매우 강력할 수 있습니다!"
	]
	quest.53D550D3FD459ED2.title: "안내 완료 2"
	quest.53E949B1A0D04290.quest_desc: [
		"가장 작은 크기의 &6주조 공장&r의 외부 벽을 설치하려면 최소 21개의 &c불 벽돌&r이 필요합니다."
		""
		"&7&o이것들은 당신의 기지 미학에 맞게 염색될 수 있습니다."
	]
	quest.53E949B1A0D04290.title: "&6주조 공장 &f외부 구조"
	quest.5417C0BED57AE8DA.quest_desc: ["네더 파우나를 소비하여 전력을 생성합니다."]
	quest.543C6917A16F266C.quest_desc: [
		" \\&z중성자 활성기&r를 사용하면 이제 태양의 힘으로 &a핵 폐기물&r을 변환할 수 있습니다."
		""
		"이것은 &6초임계 위상 변환기&r를 사용하여 \\&z반물질&r을 생성할 수 있게 해줍니다."
		""
		"[\"\", {\"text\": \"Note\", \"color\": \"yellow\"},  \": Take a look at the \", {\"text\": \"Mekanism Reactor\", \"color\": \"light_purple\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"49B8310D0C7A6C55\"}, \"hoverEvent\": {\"action\": \"show_text\", \"contents\": \"Go to Reactor Quest\"}}, \" quest if you want to learn more about creating Reactors and converting Nuclear Waste.\"]"
		""
		"또한, 다른 팩에 비해 &a핵 폐기물&r의 양이 절반만 필요합니다."
	]
	quest.543C6917A16F266C.title: "\\&z반물질&r"
	quest.54404B81EAC760E8.quest_subtitle: "(메아리 판매)"
	quest.5455CF5D3C37ECA9.quest_desc: [
		"&c네더라이트 괴물&r은 &3영혼 대장간&r에서 찾을 수 있습니다."
		""
		"이것은 &c네더&r 고리의 위쪽 부분에 있습니다."
	]
	quest.5455CF5D3C37ECA9.title: "&c네더 괴물&r 처치"
	quest.54A1D7A1D89C1A04.quest_desc: ["&b서리 감옥&r 던전은 &b바다&r 고리의 위쪽 부분에서 찾을 수 있습니다."]
	quest.54A1D7A1D89C1A04.title: "&b서리 감옥 찾기"
	quest.54A433FAF8A65CC0.quest_desc: [
		"&a주민&r을 치료했다면, &d인도의 메아리&r는 그들의 기술을 활용할 수 있는 도구를 제작하는 방법을 알고 있습니다. 이 도구를 만들려면 &6월드 엔진&r을 사용해야 합니다."
		""
		"&6월드 엔진&r은 고대 제작법의 힘을 활용하여 현재 지식을 초월하는 고급 아이템을 만들 수 있습니다."
		""
		"&6월드 엔진&r에 도달하려면, &a크로논 셀&r에 &b크로논&r이 들어 있을 때 웅크리기 + 우클릭하여 포탈을 활성화해야 합니다."
		""
		"당신의 목표는 자수정에 저장된 잠재적인 마법의 힘을 사용하여 &a메아리 인코더&r를 제작하는 것입니다."
		"{@pagebreak}"
		"[\"There are 2 main ways to get \", {\"text\": \"Leather\", \"color\": \"green\"}, \" early on: \", {\"text\": \"Killing a Cow\", \"color\": \"dark_green\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"0ACCAD3AEF57F2E2\"}, \"hoverEvent\": {\"action\": \"show_text\", \"contents\": \"Go to Grass Quest\"}}, \", or by using \", {\"text\": \"Rotten Flesh\", \"color\": \"red\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"277181E358575312\"}, \"hoverEvent\": {\"action\": \"show_text\", \"contents\": \"Go to Rotten Flesh Quest\"}}, \".\"]"
	]
	quest.54A433FAF8A65CC0.title: "&f첫 번째 월드 제작"
	quest.54B7D149B45635F4.quest_desc: ["&d크로노미터&r는 &a크로논 발전기&r보다 개선된 버전으로, 이전보다 더 많은 &b크로논&r을 수동으로 생성합니다."]
	quest.551964C1A41FA3D0.quest_desc: [
		"더 높은 등급의 재료를 얻으려면 닭이 필요하며, 닭을 &a부화기&r에서 함께 번식시켜야 합니다."
		""
		"번식이 성공하려면 닭 2마리와 번식하려는 닭의 특정 등급 씨앗을 제공해야 합니다. JEI가 번식 레시피를 찾는 데 가장 큰 도움이 될 것입니다!"
		""
		"필요한 씨앗 등급을 보려면 JEI에서 레시피를 볼 때 씨앗 위에 마우스를 올려놓으세요. 그러면 필요한 씨앗 등급이 표시됩니다."
	]
	quest.551964C1A41FA3D0.title: "닭 번식시키기"
	quest.5535D64E2B05005E.quest_desc: [""]
	quest.5535D64E2B05005E.quest_subtitle: "파괴자 블록 및 엔더릭 레이저의 작업 영역 크기 증가"
	quest.555BB3F7C11CD6F9.title: "광휘 확인 1"
	quest.558A4BBC3BDB853D.quest_desc: ["&6말쿠트&r를 &d공허&r 고리의 &6말쿠트 경기장&r에서 처치하고 &c트로피를 제출&r하여 현상금을 받으세요."]
	quest.55D17BDE3E9C81CC.quest_desc: [
		"&3업그레이드&f에 필요한 블록을 제출하고 보상을 받으면 팀의 &6월드 엔진&r이 자동으로 조립됩니다."
		""
		"&e참고&f: 업그레이드가 있어야 할 곳에 배치된 블록은 사라집니다."
	]
	quest.55D17BDE3E9C81CC.title: "&f자동 건설 &3포트론 업그레이드"
	quest.55DB51D88B9C5724.quest_subtitle: "주석과 구리의 합금"
	quest.55DF810785A9B938.title: "촉매 확인 1"
	quest.562156281B8D0843.quest_desc: [
		"이 기계는 &b물&r과 같은 특정 액체를 2개의 별도 &a기체&r로 분해하는 데 사용됩니다."
		""
		"첫 번째 용도는 물을 산소와 수소로 분리하는 것입니다. &b물&r을 &e산소&r와 &e수소&r로 분리합니다. &a산소&r는 &a정화기&r를 포함한 여러 기계에 필요합니다."
	]
	quest.562156281B8D0843.title: "&f전해 분리기&a"
	quest.5624865A6F796087.quest_desc: [
		"&a복제기&r는 당신의 물질 네트워크의 핵심 작동 기계입니다."
		""
		"아이템이 &d메모리 칩&r에 설정되고 &a복제 단말기&r에서 요청되면, 작업은 사용 가능한 &a복제기&r로 보내져 저장된 물질을 사용하여 제작됩니다."
	]
	quest.56519A6A39FA9430.quest_desc: [
		"&d필드 프로젝터&r의 매트릭스 슬롯을 통해 필드의 영역에 추가적인 조정을 적용할 수 있습니다. 각 슬롯에 하나 이상을 삽입할 수 있지만 대부분은 쌓이지 않습니다."
		""
		"하나의 &b침묵 모듈&r은 실행 중인 &d필드 프로젝터&r를 침묵시킵니다."
		""
		"&b돔 모듈&r은 투사된 모드를 조정하여 &d필드 프로젝터&r의 높이와 그 위에서만 생성되도록 합니다."
		""
		"&b위장 모듈&r은 투사된 필드가 매트릭스 슬롯에 있는 왼쪽 블록의 외관을 복사하도록 합니다. &o참고: 일부 비표준 블록은 복사되는 것을 좋아하지 않습니다. 자신의 책임하에 다른 모드 기계를 모방하세요.&r"
		"{@pagebreak}"
		"&b충격 모듈&r을 &d필드 프로젝터&r에 추가하면 보호막이 접촉하는 개체에게 모듈당 1의 피해를 입힙니다."
		""
		"&b빛 모듈&r은 필드 블록이 빛을 방출하도록 하며, 밝기는 4개의 모듈마다 발광석 수준까지 1씩 증가합니다."
	]
	quest.56519A6A39FA9430.title: "&f기능성 보호막"
	quest.5672B339AE16EE6C.quest_desc: [
		"이것은 당신의 상자를 위한 필수 업그레이드 중 하나입니다!"
		""
		"&a스택 업그레이드&r는 상자 안의 각 슬롯에 대한 스택 제한을 증가시킵니다. 이 업그레이드는 &a정교한 배낭&r 업그레이드보다 훨씬 저렴합니다."
	]
	quest.56E9C123DD727E46.quest_desc: [
		"&e방해 매트릭스&r에는 시스템의 &a생체 인식 식별자&r에 정의된 등록 및 권한을 기반으로 작동하는 &b모듈&r을 위한 8개의 슬롯이 있습니다."
		""
		"&b경고 모듈&r은 &e매트릭스&r의 추가 경고 범위를 모듈당 1블록씩 증가시킵니다. 기본적으로 다른 &b모듈&r의 범위를 벗어나는 3블록 반경이 등록되지 않은 플레이어에게 &e매트릭스의&r 행동에 영향을 받을 수 있음을 알립니다. 이것은 스택 효과가 있는 유일한 모듈입니다."
		""
		"&b블록 접근 모듈&r은 권한이 없는 플레이어가 레버, 기계 등과 상호 작용하는 것을 방지합니다."
		""
		"&b블록 변경 모듈&r은 위의 모듈과 유사하게 작동하지만, 블록의 파괴 및 설치를 완전히 금지합니다."
		""
		"{@pagebreak}"
		"&b몰수 모듈&r은 멀티플레이에서 &4매우 악랄할 수 있습니다&r. &e매트릭스&r의 나머지 9개 슬롯을 사용하여 최대 9개의 아이템을 등록되지 않은 플레이어의 인벤토리에서 가져오거나 남겨둘 수 있으며, 가져온 아이템은 &e매트릭스&r에 떨어뜨리거나 인접한 인벤토리에 배치됩니다. 이는 갑옷에도 적용됩니다. 일반적으로 &4친근한&r 서버에서 사용할 때는 &a주의하십시오&r..."
		""
		"&b반 적대&r, &b-적대적&r, 및 &b-인원 모듈&r은 매트릭스가 각각 동물, 적대적 생명체, 등록되지 않은 플레이어를 극도로 높은 피해로 처치하게 합니다."
		""
		"&b스폰 방지 모듈&r은 &e매트릭스&r의 작동 반경 내에서 모든 몹의 스폰을 방지합니다."
	]
	quest.56E9C123DD727E46.title: "&a매트릭스 동기화 장치"
	quest.56FB1BC5711CC4F9.quest_desc: [
		"이 나침반은 &3금고&3의 위치를 가리킵니다."
		""
		"&7&o나침반은 금고에서 256블록 이내에 있을 때 쉬프트 + 우클릭하면 입구로 즉시 순간이동할 수 있습니다!&r"
	]
	quest.56FB1BC5711CC4F9.title: "&f금고 찾기&3"
	quest.575A111D4418BFB6.quest_desc: [
		"&6메트로놈&r은 궁극의 &b크로논&r 생성 도구입니다."
		""
		"생산을 시작하려면 약 &b2000 크로논&r을 제공해야 합니다."
		""
		"&6메트로놈&r은 입력 및 출력 슬롯을 가지고 있어 &d크로논 배터리&r처럼 작동하며, 비공개로 설정할 수 있는 내부 네트워크의 다른 &6메트로놈&r과 연결할 수 있습니다."
		""
		"&e참고&f: &6메트로놈&r은 &c절대&f &a액션 패드&r를 통한 순간이동을 위한 신뢰할 수 있는 크로논 저장소가 아닙니다."
	]
	quest.575A111D4418BFB6.title: "&6메트로놈"
	quest.5777C137BF472784.title: "엔드 조각"
	quest.5778BAEC8F095B3D.quest_desc: [
		"&e레이저IO&r를 사용하면 레이저를 사용하여 거의 모든 것을 전송할 수 있습니다!"
		""
		"시작하려면 &a레이저 노드&r와 이를 연결하기 위한 &c레이저 렌치&r가 필요합니다. 이것들은 레이저가 부착된 블록과 직접 상호 작용할 수 있게 해주는 모드의 주요 블록입니다."
		""
		"설정 방법을 알아보려면 다음 페이지를 확인하세요!"
		""
		"&e참고&r: &a로직 칩&r은 제작을 위해 &b포트론 주입 블록&r &6월드 엔진 업그레이드&r가 필요합니다."
		"{@pagebreak}"
		"레이저가 블록과 상호 작용하는 방식을 설정하려면, 원하는 작업을 지정하기 위해 &a카드&r를 설치해야 합니다."
		""
		"이 카드들은 매우 구성 가능합니다. 예를 들어, &a아이템 카드&r는 별도의 인벤토리에서 아이템을 가져오거나 밀어내는 데 사용될 수 있으며, 정밀한 자동화를 위해 필터링될 수 있습니다."
		"{@pagebreak}"
		"&a레이저 노드&r의 인터페이스를 열면 노드의 각 면에 대한 탭이 있습니다. 이것은 카드가 작동하는 면을 결정합니다. 카드를 해당 면의 "
		""
		"카드는 다른 블록과 상호 작용하는 속도를 높이기 위해 업그레이드할 수 있으며, 자동화를 위해 매우 빠른 속도를 제공합니다. 또한 필터링하고 특정 채널로 설정할 수도 있습니다."
		""
		"모든 &a레이저 노드&r에서 항상 직선 레이저가 나오는 것은 아닙니다. 이때 &a레이저 커넥터&r가 사용됩니다!"
	]
	quest.5778BAEC8F095B3D.title: "레이저IO"
	quest.57CBEE2A35F98614.quest_desc: ["&d매트릭스 어셈블러&r의 외부 가장자리는 &a어셈블러 매트릭스 프레임&r으로 구성되어야 합니다."]
	quest.57CBEE2A35F98614.title: "&d어셈블러 매트릭스 프레임"
	quest.57DF1A1F0556B970.quest_desc: [
		"&6산업적 제조&r에는 마법 부여를 다룰 때 도움이 되는 여러 기계가 있습니다."
		""
		"&d마법 부여 적용기&r는 기계식 모루처럼 작동합니다. 아이템에 마법을 부여하기 위해 경험치를 사용하는 대신 &a에센스&r를 사용합니다."
		""
		"&d마법 부여 분류기&r는 마법 부여된 아이템과 마법 부여되지 않은 아이템을 필터링하여, 마법 부여된 모든 것을 상단 출력으로 보냅니다. 파이프를 통해 추출하기 위해 다른 면으로 보낼 수 있습니다."
		"{@pagebreak}"
		"&d마법 부여 추출기&r는 책이 제공될 때 마법 부여된 아이템에서 마법 부여된 책을 분리하여 사용하지 않는 장비의 마법 부여를 수확합니다."
		""
		"&d마법 부여 공장&r은 상당한 양의 &a에센스&r를 사용하여 레벨 30의 마법 부여로 책을 자동으로 마법 부여합니다."
	]
	quest.57DF1A1F0556B970.title: "마법 부여 기계"
	quest.57ED7DBAC5E8C5BE.quest_desc: [
		"&eMekanism&r의 &d활력 유도 매트릭스&r는 엄청난 양의 전력을 저장하는 궁극적인 방법입니다!"
		""
		"이것은 모든 전력 저장 요구를 충족시키기 위해 최대 18x18x18까지 구축할 수 있는 사용자 정의 멀티블록 구조입니다. 전력을 빼내고 밀어 넣으려면 &aInduction Cell&r 1개, &aInduction Provider&r 1개, 그리고 &aInduction Ports&r만 있으면 됩니다."
		"{@pagebreak}"
		"이를 구축하기 위한 가장 작은 구조는 3x4x3 멀티블록입니다. 프레임은 &aInduction Casings&r으로 만들어야 하며, 면은 &aStructural Glass&r 또는 &aInduction Ports&r일 수 있습니다."
		""
		"구조물 안에는 &aInduction Cells&r와 &aProviders&r를 배치하게 됩니다. 프로바이더는 매트릭스가 전력을 얼마나 빨리 밀거나 당길 수 있는지를 결정하는 반면, 셀은 저장할 수 있는 최대 전력량을 결정합니다. 구조물 안에 배치하는 한, 원하는 만큼 각 요소를 혼합하여 사용할 수 있습니다."
		"{@pagebreak}"
		"&aInduction Ports&r는 &aConfigurator&r를 사용하여 엿보기로 사용하면 전력을 입력하거나 출력하도록 구성할 수 있습니다. 첫 번째 매트릭스에는 최소 2개를 사용하는 것을 추천합니다!"
	]
	quest.57ED7DBAC5E8C5BE.title: "&f에너지화된 유도 매트릭스&d"
	quest.5804356B2AFCF14A.quest_desc: [
		"&3업그레이드&f에 필요한 블록을 제출하고 보상을 받으면 팀의 &6월드 엔진&r이 자동으로 조립됩니다."
		""
		"&e참고&f: 업그레이드가 있어야 할 곳에 배치된 블록은 무효화됩니다."
	]
	quest.5804356B2AFCF14A.title: "&fAuto-Build The &3Infinity Upgrade"
	quest.580866E99C53DB3E.quest_desc: [
		"상자에서 주변 아이템을 줍도록 허용하는 다양한 업그레이드가 있습니다."
		""
		"기본 레벨은 &a픽업 업그레이드&r이지만, &a마그넷 업그레이드&r로 업그레이드하면 더 많은 옵션과 더 넓은 범위를 사용할 수 있습니다!"
	]
	quest.580866E99C53DB3E.title: "&a업그레이드 줍기"
	quest.580CDFD2B7675485.quest_desc: [
		"&6Draconic Evolution&r의 아이템을 제작하려면 &d퓨전 제작&r이라는 특별한 제작 설정이 필요합니다."
		""
		"&d퓨전 제작 코어&r는 설정의 중앙에 있어야 하며, &d드라코늄 퓨전 제작 이젝터&r는 코어를 향해 2블록 간격으로 배치해야 합니다."
		""
		"코어는 시작을 위해 레드스톤 신호도 필요합니다."
		"{@pagebreak}"
		"&d와이번 퓨전 인젝터&r로 업그레이드하려면 코어 주위에 최소 8개의 &d드라코늄 인젝터&r가 배치되어 있어야 합니다."
		""
		"업그레이드를 제작하기 위해 필요한 각 아이템을 인젝터에 넣을 수 있습니다. 각 인젝터는 전력도 필요합니다."
		""
		"모든 아이템을 인젝터에 넣은 후, 메인 아이템을 코어에 넣으면 레드스톤 신호가 들어올 때 제작이 시작됩니다."
	]
	quest.580CDFD2B7675485.title: "&d퓨전 제작&r"
	quest.583FFE29C881EE8C.quest_desc: [
		"모드 내의 모든 블록, 예를 들어 &aFlux Plug&r 또는 &aPoint&r에서 네트워크 UI에 접근할 수 있습니다."
		""
		"거기서 첫 번째 네트워크를 만들 수 있습니다! UI의 가장 오른쪽 탭에서 &a+&r를 클릭하여 새 네트워크를 만들 수 있습니다."
		"{@pagebreak}"
		"이 화면에서 네트워크 이름을 변경하고 구성 옵션을 공개, 비공개 또는 암호화로 전환하여 서버 사용에 적합한 전력 전송 모드로 만들 수 있습니다."
		""
		"{image:ftb:textures/quests/fluxnetworks/new_network.png width:140 height:150 align:center}"
		""
		"옵션 구성을 마쳤으면 하단의 &b만들기&r를 누르면 됩니다!"
		"{@pagebreak}"
		"그러면 &a네트워크 목록&r으로 이동합니다. 이 목록에서 방금 만든 네트워크를 포함하여 자신에게 사용 가능한 모든 네트워크를 볼 수 있습니다!"
		""
		"네트워크에 연결해야 하는 모든 장치에 대해, 장치를 배치할 때마다 가장 먼저 할 일입니다."
		""
		"{image:ftb:textures/quests/fluxnetworks/network_list.png width:140 height:150 align:center}"
		""
		"네트워크를 선택한 후 홈 페이지로 이동하여 장치 설정을 구성할 수 있습니다."
		"{@pagebreak}"
		"&b홈&r 페이지에서는 장치의 여러 부분, 즉 &a이름&r, &d우선순위&r, &c전송 제한&r을 구성할 수 있습니다."
		""
		"{image:ftb:textures/quests/fluxnetworks/network_configure.png width:140 height:150 align:center}"
		""
		"&d우선순위&r 숫자가 높을수록 네트워크의 전력에 더 많은 우선순위를 갖게 됩니다."
		""
		"&c전송 제한&r을 통해 장치가 네트워크에서 끌어올 수 있는 양을 제어할 수 있습니다."
		"{@pagebreak}"
		"원하는 경우 하단의 토글을 사용하여 이러한 설정을 재정의할 수도 있습니다!"
		""
		"&a전력 서지&r는 모든 우선순위 설정을 무시하고 장치가 네트워크에서 가장 높은 우선순위를 갖도록 강제합니다."
		""
		"&a우회 제한&r은 장치의 전송 제한 설정을 무시하고 최대치로 설정합니다."
	]
	quest.583FFE29C881EE8C.title: "네트워크 설정"
	quest.584B4C34CBF0E028.quest_desc: [
		"&a부여의 방&r은 천천히 세계에서 마법 정수를 끌어낼 수 있지만, &d정수&r를 생성할 수는 없습니다. 이 정수는 &6월드 엔진&r을 업그레이드하는 데 필요합니다."
		""
		"&d정수&r는 &a소스링크&r를 사용하여 여러 다른 소스에서 끌어올 수 있습니다. 다양한 옵션이 있지만, &2농업 소스 링크&r는 훌륭한 시작점입니다."
		""
		"또한 링크가 수집하는 &d정수&r를 저장할 방법이 필요하며, 이는 링크 근처에 &a정수 단지&r를 배치하여 쉽게 할 수 있습니다."
	]
	quest.584B4C34CBF0E028.title: "&f정수 생성하기&d"
	quest.5868F616B3756FF3.quest_desc: [
		"지금까지는 주먹을 잘 사용했지만, 이제는 한 단계 더 발전할 때입니다."
		""
		"그 &2잎사귀&r에는 생기가 있습니다. 그것을 찾으려면 부수기만 하면 됩니다."
		""
		"&a대야&r를 내려놓고, 그 위에 &2잎사귀&r를 올려놓으세요. 마지막 한 방울까지 짜낼 때까지 밟으세요."
		""
		"이렇게 하면 &b물&r이 생성되지만, 퍼낼 방법이 필요할 것입니다..."
	]
	quest.5868F616B3756FF3.title: "&f밟는 것을 잊지 마세요"
	quest.586C935010D2FE74.quest_desc: ["이 퀘스트 보상을 받으면 &d에코의 &6기록보관소&r 입구에 웨이포인트가 설정됩니다."]
	quest.586C935010D2FE74.title: "&f황혼 찾기&d"
	quest.58982359699AFB7F.quest_desc: [
		"&a설정 카드&r는 네트워크 장치의 설정과 업그레이드를 복사하고 붙여넣을 수 있는 매우 유용한 도구입니다."
		""
		"네트워크 장치를 Shift + 우클릭하여 다른 장치에 설정을 복사하고 붙여넣으세요. Shift + 우클릭하여 저장된 설정을 지울 수 있습니다."
	]
	quest.58BC57B1119204CA.title: "마법사 만남"
	quest.58DDBF43D54AF67F.quest_desc: ["&e말룸&r 무기는 종종 모드의 다른 기능과 매우 잘 시너지를 내는 특별한 능력을 가지고 있어 상당한 양의 피해를 입힙니다."]
	quest.58DDBF43D54AF67F.title: "&e말룸 &f무기"
	quest.592A206B63BF556E.quest_desc: [
		"&6배터리&r는 &dCAD&r에 있는 &b선택적 부착물&r입니다. 기본 Psi 에너지가 부족할 때 즉시 방출할 수 있는 &b예비 Psi 에너지 양&r을 가질 수 있습니다."
		""
		"&e&n보조 배터리처럼요!&r"
		""
		"이것은 특히 다음을 제공합니다:"
		""
		"► &a오버플로우&r: 100"
	]
	quest.592A206B63BF556E.title: "&a1단계&f CAD 배터리"
	quest.594911C1304689E9.quest_desc: [
		"&a내보내기 장치&r는 네트워크에서 리소스를 이동하는 데 사용됩니다."
		""
		"각 &e케이블 등급&r 업그레이드는 이전 등급보다 더 빠르게 작동하며 더 많은 필터 슬롯을 가지고 있습니다."
		""
		"&7&o각 아이템의 툴팁에서 정확한 속도를 확인하세요."
	]
	quest.594911C1304689E9.title: "내보내기 장치"
	quest.59497745146C1EFD.quest_desc: [
		"&a영혼이 깃든 도구&r와 무기는 &b영혼석 낫&r과 같은 방식으로 &e영혼석&r을 수집하는 데 사용할 수 있으며, 일반적인 도구와 동일한 특성을 가지지만, 조잡한 버전에서 업그레이드된 검과 &d티르빙&r이 제공됩니다."
		""
		"하지만 금속을 영혼과 물리적인 것 모두에 분할하는 것은 이 피해가 &e마찬가지로 분할됨&r을 의미하며, 피해의 절반은 좋든 나쁘든 마법 피해로 전환됩니다."
	]
	quest.59497745146C1EFD.title: "영혼이 깃든 장비"
	quest.5964573222E4FA19.quest_desc: ["이 퀘스트 라인은 일반적인 기술 모드를 보여줍니다."]
	quest.5964573222E4FA19.title: "일반 기술"
	quest.59A6D7B544F1AE06.quest_desc: [
		"쉬운 방법으로 기지의 다른 레벨로 이동하고 싶으신가요? &d엘리베이터&r를 만드세요!"
		""
		"이것들은 또한 &d엘리베이터&r에 직접 블록을 사용하여 다른 블록의 질감을 복사할 수 있습니다."
	]
	quest.59A6D7B544F1AE06.title: "&f엘리베이터"
	quest.59C71582F19E8554.title: "좀비 처치"
	quest.59CBFA5583139A3B.quest_desc: ["&d재련 테이블&r은 &a간단 재련 테이블&r의 개선된 버전으로, \\&z신화&r 아이템을 포함한 모든 희귀도의 아이템을 재련할 수 있습니다."]
	quest.59CBFA5583139A3B.title: "&d재련 테이블&r"
	quest.59D007531CD064D9.quest_subtitle: "아이언제이를 위해 제거해야 함"
	quest.59E8FEC3758635DF.quest_desc: [
		"&d메아리&r에 따르면, 최근 치료된 주민들은 숙련도가 낮습니다. 그들의 발굴 레벨을 높이기 위해 훈련시켜야 합니다!"
		""
		"&aUnearther&r에 배치되면 시간이 지남에 따라 천천히 레벨이 오릅니다."
		""
		"토큰을 사용하여 세계에 다시 배치할 수 있지만, &a메아리 인코더&r로 다시 가져와야 합니다."
		""
		"&c경고&r: 주민을 토큰으로 세계에 다시 배치하면 주민의 직업과 레벨이 사라집니다!"
		"{@pagebreak}"
		"음식 없이도 일할 수 있지만, 먹이를 주는 것이 좋을 것입니다."
		""
		"먹이는 음식에 따라 특별한 보너스를 줄 것입니다!"
		""
		"- 더 많은 샹크 = 더 빠른 작업 속도."
		""
		"- 더 많은 포화도 = 더 오래 지속되는 음식."
	]
	quest.59E8FEC3758635DF.title: "&f주민과 훈련 방법"
	quest.5A04F7A95366D15F.quest_desc: [
		"다이아몬드를 &b다이아몬타인&r으로 재구성하는 것은 &c고급 기계 블록&r의 코어를 만드는 첫 단계일 뿐입니다."
		""
		"이 코어는 전력이 제대로 흐르도록 해야 합니다. &b강화 장치&r를 사용하여 다이아몬드를 이 목적에 맞게 강화할 수 있어야 합니다."
		""
		"&e참고&r: 장치에는 장치의 중앙에 &a강화기&r가 있어야 하며, &a강화기&r의 각 면에서 두 블록 떨어진 곳에 전력에 연결된 4개의 &2진열대&r가 있어야 합니다."
	]
	quest.5A04F7A95366D15F.title: "&f다이아몬드 강화"
	quest.5A284AE3AC14D070.title: "&f1시간 플레이"
	quest.5A7056F1FB256B5F.quest_desc: ["이 장에서는 자원 생성을 자동화하는 다양한 방법에 대해 설명합니다!"]
	quest.5A793B307C82AB91.quest_desc: [
		"&2지질학자&r는 단단한 재료의 달인이며, &2조약돌&r, &7자갈&r, &a영혼 모래&r, 그리고 &a부순 키비&r를 처리할 수 있습니다. 작업대로 &a회수 작업대&r가 필요합니다."
		""
		"이 작업자는 레벨에 따라 대부분의 광석 조각과 보석을 생성하는 훌륭한 공급원이 될 수 있습니다."
		""
		"&2지질학자&r는 &a자이코리움 보석&r과 &a검은 석영&r과 같은 아이템을 생성하는 몇 안 되는 공급원 중 하나입니다."
	]
	quest.5A793B307C82AB91.title: "지질학자"
	quest.5A8CEB600CAADCD2.quest_desc: ["&b냉기술사&r는 &a얼어붙은 맹세의 진주&r 게이트웨이를 사용하여 찾을 수 있습니다."]
	quest.5A8CEB600CAADCD2.title: "&b냉기술사 처치"
	quest.5AC7EEC3D69AF032.quest_desc: [
		"&b셀레스티젬&r 도구는 &6Just Dire Things&r의 다음 등급 도구입니다."
		""
		"내구도를 사용하는 대신, 이 도구들은 대신 &c에너지&r를 사용하며, 더 많은 업그레이드를 설치할 수 있습니다."
		""
		"이것들은 &d고대 도시&r로 가서 &d보이드쉬머 구슬&r을 만든 후에 만들 수 있습니다."
	]
	quest.5AC7EEC3D69AF032.title: "&b셀레스티젬 도구"
	quest.5B23C2EB38DCEE6E.quest_desc: [
		"백금 + 네더라이트 합금"
		""
		"원자 단조 백금 + 강화 탄소 판 2개"
	]
	quest.5B512AED08EC1899.quest_desc: [
		"&a열 발전기&r는 그 아래에 놓인 블록의 &c열&r과 어떤 면에서든 펌핑되는 &b냉각수&r를 사용하여 전력을 생성합니다."
		""
		"JEI를 사용하여 모든 유효한 &c열원&r과 &b냉각수&r를 확인할 수 있습니다."
		""
		"&e참고&r: 물은 충분한 냉각수가 아닙니다. JEI에서 열 발전기에 &aU&r를 눌러 사용할 수 있는 냉각제와 열 블록을 확인할 수 있습니다."
	]
	quest.5B7448EEC26FF0E3.quest_desc: [
		"&a요리대&r는 주방을 만들기 시작할 때 가장 먼저 만들고 싶은 큰 제작품입니다!"
		""
		"이 블록은 음식의 주요 제작대로 작용하며, &a주방 멀티블록&r의 중심입니다. 열면 멀티블록에 저장된 것과 연결된 가전제품에 따라 만들 수 있는 모든 음식을 보여줍니다."
		""
		"&a찬장&r이나 &a카운터&r를 추가하여 주방을 확장할 수 있습니다."
		""
		"&e참고&r: &b농부의 딜라이트 요리 냄비&r와 같은 일부 모드는 연결되지 않습니다. 특정 레시피는 항상 JEI를 확인하세요!"
	]
	quest.5B7448EEC26FF0E3.title: "&a주방 멀티블록&r"
	quest.5BBA51F8FE4D6C3B.quest_desc: [
		"통과할지 말지를 선택할 수 있는 고체 블록입니다! 현재 상태를 토글하려면 마우스 오른쪽 버튼을 클릭하세요."
		""
		"몹은 비고체 상태에서 통과하는 방법을 모르지만, 여전히 밀리거나 떨어질 수 있습니다."
	]
	quest.5BE257CE3FD1FDAC.quest_desc: [
		"&6각성된 드라코늄&r으로 더 고급 아이템을 제작하기 위해 주입 설정을 업그레이드할 수 있습니다."
		""
		"이제 &d와이번 장비&r를 &6드라코닉 등급&r으로 업그레이드할 수 있습니다."
	]
	quest.5BE257CE3FD1FDAC.title: "&6각성된 주입"
	quest.5BF72200F151FF24.quest_desc: [
		"&6Psi&r는 비교적 간단한 재료 진행 과정을 가지고 있어 &bCAD&r에 더 나은 구성 요소를 잠금 해제할 수 있으며, 이를 통해 더 &d복잡하고&r &3멋진&r 주문을 시전할 수 있습니다."
		""
		"► 하지만 모든 것은 시작이 있어야 합니다. 단순히 땅에 &c레드스톤 가루&r 조각을 &6쏘아&r 땅에 떨어뜨리면 &6Psi 가루&r로 변환할 수 있어야 합니다!"
		""
		"&8&o● 아직 &l실제 CAD&r&8&o를 만들지 않았다면, 단순히 &nCAD 조립기 안에 넣으세요&r."
	]
	quest.5BF72200F151FF24.title: "첫 번째 사이 재료"
	quest.5C2C0986D6014ADD.quest_desc: [
		"수세기 동안 &a떠돌이 상인&r은 가능한 한 많은 플레이어를 개인적으로 귀찮게 하기 위해 노력해 왔습니다."
		""
		"오늘 그것은 끝납니다."
		""
		"&6AlfredGG&r의 이름으로 &a떠돌이 상인&r을 처치하세요."
		""
		"&7/cry를 시도해 보세요"
	]
	quest.5C2C0986D6014ADD.title: "&6개인적인 원한"
	quest.5C8773D5561D7245.quest_desc: [
		"&3업그레이드&f에 필요한 블록을 제출하고 보상을 받으면 팀의 &6월드 엔진&r이 자동으로 조립됩니다."
		""
		"&e참고&f: 업그레이드가 있어야 할 곳에 배치된 블록은 무효화됩니다."
	]
	quest.5C8773D5561D7245.title: "&fAuto-Build The &3Awakened Core Upgrade"
	quest.5CD461E6C3E8E7D1.quest_desc: ["&3심층암&r 고리 안에 있는 이 금고는 길을 잃기 쉽습니다."]
	quest.5CD461E6C3E8E7D1.title: "&3미로 금고"
	quest.5CD7299E8709E7F6.quest_desc: [
		"마을 주민이 변환한 &a작업자 토큰&r은 &a에코 인코더&r가 할 수 있는 일의 예시일 뿐입니다."
		""
		"특정 직업을 가진 마을 주민을 인코딩하면 &2Unearther&r에서 당신을 위해 일하게 할 수 있습니다."
		""
		"이것은 블록 솔질을 자동화할 수 있는 3x3x3 블록입니다. 약간의 주민 노동력만 있으면 됩니다!"
		""
		"&o언어더&7는 호퍼와 파이프를 통해 자동 아이템 입출력을 지원합니다."
	]
	quest.5CD7299E8709E7F6.quest_subtitle: "자동화"
	quest.5CD7299E8709E7F6.title: "&f주민 노동시키기"
	quest.5CDE33FC6A041416.quest_desc: ["&3자동 제작기 관리자&r를 사용하면 이 단일 블록에서 모든 &3자동 제작기&r를 구성할 수 있습니다."]
	quest.5CFC04F4F9A4B01D.quest_desc: [
		"&6오라이테크&r는 이를 위해 몇 가지 기본 &b파이프&r를 제공합니다! 물론 파이프를 구성할 방법도 필요할 텐데, 바로 여기서 &a렌치&r가 사용됩니다."
		""
		"빈 손으로 &b파이프&r를 우클릭하면 파이프가 추출하도록 설정됩니다!"
		"{@pagebreak}"
		"&b파이프&r 끝에 있는 &a렌치&r를 사용하면 &b파이프&r가 연결된 모든 것에서 분리됩니다. 다시 연결하려면 &b파이프&r 중간에 있는 &a렌치&r를 사용하세요."
		""
		"Shift + &a렌치&r를 &b파이프&r에 사용하면 즉시 파괴됩니다."
		"{@pagebreak}"
		"&b파이프&r 처리량:"
		""
		"- 아이템 파이프: 5틱당 8개"
		"- 유체 파이프: 3틱당 500mb"
		"- 에너지 파이프: 1틱당 10k RF."
	]
	quest.5CFC04F4F9A4B01D.title: "오라이테크 파이프"
	quest.5D1DD9EA59C3078D.title: "엔더 드래곤 데이터 모델"
	quest.5D20790BCDE45CF9.quest_desc: [
		"이 아이템은 현재 버그 수정 중이므로 비활성화되어 있습니다. 불편을 드려 죄송합니다."
		"{@pagebreak}"
		"&6오라이텍&r의 &d엔더릭 레일건&r은 고속 투사체를 발사하여 적에게 상당한 피해를 입히고 멀리서 블록을 부수는 강력한 원거리 무기입니다."
		""
		"왼쪽 마우스 버튼으로 연속 빔을 발사하여 경로상의 모든 개체에 피해를 주고, 직선상의 첫 번째 블록을 채굴할 수도 있습니다. 에너지 함유 블록에 에너지가 전달되면 파괴되는 대신 에너지가 전달됩니다. &a엔더릭 레이저&r와 유사하게 채굴된 블록을 변환할 수도 있습니다."
		"{@pagebreak}"
		"채굴 모드는 아이템을 손에 든 채 Shift + 우클릭하여 토글할 수 있습니다."
		""
		"오른쪽 마우스 버튼을 사용하면 강력한 투사체가 발사되어 목표 위치에서 폭발하며 주변 블록과 개체를 파괴합니다."
	]
	quest.5D2936B7F8D0F8FA.title: "이그니티움 블록 거래"
	quest.5D3ED71A2ADB7F8E.quest_subtitle: "네더라이트 닭으로 제작"
	quest.5D7BABE1A37EC6D3.quest_desc: [
		"&e사악한 무기&r가 의지를 가진 것처럼 보였던 반면, &o융합된 의식&r으로 만들어진 무기는 의심의 여지를 남기지 않습니다."
		""
		"&6분열 닻&r은 적과 싸움이 끝나지 않은 것처럼, 당신이 휘두른 후에도 계속 공격합니다."
		"칼날을 휘두르면 그것이 발사되어, 거대한 범위 내의 모든 적을 반복적으로 공격하며 그들의 영혼 깊숙이 파고들어 돌아옵니다."
		"&7물론 당신을 제외하고요. 누가 그것을 휘두르겠어요?&r"
		""
		"&6풀리는 혼돈&r은 마법적인 열정으로 영향을 받는 모든 적을 태우며, 지팡이는 마법적인 열정으로 인해 발생한 불꽃에서 에너지를 흡수하여 그것을 만드는 데 사용된 저주 충전을 되찾습니다."
		"&7결국 끝나기를 원하지는 않겠죠? 적어도 아직은요.&r"
	]
	quest.5D7BABE1A37EC6D3.title: "&6의식 있는 무기"
	quest.5D96F0CE1154B9B8.quest_desc: [
		"&e크리에이트&r는 멋진 증기 기관차 스타일의 구조물을 사용하여 건설, 장식 및 자동화를 위한 다양한 도구와 블록을 제공하는 모드입니다."
		""
		"&e크리에이트&r의 게임 내 시각적 설명서인 &b폰더&r는 대부분의 블록이 어떻게 작동하는지 알려줄 것입니다. JEI 또는 인벤토리에서 아이템에 마우스를 올리면 &b폰더&r가 있는지 확인할 수 있습니다."
		""
		"시작하려면 &a안데사이트 합금&r을 제작하세요. 이것이 많이 필요할 것입니다."
		"{@pagebreak}"
		"&a렌치&r는 &e크리에이트&r 구조물을 다루는 다목적 도구입니다."
		""
		"블록, 구조물 등을 회전, 구성, 분해할 수 있습니다!"
	]
	quest.5D96F0CE1154B9B8.title: "&a크리에이트"
	quest.5D9EAE2A6D2B6646.quest_desc: [
		"&6조각화기 대장간&r은 주로 광석을 &b조각화하고&r 처리하여 주괴 생산량을 늘리는 고급 멀티블록 기계입니다."
		""
		"대부분의 &b애드온&r은 &6조각화기 대장간&r의 작동에 영향을 미칩니다. &b기계 수율 애드온&r은 &6조각화기 대장간&r에 설치하면 추가 부산물을 생산합니다."
	]
	quest.5DF92F096DB91299.quest_desc: ["&d메카-도구&r는 전력을 소비하는 도구로, &a개조 스테이션&r에서 다양한 &b모듈&r로 업그레이드하고 사용자 정의하여 성능을 향상시킬 수 있습니다.&r"]
	quest.5DF92F096DB91299.title: "&d메카-도구"
	quest.5E1FD04538F89292.quest_desc: [
		"메인 &eRS2&r 네트워크에 두 번째 네트워크를 무선으로 연결하려면, 보조 네트워크의 &d네트워크 수신기&r에 &a네트워크 카드&r를 바인딩한 다음, 해당 &a네트워크 카드&r를 메인 네트워크에 연결된 &d네트워크 송신기&r에 넣으면 됩니다."
		""
		"메인 시스템이 청크 로드되어 있는 한 차원 간에도 작동합니다."
	]
	quest.5E1FFB29D89798F5.quest_desc: ["필요할 때마다 &aQIO 대시보드&r를 내려놓는 것만으로도 저장 공간에 접근할 수 있다는 것은 강력하지만, 만약 그것을 전혀 내려놓을 필요가 없다면 어떨까요?"]
	quest.5E1FFB29D89798F5.title: "&f휴대용 &aQIO 대시보드"
	quest.5E2764E8DB1B789B.title: "빛의 굴절기 만남"
	quest.5E2F4A6147694D5C.quest_desc: [
		"[\"\", {\"text\": \"Chaotic\", \"color\": \"rainbow\"}, \" tools are the final upgrades to \", {\"text\": \"Draconic\", \"color\": \"gold\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"11A35E8F97ACA240\" }, \"hoverEvent\": {\"action\": \"show_text\", \"contents\": \"Go to Draconic Tools Quest\"}}, \" tools, with the most room for \", {\"text\": \"Upgrade Modules\", \"color\": \"green\"}, \" and maximum customizability.\"]"
		""
		"또한 올인원 도구 및 무기인 \\&z카오틱 파워 스태프&r로 업그레이드하거나 제작할 수 있습니다."
		""
		"모듈 인벤토리는 기본적으로 바인딩되지 않은 키 바인딩 &e도구 모듈&r을 통해 액세스할 수 있습니다."
	]
	quest.5E2F4A6147694D5C.title: "\\&z카오틱 &f도구"
	quest.5E3A4A3F00FDDEC0.quest_desc: [
		"&a비전 대장간&r은 이 모드를 사용할 때 빠르게 당신의 가장 친한 친구가 될 것입니다."
		""
		"이 대장간은 &b주문, 장비를 업그레이드하고&r 심지어 &b장비에 주문을 부여하는 데에도 사용할 수 있습니다!&r"
		""
		"좋아하는 주문이 있지만 꽤 약한가요? &a비전 대장간&r을 사용하여 더 높은 등급의 잉크로 업그레이드하세요!"
	]
	quest.5E3A4A3F00FDDEC0.title: "&f주문 &b및 &r장비 &f업그레이드&a"
	quest.5E5BDCBF185E48E3.quest_desc: [
		"&a엔지니어 작업대&r는 모든 엔지니어링 요구에 대한 주요 제작대입니다!"
		""
		"&a엔지니어 작업대&r를 사용하여 아이템을 만들려면 다양한 종류의 아이템을 제작하기 위해 다양한 종류의 &b청사진&r이 필요합니다."
		""
		"맨 왼쪽 슬롯에 &b청사진&r을 놓으면 작업대 오른쪽에 제작 가능한 레시피가 표시됩니다. 그런 다음 레시피에 필요한 아이템을 넣고 제작된 아이템을 꺼낼 수 있습니다."
	]
	quest.5E5BDCBF185E48E3.title: "&f엔지니어 작업대"
	quest.5E74E0339A6F5314.quest_desc: ["&d체세드&r를 &d체세드 경기장&r의 &e끝&r에서 처치하고 트로피를 &c제출&r하여 현상금을 획득하세요."]
	quest.5E74E0339A6F5314.title: "&d체세드 처치"
	quest.5E79F24C893AFF65.quest_subtitle: "탐험가, 지질학자"
	quest.5E90192C6F3011B7.quest_desc: [
		"&6월드 엔진&r의 힘과 &a에코 인코더&r를 사용하여, &2작업자 토큰&r을 최소 1개 보유하면 음식으로 더 많은 주민을 생산할 수 있습니다."
		""
		"&7&o이제 수동으로 주민을 더 많이 만드는 시대는 끝났습니다."
	]
	quest.5E90192C6F3011B7.title: "&f주민 번식"
	quest.5ED062BF97780287.title: "엔드 서쪽"
	quest.5ED10C54AE06DB40.quest_desc: [
		"§z무한의 갑옷&r은 플레이어에게 가해지는 모든 피해를 무효화하고 점프 강화 및 이동 속도 증가를 제공합니다."
		""
		"&e참고&r: 피해를 방지하려면 전체 세트를 착용해야 합니다."
	]
	quest.5ED10C54AE06DB40.title: "무한의 갑옷"
	quest.5FBD41923B66C239.quest_desc: [
		"기본적으로 서랍은 크기에 따라 기본 아이템 수량만 담을 수 있습니다. 이 업그레이드로 업그레이드할 수 있습니다! "
		""
		"예를 들어, 한 종류의 아이템을 담는 표준 서랍은 기본 수량으로 약 &a2,000개의 아이템&r을 담을 수 있습니다. 각 업그레이드는 총 저장량을 곱하므로 업그레이드는 중첩됩니다. 대부분의 서랍은 어떤 등급이든 4개의 &a인벤토리 크기 업그레이드&r를 담을 수 있습니다."
		""
		"팁: 연결 범위를 늘리기 위해 &3저장 컨트롤러&r 안에 이것들을 넣을 수도 있습니다."
	]
	quest.5FBD41923B66C239.title: "저장소 업그레이드"
	quest.5FD42392FCECCB47.quest_desc: [
		"&d엔더 레이저&r의 힘으로 레이저를 집중하여 자수정 군집을 채굴하여 &d플럭사이트&r를 얻을 수 있습니다."
		""
		"싹트는 자수정에 레이저를 사용하면 에너지를 공급하고 성장 속도를 높일 수 있습니다."
		""
		"&d플럭사이트&r는 &d플럭스 게이트&r를 만드는 데 사용됩니다."
	]
	quest.5FD42392FCECCB47.title: "&d플럭사이트"
	quest.5FDB9EC42FE936C6.quest_desc: [
		"&3업그레이드&f에 필요한 블록을 제출하고 보상을 받으면 팀의 &6월드 엔진&r이 자동으로 조립됩니다."
		""
		"&e참고&f: 업그레이드가 있어야 할 곳에 배치된 블록은 사라집니다."
	]
	quest.5FDB9EC42FE936C6.title: "&f자동 제작: &3공명하는 공허 업그레이드"
	quest.5FFC80176D33E4E1.quest_desc: [
		"&6프로젝트 E&r 장비는 착용 시 일정 비율의 피해를 무효화하며, &c붉은 물질&r 장비가 전반적으로 가장 강력한 피해 감소 효과를 제공합니다."
		""
		"&e참고&r: 이를 제작하려면 &a기계 블록&r &6월드 엔진 업그레이드&r가 필요합니다."
	]
	quest.5FFC80176D33E4E1.title: "프로젝트 E 갑옷"
	quest.60633295CFD82152.quest_desc: [
		"곡괭이로 채굴하면 한 번에 블록 하나만 채굴하므로 영원히 걸릴 것입니다."
		""
		"&bJustHammers&r 모드의 &b망치&r로 업그레이드하세요! 기본 &a돌 망치&r는 스윙당 3x3x1 영역을 채굴할 수 있으며, 더 좋은 망치는 더 큰 영역을 채굴할 수 있습니다."
	]
	quest.60633295CFD82152.title: "&f망치 시간"
	quest.606BDEB81F65A79F.quest_desc: [
		"주변 아이템을 줍도록 서랍을 업그레이드할 수 있는 다양한 방법이 있습니다."
		""
		"기본 레벨은 &a줍기 업그레이드&r이지만, &a자석 업그레이드&r로 업그레이드하면 더 많은 옵션과 더 넓은 범위를 사용할 수 있습니다!"
	]
	quest.60871670B71C711F.quest_desc: [
		"&2싹트는 수정&r은 자라는 데 시간이 걸릴 수 있으며, 시스템을 가동할 때 특히 그렇습니다."
		""
		"&b성장 촉진제&r는 제작하여 발아 블록 아래에 배치하면 성장을 상당히 가속할 수 있습니다. 작동하려면 전력이 필요합니다."
	]
	quest.6089F3DC28FB69C0.quest_desc: [
		"&a흙&r에는 사용할 수 있는 &2묘목&r이 충분한 것 같습니다! &a흙&r을 &2갈퀴&r로 채굴하여 이 묘목을 얻을 수 있습니다."
		""
		"나무가 자라기를 기다릴 수도 있지만, &e쪼그려 앉아 성장시키기&r를 사용하여 강제로 자라게 할 수 있습니다."
		""
		"[\"This can be toggled with the keybind \", { \"keybind\": \"key.squatgrow.toggle\", \"color\": \"green\" }, \".\"]"
	]
	quest.6089F3DC28FB69C0.title: "&f흙 속 파기"
	quest.609DF15D870AE2C0.quest_desc: [
		"&e소울플라이드 에너지틱스&r는 &eIF 소울&r의 애드온 모드로, &eAE2&r를 사용하여 영혼을 전송할 수 있습니다."
		""
		"&a저장소 버스&r를 &d소울 레이저 베이스&r에 연결하면 네트워크가 내부에 있는 &3워든 영혼&r에 접근할 수 있습니다. 그런 다음, 시스템에 저장된 &3영혼&r을 요청하기 위해 &eIF 소울&r 아이템을 &a인터페이스 필터&r에 우클릭합니다."
		""
		"마지막으로, &b소울 파이프&r를 &a인터페이스&r에 연결하면 &3워든 영혼&r을 사용하여 &b소울 서지&r를 구동합니다."
	]
	quest.609DF15D870AE2C0.title: "&e영혼 공급 에너지학"
	quest.60B8D5DAA4BA7DC4.quest_desc: [
		"&e복제: 물질 과부하&f를 사용하면 설정된 유형의 초과 물질을 자동으로 삭제하는 &a과부하 탱크&r를 제작할 수 있습니다."
		""
		"각 물질 유형별로 하나씩 만들고 잠가두어야 초과 물질이 네트워크의 다른 탱크로 넘치지 않고 항상 갈 곳이 있도록 해야 합니다."
	]
	quest.60B8D5DAA4BA7DC4.title: "물질이 너무 많아요"
	quest.60BBE214131DF6EB.quest_desc: [
		"몹에 대한 데이터 모델을 얻은 후에는 해당 유형의 몹을 처치하여 최소 &a기본&r 등급으로 레벨을 올려야 합니다."
		""
		"&2예측 행렬&r과 전력을 제공하면 &a시뮬레이션 챔버&r가 해당 특정 몹을 처치하는 것처럼 시뮬레이션을 실행합니다."
		""
		"시뮬레이션이 실패하면 &b일반화된 예측&r을 얻게 됩니다. 성공하면 해당 몹의 &6예측&r을 얻게 됩니다."
		""
		"이 &6예측&r은 &d전리품 제작기&r를 통해 실행하여 전리품을 만들 수 있습니다!"
	]
	quest.60BBE214131DF6EB.title: "전리품 시뮬레이션"
	quest.60C650264AA5525D.quest_desc: [
		"&a컨트롤러&r는 &eRS2&r 네트워크에 전력을 공급하는 주요 장치입니다."
		""
		"더 많은 전력이 필요하면 네트워크에 여러 개의 컨트롤러를 배치할 수 있습니다. &eAE2&r 컨트롤러와 달리 컨트롤러는 네트워크 어디에나 배치할 수 있습니다."
	]
	quest.60C650264AA5525D.title: "컨트롤러"
	quest.60FDF616DEDE5E73.quest_desc: [
		"&e아포테오시스&r는 RPG와 같은 경험을 만들어 탐험과 전투를 개편합니다."
		""
		"월드에서 찾을 수 있는 아이템과 몹은 특별한 &b접사&r를 가질 수 있어 훨씬 강해지고, 때로는 특별한 능력을 부여하여 재미를 더합니다!"
		""
		"길을 잃었다고 느껴지면 언제든지 모드의 가이드북인 &a그림자의 연대기&r를 참조할 수 있습니다."
	]
	quest.60FDF616DEDE5E73.title: "&e연금술 보석&f!"
	quest.6120A9478D66C2F9.quest_desc: [
		"만든 &aStraw&r로 마침내 여정에서 가장 중요한 도구의 기본 버전인 &3The Crude Brush&r를 만들 수 있습니다."
		""
		"부드러운 손길과 &3Brush&r의 한 번의 스트로크로 부서진 돌 안에 숨겨진 광물을 찾을 수 있습니다."
		""
		"진행 상황을 보여주기 위해 &d안내의 메아리&r에게 돌아가야 합니다."
		""
		"&e참고&r: 로비로 돌아가려면 /spawn 명령어를 사용할 수 있습니다."
	]
	quest.6120A9478D66C2F9.title: "&f시간의 가닥"
	quest.612340743D7C7536.quest_desc: [
		"&3무선 송신기&r를 사용하면 &d무선 그리드&r가 설정된 범위 내에서 네트워크에 접근할 수 있으며, 최대 4개의 &a범위 업그레이드&r로 확장할 수 있습니다."
		""
		"&7&o기본 범위는 16블록이며 최대 48블록까지 확장할 수 있습니다."
	]
	quest.615D1A52ED3A9C78.quest_desc: [
		"&2작업자 토큰&r을 사용하여 &d인도의 메아리&r가 방문할 수 있는 더 많은 &6기록 보관소&r를 해제했습니다."
		""
		"그 안에는 새로운 &dEchoes&r가 있으며, 이들의 임무를 통해 &6World Engine&r을 업그레이드할 수 있습니다! 각 에코를 만나보세요. 선물을 줄지도 모릅니다."
		""
		"&6월드 엔진&r에는 많은 업그레이드가 있으며, 진행하려면 몇 가지만 필요합니다. 각 단계는 &d메아리&r와 협력하여 2개의 업그레이드를 완료해야 합니다."
		""
		"&e참고&r: &d주요 업그레이드&r가 필요하며, &a보조 업그레이드&r는 선택 사항입니다."
	]
	quest.615D1A52ED3A9C78.quest_subtitle: "1단계 챕터 잠금 해제"
	quest.615D1A52ED3A9C78.title: "&f기록 보관소 잠금 해제"
	quest.616E3CE38F1D73AE.quest_desc: [
		"&6메카니즘&r은 궁극의 기술 모드입니다!"
		""
		"&2야금 주입기&r는 &6메카니즘&r에서 사용되는 핵심 기계입니다."
		""
		"이 기계를 사용하여 금속에 특정 재료를 주입하여 더 발전된 기계에 사용되는 &a합금&r과 &2회로&r를 만듭니다."
		""
		"인터페이스에 대한 자세한 내용은 다음 페이지를 확인하세요!"
		"{@pagebreak}"
		"&2Infuser's&r 인터페이스 안에는 새로운 아이템을 만들기 위해 상호작용할 수 있는 여러 슬롯이 있습니다."
		""
		"가장 왼쪽 슬롯은 &a추가 슬롯&r이며, &c레드스톤&r이나 &a석탄&r과 같은 주입 아이템을 넣는 곳입니다."
		""
		"중간 왼쪽 슬롯은 철이나 오스뮴과 같이 주입하려는 아이템을 위한 것입니다!"
		""
		"오른쪽에는 출력 슬롯과 에너지 슬롯이 있습니다. 이 슬롯은 배터리와 같이 에너지를 저장하는 아이템을 사용할 수 있습니다. &e메카니즘&r 기계에서 에너지 슬롯을 본다면, 이 아이템들을 넣을 수 있을 것입니다!"
	]
	quest.616E3CE38F1D73AE.title: "&f&e메카니즘&f에 오신 것을 환영합니다!"
	quest.61B830759B316300.quest_desc: [
		"&6Classic Pipes&r는 제작 및 사용이 쉬운 파이프로 원래 &aBuildcraft&r의 느낌을 되살립니다."
		""
		"기본 나무 파이프는 아이템과 유체를 운반하는 데 사용할 수 있습니다."
		""
		"&aIron&r 버전은 레드스톤 전원이 공급될 때 아이템이나 유체를 추출하는 데 사용됩니다."
		""
		"다양한 기능을 수행하는 여러 등급의 파이프도 있으니 확인해보세요!"
		""
		"&e참고&r: 이 파이프가 넘치면 월드에 지연이 발생합니다. 오버플로우 시스템을 만드세요!"
	]
	quest.61B948F3E526ADF9.quest_desc: [
		"&aSoulbinding Brazier&r에 올바른 조합의 재료를 넣으면, 사소한 것부터 극단적인 것까지 경험을 바꾸는 영혼에 맹세하는 반-영구적인 &bOaths&r(게이사라고도 함, 단수: 게이스)를 맹세할 수 있습니다."
		""
		"예를 들어, &2고유 방어구&r를 제공하는 대신 &o절대&r 방어구를 착용할 수 없게 되거나, 물속에 있을 때만 &3바다의 거인&r이 될 수 있지만, &o오직&r 물속에서만 가능합니다..."
		""
		"이러한 다양한 맹세의 조건을 보려면 &e말룸의 백과사전&r을 확인하세요."
		"맹세 제작 과정에 대한 자세한 내용은 다음 페이지를 확인하세요."
		"{@pagebreak}"
		"&aBrazier&r를 사용하려면 &eEncyclopedia&r에 설명된 중앙 아이템을 먼저 삽입해야 합니다. 거기서부터 영혼과 추가 재료를 적용할 수 있습니다. &bOath&r가 준비되면, &eEther&r를 화로에 사용하여 불을 붙이고 맹세를 시작하세요."
		""
		"맹세 과정은 수십 초가 걸리며, 동의하는 플레이어는 이 시간에 약간의 피해를 감수하고 점화기에 상호 작용하여 맹세를 수락할 수 있습니다. 각 플레이어는 한 번에 두 개의 맹세를 할 수 있습니다."
		""
		"&o&7원치 않거나 무의식적인 플레이어와 생물은 용광로에 불을 붙이기 전에 약점을 적용하여 맹세에 포함될 수 있습니다."
		""
		"맹세의 효과를 끝내려면, &aBrazier&r에 &eParacasual Flame&r을 사용하여 불을 붙이는 과정을 반복할 수 있습니다."
	]
	quest.61B948F3E526ADF9.title: "영혼 결속 계약"
	quest.61D55FA7CEA6F414.quest_desc: ["이 던전은 &dVoid Chasm&r 고리에서 찾을 수 있습니다."]
	quest.61D55FA7CEA6F414.title: "&d다른 세계 던전⟧ 찾기"
	quest.61D79267453CA30C.quest_desc: [
		"&aFlux Plug&r는 발전기나 전력 저장 장치에 배치하는 장치입니다. &cPower Tap&r 역할을 하며 네트워크에 전력을 어디서 가져올지 알려줍니다."
		""
		"&aFlux Point&r는 전력이 필요한 블록이나 파이프에 배치하는 장치입니다. 이것이 많이 필요할 것입니다!"
		""
		"네트워크를 위한 전력 버퍼를 만들기 위해 &aFlux Storage&r 블록 중 아무거나 제작할 수 있습니다."
	]
	quest.61D79267453CA30C.title: "전력 전송"
	quest.620F29613800DC94.quest_desc: [
		"&aRune Inscribed Ring&r 패턴을 사용하면 &6Iron's Spells&r 모드의 &dRunes&r를 새길 수 있습니다."
		""
		"이 &dRunes&r는 반지에게 다양한 힘을 부여할 것입니다. 실험해 보세요!"
		""
		"&eNote&r: 이것은 &dEnchanter's&r \\&zShop&r에서만 구매할 수 있습니다."
	]
	quest.620F29613800DC94.title: "룬 새기기"
	quest.62531896A7E58F55.quest_desc: [
		"&3Vault&r 안의 합금은 &dMachinist&r가 &6World Engine&r 업그레이드를 위해 필요하다고 말했던 바로 그것입니다."
		""
		"그 업그레이드 재료들을 만들어서 &dEcho&r로 돌아가세요."
		""
		"&eNote&r: 아래의 &aEncased Chain Drive&r를 통해 &6World Engine&r에 회전력을 공급해야 합니다."
	]
	quest.62531896A7E58F55.quest_subtitle: "사소한 월드 엔진 업그레이드"
	quest.62531896A7E58F55.title: "&f그림자 케이싱 및 스트레스"
	quest.62802965CA91E8C9.quest_desc: [
		"&6CAD's Socket&r는 기본적으로 &a탄창&r과 같습니다."
		"&aSpell Bullets&r가 장전되는 곳이며, 탄환에 포함된 컴파일된 &bSpells&r를 처리용 &dCore&r로 전송하는 역할을 합니다."
		""
		"&6Socket&r에는 &eBandwidth&r가 있으며, 이는 한 번에 &dCore&r로 전송할 수 있는 &bSpell&r의 최대 크기(&8&o격자 공간 기준&r&r)입니다."
		"&8&o(예: 대역폭 5인 소켓은 최대 5x5 크기의 주문을 전송할 수 있습니다)&r&r"
		""
		"또한, &6Sockets&r의 또 다른 중요한 속성은 &3영구 정보&r를 저장할 수 있는 방법을 제공하는 것입니다. &6Socket&r가 제공하는 &bMemory&r가 많을수록 나중에 &bSpell&r 실행을 위해 더 많은 &bVectors&r를 저장할 수 있습니다."
		""
		"&8&o(&l트릭: 벡터 저장&r&8&o은 지정된 메모리 슬롯에 벡터를 저장하고, &l선택기: 저장된 벡터&r&8&o는 지정된 메모리 슬롯에 저장된 벡터를 검색합니다)&r&r"
		""
		"&6이것들&r은 특히 다음과 같은 것을 제공할 수 있습니다:"
		""
		"► &eBandwidth&r: 6 또는 7"
		""
		"► &2소켓&r: 6개 또는 8개"
		""
		"► &b메모리&r: 7개"
	]
	quest.62802965CA91E8C9.title: "&b2단계&f CAD 소켓"
	quest.62BB5925FB6C05C6.title: "&d마법사의 메아리 &f이정표"
	quest.62C92C8960875611.quest_desc: ["금속 가공은 평범한 세계에서만큼이나 마법 세계에서도 중요합니다. 비록 방법은 매우 다르지만요. 영적인 속성으로 주입된 주괴는 이 공예를 더 깊이 진행하는 데 필수적일 것입니다."]
	quest.62C92C8960875611.title: "&f영적 야금술"
	quest.62CEFEB50E7D4489.title: "병참 장교 확인 2"
	quest.6323068C93CF7DCE.quest_desc: ["&d대칭의 지팡이&r는 배치하는 블록을 자동으로 복제하는 레이아웃을 설정할 수 있습니다."]
	quest.634884134E2786B2.quest_desc: [
		"&d말쿠트 경기장&r은 &d공허 협곡&r 고리 안에 있는 거대한 구조물입니다."
		""
		"이 경기장에는 자체 보스 전투가 포함되어 있습니다!"
	]
	quest.634884134E2786B2.title: "&d말쿠트 경기장&r 찾기"
	quest.637CDD290456F2B2.quest_desc: [
		"&a용해 장치&r는 모드의 주요 제작 기계입니다. 이 기계는 &2라텍스&r와 같은 유체를 아이템과 결합하여 새로운 아이템을 만듭니다."
		""
		"나중에 더 고급 액체를 다루게 되겠지만, 지금은 대부분의 레시피에 &2라텍스&r가 사용될 것입니다!"
	]
	quest.637CDD290456F2B2.title: "&a유체로 제작하기"
	quest.63ACBB448387B83C.quest_desc: ["&r크리에이티브 메모리 칩&r을 설치하면 복제 시스템에서 복제할 수 있는 모든 아이템의 잠금을 해제할 수 있습니다."]
	quest.63ACBB448387B83C.title: "크리에이티브 메모리 칩"
	quest.63B7AC676FC1EE7F.quest_desc: [
		"&3크레오소트 오일&r을 사용하여 판자와 결합하여 &a처리된 목재&r를 만들 수 있습니다."
		""
		"&a처리된 목재&r는 &6I.E&r 작업대와 같은 다양한 작업대를 제작하는 데 사용됩니다. 예를 들어 &a엔지니어 작업대&r가 있습니다."
	]
	quest.63B7AC676FC1EE7F.title: "&f처리된 목재 판자"
	quest.63BA03EC05C8105F.title: "TF 북쪽"
	quest.63BED4D08224B3EF.quest_desc: [
		"병과 블록 사이에 &d마나&r를 전달하는 더 많은 종류의 중계기가 있습니다!"
		""
		"&d분배기&r는 마나를 여러 마나 병으로 동시에 보내는 데 사용됩니다!"
		""
		"&a예치 중계기&r는 연결되지 않은 마나 병에 마나를 예치합니다. 마나 저장실을 만드는 데 좋습니다!"
		"{@pagebreak}"
		"&d워퍼 중계기&r는 아무리 멀리 떨어져 있더라도 다른 &d워퍼 중계기&r로 마나를 순간이동하는 데 사용됩니다."
		""
		"&e참고&r: 30블록 이상 떨어진 거리에서는 순간이동 시 일부 마나가 손실될 수 있습니다."
		""
		"&a수집기 중계기&r는 연결되지 않은 마나 병에서 마나를 자동으로 가져옵니다."
	]
	quest.63E9BE547681EB33.quest_desc: [
		"첫 가동 시 &d핵분열 반응로&r 설정을 관리하는 것이 중요하지만, 자체적으로 잘 작동하기 시작하면 다른 할 일도 있습니다. 이것이 안전을 희생하면서까지 할 필요는 없습니다!"
		""
		"이것이 바로 &a핵분열 반응로 로직 어댑터&r가 필요한 이유입니다. 하나 이상의 어댑터가 있는 &d반응로&r를 구축하면, &c위험한 조건&r에서 레드스톤 신호를 방출하거나 &d반응로&r를 자동으로 활성화하도록 구성할 수 있습니다."
		""
		"예를 들어, 비교기를 사용하여 &a방사성 폐기물 통&r을 읽어 통이 너무 꽉 찼을 때 &d원자로&r를 끄도록 하거나, 원자로가 &c과열&r되기 시작하면 비상 냉각 공급을 전환하도록 할 수 있습니다."
	]
	quest.63E9BE547681EB33.title: "&a핵분열로 원자로 논리 어댑터"
	quest.64123F6FE4DEB4EF.quest_desc: ["이 퀘스트 보상을 받으면 &d메아리의 &6기록 보관소&r 입구에 이정표가 설정됩니다."]
	quest.64123F6FE4DEB4EF.title: "&f빛 굴절자를 찾아서&d"
	quest.6461D19F839957B6.quest_desc: [
		"&c이그니티움 주괴&r의 열기는 &b영혼 얼룩 강철 주괴&r에 깃든 영혼들에게 집의 느낌을 줄 것입니다..."
		""
		"&6월드 엔진&r은 영혼을 제대로 블록으로 감싸서 &3영혼 월드 엔진 업그레이드&r에 사용할 수 있어야 합니다."
	]
	quest.6461D19F839957B6.quest_subtitle: "마이너 월드 엔진 업그레이드"
	quest.6461D19F839957B6.title: "&f영혼 블록"
	quest.648083DCC5BDF216.quest_desc: [
		"&a운동 에너지 다이나모&r는 &a수차&r에 의해 생성된 힘을 사용하여 전력을 생성합니다."
		""
		"&a수차&r는 바퀴 주위의 물의 양에 따라 일정한 전력을 제공합니다. 최대 세 개의 &a수차&r를 같은 축에 연결할 수 있습니다."
	]
	quest.648083DCC5BDF216.title: "&f운동 에너지 생성"
	quest.64B237B611F88036.quest_desc: [
		"&d이클립스 합금&r은 &6Just Dire Things&r의 최종 단계입니다."
		""
		"이것들은 모드의 최고의 업그레이드를 사용할 수 있는 동력 갑옷입니다."
		""
		"이것들은 &d치킨 조키&r를 물리치고 &d섀도우펄스 구&r를 만든 후에 만들 수 있습니다. "
	]
	quest.64B237B611F88036.title: "&d이클립스 합금 &f갑옷"
	quest.652650C157E16712.quest_desc: [
		"&b영혼&r의 명백한 용도 중 하나는 그것으로 장비를 만드는 것입니다. 천에 그것을 주입하면 영혼의 속성을 사용하는 훌륭한 기반이 됩니다."
		""
		"&a영혼 직조 주머니&r는 영혼과 기타 특정 아이템을 홀더의 인벤토리에 닿기 전에 최대 8 스택까지 주머니 자체로 모아주어 영혼을 모을 때 도움이 될 수 있습니다. 이 주머니는 내용물을 월드에 쏟아내거나 인벤토리에서 한 번에 여러 세트의 아이템을 꺼내는 데 사용할 수 있습니다."
	]
	quest.65B10C46C1AE5026.quest_desc: [
		"&3업그레이드&f에 필요한 블록을 제출하고 보상을 받으면 팀의 &6월드 엔진&r이 자동으로 조립됩니다."
		""
		"&e참고&f: 업그레이드가 있어야 할 곳에 배치된 블록은 무효화됩니다."
	]
	quest.65B10C46C1AE5026.title: "&f어둠의 공허 업그레이드 자동 빌드&3"
	quest.65C1A809B6A22758.title: "웜라이트 확인 2"
	quest.6600E26635FD3D0E.quest_desc: [
		"&2속도 모듈&r은 많은 &eMFFS&r 기계의 성능을 일반적으로 향상시키는 데 사용될 수 있습니다."
		""
		"또한 &a강제 유도기&r의 생성 속도와 &3포트론&r의 &a포트론 축전기&r 전송 한도를 높일 수 있습니다."
		""
		"&2용량 모듈&r은 기계가 한 번에 보유할 수 있는 &3포트론&r의 양을 늘립니다."
	]
	quest.6600E26635FD3D0E.title: "&a기계 업그레이드"
	quest.663460DE8AF7E464.quest_desc: [
		"&a회로 제작기&r는 &6AE2&r와 &6RS2&r 모두에 대한 프로세서를 생성하는 멀티블록입니다. 이들은 전력을 필요로 하지만 다른 모드 소스의 일반 FE 전력을 수용할 수 있습니다."
		""
		"멀티블록을 만들려면 &d파란색 시트메탈&r과 &d생기석 유리&r, 그리고 &d신비한 큐브&r가 필요합니다. 이 큐브는 &6기계공&r에게 구매하거나 &d떠돌이 상인&r 또는 &a플럭스 연구원&r에게서 거래할 수 있습니다."
		"{@pagebreak}"
		"&a회로 제작기&r는 &6월드 엔진&r과 동일한 차원 시차를 활용하며 한 번에 최대 16개의 레시피를 처리할 수 있습니다! 업그레이드 슬롯에 최대 10개의 &d가속 카드&r를 넣어 제작기를 오버클럭할 수 있습니다. 완전히 업그레이드된 이 기계는 엄청난 양의 전력을 소비할 수 있습니다!"
	]
	quest.663460DE8AF7E464.title: "&a프로세서 대량 생산"
	quest.664F7957756D84FF.quest_desc: [
		"어떤 주문 학파를 사용하든 당신에게 맞는 갑옷 세트가 있습니다."
		""
		"이것들을 만들려면 먼저 &d비전 천&r을 만들어야 합니다. 천 조각 몇 개와 &a룬&r을 결합하면 가장 강력한 마법사 갑옷을 만들 수 있습니다!"
	]
	quest.66545AFE0DEA820F.quest_desc: ["어두운 제작을 위한 어두운 아이템 세트입니다."]
	quest.66545AFE0DEA820F.title: "&f우물의 보답"
	quest.665C261B98E4D20B.quest_desc: ["모험에서 승리를 거두고 돌아온 후 &dTwilight&r와(과) 대화하여 &3Twilight World Engine Upgrade&r를 설치하는 방법을 보여주도록 하세요."]
	quest.6681C945EBF3E114.quest_desc: ["입력 모드"]
	quest.6697F832067F1A9C.quest_desc: [
		"&eOritech의 &3Enderic Railgun&r은 모드에 따라 집중된 레이저 빔과 폭발적인 피해 빔을 모두 발사할 수 있습니다. Shift + 오른쪽 클릭으로 &b채굴 모드&r를 켜거나 끌 수 있습니다."
		""
		"&b채굴 모드&r에서 이 올인원 도구는 무한한 블록 상호 작용 범위로 블록을 직접 인벤토리로 채굴합니다."
	]
	quest.66BC4434409F959B.quest_desc: [
		"&3플루토늄&r은 약간의 염수 또는 소금 처리를 통해 &7핵분열 연료&r로 회수할 수 있습니다."
		""
		"발전용으로 &d반응로&r를 사용하고 있고 &a우라늄&r, &e황&r, 또는 &7형석&r이 부족하다면, 이 과정을 반복하여 초기 연료를 5배 더 오래 지속시키고 폐기물은 1/10로 줄일 수 있습니다. 이것이 바로 재활용의 마법입니다!"
	]
	quest.66BC4434409F959B.title: "&d재처리된 핵분열 조각"
	quest.66E73F99D943365C.quest_desc: [
		"&dFabricator&r의 첫 번째 작업은 매우 높은 온도를 견딜 수 있는 요소를 만드는 것입니다."
		""
		"&6World Engine&r은 &3기계 블록 업그레이드&r가 있다면 이러한 요소를 제련할 수 있어야 합니다."
	]
	quest.66E73F99D943365C.title: "&f초고온"
	quest.66FF7D88B712C969.quest_desc: ["이 퀘스트 보상을 받으면 &dEcho's &6Archive&r 입구에 웨이포인트가 설정됩니다."]
	quest.66FF7D88B712C969.title: "&f찾아가는 길 &dThe Wayfinder"
	quest.67012432915196A3.title: "무기"
	quest.67078BCAD52BC4B4.title: "슬라임 처치"
	quest.67181BD1F2434E2C.title: "와름라이트 확인 1"
	quest.67396087E1916115.quest_desc: [
		"&a분자 변환기&r는 결속된 &e오벨리스크&r의 경험치를 사용하여 재료를 주입하는 장치입니다. 이를 통해 일부 제작법을 더 저렴하게 만들 수 있지만, &2Cognition&r의 일부 자원을 제작하는 데 필수적인 방법이기도 합니다."
		""
		"이는 &a변환 포커스&r로 더욱 확장되어 다양한 바닐라 아이템을 틈새 변형으로 변환합니다."
		""
		"&7제작에 나열된 모든 경험치 레벨은 포인트 값을 사용하며, 필요한 것보다 더 많은 경험치 레벨을 사용하지 않습니다."
		""
		"&7아이템 슬롯은 외부 자동화를 위해 잠글 수도 있습니다."
	]
	quest.6739E7A96309D0A8.quest_desc: [
		"&a강제 유도기&r는 에너지를 변환하여 시간이 지남에 따라 &b포트론&r을 생성합니다."
		""
		"&b포트론&r은 주로 &eMFFS&r 기계에 전력을 공급하는 데 사용되지만, 업그레이드된 &6월드 엔진&r에서 더 많은 \\&#41AA71포트론 주입 주괴&r를 만드는 데도 사용할 수 있습니다."
		""
		"&7&oMFFS 기계는 기본적으로 작동하려면 레드스톤 신호가 필요하며, 대부분은 인터페이스의 왼쪽 상단에서 반전시킬 수 있습니다."
		"{@pagebreak}"
		"&a강제 유도기&r에는 두 가지 모드가 있습니다:"
		""
		"&e유도 모드&r는 다른 모드나 인벤토리의 방전 가능한 아이템에서 에너지를 변환하여 &3포트론&r을 생성합니다."
		""
		"&e통합 모드&r는 &3포트론&r을 약간의 손실로 에너지로 변환합니다."
		""
		"&2Lapis&r 또는 &2Nether Quartz&r를 안에 넣으면 소비될 때 &aCoercion Deriver's&r 변환율이 세 배가 됩니다."
	]
	quest.6739E7A96309D0A8.title: "&f포트론 생성"
	quest.674AFF1CFDE5886F.title: "갑옷 제조인"
	quest.6755CACD4957A4CB.quest_desc: [
		"&6코어&r는 &aCAD의 필수적인 부분&r이며, 항상 최고의 것을 만들려고 노력하세요. &a기본적으로 CAD의 CPU와 같습니다&r."
		""
		"모든 &6CAD 코어&r에는 &d&l복잡도 값&r&r이 있으며, 이는 &d수행할 수 있는 연산 횟수&r를 의미합니다."
		"&8&o(선택기, 연산자 등은 주문의 복잡성을 증가시킬 수 있습니다)&r&r"
		""
		"또한, 모든 &6CAD 코어&r에는 &3&l투영 값&r&r이 있으며, 이는 단순히 &3한 번에 수행할 수 있는 디버그가 아닌 트릭의 총 수&r입니다."
		""
		"특히 이 &6코어&r는 다음과 같은 기능을 제공합니다:"
		""
		"► &d복잡도&r: 14"
		""
		"► &3투영&r: 1"
	]
	quest.6755CACD4957A4CB.title: "&a1단계&f CAD 코어"
	quest.67747675548AAC80.quest_subtitle: "발굴자, 고고학자"
	quest.6781D1A7A53A5F1D.quest_desc: [
		"이 나침반은 &3금고의 위치를 가리킵니다."
		""
		"&7&o금고에서 256블록 이내에 있을 때 나침반을 쉬프트 + 우클릭하면 입구로 즉시 순간이동할 수 있습니다!&r"
	]
	quest.6781D1A7A53A5F1D.title: "&f금고 찾기 &3The Vault"
	quest.67AA6621E5A00E37.title: "황혼 확인 1"
	quest.67AD604F2C4E5CC9.quest_desc: [
		"모든 &b유체 소&r를 번식이나 &a클래플&r을 사용하여 만들 수 있는 것은 아닙니다."
		""
		"특정 유형의 &b유체 소&r를 만들기 위해 소에게 먹일 수 있는 다른 아이템이 몇 가지 있습니다. 예를 들어, &d엔더의 눈&r은 &c녹은 엔더&r 소를 만들고, &d블레이즈 막대&r는 &c용암&r 소를 만듭니다..."
		""
		"&b라텍스&r 소도 꽤 좋습니다."
		""
		"유체 소에게 &b우유 양동이&r를 먹이면 일반 소로 초기화됩니다."
	]
	quest.67AD604F2C4E5CC9.title: "특수 유체 소"
	quest.67D1E0D81B2C5D8D.quest_desc: [
		"&d리바이어던&r은 &b물 구체&r 구조물 안에서 찾을 수 있습니다."
		""
		"이것은 &b바다&r 고리 주위에 흩어져 있습니다."
		""
		"&e참고&r: 제단을 활성화하려면 &d심연의 희생&r이 필요합니다. 이를 제작하는 데 필요한 아이템은 &9코랄서스&r의 &a영원의 관문&r에서 얻을 수 있습니다."
	]
	quest.67D1E0D81B2C5D8D.title: "리바이어던 처치 &dThe Leviathan&r"
	quest.67DE9E103F50E3F1.quest_desc: [
		"&a안산암 케이싱&r은 대부분의 초반 블록과 기계를 제작하는 데 사용됩니다."
		""
		"또한 여러 &eCreate&r 구성 요소를 덮어 장식을 더 예쁘게 만드는 데 사용할 수도 있습니다."
	]
	quest.67F596597F0B2825.title: "&f가이드 만나기"
	quest.68258EA281734B4A.quest_desc: [
		"&b포트론 축전기&r는 모든 &eMFFS&r 시스템에서 &3포트론&r 버퍼 역할을 하고 등록된 &b주파수&r를 통해 전송하는 데 필요합니다. UI 중앙의 큰 버튼은 &b축전기&r가 시스템 전체에 &3포트론&r을 분배하는 방식을 조정합니다."
		""
		"각 &2속도 모듈&r은 전송 속도를 증가시킵니다."
		""
		"각 &2규모 모듈&r은 모듈당 15블록 반경에서 기본 작동 범위를 1씩 증가시킵니다."
		""
		"각 &2용량 모듈&r은 저장 용량을 증가시킵니다."
	]
	quest.68258EA281734B4A.title: "&f포트론 저장&3"
	quest.68583162106594A8.quest_desc: [
		"&7&o상자를 옮기는 것은 항상 번거로웠습니다. 하지만 이제 더 이상 그렇지 않습니다!"
		""
		"&a포장 테이프&r를 사용하면 &e고급 상자&r를 포장하여 쉽게 옮길 수 있습니다."
		""
		"먼저 포장 테이프를 사용한 다음, 부수면 상자가 하나의 아이템으로 나옵니다. 일단 내려놓으면 테이프는 사라집니다!"
		""
		"&e참고&r: &a스택 업그레이드&r가 있는 상자는 옮기기 전에 먼저 포장해야 합니다."
	]
	quest.68583162106594A8.title: "&f상자 옮기기"
	quest.68668718B414B6E4.quest_desc: [
		"&a용광로 배수구&r (또는 대부분의 다른 모드에서 제공하는 &2탱크&f)에 &a용광로 탭&r을 부착하면 생성된 용융 금속을 &2주조대&r로 추출할 수 있습니다."
		""
		"용융 금속을 주조대에 붓기 전에 &b주조물&r이 필요합니다."
		""
		"&2주조 대야&r는 금속 블록을 저장하고 만드는 데 사용할 수 있습니다."
		""
		"&7&o이것들은 당신의 기지 미학에 맞게 염색될 수 있습니다."
	]
	quest.68668718B414B6E4.title: "&6용광로 &f배수구"
	quest.68778308CBAB4AE3.quest_desc: ["&a외부 저장소&r는 상자, 서랍, 탱크 등 저장소 네트워크 외부의 인벤토리에 접근할 수 있습니다."]
	quest.689F96B63A0455D9.title: "도구"
	quest.6910347C765AE7C6.title: "&b해저 던전 찾기"
	quest.695B2CCD18E5DDFE.quest_desc: [
		"더 많은 &6기록 보관소&r가 잠금 해제됨에 따라, 로비 탐험을 시작하고 &d지옥의 메아리&r를 찾을 시간입니다."
		""
		"이 &d메아리&r를 사용하여 당신의 &b월드 엔진&r에 대한 &6정령&r 업그레이드를 잠금 해제하세요!"
		""
		"&7&o로 만난 후 로비 어디에서든 이 메아리로 직접 순간이동할 수 있습니다. &e/echo infernal&7"
	]
	quest.695B2CCD18E5DDFE.title: "&f만나기 &d지옥의 존재"
	quest.69997DAB93184551.quest_desc: [
		"&d와이번 흉갑&r은 전력이 공급될 때 플레이어가 장신구 슬롯에 착용했을 때 받는 피해를 무효화하는 에너지 보호막을 제공합니다. 이것은 &a업그레이드 모듈&r을 통해 업그레이드될 수 있습니다."
		""
		"모듈 인벤토리는 기본적으로 바인딩되지 않은 &e도구 모듈&r 키 바인딩을 통해 접근할 수 있습니다."
	]
	quest.69997DAB93184551.title: "&d와이번 &f흉갑"
	quest.69E90341CD1AD494.quest_desc: [
		"► &6주문 프로그래머&r를 &d우클릭&r하면 GUI에 접근할 수 있습니다. 이것은 9x9 &8&o(Direwolf 승인)&r 그리드로, &b\"코드 블록\"&r을 함께 배치하고 연결할 수 있습니다."
		""
		"또한 &6주문 탄환&r도 잊지 마세요. 주문을 담는 데 사용될 것이며, 다음 퀘스트로 넘어가 당신의 &b첫 주문&r을 만들 것입니다!"
	]
	quest.69E90341CD1AD494.quest_subtitle: "이제 당신만의 주문 코딩을 시작하세요!"
	quest.69E90341CD1AD494.title: "재미는 지금부터 시작됩니다!"
	quest.69F87073390131D5.quest_desc: [
		"시스템이 아이템을 제작하도록 하려면 &a제작 패턴&r을 제공해야 합니다. 이것은 &d패턴 인코딩 터미널&r 안에서 만들어집니다."
		""
		"터미널에 &a빈 패턴&r을 제공하면, &eJEI&r를 사용하여 만들고 싶은 아이템을 검색한 다음, &b+&r를 클릭하여 레시피를 터미널에 추가할 수 있습니다."
		""
		"패턴이 테이블에 올라가면, &a빈 패턴&r 아래의 버튼을 클릭하여 레시피를 패턴에 인코딩하여 자동 제작에 사용할 수 있습니다!"
	]
	quest.69F87073390131D5.title: "&a패턴 만들기"
	quest.6A3BFD63419A15CE.quest_desc: [
		"&a분쇄기&r는 &e메카니즘&r에서 세 가지 주요 용도로 사용됩니다."
		""
		"1. 주괴를 직접 &b가루&r로 분해하는 데 사용되며, 이는 특정 기계나 업그레이드에 필요한 가루를 만드는 데 유용할 수 있습니다."
		""
		"2. 티어 2 광물 처리 체인에서 &a분쇄기&r는 &a정제기&r에서 만든 &e광물 덩어리&r를 받아 &a더러운 가루&r로 분해합니다."
		""
		"3. 유기물에서 &a바이오 연료&r를 만들 수 있으며, 이는 나중에 필요한 새로운 기계와 부산물을 만드는 데 사용됩니다!"
	]
	quest.6A3BFD63419A15CE.title: "&f분쇄기&a"
	quest.6A4A2A2EFD552316.quest_desc: [
		"전력을 저장하고 싶다면 &e파와&r의 &a에너지 셀&r이 해결책이 될 것입니다."
		""
		"또한 &a배터리&r를 제작하고 셀을 사용하여 충전할 수 있습니다. 그런 다음 배터리를 사용하여 초반 게임에서 인벤토리의 아이템을 충전할 수 있습니다!"
	]
	quest.6A4A2A2EFD552316.title: "&c에너지 셀&r"
	quest.6A67A14C8770B8C5.quest_desc: [
		"&c용암&r과 &b물&r 닭은 제작 가능한 티어 2 닭입니다!"
		""
		"이 닭들은 &a티어 2 영혼&r을 얻는 데 사용될 수 있으며, 이는 &2티어 2 씨앗&r을 의미합니다."
	]
	quest.6A67A14C8770B8C5.title: "&f제작 가능한 티어 2 닭"
	quest.6AA51581B0CA5271.quest_desc: [
		"&a디스크 드라이브&r는 다양한 리소스를 저장할 수 있는 &b저장 디스크&r를 수용하며, 저장 우선순위, 삽입/추출 모드, 비움 모드 등 여러 구성 옵션을 제공합니다."
		""
		"또한 인터페이스 상단 9개 슬롯 중 하나에 아이템을 배치하여 &a디스크 드라이브&r에 저장할 수 있는 아이템을 필터링할 수 있습니다."
		""
		"&b저장 장치&r는 업그레이드된 부품을 기존 &b저장 장치&r와 함께 제작하여 다음 등급으로 직접 업그레이드할 수 있으며, 이 과정에서 기존 장치를 반환하면서 저장된 모든 항목을 유지합니다."
		""
		"&b저장 장치&r는 항목이 저장되어 있지 않을 때 Shift + 우클릭하여 하우징에서 분리할 수 있습니다."
	]
	quest.6AA51581B0CA5271.title: "가상 저장 드라이브"
	quest.6B2F4AA722DAC535.quest_desc: ["네더 스타를 소비하여 전력을 생성합니다."]
	quest.6B31A5D836677A89.title: "와이번라이트 확인 3"
	quest.6B387999FBEE2E9E.quest_desc: [
		"이 팩에는 기본적으로 비활성화된 무작위 이벤트가 포함되어 있습니다. 이벤트를 활성화하려면 이 퀘스트를 완료하세요!"
		""
		"&e참고&r: 일부 이벤트에는 점프 스케어가 포함될 수 있습니다. &b/events toggle <event>&r 명령어를 사용하여 각 이벤트를 토글할 수 있습니다."
		""
		"예를 들어, 점프 스케어 이벤트를 비활성화하려면 &a/events toggle ftb:creeper&r 명령어를 사용할 수 있습니다."
	]
	quest.6B387999FBEE2E9E.title: "&6FTB 이벤트"
	quest.6B391D0B32AF8529.quest_desc: ["충분한 &2그림자 강철&r을 제작한 후에는 &d기계공&r에게 돌아가 &6월드 엔진&r의 어디에 배치해야 하는지 배워야 합니다."]
	quest.6B584FB6F2EEBCD0.quest_desc: [
		"&d신비한 정수&r는 &6아이언의 주문&r에서 첫 마법 갑옷 세트를 만드는 데 유용할 수 있습니다."
		""
		"가죽 갑옷 조각과 결합하면 &a방랑 마법사 세트&r의 조각이 만들어집니다."
		""
		"충분한 정수를 얻으면 &d마법사&r 세트를 &d신비한 천&r을 사용하여 만들 수 있습니다."
		""
		"이 두 가지 모두 주문을 시전하는 데 훌륭한 시작 세트입니다."
	]
	quest.6B584FB6F2EEBCD0.title: "&e아이언의 주문 &f기본 갑옷"
	quest.6B6C60BFE1D378D0.quest_desc: [
		"이것은 패턴 저장, 속도 및 처리 능력에 중점을 둔 일반적인 고급 &d조립기 매트릭스 &r설정을 완료하는 데 필요한 모든 블록입니다."
		""
		"&7&o이것은 7x7x7 구조물을 만듭니다."
	]
	quest.6B6C60BFE1D378D0.title: "&6최대 크기 조립기 매트릭스"
	quest.6B971FA156A96BD5.quest_desc: [
		"&a정령 촉매제&r는 삽입된 용광로 연료를 소비하여 근처 &e도가니&r의 처리 속도를 가속하며, 단일 도가니에 최대 8개까지 작동할 수 있습니다."
		""
		"이 속도는 때때로 초점 &e임페투스&r에 평소보다 더 많은 피해를 입혀, 수리하거나 교체하기 전에 생성할 수 있는 재료의 총량을 감소시킬 수 있습니다."
	]
	quest.6BB9FD515DFD8FF1.quest_desc: [
		"&bAE2&r에는 JEI에서 언제든지 접근할 수 있는 내장 가이드가 있습니다."
		""
		"모드의 아이템에 마우스를 올리면 가이드를 열기 위한 키 바인딩을 누르라는 메시지가 표시됩니다."
		""
		"이 가이드는 믿을 수 없을 정도로 상세하며, 진행 중에 도움이 필요하다면 매우 유용할 것입니다!"
	]
	quest.6BB9FD515DFD8FF1.title: "&6Applied Energistics 2&r 시작하기"
	quest.6BCA2ED05C7D9D4E.quest_desc: [
		"마법을 거부하는 것은, 마법사가 착용한 마법으로부터 제대로 분리될 때 강력한 방어력을 제공합니다."
		""
		"마법 공격과 이로운 효과 모두 &5사악한 성채&r에 부분적으로 흡수되어, 갑옷의 무결성과 방어 능력을 더욱 강화하는 데 사용됩니다."
		""
		"&7싸울수록 그들의 끝은 다가옵니다."
	]
	quest.6BCA2ED05C7D9D4E.title: "&6사악한 갑옷"
	quest.6BF5A24142C8FC67.quest_subtitle: "발굴자, 지질학자"
	quest.6C25708068B5197C.quest_desc: [
		"&a정밀 제거기&r는 아이템에서 원치 않는 마법 부여를 선택적으로 제거할 수 있으며, 30 레벨을 소모하여 저주를 제거할 수 있습니다."
		""
		"이 장치를 &7오벨리스크에 연결하면 가능한 경우 플레이어의 저장소가 아닌 오벨리스크의 저장소를 사용하여 경험치 획득 및 소모가 가능합니다."
		""
		"&e경험치 오벨리스크&r에 바인딩된 &a경험치 분수&r는 레드스톤으로 활성화하여 특정 비율로 오벨리스크에서 세계로 경험치를 쏟아낼 수 있습니다. 플레이어가 위에 서 있을 때도 마찬가지입니다."
		""
		"바인딩된 분수에 특정 아이템을 우클릭하면 경험치를 부여할 수 있습니다."
	]
	quest.6C25708068B5197C.title: "경험치 추가 기능"
	quest.6C293F6A07C1657A.title: "카오스 확인 1"
	quest.6C4441CC63BC7603.quest_desc: [
		"&c열 증발탑&r은 내부에 액체를 가열하여 새로운 액체를 만드는 멀티블록입니다. 이를 위해 &9물&r로 &e염수&r를 만들 것입니다."
		""
		"이를 만들기 위해서는 최소 53개의 열 증발 블록, 3개의 밸브, 1개의 컨트롤러가 필요합니다. 해당 부품들을 갖추었다면, 어떻게 만드는지 배워봅시다!"
		"{@pagebreak}"
		"&c열 증발탑&r 멀티블록은 너비 4블록, 길이 4블록으로, 최소 높이 3블록, 최대 높이 18블록으로 만들어집니다. 첫 번째 층을 제외하고는 높이에 상관없이 중앙이 비어 있습니다. 거대한 양동이라고 생각하세요! 프레임은 열 증발 블록으로 만들어야 하며, 컨트롤러와 밸브는 면에 배치해야 합니다."
		""
		"만들어진 모습의 예시는 다음과 같습니다:"
		""
		"{image:ftb:textures/quests/mekanism/thermalevaptower.png width:125 height:100 align:center}"
		"{@pagebreak}"
		"블록과 상호 작용하려면 &a컨트롤러&r를 면 중 하나에 배치해야 합니다."
		""
		"각 &c밸브&r는 타워 안팎으로 액체를 펌핑하는 데 사용됩니다. &e염수&r를 만들려면 물을 공급해야 하며, 이는 물 공급원에서 기계식 파이프를 사용하여 밸브로 물을 펌핑하여 수행할 수 있습니다."
		""
		"만든 염수를 배출하기 위한 밸브가 하나 더 필요하며, 세 번째 밸브는 멀티블록을 가열하는 데 사용됩니다. 이를 위해 &a장작 난방기&r 또는 &c저항 난방기&r를 만들 수 있습니다. 장작 난방기는 석탄과 같은 아이템을 태우고, 저항 난방기는 대신 전력을 사용합니다. 최대 크기 탑에는 2k가 완벽한 수치입니다!"
		""
		"완성되면, 형성되었음을 나타내는 빨간색 반짝임이 보일 것입니다!"
		""
		"팁: 난방기를 밸브 바로 위에 놓을 수 있으므로 파이프가 필요 없습니다!"
	]
	quest.6C4441CC63BC7603.title: "&c열 증발탑"
	quest.6C4783132CC50BF0.quest_desc: [
		"&d슈뢰딩거의 금고&r는 제대로 설정하면 수십억 RF를 저장할 수 있는 에너지 저장 멀티블록입니다."
		""
		"이 멀티블록은 &d슈뢰딩거의 금고&r의 기본 저장소 배율을 변경하는 &b용량 블록&r을 필요로 합니다."
		""
		"낮음, 중간, 높음 용량 블록은 기본 저장을 각각 0.3배, 1배, 5배로 곱합니다. 사용 가능한 용량 블록의 전체 목록은 아이템 툴팁을 확인하세요."
		""
		"또한 &d슈뢰딩거의 금고&r의 용량을 5000배까지 기하급수적으로 늘릴 수 있습니다. &a엔더 레이저&r로 측면을 전력 공급하면 됩니다."
	]
	quest.6C6A347673F0A8F7.title: "크리에이티브 주문책"
	quest.6C7F31673B12795D.quest_desc: [
		"&d이클립스 합금&r은 &6Just Dire Things&r의 최종 단계입니다."
		""
		"이것들은 모드의 최고의 업그레이드를 사용할 수 있는 전력 무기입니다."
		""
		"&d치킨 조키&r를 처치하고 &d섀도우펄스 구슬&r를 만든 후에 만들 수 있습니다."
	]
	quest.6C7F31673B12795D.title: "&d이클립스 합금&f 무기"
	quest.6C974CC33C5BADD8.quest_desc: ["액체 고기와 모든 주괴를 소비하여 전력을 생성합니다."]
	quest.6D06EDA1F34FA4E9.quest_desc: [
		"저장 시스템을 위한 무한한 전력과 &6Ars&r의 &r크리에이티브 주문⟧에 접근할 수 있다면, 주변 세계를 형성하기 전에 처리해야 할 마지막 한 가지 일만 남았습니다."
		""
		"모든 것을 위한 &r크리에이티브 파워⟧."
	]
	quest.6D06EDA1F34FA4E9.title: "승천 티어 3 - 전지전능"
	quest.6D0C1811DA909BBD.quest_desc: [
		"&d고대 도시 금고&r에는 전리품이 가득하지만, 가장 중요한 아이템은 보스에게서 나옵니다."
		""
		"매번 처치할 때마다 &b커슘 주괴&r 3-4개가 드롭됩니다. 이 주괴는 &6월드 엔진&r에서 사용할 수 있는 업그레이드로 변환될 수 있습니다."
	]
	quest.6D0C1811DA909BBD.quest_subtitle: "마이너 월드 엔진 업그레이드"
	quest.6D0C1811DA909BBD.title: "&d유포니움"
	quest.6D28E1AFBB33C43E.quest_desc: [
		"&e시간 강철&r은 기존 장치의 더 나은 버전을 제작하고 몇 가지 새로운 장치도 만드는 데 사용됩니다."
		""
		"&d크로논 배터리&r는 가장 먼저 제작해야 할 업그레이드입니다."
		""
		"단순한 &a크로논 셀&r보다 훨씬 더 많은 &b크로논&r을 저장할 수 있으며, 더 고급 &e템파드&r 레시피 제작에도 사용되는 재료입니다."
		""
		"&e참고&r: 이것을 제작하려면 &e크로니톤 유리&r와 &a기계 블록&r &6월드 엔진 업그레이드&r가 필요합니다."
	]
	quest.6D28E1AFBB33C43E.title: "&e시간 강철&r"
	quest.6D2B6421B1115667.quest_desc: [
		"철 조각, 주괴, 블록을 3개의 별도 서랍에 저장하는 대신 &a압축 서랍&r에 모두 저장할 수 있습니다."
		""
		"이것은 아이템을 압축된 버전으로 직접 저장하고 변환하는 특수 서랍입니다. 철이나 금과 같은 아이템을 쉽게 앞뒤로 변환하는 데 유용합니다!"
		""
		"&a간단 압축 서랍&r을 사용하면 기본 및 블록 레시피만 사용하는 아이템을 저장할 수 있습니다. 레드스톤, 다이아몬드, 에메랄드와 같은 아이템에 매우 유용합니다!"
	]
	quest.6D5905345348ABEF.quest_desc: [
		"&d플럭스 컨트롤러&r를 사용하면 장착 중이거나 단축 바에 있는 아이템을 무선으로 충전할 수 있습니다."
		""
		"네트워크에 연결하고 배치한 후에는 &d무선 충전&r 탭을 열어 무선으로 충전할 슬롯을 선택할 수 있습니다."
		""
		"하단의 토글을 켜고 적용을 클릭하는 것을 잊지 마세요!"
	]
	quest.6D5905345348ABEF.title: "무선 인벤토리 충전"
	quest.6D5A9E9E8B0D8AC2.quest_desc: [
		"모은 재료로 &3크로논 생성기&r를 &d에코&r가 원했던 대로 제작할 수 있습니다!"
		""
		"&a크로노 생성기&r를 제출하고 &d안내의 메아리&r로 돌아갈 시간입니다. 이렇게 하면 팀의 모든 플레이어에게 &a셀&r과 &2생성기&r가 보상으로 주어집니다."
		""
		"&e참고&f: 이 퀘스트를 완료하고 &d마법 부여가의 메아리&r를 업데이트하려면 &a크로노 생성기&r를 제출해야 합니다."
	]
	quest.6D5A9E9E8B0D8AC2.title: "&f크로노 생성기"
	quest.6D9862948E97E696.title: "엔드 동쪽"
	quest.6DB6B40C3E07E389.quest_desc: [
		"이 금고의 퍼즐을 통과하면 &2크로노톤 별&r을 얻을 수 있습니다."
		""
		"케이크는 거짓말이라는 것을 기억하세요."
	]
	quest.6DC738A434C5B02F.title: "엔더맨 처치"
	quest.6DD9A75EE8C97710.title: "&7강령술사&7 처치"
	quest.6DEB5453D8E3BD76.quest_subtitle: "발굴가, 지질학자"
	quest.6DEB5453D8E3BD76.title: "고대 잔해 또는 네더라이트"
	quest.6E149F8E8B3F150B.quest_desc: ["&2메아리치는 깊은 선반&r을 제작한 후 &d마법 부여자의 메아리&r로 돌아가 &6월드 엔진&r에 업그레이드로 설치하는 방법을 배우세요."]
	quest.6E24701C49A6114D.quest_desc: [
		"&6월드 엔진&r이 \\&z공허&r의 힘으로 업그레이드되면, &d중성자 압축기&r를 만들어 아이템을 \\&z특이점&r으로 압축할 수 있습니다."
		""
		"이것들을 사용하여 \\&z무한 특이점&r을 만드세요."
		""
		"&e참고&f: 에너지 버퍼를 늘리려면 &6월드 엔진&f에 &3드라코닉 에너지 코어&r를 설치해야 합니다."
	]
	quest.6E24701C49A6114D.title: "\\&z특이점&r"
	quest.6E458E2978B64C77.title: "기본 판금 거래"
	quest.6EE1C1B7FFB86C6C.quest_desc: [
		"&a소켓 부여 시길&r은 &b부여 속성&r 아이템의 &b보석 소켓&r 수를 늘리는 데 사용됩니다."
		""
		"이것들은 \\&z상점&r에서도 구매할 수 있습니다!"
	]
	quest.6F258F4C7BE2EE44.quest_desc: [
		"이 나침반은 &3보관소&3의 위치를 가리킵니다."
		""
		"&7&o보관소에서 256블록 이내에 있을 때 나침반을 쉬프트 + 우클릭하면 입구로 즉시 순간이동할 수 있습니다!&r"
	]
	quest.6F258F4C7BE2EE44.title: "&f&3예티 찾기"
	quest.6F4A4B4C261FF84B.quest_desc: ["화로 연료를 소비하여 전력을 생성합니다."]
	quest.6F53C65C3131B68A.quest_desc: [
		"&2고고학자&r는 부드러운 재료의 달인으로, &2흙&r, &e모래&r, &e먼지&r, &7진흙&r을 처리할 수 있습니다. 작업장으로 &a장식된 항아리&r가 필요합니다."
		""
		"이 작업자는 씨앗, 점토 및 &2우라늄&r과 같은 더 독특한 광물 덩어리를 생성하는 데 유용할 수 있습니다."
		""
		"레벨 4 &2고고학자&r는 &d아치우드 묘목&r을 얻는 데 아주 좋습니다!"
	]
	quest.6F53C65C3131B68A.title: "&f고고학자&r"
	quest.6F68D2CC4B83671E.quest_subtitle: "발굴가, 지질학자"
	quest.6F91297C4FAA43FE.quest_desc: [
		"&d차원술사&r는 다른 세계의 재료 전문가이며, &c네더랙&r, &e엔드 돌&r, &7다른 돌&r을 처리할 수 있습니다. 작업장으로 &a공명 공학 블록&r이 필요합니다."
		""
		"이것은 &a백금&r 및 &b차원 파편&r과 같은 더 희귀한 재료를 얻을 수 있는 고급 작업자입니다."
		""
		"레벨 4 &d차원술사&r는 &a복제 광석&r 및 &a드라코늄 가루&r를 얻는 데 필요합니다."
	]
	quest.6F91297C4FAA43FE.title: "차원 이동 전문가"
	quest.6FB2393F2348D59E.quest_desc: [
		"&a몹 감금 도구&r는 몹을 원하는 곳에 배치할 수 있도록 몹을 붙잡는 간단하고 재사용 가능한 장치입니다."
		""
		"&a생물 포획기&r도 같은 방식으로 작동하지만, 아이템을 몹에게 던져야 합니다... 이름은 말할 수 없는 다른 게임처럼요."
	]
	quest.6FF752712E99A936.quest_desc: ["모든 업그레이드를 제작하려면 &a업그레이드 베이스&r를 만들어야 합니다."]
	quest.700716B4ACCBD4F4.quest_desc: [
		"[\"The \", {\"text\": \"Draconic Chestpiece\", \"color\": \"gold\"}, \" is an upgraded versions of the \", {\"text\": \"Wyvern Chestpiece\", \"color\": \"light_purple\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"69997DAB93184551\" }, \"hoverEvent\": {\"action\": \"show_text\", \"contents\": \"Go to Wyvern Chestpiece Quest\"}}, \", with room for more \", {\"text\": \"Upgrade Modules\", \"color\": \"green\"}, \".\"]"
		""
		"모듈 인벤토리는 기본적으로 바인딩되지 않은 키 바인딩 &e도구 모듈&r을 통해 액세스할 수 있습니다."
	]
	quest.700716B4ACCBD4F4.title: "&6드라코닉 &f흉갑"
	quest.705E4FFB4FCADFD1.quest_desc: [
		"&a분해기&r를 사용하여 아이템에서 물질을 추출할 수 있습니다."
		""
		"이 물질은 나중에 사용할 수 있도록 &a물질 탱크&r에 저장해야 하며, &e물질 네트워크 파이프&r를 사용하여 기계와 탱크 간에 파이핑할 수 있습니다."
	]
	quest.705E4FFB4FCADFD1.title: "물질 생성"
	quest.706E469302F9F383.quest_desc: ["&a소스 응축기&r는 일반 소스를 유체로 변환하는 데 사용할 수 있습니다."]
	quest.706E469302F9F383.title: "액화된 소스 거래"
	quest.70753CD7045AE9E1.quest_desc: [
		"&d악성 주석&r은 마법의 세계와 창조의 세계에 본질적으로 반대되는 마법으로 만들어진 재료입니다."
		"이것으로 만든 무기와 갑옷은 파괴하지 않더라도, 궁극적으로는 무효화하고 끝내려는 것처럼 보입니다."
		""
		"&7가장 위대한 이야기들은 모두 침묵으로 끝납니다."
	]
	quest.70753CD7045AE9E1.title: "&d악성 주석"
	quest.708CFC310C5408B6.quest_desc: [
		"렌즈는 기능 변경을 위해 &e원자 분해기&r에 배치됩니다."
		""
		"기본 &a렌즈&r는 다른 렌즈의 제작 재료로만 사용됩니다."
	]
	quest.708DD6CD3AE7F0FE.title: "시듦 골렘 처치"
	quest.70A9E1AC900A77B4.quest_desc: [
		"&a플레이어 송신기&r는 인벤토리의 아이템에 전력을 공급하는 데 사용됩니다."
		""
		"이를 위해 먼저 &a바인딩 카드&r를 제작한 다음 손에 들고 사용하여 청구해야 합니다. 카드를 송신기에 배치하면 인벤토리에 전력을 공급하도록 지시합니다."
		""
		"또한 &a바인딩 카드&r를 엔더맨에게 사용하여 &d차원 바인딩 카드&r로 변환할 수 있으며, 이를 통해 송신기가 차원을 넘나들며 작동할 수 있습니다."
	]
	quest.70BB982228095E51.quest_desc: [
		"&6월드 엔진&r의 &c고급 기계 블록&r을 만들려면 먼저 튼튼한 프레임이 필요합니다."
		""
		"프레임 처리를 위해서는 &a플라스틱&r을 만들어야 합니다. 이것은 몬스터로부터 특정 유체를 추출하는 기계를 만드는 데 사용될 수 있습니다."
		""
		"[\"\", {\"text\": \"Note\", \"color\": \"yellow\"}, \": \", {\"text\": \"Latex\", \"color\": \"green\"}, \" can also be acquired by making a \", { \"text\": \"Fluid Cow\", \"color\": \"dark_green\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"150BB4679DD2B4B5\" }, \"hoverEvent\": {\"action\": \"show_text\", \"contents\": \"Go to Fluid Cows Quest\"}}, \"!\" ]"
	]
	quest.70BB982228095E51.title: "&f프레임 강화"
	quest.70C02FCA0C7B8777.quest_desc: [
		"닭은 생성할 수 있는 자원에 따라 &b등급&r이 있습니다. 이 &b등급&r은 먹어야 할 씨앗의 등급을 결정합니다. 이 씨앗을 만들려면 &d영혼&r이 필요합니다."
		""
		"씨앗을 만들기 위해 닭에서 &b등급 영혼&r을 추출하려면 &d영혼 추출기&r를 만들어야 합니다."
		""
		"다행히 각 등급별 씨앗은 하나만 있으면 됩니다. 그런 다음 심어서 키울 수 있습니다!"
		""
		"&e참고&r: &6월드 엔진&r은 영혼 업그레이드를 제작할 수도 있습니다."
	]
	quest.70C02FCA0C7B8777.quest_subtitle: "닭을 교배하기 위해 닭을 사용하세요"
	quest.70C02FCA0C7B8777.title: "영혼 추출과 씨앗"
	quest.70D3D4701167B4D5.title: "&f언제나 남의 떡이 더 커 보인다"
	quest.70D5BEA5CC437AB6.quest_desc: [
		"무작위로 마법 부여된 장비가 많으신가요? &d스크랩의 서책&r을 사용하면 분해하여 마법 부여의 일부를 추출할 수 있습니다."
		""
		"&d추출의 서책&r은 모든 마법 부여를 제거하지만 아이템이 파괴되지 않도록 하여 원하는 만큼 마법 부여를 제거하고 교체할 수 있습니다."
		""
		"특정 도구에 대한 특정 마법 부여를 찾고 있다면, 특정 종류의 마법 부여만 지원하도록 제작할 수 있는 &d서책&r을 사용할 수 있습니다."
	]
	quest.71024D8DC19834AC.quest_desc: [
		"아이템을 &b디지털 방식으로&r 저장하고 싶다면 &aME 드라이브&r와 몇 개의 &2저장 셀&r을 만드는 것이 좋습니다."
		""
		"&aME 드라이브&r에는 최대 &b10개의 AE 디스크&r를 수용할 수 있습니다. 네트워크에 연결되면 아이템은 디지털 미디어로 자동 저장되고 인터페이스, I/O 버스 및 터미널을 통해 액세스할 수 있습니다."
		""
		"아이템 저장 드라이브에는 두 가지 유형이 있습니다. &a아이템 저장 셀&r은 63가지 종류의 아이템을 저장할 수 있으며, &aME 디스크 드라이브&r는 제작 비용이 더 높지만 무한한 종류의 아이템을 저장할 수 있습니다."
		""
		"&a셀 작업대&r를 사용하면 &2AE 저장 셀&r에 어떤 종류의 아이템을 허용할지 구성할 수 있습니다."
	]
	quest.71024D8DC19834AC.title: "&f디지털 저장&d의 시작!&f"
	quest.711D381A7974F88A.quest_desc: [
		"&d어셈블러 매트릭스&r는 &a분자 어셈블러&r와 &2패턴 제공기&r의 기능을 결합한 멀티블록 구조이며, 여러 제작 작업을 동시에 실행할 수 있습니다."
		""
		"&a어셈블러 매트릭스&r는 3x3x4에서 7x7x7 사이의 크기일 수 있으며, 최소 1개의 매트릭스 패턴 코어와 1개의 매트릭스 제작 코어를 포함해야 하고, 속이 빈 공간이 없어야 합니다."
		""
		"- 가장자리는 &b어셈블러 매트릭스 프레임&r으로 구성되어야 합니다."
		"- 면은 &a어셈블러 매트릭스 벽&r/&2유리&r로 구성될 수 있습니다."
		"- 내부는 &d매트릭스 코어&r로 구성되어야 합니다."
	]
	quest.711D381A7974F88A.title: "&f어셈블러 매트릭스&d 구조&f"
	quest.711E7B6204708BD7.quest_desc: [
		"&d포스 필드 프로젝터&r는 블록으로 이루어진 영역을 절차적으로 재생성하기 위해 &3포트론&r을 소모합니다. 작동할 &2모드&r 없이는 큰 역할을 하지 못하지만, 모든 &m마법&r 기술을 가능하게 하는 요소입니다!"
		""
		"인터페이스의 각 변경 사항은 &d투사기&r가 현재 투사를 삭제하고 새 투사를 다시 구축하게 하므로 변경 빈도에 유의해야 합니다."
		""
		"&7&o더 큰 역장은 성능에 부정적인 영향을 미칩니다."
		"{@pagebreak}"
		"&e매트릭스 슬롯&r은 &2모듈&r을 수용하여 &d투사기&r와 보호막 블록의 기능을 수정하거나 향상시킵니다. 예를 들어, 침묵하게 하거나, 영향을 받는 영역을 채우거나, 지형을 파괴하는 등의 기능을 추가할 수 있습니다."
		""
		"중앙에 있는 빨간색 &e모드 슬롯&r은 투사 영역의 기본 모양을 정의합니다."
		""
		"12개의 &e필드 슬롯&r은 &2크기&r, &2이동&r 및 &2회전 모듈&r용이며, 이는 &d투사기&r가 세 축(북/남, 동/서, 위/아래) 각각에 대해 구축할 영역을 정의하는 데 도움이 됩니다."
	]
	quest.711E7B6204708BD7.title: "&d포스 필드 프로젝터"
	quest.71205F3FE5AD49B3.quest_desc: [
		"이 세상에서 &3채굴&r하는 법을 배웠다는 것을 &d메아리&r에게 보여주려면, &7자갈&r에서 긁어낼 수 있는 재료로 &a철 망치&r를 만들어야 합니다."
		""
		"이것은 조약돌 채집 속도를 크게 향상시킬 것입니다."
		""
		"&e참고&r: 이 퀘스트를 완료하면 &3채굴 레벨&r이 업그레이드되어, &3긁어낼 때&r 받는 아이템의 종류가 늘어납니다."
	]
	quest.71205F3FE5AD49B3.title: "&f자기 증명"
	quest.7131F9C883EE955E.quest_desc: [
		"&6CAD's Socket&r는 기본적으로 &a탄창&r과 같습니다."
		"이것은 &a주문 탄환&r이 장전되는 곳이며, 탄환에 포함된 컴파일된 &b주문&r을 처리용 &d코어&r로 전송하는 역할을 합니다."
		""
		"&6Socket&r에는 &eBandwidth&r가 있으며, 이는 한 번에 &dCore&r로 전송할 수 있는 &bSpell&r의 최대 크기(&8&o격자 공간 기준&r&r)입니다."
		"&8&o(예: 대역폭이 5인 소켓은 최대 5x5 크기의 주문을 전송할 수 있습니다)&r&r"
		""
		"또한 &6소켓&r의 또 다른 중요한 속성은 &3영구적인 정보&r를 저장할 방법을 제공하는 것입니다. &b소켓&r이 제공하는 &6메모리&r가 많을수록 나중에 &b주문&r 실행을 위해 저장할 수 있는 &b벡터&r가 많아집니다."
		""
		"&8&o(&lTrick: Save Vector&r&8&o는 지정된 메모리 슬롯에 벡터를 저장하고, &lSelector: Saved Vector&r&8&o는 지정된 메모리 슬롯에 저장된 벡터를 검색합니다)&r&r"
		""
		"&6이것들&r은 특히 다음을 제공할 수 있습니다:"
		""
		"► &e대역폭&r: 8 또는 9"
		""
		"► &2소켓&r: 10 또는 12"
		""
		"► &b메모리&r: 18 또는 21"
	]
	quest.7131F9C883EE955E.title: "&d3단계&f CAD 소켓"
	quest.715F30D0A9B79DD7.quest_desc: [
		"&6월드 엔진의 &3기계 블록 업그레이드&r는 이동에 가장 좋은 도구 중 하나를 포함하여 여러 새로운 제작법을 잠금 해제합니다."
		""
		"&a탐험가의 나침반&r은 팩 내의 모든 구조물, 신비로운 &3보물 상자&r까지도 찾는 데 도움이 될 수 있습니다!"
	]
	quest.715F30D0A9B79DD7.title: "&f길 찾기"
	quest.7169587C7DC4C8C0.quest_desc: [
		"&5그림자 영혼&r은 &e말룸&r 및 &e응시&r 모드의 가장 강력하고 신비로운 장비를 제작하는 데 사용됩니다."
		""
		"이것은 &d지옥의 메아리&r에게서만 구매할 수 있습니다."
		""
		"&5계시된 백과사전&r을 제작하는 것이 좋습니다. 이 백과사전은 새로운 &e응시&r 메커니즘을 보여줍니다."
	]
	quest.718C72A43E57B75A.quest_desc: ["이 &b장&r에서는 아이템, 에너지, 유체 등을 전송하는 대부분의 방법을 찾을 수 있습니다!"]
	quest.7191726ECAAFE40F.quest_desc: ["충분한 &2크로니톤 유리&r를 제작한 후, &d길잡이의 메아리&r에게 돌아가 &6월드 엔진&r에 업그레이드로 설치하는 방법을 배우세요."]
	quest.71BDC5B453B8CAB4.quest_desc: [
		"거대한 블랙홀의 사건의 지평선에 서 있습니다. 주변을 탐험하고 &6광채&r를 찾으세요."
		""
		"그들과 협력하여 자신만의 &d블랙홀&r을 만들고 봉인하여 &6월드 엔진&r에 &3어둠의 공허 업그레이드&r를 획득하세요."
	]
	quest.71BDC5B453B8CAB4.title: "&f만나기 &6광채"
	quest.71EF740F3234EA08.title: "균사체 반응기"
	quest.71F17C85D540C559.quest_desc: [
		"&a케이블&r은 네트워크 장치들을 서로 연결하는 데 사용됩니다."
		""
		"전체 블록은 색상에 관계없이 인접한 블록에 연결되지만, &a케이블&r 블록은 같은 색상의 블록에만 연결됩니다."
	]
	quest.71F17C85D540C559.title: "네트워크 연결하기"
	quest.71F25B7D688EE182.quest_desc: [
		"&b미로 보물 상자&r를 완료하면 최소 4개의 &b포트론 주입 블록&r을 보상으로 받게 됩니다."
		""
		"이것은 &b소형&r &6월드 엔진&r &b업그레이드&r로, 자동 제작이나 &a추출기&r를 이용한 자원 생성과 같은 기능들을 잠금 해제합니다."
		""
		"&dEcho of The Light Bender&r가 이 &3Upgrade&r를 설치하는 방법을 보여줄 것입니다."
	]
	quest.71F25B7D688EE182.quest_subtitle: "마이너 월드 엔진 업그레이드"
	quest.71F25B7D688EE182.title: "&f포트론의 힘"
	quest.722901B4259D8AEC.quest_desc: [
		"다음 목표는 &a60&r &6에테르나&r, &a40&r &c퀀텀&r, 그리고 &a40&r &d아르카나&r에 도달하는 것입니다."
		""
		"이를 위해서는 &d주입된 책장&r을 업그레이드해야 합니다. "
	]
	quest.7244348CAB8356E0.quest_desc: [
		"[\"The \", {\"text\": \"Chaotic Chestpiece\", \"color\": \"rainbow\"}, \" is the final upgrade to the \", {\"text\": \"Draconic Chestpiece\", \"color\": \"gold\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"5388B67410670702\" }, \"hoverEvent\": {\"action\": \"show_text\", \"contents\": \"Go to Draconic Chestpiece Quest\"}}, \", with the most room for \", {\"text\": \"Upgrade Modules\", \"color\": \"green\"}, \" and maximum customizability.\"]"
		""
		"모듈 인벤토리는 기본적으로 설정되지 않은 키 바인딩인 &e도구 모듈&r을 통해 접근할 수 있습니다."
	]
	quest.7244348CAB8356E0.title: "§z혼돈의 흉갑"
	quest.7244D5DADCF0D7A2.quest_desc: [
		"&b수중 여과 해초&r에는 최대 6개의 마법 부여된 책을 넣을 수 있으며, 해당 마법 부여가 다시 나타나는 것을 막아줍니다."
		""
		"&c저주받은 마법 부여&r와도 함께 작동합니다!"
	]
	quest.726891EAC51F5F70.quest_desc: [
		"기계 프레임의 최종 등급으로 업그레이드하려면 &b에테르 가스&r를 &d시듦&r에서 추출해야 합니다."
		""
		"이를 위해 &d유체 레이저 베이스&r와 &a레이저 드릴&r 몇 개가 필요합니다. 폭발을 방지하기 위해 &d정지 장치&r 제작도 고려해 볼 수 있습니다!"
		""
		"레이저 베이스는 시듦 위에 중앙에 배치되며, 작동하려면 &a레이저 드릴&r과 &5보라색 레이저 렌즈&r가 필요합니다."
		"{@pagebreak}"
		"이 설정을 위한 주요 \"작업\" 기계는 &a레이저 드릴&r입니다. 드릴은 레이저 베이스 또는 다른 레이저 드릴에 연결하여 배치됩니다."
		""
		"가장 쉬운 배치는 레이저 베이스 측면을 직접 바라보고, 웅크린 상태에서 우클릭하여 드릴을 배치하는 것입니다. 제대로 배치되었다면 애니메이션 얼굴이 당신을 향해야 합니다."
		""
		"레이저 드릴 중 하나의 인터페이스를 열어 베이스에 연결되었는지 확인할 수 있습니다!"
		"{@pagebreak}"
		"&d유체 레이저 베이스&r 내부에 &5보라색 레이저 렌즈&r를 넣어 어떤 종류의 유체를 추출할지 알려주세요."
		""
		"또한 시듦과 일치하도록 &bY 레벨&r을 조정해야 합니다. 제대로 수행하면 &d에테르 가스&r 추출이 시작될 것입니다!"
	]
	quest.726891EAC51F5F70.title: "&d유체 레이저"
	quest.726B56E54CAC971B.quest_desc: [
		"&a의식&r에는 땅에 그려진 몇 가지 기호 이상의 것이 필요할 것입니다!"
		""
		"각 의식에는 여러 개의 &a제물 그릇&r이 필요하며, 이는 의식을 수행하기 위해 희생될 아이템을 배치하는 데 사용됩니다. 첫 번째 의식에는 이 중 네 개만 있으면 됩니다."
		""
		"&a황금 제물 그릇&r은 의식 &b오망성진&r의 중심입니다. 이 그릇에는 의식에 사용되는 핵심 아이템이 담기며, 이는 보통 &d결속된 책&r입니다."
		""
		"일반 &a제물 그릇&r의 경우, &a황금 제물 그릇&r에서 8블록 이내에 있다면 정확한 배치는 중요하지 않습니다."
		"{@pagebreak}"
		"만약 &e초콜릿 초&r가 필요하지 않다면 어떤 종류의 의식이겠습니까! 어떤 바닐라 초도 괜찮습니다."
		""
		"특별하게 만들고 싶다면, 수지를 사용하여 &a큰 초콜릿 초&r를 만들 수도 있습니다."
		""
		"&a수지&r를 얻으려면, &a정육점 칼&r로 큰 동물을 처치해야 합니다. 큰 동물에는 다음이 포함됩니다:"
		""
		"- 소"
		"- 말"
		"- 라마"
		"- 돼지"
		"- 양"
	]
	quest.726B56E54CAC971B.title: "오망성진 구성 요소"
	quest.727070B13B966DE1.quest_desc: [
		"&3업그레이드&f에 필요한 블록을 제출하고 보상을 받으면 팀의 &6월드 엔진&r이 자동으로 조립됩니다."
		""
		"&e참고&f: 업그레이드가 있어야 할 곳에 배치된 블록은 삭제됩니다."
	]
	quest.727070B13B966DE1.title: "&f자동 제작 &3테서랙트 업그레이드"
	quest.72766EEF59130E19.title: "&fPlay For &c25 Hours"
	quest.7279FFED00B223D7.quest_desc: ["&a드라코늄 코어&r는 &eDE&r의 주요 제작 부품 중 하나이며, 드라코닉 갑옷 및 도구에 사용되는 아이템과 &b모듈&r의 일부 기본 제작법에 사용될 수 있습니다."]
	quest.727FAF20A8E1303B.quest_subtitle: "치유의 샘에서 발견"
	quest.72934B141A741423.quest_subtitle: "노란색 + 철"
	quest.7312FFEDAD1A6F75.quest_desc: [
		"&d공허 업그레이드&r - 현재 스택 제한을 초과하는 아이템을 자동으로 삭제합니다."
		""
		"&a수집기 업그레이드&r - 주변 땅에 떨어진 아이템을 줍기 위한 내부 자석을 추가합니다."
		""
		"&a끌어당기기 업그레이드&r - 서랍이 인접한 인벤토리에서 아이템을 끌어올 수 있게 합니다."
		""
		"&a밀어내기 업그레이드&r - 서랍이 인접한 인벤토리로 아이템을 밀어낼 수 있게 합니다."
		""
		"서랍 안에서 업그레이드를 우클릭하여 설정할 수 있습니다."
	]
	quest.7312FFEDAD1A6F75.title: "유틸리티 업그레이드"
	quest.73268E8255CBB44A.quest_desc: [
		"&a영혼 단지&r를 제작하여 몹에게 웅크리기+우클릭하면 해당 몹의 영혼을 포획할 수 있습니다."
		""
		"이 영혼을 &a부서진 스포너&r와 &d영혼 결속기&r 안에서 조합하여 해당 몹의 영혼으로 스포너를 주입할 수 있습니다."
		""
		"해당 주입된 스포너를 사용하여 &2동력 스포너&r를 제작하면 자신만의 동력 스포너를 만들 수 있습니다!"
	]
	quest.73268E8255CBB44A.quest_subtitle: "엔더IO"
	quest.73268E8255CBB44A.title: "&f맞춤형 스포너"
	quest.735CB0E29FB372C1.title: "&d반물질 펠릿 &f거래"
	quest.7379486ABDDE4430.quest_desc: ["이 퀘스트는 &d빛 굴절자의 &6기록 보관소&r로 가는 길잡이를 설정합니다."]
	quest.7379486ABDDE4430.title: "&f찾기 &d빛 굴절자"
	quest.73871351B8E5775B.quest_desc: [
		"주문 시전자인 당신이 주문을 강화하고 싶다면, &6아이언의 주문&r에는 장비를 갖추기 위한 많은 옵션이 있습니다."
		""
		"다양한 주문 학파에 강력한 버프를 제공하는 여러 갑옷 세트가 있습니다."
	]
	quest.73871351B8E5775B.title: "&e아이언의 주문 원소 갑옷&f"
	quest.73EC5E7F2300B99D.quest_desc: [
		"&a자수정 결정체&r는 자수정과 유사하게 작동하며 시간이 지남에 따라 결정을 생성합니다."
		""
		"이것들은 채굴 시 &7결함 있는 자수정 결정체&r로 부패하지만, &2골판지 상자&r와 같은 것을 사용하여 안전하게 옮길 수 있습니다."
		""
		"&e참고&r: 웅크리기 성장은 발아하는 블록에 효과가 있습니다."
	]
	quest.73EC5E7F2300B99D.title: "&b서투스 석영&r"
	quest.73FD015A3696ABFB.quest_desc: ["&a드래곤의 심장&r을 &d드라코늄&r에 주입하면 &6각성된 드라코늄&r을 얻을 수 있으며, 이는 기존 &eDE&r 설정을 업그레이드하려는 경우 필요합니다."]
	quest.73FD015A3696ABFB.title: "&6각성된 드라코늄"
	quest.73FEE6C6149817E7.title: "지옥의 확인 1"
	quest.7408FB23D476F791.title: "안내 완료 1"
	quest.740B9F63604944F3.title: "바다 북쪽"
	quest.7435EC96F4A4B39F.title: "크리에이티브 마나 단지"
	quest.744120E37CD03AE0.quest_desc: [
		"&a원자 분해기&r는 &6메카니즘&r의 도구로, 전력을 소모하여 블록을 부수는 파괴 불가능한 도구입니다."
		""
		"곡괭이, 도끼, 삽의 기능을 동시에 수행합니다."
	]
	quest.744120E37CD03AE0.title: "&f원자 분해기"
	quest.744AB20A66A1835E.title: "&d블랙홀 &f거래"
	quest.749634B68269401A.quest_desc: [
		"&6ProjectE&r에는 충분한 EMC와 &c네더라이트 대장장이 형판&r을 확보하면 만들 수 있는 매우 강력한 무기들이 있습니다."
		""
		"이 무기들은 더 많은 피해를 입히거나 광역 범위를 증가시키기 위해 사용할 수 있는 다양한 모드를 가지고 있습니다."
		""
		"&e참고&r: 이를 제작하려면 &a기계 블록&r &6월드 엔진 업그레이드&r가 필요합니다."
	]
	quest.749634B68269401A.title: "ProjectE 무기"
	quest.74AD70F5C648DBDF.quest_desc: ["이 섹션은 대부분의 전력 저장 방법에 관한 것입니다!"]
	quest.74AD70F5C648DBDF.title: "전력 저장 옵션"
	quest.74CC5FF2097C0839.quest_desc: [
		"&6호전적인 신경망&r (또는 줄여서 &6HNN&r)을 사용하면 몹으로부터 데이터를 수집하여 &b예측&r 형태로 드롭을 수확할 수 있습니다."
		""
		"모드를 시작하려면 먼저 &a모델 프레임워크&r를 제작하고 몹에게 우클릭하여 &c데이터 모델&r을 수집하세요."
		""
		"다음으로 &2딥 러너&r를 제작하여 그 안에 &c데이터 모델&r을 넣어야 합니다. 안에 넣으면 해당 몹에 대한 모든 처치가 &b데이터 모델&r을 개선할 수 있게 해줍니다."
		""
		"&e참고&r: 이 모드를 사용하려면 &b크로니톤 유리&r &6월드 엔진 업그레이드&r가 필요합니다."
	]
	quest.74CC5FF2097C0839.title: "서버 친화적인 몹 파밍"
	quest.74E9653C810F045B.quest_desc: [
		"무선으로 전력을 전송하는 초반 게임 옵션을 찾고 있다면, &6불규칙한 도구들&r이 간단한 해결책을 가지고 있습니다!"
		""
		"첫 번째 단계는 &b벡&r을 처치하여 &r점액&b을 얻는 것입니다. 하나를 얻으면 몹을 재생 가능한 자원으로 만들기 위해 &b스펙터 묘목&r을 만들 수 있습니다."
		"{@pagebreak}"
		"다음 단계는 &a스펙터 에너지 주입기&r를 제작하여 설치하고 전력을 공급하는 것입니다."
		""
		"전력을 무선으로 사용해야 하는 곳 어디든, &e스펙터 코일&r을 설치하여 에너지를 전송하세요!"
		""
		"&e참고&r: &a스펙터 에너지 주입기&r는 전력망으로 간주되며, 설치한 플레이어를 기준으로 작동합니다."
	]
	quest.74E9653C810F045B.title: "무선 스펙터 전력"
	quest.74EA9D857CB71A91.quest_desc: [
		"&a용해 장치&r를 사용하여 단순 기계 프레임에 &c네더라이트&r와 \\&#ffa5fc분홍색 슬라임&r을 주입할 수 있습니다."
		""
		"이를 통해 &6월드 엔진&r 업그레이드에 필요한 &c고급 기계 블록&r을 만들기에 충분히 튼튼한 프레임을 만들 수 있습니다."
	]
	quest.74EA9D857CB71A91.title: "&f프레임 조립&r"
	quest.754048401D3A6A7B.quest_desc: ["이 장에서는 전력을 생성하는 다양한 방법에 대해 다룹니다."]
	quest.754048401D3A6A7B.title: "전력 옵션"
	quest.754ADB22C6B8041F.quest_desc: [
		"이 구조물은 더 낮은 &7심층암&r 고리에서 생성됩니다."
		""
		"&a흐느끼는 우물&r은 &6말룸&r에서 진행하기 위해 필요합니다!"
		""
		"&e참고&r: &a흐느끼는 우물&r은 &d비전 숲&r에서도 찾을 수 있습니다."
	]
	quest.754ADB22C6B8041F.title: "&5흐느끼는 우물 찾기"
	quest.7552BF792403EF44.quest_desc: ["&3마법 부여 단서&r는 마법 부여대에 더 많은 텍스트를 제공하여, 버튼을 클릭하기 전에 책과 아이템에 무엇이 들어갈지 더 많이 볼 수 있게 해줍니다."]
	quest.75A7DDE0D617B5E6.quest_desc: [
		"이것들은 가장 최적의 &6양자 컴퓨터&r 설정을 완료하는 데 필요한 모든 블록입니다."
		""
		"내부에 &6256M&r 저장 장치를 더 많이 가질 수 있지만, 1개의 장치만으로도 이 팩에서 필요한 모든 제작 요구를 처리하기에 충분할 것입니다."
		""
		"&7&o이것으로 7x7x7 구조물을 만들 것입니다."
	]
	quest.75A7DDE0D617B5E6.title: "&f최대 크기 &6양자 컴퓨터"
	quest.75CAB7B10BA85935.title: "융합 제작"
	quest.75D124AF83D637A8.quest_desc: [
		"&e산업 자동화&r (&eI.F&r)는 기계를 사용하여 작업을 대신 처리하는 것입니다."
		""
		"시작하려면 &a하찮은 기계 프레임&r을 만들어야 합니다. 이 기계 프레임은 모든 초반 기계와 블록 파쇄기, 블록 설치기와 같은 일부 저렴한 기계에 사용됩니다."
		""
		"다음으로 &a하찮은 기계 프레임&r을 사용하여 &7플라스틱&r을 만들어 봅시다!"
	]
	quest.75D124AF83D637A8.title: "&e산업 자동화"
	quest.75D3AC9CCA5A82E4.quest_desc: [
		"&d기계식 제작기&r는 여러 가지 방법으로 자동화할 수 있는 거대한 제작대입니다."
		""
		"&a제작기 슬롯 덮개&r는 자동 제작에서 사용되지 않는 슬롯을 덮는 데 사용할 수 있습니다. 그러나 레드스톤 신호를 사용하여 제작법을 강제로 시작할 수도 있습니다."
		""
		""
		"&c&lFTB 공지&r: 로딩 시간에 영향을 미치므로 일반 제작은 현재 비활성화되어 있습니다. 불편을 드려 죄송합니다."
	]
	quest.75D3AC9CCA5A82E4.title: "&d기계식 제작기"
	quest.75D7595FD90E77E5.quest_desc: ["각 &d어셈블러 매트릭스 패턴 코어&r는 &6어셈블러 매트릭스&r에 36개의 패턴 슬롯을 제공합니다."]
	quest.75D7595FD90E77E5.title: "&d어셈블러 매트릭스 패턴 코어"
	quest.75DB0E723089281E.quest_desc: [
		"&a주방 멀티블록&r에 연결할 수 있는 여러 가전제품이 있습니다!"
		""
		"&a싱크대&r는 물을 필요로 하는 제작법에 접근할 수 있게 해줍니다. 싱크대에 물을 공급해야 합니다; 물은 무한하지 않습니다."
		""
		"&a냉장고&r는 차가운 아이템을 보관하기에 완벽한 장소이며, &b주방 멀티블록&r에 더 많은 제작법을 제공하도록 업그레이드할 수 있습니다!"
		""
		"&a오븐&r은 연료가 있는 한 화로 또는 훈연기를 사용하는 제작법에 접근할 수 있게 해줍니다."
	]
	quest.75DB0E723089281E.title: "주방 가전"
	quest.75F6827C1FB52C91.quest_desc: [
		"돌에 둘러싸여 있을지 모르지만, 자동화에는 도움이 되지 않습니다."
		""
		"&a조약돌 생성기&r는 시간이 지남에 따라 조약돌을 생성하며, 상위 티어는 틱당 더 많이 생성합니다."
		""
		"또한 &a자동 망치&r를 만들어 조약돌을 &a언더서&r에 필요한 다양한 블록으로 분해할 수 있습니다!"
		""
		"&e참고&r: &c용암&r은 &d기계공의 메아리&r를 만났을 때 받는 선물로 쉽게 얻을 수 있습니다. &c네더&r 고리에서도 얻을 수 있습니다."
	]
	quest.75F6827C1FB52C91.title: "&f조약돌 생성기&r"
	quest.7614FCF3E2012C48.title: "&d프시메탈 외골격"
	quest.76482BDD2CD6CB8E.quest_desc: [
		"&6오컬티즘&r에는 나무를 베어주는 &a벌목꾼 폴리오트&r를 소환할 수 있습니다."
		""
		"이것은 간단한 나무 농장을 만드는 매우 마법적인 방법이 될 수 있습니다!"
	]
	quest.76482BDD2CD6CB8E.title: "악마 나무 농사"
	quest.765E218999FC00BD.quest_desc: [
		"&6배터리&r는 &d선택적 부착물&r로 &bCAD&r에 장착할 수 있습니다. 기본 프시 에너지 고갈 시 &b예비 프시 에너지 양을 준비&r할 수 있습니다."
		""
		"&e&n보조 배터리처럼요!&r"
		""
		"이것은 특히 다음을 제공합니다:"
		""
		"► &a오버플로우&r: 200"
	]
	quest.765E218999FC00BD.title: "&b2단계&f CAD 배터리"
	quest.76673B8374630924.quest_desc: [
		"&3업그레이드&f에 필요한 블록을 제출하고 보상을 받으면 팀의 &6월드 엔진&r이 자동으로 조립됩니다."
		""
		"&e참고&f: 업그레이드가 필요한 곳에 배치된 블록은 삭제됩니다."
	]
	quest.76673B8374630924.title: "&f자동 조립 &3기계 블록 업그레이드"
	quest.7675666E156F0A94.quest_desc: [
		"각 &d어셈블러 매트릭스 속도 코어&r는 전체 구조물에 대한 &a가속 카드&r로 간주됩니다."
		""
		"&6어셈블러 매트릭스&r는 5개의 &d속도 코어&r로 최대 속도로 실행됩니다. 그 이상은 처리 속도에 추가적인 영향을 미치지 않습니다."
	]
	quest.7675666E156F0A94.title: "&d어셈블러 매트릭스 속도 코어"
	quest.76D5941D76026588.quest_desc: ["음식을 소모하여 전력을 생성합니다."]
	quest.77074CE5719763BB.quest_desc: [
		"이 &aHex Staff&r은 근접 전투에서 강력한 힘을 지니고 있으며 영혼을 수집할 수 있지만, 당신의 영혼에서 나오는 강력한 &b정령 에너지&r의 충전을 발사하는 능력으로 인해 더욱 돋보입니다."
		""
		"이 충전은 시간이 지남에 따라 보충되며(핫바에서 확인 가능), 다양한 마법 부여나 장신구를 통해 증가하거나 회복될 수 있습니다."
	]
	quest.7713D75A36D0A23D.quest_desc: [
		"지정된 위치에 &a양자 연결&r을 설정하고 패턴 제공자를 사용하여 메인 &6월드 엔진&r 기계 블록에 연결하면, ME 시스템은 &6월드 엔진&r과 직접 연결되어 &6월드 엔진&r에서 제작 레시피와 프로세스를 직접 요청할 수 있습니다."
		""
		"&d빛 굴절자&r는 이 비교적 간단한 업그레이드가 &6월드 엔진&r과 상호 작용하는 방식을 바꿀 것이라고 확신하는 것 같습니다."
		""
		"&e참고&f: &6월드 엔진&r의 각 면은 입력 및 출력을 위해 개별적으로 구성해야 합니다."
	]
	quest.7713D75A36D0A23D.quest_subtitle: "마이너 월드 엔진 업그레이드"
	quest.7713D75A36D0A23D.title: "자동화의 시작"
	quest.775BE99DF402AF0D.quest_desc: [
		"&d금고&r에서 돌아온 후 &3고대인&r과 대화하세요."
		""
		"그들이 &3유포니아 월드 엔진 업그레이드&r를 설치하는 방법을 보여줄 것입니다."
	]
	quest.777F76601D213DF2.quest_desc: [
		"&e심플 소드&r 모드는 제작할 수 있는 다양한 무기를 추가합니다."
		""
		"&d룬 무기&r는 세계를 탐험하며 찾을 수 있는 &d룬 태블릿&r을 필요로 합니다."
		""
		"&6고유 무기&r는 탐험 중에 드물게 발견될 수도 있지만, 일부는 제작될 수도 있습니다."
	]
	quest.777F76601D213DF2.title: "&e심플 소드"
	quest.778A876616D4638E.quest_desc: [
		"직선이 아닌 &a가이드 링&r에 레드스톤 신호가 적용되면 스위치 블록이 됩니다. 전원이 켜지면 입자를 직선으로 안내하고, 전원이 꺼지면 원래의 곡선 방향으로 안내합니다. 작은 빨간색 유리관으로 시각화된 '다른' 방향에서 입자가 들어와 흰색 관과 빨간색 관 모두에서 들어오는 경로를 따를 수 있습니다."
		""
		"더 높은 속도에서는 입자가 급격한 회전을 할 수 없습니다. 마지막으로 90도 회전한 지점이 너무 가까우면 안내 경로를 벗어나 세계로 튀어나갑니다. &a가이드 링&r 사이의 거리가 너무 멀거나 다음 &a가이드 링&r을 찾을 수 없으면 또한 튀어나갑니다."
		""
		"{@pagebreak}"
		"입자의 속도는 &a입자 가속기 센서&r로 측정할 수 있습니다. 비교기는 입자 속도를 기반으로 레드스톤 신호를 제공할 수 있습니다."
		""
		"다음은 각 레드스톤 레벨에 필요한 속도입니다:"
		""
		"&71.&r 0"
		"&72.&r 10"
		"&73.&r 50"
		"&74.&r 75"
		"&75.&r 100"
		"&76.&r 150"
		"&77.&r 250"
		"&78.&r 500"
		"&79.&r 750"
		"&710.&r 1000"
		"&711.&r 2500"
		"&712.&r 5000"
		"&713.&r 7500"
		"&714.&r 10000"
		"&715.&r 15000"
	]
	quest.7791DA964DA2A80D.quest_desc: [
		"다른 아이템의 입자가 충돌하면 새로운 아이템을 만들 수 있습니다. 입자는 &a입자 가속기 블록&r에서 시작되며, 여기서 입자로 사용할 아이템을 삽입할 수 있습니다. 직선 &a가이드 링&r은 &a컨트롤러&r 바로 뒤쪽에 배치해야 하며, 옆을 향하고 시각 효과가 올바르게 정렬되어야 합니다."
		"{@pagebreak}"
		"삽입되면 입자는 &a가이드 링&r에 의해 정의된 경로를 따라 이동합니다. 한쪽 면에 45도 회전을 추가하기 위해 우클릭할 수 있습니다. &a가이드 링&r에 의해 정의된 입자 경로에 다른 &a가이드 링&r이 있어야 합니다. 속도에 따라 &a가이드 링&r 사이의 허용 거리가 증가합니다."
		""
		"이는 더 높은 속도에서 &a가이드 링&r 사이의 거리가 더 멀어질 수 있음을 의미합니다."
	]
	quest.7791DA964DA2A80D.title: "&f가속기 설정"
	quest.779460FD700CB351.quest_subtitle: "발굴자, 지질학자"
	quest.77ABD20EB652F302.quest_desc: [""]
	quest.77ABD20EB652F302.title: "&f농장 동물 스폰"
	quest.77DE3D57E5B58948.quest_desc: [
		"이번에는 &e나침반&r이 없습니다!"
		""
		"바다 고리(Ocean Ring)로 가서 &b탐험가 나침반&r을 사용하여 물의 구체(Water Orb) 경기장을 찾으세요. 거기서 &d리바이어던&r을 소환할 수 있습니다!"
	]
	quest.77DE3D57E5B58948.title: "&f리바이어던 찾기&3"
	quest.77F8CCE971B9B186.quest_desc: [
		"&e오컬티즘&r의 업그레이드 가능한 저장 시스템을 통해 &9다른 세계&r의 별도 차원에 아이템을 저장할 수 있습니다."
		""
		"&a저장소 작동기 베이스&r는 저장소 차원에 접근하는 데 필요한 두 가지 부품 중 첫 번째입니다."
		""
		"이 블록은 큰 셜커 상자와 매우 유사하게 작동합니다. 이는 &a차원 저장소 작동기&r를 파괴할 때 아이템이 블록 안에 안전하게 보관된다는 것을 의미합니다."
		"{@pagebreak}"
		"&a저장소 안정기&r는 &a저장소 작동기&r의 저장 공간을 증가시킵니다."
		""
		"더 높은 등급의 &a저장소 안정기&r는 아이템과 아이템 유형 모두에 대해 더 큰 저장 공간 증가를 제공합니다."
		""
		"&a저장소 안정기&r는 최대 5블록 떨어진 곳에 배치할 수 있으며, &a차원 매트릭스&r 텍스처를 향해야 합니다. 정확한 배치는 &a정령 사전&r을 참조하세요."
		""
		"각 &a1단계 차원 저장 안정기&r는 512000개의 아이템과 64개의 아이템 유형을 추가하며, 최대 4개의 &a안정기&r까지 가능합니다."
		"{@pagebreak}"
		"&a안정된 웜홀&r은 원격지에서 차원 저장소에 접근할 수 있게 합니다."
		""
		"&a차원 저장 액추에이터&r를 Shift+클릭하여 연결한 다음, &a안정된 웜홀&r을 월드에 배치하여 원격 액세스 지점으로 사용하세요."
		""
		"&a차원 저장 액추에이터&r를 &c저장 접근기&r로 Shift+우클릭하여 연결하면, 차원을 넘어서도 월드 어디에서든 아이템에 접근할 수 있습니다."
	]
	quest.77F8CCE971B9B186.title: "&d오컬티즘&r 저장소"
	quest.77F964631F38EA2E.title: "크리퍼 처치"
	quest.77FC846DC0EF4ED2.quest_desc: [
		"&a/home&r | 이 명령어는 게임 초반 메인 퀘스트 중에 잠금 해제되며, 기지로 돌아가는 포털을 엽니다."
		""
		"&a/back&r | 죽은 후 이전 지점으로 돌아갈 수 있게 해줍니다."
		""
		"&a/spawn&r | 플레이어를 로비로 순간이동시킵니다. 이 팩에서 로비는 매우 중요합니다!"
		"{@pagebreak}"
		""
		"&a/spark tps&r | 서버의 TPS를 확인합니다. 월드가 느려지는지 확인하는 데 유용합니다."
	]
	quest.7804E97C7772403E.quest_desc: [
		"휴대용 제작대를 원하시나요? &a막대기에 붙은 제작대&r를 만드세요!"
		""
		"이것은 &b장신구 슬롯&r에 넣을 수 있으며, 빠른 접근을 위해 키 바인딩까지 설정할 수 있습니다."
	]
	quest.7804E97C7772403E.title: "&f막대기에 붙은 것!"
	quest.78115154B5DC07B3.quest_desc: ["이 블록은 다른 모든 &d균사체 발전기&r가 활성화되었을 때 &6초당 2500만 RF&r를 생성합니다."]
	quest.78115154B5DC07B3.title: "&f균사체 반응로"
	quest.781D7DA09E444B95.quest_desc: [
		"&d흐느끼는 우물&r은 &7심층암&r 내부 또는 &d비전의 숲&r 구조물에서 찾을 수 있습니다."
		""
		"이 구조물은 속삭임과 심장 박동, 울음소리를 내뿜으며 어둠의 힘으로 특정 아이템을 끌어당깁니다. 무언가를... 원하고 있습니다. &e비전 지식&r이나 원자재를 바쳐 무엇을 얻을 수 있는지 알아보세요."
		""
		"[\"You can find \", {\"text\": \"Runewood Trees\", \"color\": \"dark_green\"}, \" within the \", { \"text\": \"Arcane Grove\", \"color\": \"light_purple\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"066B47D2AB72355C\" }, \"hoverEvent\": {\"action\": \"show_text\", \"contents\": \"Go to Arcane Grove Quest\"}}, \" just be ready to put up a fight.\"]"
		""
		"&e참고&r: 일부 제작법은 뛰어들기 전까지 숨겨져 있습니다."
	]
	quest.781D7DA09E444B95.title: "흐느끼는 우물"
	quest.78610F56E29472F7.title: "0단계 확인"
	quest.787BD711CFF837C6.quest_desc: [
		"더 많은 &6기록 보관소&r를 해제했으니, 로비를 탐험하고 &d빛의 인도자 메아리&r를 찾을 시간입니다."
		""
		"이 &d메아리&r와 함께 작업하여 &6월드 엔진&r의 &b포트론 블록&r 업그레이드를 해제하세요!"
		""
		"&7&o만나고 나면 &e/echo light_bender&7를 사용하여 로비 어디에서든 이 메아리로 직접 순간이동할 수 있습니다."
	]
	quest.787BD711CFF837C6.title: "&f만나기 &d빛의 인도자"
	quest.789A4FE79256A4C6.quest_desc: ["마법 부여된 책을 소비하여 전력을 생성합니다."]
	quest.78A644464D4C506A.quest_desc: [
		"&6포탈 건&r은 여러분이 이동할 포탈을 만들 수 있는 매우 재미있는 장치입니다. 작동하려면 전력이 필요합니다!"
		""
		"왼쪽 클릭은 파란색 포털을 만들고, 오른쪽 클릭은 주황색 포털을 만듭니다. 둘 중 하나를 통과하면 다른 쪽으로 이동합니다."
		""
		"&d고급 포탈 건&r을 사용하면 전력과 &d포탈 유체&r가 있는 한, 순간이동할 위치를 저장할 수 있습니다."
		""
		"&e참고&r: 이를 제작하려면 &b크로니톤 유리&r &6월드 엔진 업그레이드&r가 필요합니다."
	]
	quest.78ADC11570C5561E.quest_desc: [
		"&d플럭스&r는 Applied Energistics의 모든 기술의 핵심입니다."
		""
		"&d플럭스 결정&r을 만들려면 먼저 충전기에서 &b서투스 석영 결정&r을 충전해야 합니다. 다음으로, 이 결정을 레드스톤 조각 및 네더 석영과 함께 세상의 물웅덩이에 던지세요."
		""
		"부품들이 반응하여 정제할 준비가 된 &d플럭스 결정&r을 형성합니다! 한 번에 여러 개를 만들어 과정을 가속화할 수 있으며, 나중에는 제작 과정을 자동화하는 기계를 만들 수도 있습니다."
	]
	quest.78ADC11570C5561E.title: "&dFluix Crystals"
	quest.78C4840B377E14FD.quest_desc: [
		"&6EnderIO&r의 &a마법 부여기&r는 원하는 마법 부여를 선택할 수 있는 &d마법 부여대&r입니다."
		""
		"특정 아이템과 &2경험치&r를 제공하면, 원하는 마법 부여가 적용된 &a책과 깃펜&r에 마법을 부여할 수 있습니다."
		""
		"만들 수 있는 마법 부여를 보려면 JEI에서 사용법을 확인하세요!"
	]
	quest.78D488A506FD3EB8.title: "기계공 확인 2"
	quest.78F7CFEA0EB5024C.quest_desc: ["이 줄의 발전기는 여러분이 첫 전력을 생산하는 데 도움이 되는 &a시작 발전기&r로 간주됩니다!"]
	quest.7913B52AD9D28D2B.quest_desc: [
		"&6파수꾼&r은 &6고대 공장&r 구조물에서 발견되는 강력한 몹입니다."
		""
		"이것은 &d공허 균열&r 고리에서 찾을 수 있습니다."
		""
		"&e참고&r: 먼저 &d네더 별&r을 사용하여 보스를 활성화해야 합니다."
	]
	quest.7913B52AD9D28D2B.title: "&6파수꾼&r 처치"
	quest.795A3ABA29AC0E4F.quest_desc: ["얼어붙은/눈 아이템을 소비하여 전력을 생성합니다."]
	quest.7983727D0EE456FD.quest_desc: [
		"&eJust Dire Things&r(&eJDT&r)는 이름과는 달리 실제로 &o인상적인&r 약간 강력한 &2장치&r, &a도구&r 및 &9갑옷&r을 추가하는 멋진 기술 모드입니다!"
		""
		"&eJDT&r는 재료를 얻는 매우 독특한 메커니즘을 가지고 있습니다."
		""
		"다른 블록으로 퍼져나가 시간이 지남에 따라 변환시키는 &b점액&r을 만드는 것부터 시작합니다."
		""
		"만들게 될 첫 번째 &b점액&r은 &a프리모겔 점액&r이라고 하며, 몇 가지 기본 재료만 있으면 됩니다."
	]
	quest.7983727D0EE456FD.title: "&eJust Dire Things"
	quest.79873815DEB7A086.quest_desc: [
		"&a수입기&r와 &a수출기&r는 주파수에 맞춰 설정된 &dQIO 시스템&r에 무선으로 삽입하고 끌어올 수 있습니다."
		""
		"여러 주파수를 만들 수 있어 격리된 아이템 시스템을 만들거나 메인 저장소 네트워크로 사용할 수 있습니다."
		""
		"&bQIO 레드스톤 어댑터&r는 설정된 주파수의 아이템 수에 따라 레드스톤 신호를 방출하도록 구성할 수 있으며, 스토리지 시스템에 아이템을 넘치게 하지 않고 시스템을 자동화하는 데 유용합니다."
	]
	quest.79873815DEB7A086.title: "&dQIO &a수입 및 수출"
	quest.79CB07BC6B2333AE.title: "프리즈머린"
	quest.79E5C4E3958DA8DD.quest_desc: [
		"&2엔트로 결정&r은 서투스 결정처럼 발아 블록에서 수확됩니다!"
		""
		"엔트로 결정을 자라게 하는 발아 블록을 만들려면 먼저 &a엔트로 씨앗&r을 만든 다음, 세상의 &d플럭스 블록&r에 우클릭하여 변환해야 합니다."
		""
		"특히 &b확장 AE&r를 사용하려는 경우, 이 결정을 일찍부터 키우는 것이 좋습니다!"
	]
	quest.79E5C4E3958DA8DD.title: "&f성장하는 &2엔트로 결정"
	quest.79EB0239FE299185.quest_desc: [
		"&d군수 담당관&r에 따르면, 이제 &6월드 엔진&r에서 &2월드 엔진 기계 프레임&r을 제작하는 데 필요한 모든 것을 갖추었습니다."
		""
		"&6월드 엔진&r의 일부 기능을 복원하여 더 복잡한 아이템을 제작할 수 있도록 하려면 이 부품이 많이 필요합니다!"
	]
	quest.79EB0239FE299185.quest_subtitle: "주요 월드 엔진 업그레이드"
	quest.79EB0239FE299185.title: "&a첫 번째 큰 업그레이드"
	quest.7A0028FE5DF359E8.quest_desc: [
		"&a에너지 송신기&r는 구성 가능한 반경 내에서 블록을 무선으로 충전할 수 있는 작은 기계입니다."
		""
		"기본적으로 이 기계는 최대 1k RF/t를 전송할 수 있습니다. 또한 약간의 전송 손실이 있습니다."
	]
	quest.7A06D08AC7C65D20.quest_desc: [
		"원하는 마법 부여가 있지만, 사용하지 않는 아이템에 붙어 있나요?"
		""
		"&b모루&r 방법을 사용하여 마법 부여를 쉽게 분리할 수 있습니다."
		""
		"먼저 &d드라코늄&r 블록을 놓고 마법 부여가 적용된 아이템을 던지세요. 제거하려는 마법 부여마다 빈 책도 던져야 합니다."
		""
		"분리하려면 &b모루&r를 아이템 더미에 떨어뜨리세요!"
	]
	quest.7A06D08AC7C65D20.title: "&f쉬운 마법 부여 제거"
	quest.7A1BCD0876713992.quest_desc: ["결함 있는 발아 블록은 기본 &a기계 블록&r 업그레이드가 있는 &b월드 엔진&r에서 제작할 수 있습니다."]
	quest.7A26B0FFC0BCA275.quest_subtitle: "엔더릭 레이저가 살아있는 개체를 대상으로 할 수 있습니다."
	quest.7A26B0FFC0BCA275.title: "&f기계 사냥꾼 애드온"
	quest.7A62B07AD0BCCCEA.quest_desc: [
		"처음에는 &b정령&r을 수동으로만 수집할 수 있는 것처럼 보이지만, &5사악한&r 룬나무 &e정령 의식&r을 자세히 살펴보면 특별한 시너지가 있음을 알 수 있습니다."
		""
		"하위 의식은 주변의 적대적인 몹을 저체력으로 &d천천히 피해를 입히고&r, 상위 의식은 저체력일 때 몹을 몸과 영혼 모두에서 &d제거하여&r 일반 드롭과 함께 &b정기&r를 생성합니다!"
		""
		"&7다양한 의식 속에서 수동적인 동물들에게도 비슷한 시너지가 존재합니다..."
	]
	quest.7A62B07AD0BCCCEA.title: "정령 자동화"
	quest.7A6F14DB74189B67.quest_desc: ["&6상점&r에서 &b미리 코딩된 주문 구매&r를 할 수 있습니다. 어떤 것은 다른 것보다 더 복잡하며, 기본 용도로 사용하거나 새로운 기술을 배우는 데 사용할 수 있습니다 :p"]
	quest.7A6F14DB74189B67.quest_subtitle: "주문 예시가 필요하신가요?"
	quest.7A6F14DB74189B67.title: "상점은 당신에게 좋은 거래를 제공할 수 있습니다!"
	quest.7A6F1E301DB2EDC3.quest_desc: [
		"Cx: -1"
		"Cz: 185"
	]
	quest.7A8669713BE28E8F.quest_desc: ["&d워든&r은 &3심층암&r 고리의 가장 아래층에서 찾을 수 있는 &d고대 도시&r에 서식합니다."]
	quest.7A8669713BE28E8F.title: "&e처치하기&f: &3워든"
	quest.7A8D31482AB1FCAA.quest_desc: [
		"&6압축 기계&r를 사용하면 주머니 차원 안에 자신만의 방을 만들 수 있습니다!"
		""
		"이것은 FPS 저하를 유발할 수 있는 농장을 짓는 데 매우 유용할 수 있습니다."
		""
		"&e참고&r: 이것은 \\&z상점 전용&r 아이템입니다!"
	]
	quest.7AB7D06E0DD24F7A.quest_desc: [
		"&3금고&r나 &c이그니스&r 처치에 어려움을 겪고 있다면, 보조 손에 이 음악 디스크를 사용하여 &6내면의 불꽃을 밝히세요&r."
		""
		"이것은 블레이즈를 처치하고 춤 퍼즐을 할 때 열 배의 열을 생성하며, 색상 누락에 대한 페널티도 제거합니다."
		""
		"또한 &c이그니스&r에 대한 모든 공격에 세 배의 피해를 입힐 수 있습니다."
	]
	quest.7AB7D06E0DD24F7A.title: "지옥의 리듬"
	quest.7ACCC2EECD9883FD.quest_desc: ["&e인지&r 도구는 다이아몬드 장비만큼 좋으며 추가적인 블록 상호 작용 범위를 제공합니다."]
	quest.7ACCC2EECD9883FD.title: "&e인지 &f도구"
	quest.7B20023BE78887DA.quest_desc: [
		"다른 모드는 자체 유형을 추가할 수 있지만, &e간단한 자석&r은... 간단하게 유지합니다. 그냥 &a자석&r을 제작하고, 우클릭으로 활성화하면, 당신이 가지고 있는 동안 범위 내의 모든 아이템이 당신에게 빠르게 끌려와 집을 수 있습니다!"
		""
		"&d고급 자석&r은 더 넓은 범위와 쉬프트 + 우클릭으로 열리는 필터 메뉴를 가지고 있습니다."
		""
		"특정 영역의 아이템을 자석으로 끌어오고 싶지 않으신가요? &2자석 제거 코일&r을 확인해보세요!"
		""
		"범위 내의 아이템은 &a간단한 자석&r이 자신을 끌어당기는 것을 무시할 것입니다."
	]
	quest.7B20023BE78887DA.title: "&a간단한 자석"
	quest.7B2044D285C9F1E3.quest_desc: [
		"주요 챕터에서 &a톱니바퀴&r 모양의 퀘스트는 대부분 &d에코&r 관련 퀘스트입니다!"
		""
		"이는 작업을 완료하거나 새로운 것을 볼 수 있는지 확인하기 위해 &d에코&r로 돌아가야 할 가능성이 높다는 것을 의미합니다."
	]
	quest.7B2044D285C9F1E3.title: "톱니바퀴 모양 퀘스트!"
	quest.7B496376BC7B399A.quest_desc: ["&a엔더&r는 적의 머리를 베는 데 특화된 다이아몬드 등급의 검입니다."]
	quest.7B496376BC7B399A.title: "&f엔더"
	quest.7B579D0762DB9F33.quest_desc: [
		"&a오스뮴&r을 얻으면 &e열 발생기&r를 사용하여 기본 전력을 쉽게 생성할 수 있습니다. &6메카니즘&r에서 제공합니다."
		""
		"이 &a발전기&r는 석탄이나 나무와 같은 연소 가능한 모든 아이템을 공급하여 전력을 생산할 수 있으며, 주변의 &c용암&r에서 열을 흡수하여 수동적으로 전력을 생산할 수도 있습니다."
		""
		"발전기에서 전력을 추출하려면 사각형이 있는 앞면에 파이프나 기계를 연결해야 합니다!"
	]
	quest.7B579D0762DB9F33.title: "&c열&r &f발생기"
	quest.7B5B32A08ADB5E76.quest_desc: [
		"&d정밀 메커니즘&r은 &e크리에이트&r가 제공하는 최고의 도구와 기계에 사용되는 중요한 제작 부품입니다."
		""
		"&e참고&r: 이 제작법은 20%의 실패 확률이 있으므로, 이를 고려하여 필터를 준비하십시오."
		""
		"또한 \\&z상점&r에서 구매할 수도 있습니다!"
	]
	quest.7B6A17901EC8180C.quest_desc: ["\\&z붉은 모닝스타&r는 &6프로젝트E&r의 궁극적인 올인원 도구입니다."]
	quest.7B6A17901EC8180C.title: "&c붉은 모닝스타&r"
	quest.7B772A85691C60F5.quest_desc: [
		"각 반지마다 4개의 미리 만들어진 &d텔레포트 패드&r가 있습니다; 각 주요 방향마다 하나씩 있습니다."
		""
		"땅을 파면서 이것들을 발견할 수도 있지만, 상점&r에서 연결된 &d엔더 조각&r을 구매할 수도 있습니다!"
	]
	quest.7B772A85691C60F5.title: "순간이동 패드"
	quest.7B77544B48E690CB.quest_desc: [
		"모든 저장 공간을 단일 네트워크로 연결하고 싶다면, &a저장소 컨트롤러&r를 만들어 쉽게 할 수 있습니다."
		""
		"&a컨트롤러&r 옆에 놓인 모든 저장 용기는 자동으로 연결됩니다. 이를 통해 컨트롤러에서 우클릭하거나 쉬프트-우클릭하여 아이템을 쉽게 덤프할 수 있어 인벤토리 관리가 용이합니다!"
		""
		"&e참고&r: &a저장소 컨트롤러&r는 제작을 위해 &a기계 블록&r &6월드 엔진 업그레이드&r가 필요합니다."
		"{@pagebreak}"
		"컨트롤러에 연결된 모든 것에 저장 공간을 배치하면 큰 멀티블록 상자처럼 네트워크에 추가됩니다!"
		""
		"메인 저장 허브와 분리된 저장 용기를 연결하기 위해 &a저장소 링크&r를 만들 수 있으며, &a저장소 도구&r를 사용하여 컨트롤러에 연결할 수 있습니다!"
	]
	quest.7B77544B48E690CB.title: "&a저장소 네트워크 생성"
	quest.7BA228FC749BF70A.quest_desc: [
		"&e촉매제&r는 &e정령 도가니&r의 속도를 높일 수 있지만, 기능의 많은 측면이 다양한 &a강화 장치&r로 조정될 수 있습니다. 일부는 다른 도가니 스탯에 영향을 미치고, 다른 일부는 시스템에 완전히 새로운 메커니즘을 추가합니다. 자세한 내용은 &e말룸 책&r을 참조하세요!"
		""
		"&a튜닝 포크&r는 들고 있을 때 도가니 위에 이러한 스탯과 기능을 표시하며, 도가니에 사용하면 일부 사소한 측면을 조정할 수 있습니다."
		""
		"도가니 자체에 최대 4개를 적용할 수 있으며, 연결된 촉매제는 각각 하나의 강화 장치를 받아 도가니에 적용할 수 있습니다."
	]
	quest.7BF4EF06E2D0D763.quest_desc: [
		"이제 막 얻은 &b사이 금속&r로 &6사이 금속 CAD&r를 만들 수 있습니다."
		""
		"이것은 &d훨씬 더 나은 스탯을 제공하여&r &3더 흥미로운 주문을 시전할 수 있게 합니다!&r"
	]
	quest.7BF4EF06E2D0D763.title: "훨씬 더 나은 CAD 조립"
	quest.7C0FD2B2589BC66D.quest_desc: [
		"&b화로&r 3x3x3을 만들어 &b점보 화로&r를 만드세요."
		""
		"&b점보 화로&r는 여러 제작법을 동시에 처리할 수 있으며, 오른쪽 하단 슬롯에 더 많은 &b점보 화로&r를 업그레이드할 수 있습니다. (최대 64개) 각 화로는 한 번에 제련할 수 있는 아이템 수를 나타냅니다."
	]
	quest.7C0FD2B2589BC66D.title: "&b더 크고 더 좋은 것"
	quest.7C6BB27CCDA5E878.quest_desc: ["이 퀘스트는 &d지옥의 &6기록 보관소&r로 가는 웨이포인트를 설정합니다."]
	quest.7C6BB27CCDA5E878.title: "&f찾기 &d지옥"
	quest.7C72E7E48CCA7BB1.quest_desc: [
		"&d고급 분리 장치&r를 사용하면 여러 워프 지점을 한 번에 저장할 수 있습니다. 무한히 사용할 수 있지만, 작동하려면 &d엔더 진주&r로 연료를 공급해야 합니다."
		""
		"연료를 공급하려면, 인벤토리에 엔더 진주를 넣은 상태로 인터페이스를 열고 GUI 하단의 + 버튼을 클릭하여 연료로 추가하세요."
	]
	quest.7C94432EFD49611F.quest_desc: [
		"&r무한함&r은 여러분이 아는 현실의 붕괴를 막고 있는 유일한 존재입니다."
		""
		"이것들을 사용하여 &3Infinity World Engine Upgrade&r를 잠금 해제하세요."
		""
		"&7&o모든 것이 이것으로 귀결됩니다."
	]
	quest.7C94432EFD49611F.title: "&f만나기 \\&z무한함"
	quest.7C9B4CE2A2F62096.quest_desc: [
		"&a가압 반응기&r를 사용하여 기질을 통해 &6HDPE 펠릿&r을 만들 수 있습니다. 이 고급 펠릿은 많은 고급 아이템과 기계를 만드는 데 사용됩니다!"
		""
		"이를 만들려면 &6액체 에텐&r, 산소 및 기질을 결합해야 합니다. 여기서부터 농축기에서 처리하여 &6HDPE 시트&r를 만들 수 있습니다!"
		""
		"액체 상태의 에텐을 사용하므로, 먼저 기체를 액체로 변환하기 위해 &a회전식 응축기&r를 제작해야 합니다. 이미 기체를 주입했나요? &a게이지 드로퍼&r를 사용하여 제거하세요!"
	]
	quest.7CA687749E953A19.quest_desc: [
		"► 특히 &6Psi의 진행 상황&r을 위해, CAD에 더 나은 재료인 &6프시메탈&r에 접근하기 위한 간단한 &b&l주문: 주입&r&r을 원합니다!"
		""
		"&61.&r 이 그리드의 아무 곳이나 &d마우스 오른쪽 버튼으로 클릭&r한 다음 -> &b\"주문: 주입\"&r이라고 입력하고 클릭하여 그리드에 배치하세요."
		""
		"&62.&r &o원하는 경우 주문에 이름을 지정하세요&r."
		""
		"&63.&r 이 GUI에서 나와서 &d총알을 들고 마우스 오른쪽 버튼으로 클릭&r하여 테이블에 &b주문을 복사하세요&r."
		""
		"&64.&r &l이득을 보세요&r! 당신의 &b첫 번째 Psi 주문&r을 만들었습니다!"
		""
		"&8&o● 그리고 걱정하지 마세요, 아무도 무한한 지식을 가지고 태어나지 않습니다. 작게 시작해서 시간이 지남에 따라 모드에 대해 더 많이 배우면서 주문의 복잡성을 늘리세요 =)&r&r"
	]
	quest.7CA687749E953A19.quest_subtitle: "이것은 까다롭습니다"
	quest.7CA687749E953A19.title: "당신의 첫 주문"
	quest.7CC7824471E1B45F.quest_desc: ["\\&z크리에이티브 구&r는 결코 죽지 않으며, 가장 높은 등급의 구로 사용됩니다."]
	quest.7CC7824471E1B45F.title: "크리에이티브 구"
	quest.7D1FB9A40B5CAE97.quest_desc: [
		"&b확인&f: 작업자 토큰 획득"
		""
		"&b잠금 해제&f: T1 에코 및 챕터 1로 가는 문"
	]
	quest.7D1FB9A40B5CAE97.title: "가이드 1.3 확인"
	quest.7D23D1C9DE75721F.title: "스켈레톤 처치"
	quest.7D2A583FBDCE4FC7.quest_desc: [
		"&6CAD의 소켓&r은 기본적으로 &a주문 탄환의 탄창&r입니다."
		"&a주문 탄환&r이 장전되는 곳이며, 탄환에 포함된 컴파일된 &b주문&r을 &d코어&r로 전송하여 처리하는 역할을 합니다."
		""
		"&6소켓&r에는 &e대역폭&r이 있으며, 이는 컴파일된 &8&o(그리드 공간 기준)&r&r 크기의 &b주문&r을 한 번에 &d코어&r로 전송할 수 있는 최대 크기입니다."
		"&8&o(예: 대역폭이 5인 소켓은 최대 5x5 크기의 주문을 전송할 수 있습니다)&r&r"
		""
		"또한, &6소켓&r의 또 다른 중요한 속성은 &3영구 정보&r를 저장할 수 있는 방법을 제공하는 것입니다. &b메모리&r가 많을수록 &6소켓&r은 나중에 &b벡터&r를 더 많이 저장하여 &b주문&r 실행에 사용할 수 있습니다."
		""
		"&8&o(&l주문: 벡터 저장&r&8&o은 지정된 메모리 슬롯에 벡터를 저장하고, &l선택: 저장된 벡터&r&8&o은 지정된 메모리 슬롯에 저장된 벡터를 검색합니다)&r&r"
		""
		"&6이것&r은 특히 \""
		""
		"► &e대역폭&r: 5"
		""
		"► &2소켓&r: 4"
		""
		"► &b메모리&r: 7"
	]
	quest.7D2A583FBDCE4FC7.title: "&a1단계&f CAD 소켓"
	quest.7D3A5740B5857874.quest_desc: [
		"&d보안 관리자&r를 사용하면 다양한 네트워크 기능에 대한 액세스 권한을 제어할 수 있습니다."
		""
		"&a보안 카드&r를 마우스 오른쪽 버튼으로 클릭하여 플레이어에게 바인딩하고 구성하십시오. Shift + 마우스 오른쪽 버튼 클릭으로 구성을 지웁니다."
	]
	quest.7D3A5740B5857874.quest_subtitle: "서버에 유용"
	quest.7D945B6D1311B741.quest_desc: [
		"&d에코&r가 당신의 기지 북쪽에 &2치유의 샘&r이 있다고 말했는데, 그곳에서 &a크로논 셀&r을 만드는 데 필요한 자원을 얻을 수 있습니다."
		""
		"&7&o파고, 파고, 파야 할 시간입니다"
	]
	quest.7D945B6D1311B741.title: "&f샘의 비밀"
	quest.7DCF86E4B24A764A.title: "크리에이티브 디스크 인터페이스"
	quest.7DE26DE10C64D2E7.quest_desc: ["이 퀘스트 보상을 받으면 &d에코의 &6아카이브&r 입구에 웨이포인트가 설정됩니다."]
	quest.7DE26DE10C64D2E7.title: "&f위치 찾기 &d지옥의 존재"
	quest.7DE9A4C7979AC1FA.quest_desc: [
		"&6템패드&r를 사용하면 표시된 위치로 가는 문을 열 수 있습니다."
		""
		"또한 현재 좌표를 통해 수동으로 새 위치를 추가할 수 있으며 여러 구성 옵션이 있습니다. 고정된 위치는 키 바인딩을 통해 순간이동할 수 있습니다."
		""
		"&a위치 카드&r도 템패드 인터페이스에서 위치를 등록하거나 복사하는 데 사용할 수 있습니다."
		""
		"&e참고&f: &6템패드&r는 &c아닙니다&f. &a액션 패드&r를 통한 순간이동을 위한 크로논 저장소 역할을 합니다."
	]
	quest.7DE9A4C7979AC1FA.title: "&6템패드"
	quest.7E062B48AD37EAF1.quest_desc: [
		"프로세서는 &eRS2&r 네트워크의 대부분의 핵심 구성 요소를 제작하는 데 사용됩니다."
		""
		"[\"These can only be assembled inside a \", { \"text\": \"Circuit Fabricator\", \"color\": \"light_purple\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"663460DE8AF7E464\" }, \"hoverEvent\": {\"action\": \"show_text\", \"contents\": \"Go to Circuit Fabricator Quest\"} }, \".\"]"
	]
	quest.7E062B48AD37EAF1.title: "프로세서"
	quest.7E0E4E6260C1D61E.quest_desc: [
		"저장 시스템에 무한한 전력을 공급하고 &6Ars&r의 \\&z크리에이티브 주문&r에 접근할 수 있게 되면, 주변 세계를 형성하기 전에 처리해야 할 마지막 한 가지 일만 남았습니다."
		""
		"모든 것을 위한 \\&z크리에이티브 파워&r."
	]
	quest.7E0E4E6260C1D61E.title: "승천 티어 3 - 전지전능"
	quest.7E1A18D82B74B6CC.title: "마법 부여사 확인 2"
	quest.7E4FF5A454039E47.quest_desc: [
		"디지털 저장의 주요 용도 중 하나는 &3아이템 자동 제작&r 기능입니다."
		""
		"&eAE2&r에서는 &a크래프팅 CPU, 보조 프로세서&r 등을 활용하는 사용자 정의 멀티블록을 만들어 이를 수행합니다."
		""
		"시작하려면 주요 제작 구성 요소인 &3크래프팅 유닛&r을 만들어야 합니다."
		""
		"&e참고&r: &3크래프팅 유닛&r을 제작하려면 &b포트론 주입 블록&r &6월드 엔진 업그레이드&r가 필요합니다."
	]
	quest.7E4FF5A454039E47.title: "&3자동 제작"
	quest.7E685EAD7FB60B45.quest_desc: [
		"&a인챈트 테이블&r은 접두사 아이템을 해당 희귀도 재료로 분해하는 데 사용됩니다:"
		""
		"{\"text\": \"Common - Mysterious Scrap Metal\", \"color\": \"#7E7E7E\"}"
		"{\"text\": \"Uncommon - Timeworn Fabric\", \"color\": \"#55FF55\"}"
		"{\"text\": \"Rare - Luminous Crystal Shard\", \"color\": \"#5454FC\"}"
		"{\"text\": \"Epic - Arcane Sands\", \"color\": \"#B900B9\"}"
		""
		"&a인챈트 테이블&r은 테이블의 위쪽 또는 옆면에서 아이템을 보내고 테이블 아래쪽에서 추출하여 자동화할 수 있습니다. 아이템을 잃지 마세요!"
		""
		"&eNote&f: \\&#EA6F14Godforged Pearls &cCANNOT&r be salvaged in this pack. You will have to craft them via the &6World Engine&r after unlocking the &3Draconic Upgrade&r."
	]
	quest.7E685EAD7FB60B45.title: "&f인챈트 &a테이블"
	quest.7E7745D3E460831F.quest_desc: [
		"&a양자 연결&r은(는) &6월드 엔진&r에서 점점 더 많은 자동화가 필요함에 따라 큰 도움이 될 것입니다."
		""
		"이 &3월드 엔진 업그레이드&r를 어디에 설치해야 하는지 보여줄 수 있도록 &d빛 조절자&r와 대화하세요."
	]
	quest.7E88C7654F281E43.quest_desc: [
		"&r강화 테이블&r은 아이템의 개별 접사를 강화하는 데 사용되는 게임 후반 제작대입니다."
		""
		"이것은 두 개의 &r강화 부적&r 비용으로 기존 접사를 업그레이드하거나, 1개의 &r강화 부적&r 비용으로 접사를 재설정할 수 있습니다."
	]
	quest.7E88C7654F281E43.title: "The \\&#EA6F14증강 테이블"
	quest.7E8C48A1F0A2F37A.title: "&f무한 블록 거래"
	quest.7EA0870C93C7DBA5.quest_desc: [
		"&a파워셀&r은 에너지 저장 블록으로, 단일 구조물로서 서로 인접하게 저장 공간을 공유할 수 있습니다."
		""
		"에너지를 삽입하거나 추출하려면 &e스마트 렌치&r를 사용하여 셀의 측면을 구성하십시오. 파란색 측면은 에너지 셀로 에너지를 허용하고, 노란색 측면은 에너지를 내보냅니다."
	]
	quest.7EA0870C93C7DBA5.title: "&a파워셀&r"
	quest.7EACA525066908E0.title: "황혼의 금고 나침반"
	quest.7EEBD17F0EA6EE0C.quest_desc: [
		"&3업그레이드&f에 필요한 블록을 제출하고 보상을 받으면 팀의 &6월드 엔진&r이 자동으로 조립됩니다."
		""
		"&c중요&f: 이 업그레이드는 새로운 제작법 잠금 해제를 제외하고는 &6월드 엔진&r의 어떤 것에도 영향을 미치지 않습니다. 새로 제작된 &a엔더 셀&r을 제출해야 합니다. 여기에 적용된 업그레이드는 &c전달되지 않습니다&f."
		""
		"&e참고&f: 업그레이드가 있어야 할 위치에 배치된 블록은 무효화됩니다."
	]
	quest.7EEBD17F0EA6EE0C.title: "&f자동 빌드 &3엔더 파워 업그레이드"
	quest.7EF7546FF007EF36.quest_desc: [
		"&2바이오 연료&r는 &a분쇄기&r에서 유기 물질을 분쇄하여 생성됩니다."
		""
		"이것은 &a바이오 발전기&r를 제작하고 동력을 공급하는 데 사용되며, 게임 초반에 유용한 전력 업그레이드가 될 수 있습니다!"
		""
		"또한 &6에텐&r을 만드는 데 사용되며, 이는 에너지 밀도가 높은 가스로 전력 및 &eHDPE 펠릿&r 제작에 사용됩니다."
	]
	quest.7EF7546FF007EF36.title: "&2바이오 연료"
	quest.7F022A9289CCBF5D.title: "엔드 남쪽"
	quest.7F27B48C280FA27F.title: "아이템 저장"
	quest.7F42E2C4AAC3D131.quest_desc: ["&7&o무한 회전력"]
	quest.7F42E2C4AAC3D131.title: "크리에이티브 모터"
	quest.7F4E7C687E7D8707.quest_desc: [
		"농장에서 아이템이 땅에 쌓이는 것을 막을 수 있는 여러 가지 방법이 있습니다!"
		""
		"이것들은 모두 구성 가능하며, 아이템 수집 범위를 설정할 수 있습니다."
	]
	quest.7F4E7C687E7D8707.title: "아이템 수집기"
	quest.7F5729C2350E3087.quest_desc: [
		"더 진행하려면 &9다른 세계&r의 아이템이 필요하며, &a영혼의 불꽃&r이 바로 그것입니다."
		""
		"땅에 &a악마의 꿈 열매&r를 던지고 불을 붙이면 &d영혼의 불꽃&r이 생성됩니다. 이 불꽃은 절대 꺼지지 않으며 엔티티에게 해를 끼치지 않습니다."
		""
		"&d영혼의 불꽃&r에 아이템을 던지면 &9다른 세계&r의 해당 아이템으로 변환됩니다."
	]
	quest.7F5729C2350E3087.title: "정화된 불꽃"
	quest.7F7C0B1523AA28C4.quest_desc: [
		"&d마법사&r의 첫 번째 임무는 세계에서 마법 나무를 발굴하는 것입니다."
		""
		"마법 묘목을 캐내려면 전문가 또는 달인 &2고고학자&r와 함께 &a발굴기&r에서 협력해야 합니다."
		""
		"[\"If you're more of the explorer type, you may also find some magical resources in the \", {\"text\": \"Arcane Grove\", \"color\": \"dark_green\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"066B47D2AB72355C\"}, \"hoverEvent\": {\"action\": \"show_text\", \"contents\": \"Go to Arcane Grove Quest\"}}, \". Use the compass provided by the \", {\"text\": \"Magician\", \"color\": \"light_purple\"}, \" to guide you.\"]"
		""
		"&2숲&r 안의 적들과 싸울 계획이라면, 최소한 &b다이아몬드 등급&r의 장비를 갖추는 것이 좋습니다. &c경고했습니다!&r"
		""
		"임무를 완료하면 &d마법사&r에게 돌아가야 합니다."
	]
	quest.7F7C0B1523AA28C4.quest_subtitle: "아르스 잠금 해제"
	quest.7F7C0B1523AA28C4.title: "&f마법 나무"
	quest.7F7D54E743F4E1DE.title: "WE 설계도를 보상으로 추가"
	quest.7FBA170218539BE8.quest_desc: [
		"인지력은 &a도서관충&r을 통해 독특한 XP 생성 방식을 가지고 있습니다. 이들은 책장을 꾸준히 분해하여 XP 구슬로 만들고, &7잊혀진 가루&r만 남깁니다."
		""
		"&a감염된 책장&r은 다른 책장으로 충매를 퍼뜨릴 수 있어, 단 한 번의 도서관충 사용으로 연결된 책장 여러 개에 영향을 줄 수 있습니다. 이 과정은 감염된 책장에 &e조율의 지팡이&r를 사용하여 중단할 수 있습니다."
		""
		"쓰여진 책과 마법 부여된 책을 사용하여 만든 &a특수 책장&r도 감염될 수 있으며, 일반 책장보다 부패 시 더 많은 XP 가치를 생산합니다."
		"{@pagebreak}"
		"책장이 충분히 준비되지 않은 경우, 충매를 위한 '둥지'를 만들 수 있습니다. &a형광 한천&r은 부패한 책장에서 남은 가루를 사용하여 만들며, 감염된 책장 사이에 배치하면 충매가 이를 적절한 &a영양 한천&r으로 변환할 수 있습니다. 이 한천은 가능한 경우 주변 26개 블록에 수동으로 충매 감염을 퍼뜨릴 수 있습니다."
		""
		"이 한천은 더 향상시키기 위해 부수고 다시 주울 수 있습니다:"
		"&6통찰력 있는 한천&r은 감염 속도와 부패로부터 얻는 XP 가치를 증가시킵니다."
		"&d호화로운 한천&r은 감염 속도와 부패로부터 얻는 XP 가치를 증가시킵니다."
	]
	quest.7FCCB25011D69673.quest_desc: [
		"&a농축기&r는 몇 가지 중요한 용도가 있습니다!"
		""
		"이 기계는 3개의 원석을 &e4개의 가루&r로 분쇄하여, 본질적으로 주괴 수익을 배가시킬 수 있습니다."
		""
		"또한 &c강화된 레드스톤&r, &c강화된 탄소&r 등 아이템의 &2강화된 버전&r을 만드는 데 사용됩니다!"
		""
		"이 강화된 아이템은 &a야금 주입기&r에서 원래 값의 8배로 사용될 수 있습니다."
	]
	quest.7FCCB25011D69673.title: "&f농축기&a"
	quest.7FEDD82D9B47EFCD.quest_desc: ["&a바이오 발전기&r는 바이오매스를 소비하여 에너지를 생성하며, &b애드온&r으로 에너지를 증가시킬 수 있습니다."]
